{%- comment -%}
  MILAURA CART REWARDS
  Cartes a gratter panier. Non bloquant pour le paiement.
{%- endcomment -%}

{%- if cart.item_count > 0 -%}
  {%- liquid
    assign reward_threshold_1_cents = section.settings.threshold_1 | default: 20 | times: 100
    assign reward_threshold_2_cents = section.settings.threshold_2 | default: 50 | times: 100
    assign reward_threshold_3_cents = section.settings.threshold_3 | default: 80 | times: 100
    assign reward_threshold_1_label = reward_threshold_1_cents | money_without_trailing_zeros | remove: '€' | strip | append: ' €'
    assign reward_threshold_2_label = reward_threshold_2_cents | money_without_trailing_zeros | remove: '€' | strip | append: ' €'
    assign reward_threshold_3_label = reward_threshold_3_cents | money_without_trailing_zeros | remove: '€' | strip | append: ' €'
    assign paid_cart_cents = 0
    assign paid_cart_signature = ''
    assign gift_2_variant_id_num = section.settings.gift_2_variant_id | plus: 0
    assign gift_2_in_cart = false
    assign card_1_attribute = ''
    assign card_3_attribute = ''

    for attribute in cart.attributes
      if attribute.first == 'Carte MilAura 1'
        assign card_1_attribute = attribute.last
      endif
      if attribute.first == 'Carte MilAura 3'
        assign card_3_attribute = attribute.last
      endif
    endfor

    for item in cart.items
      assign is_milaura_gift = false
      if item.product.tags contains 'milaura-gift' or item.product.title contains 'Cadeau -'
        assign is_milaura_gift = true
      endif
      for property in item.properties
        if property.first == '_milaura_gift' and property.last == 'true'
          assign is_milaura_gift = true
        endif
      endfor

      if is_milaura_gift
        if gift_2_variant_id_num > 0 and item.variant_id == gift_2_variant_id_num
          assign gift_2_in_cart = true
        endif
      else
        assign item_paid_line_price = item.final_line_price
        if item_paid_line_price == blank
          assign item_paid_line_price = item.line_price
        endif
        if item_paid_line_price == blank
          assign item_paid_line_price = item.original_line_price
        endif
        assign paid_cart_cents = paid_cart_cents | plus: item_paid_line_price
        assign paid_cart_signature = paid_cart_signature | append: item.variant_id | append: ':' | append: item.quantity | append: ';'
      endif
    endfor

    assign paid_cart_label = paid_cart_cents | money_without_currency | append: ' €'

    assign unlocked_cards = 0
    if paid_cart_cents >= reward_threshold_1_cents
      assign unlocked_cards = 1
    endif
    if paid_cart_cents >= reward_threshold_2_cents
      assign unlocked_cards = 2
    endif
    if paid_cart_cents >= reward_threshold_3_cents
      assign unlocked_cards = 3
    endif

    assign stale_reward_indexes = ''
    assign card_1_code_matched = false
    assign card_3_code_matched = false
    assign card_1_discount_applied = false
    assign card_3_discount_applied = false
    if card_1_attribute == section.settings.gift_1_discount_code and section.settings.gift_1_discount_code != blank
      assign card_1_code_matched = true
    endif
    if card_3_attribute == section.settings.gift_3_discount_code and section.settings.gift_3_discount_code != blank
      assign card_3_code_matched = true
    endif
    for discount_application in cart.cart_level_discount_applications
      if discount_application.title == section.settings.gift_1_discount_code and section.settings.gift_1_discount_code != blank
        assign card_1_discount_applied = true
      endif
      if discount_application.title == section.settings.gift_3_discount_code and section.settings.gift_3_discount_code != blank
        assign card_3_discount_applied = true
      endif
    endfor

    assign card_1_active = false
    assign card_2_active = false
    assign card_3_active = false
    if card_1_code_matched or card_1_discount_applied
      assign card_1_reward_applied = true
    else
      assign card_1_reward_applied = false
    endif
    if card_3_code_matched or card_3_discount_applied
      assign card_3_reward_applied = true
    else
      assign card_3_reward_applied = false
    endif
    if card_1_reward_applied and paid_cart_cents >= reward_threshold_1_cents
      assign card_1_active = true
    elsif card_1_reward_applied
      assign stale_reward_indexes = stale_reward_indexes | append: '1,'
    endif
    if gift_2_in_cart and paid_cart_cents >= reward_threshold_2_cents
      assign card_2_active = true
    elsif gift_2_in_cart
      assign stale_reward_indexes = stale_reward_indexes | append: '2,'
    endif
    if card_3_reward_applied and paid_cart_cents >= reward_threshold_3_cents
      assign card_3_active = true
    elsif card_3_reward_applied
      assign stale_reward_indexes = stale_reward_indexes | append: '3,'
    endif
  -%}

  {%- capture milaura_reward_closed_lock_icon -%}
    <svg class="milaura-cart-reward__step-svg" viewBox="0 0 24 24" aria-hidden="true" focusable="false">
      <rect x="4" y="10.5" width="16" height="10" rx="2.8"></rect>
      <path d="M7.5 10.5V7.8a4.5 4.5 0 0 1 9 0v2.7"></path>
      <path d="M12 14.3v2.5"></path>
    </svg>
  {%- endcapture -%}

  {%- capture milaura_reward_open_lock_icon -%}
    <svg class="milaura-cart-reward__step-svg" viewBox="0 0 24 24" aria-hidden="true" focusable="false">
      <rect x="4" y="10.5" width="16" height="10" rx="2.8"></rect>
      <path d="M7.5 10.5V7.8a4.5 4.5 0 0 1 8.1-2.7"></path>
      <path d="M12 14.3v2.5"></path>
    </svg>
  {%- endcapture -%}

  {%- capture milaura_reward_brand_logo -%}
    {%- if settings.logo != blank -%}
      {{ settings.logo | image_url: width: 160 | image_tag: class: 'milaura-cart-reward__logo-img', alt: 'MilAura', loading: 'lazy' }}
    {%- else -%}
      <span class="milaura-cart-reward__logo-text">MilAura</span>
    {%- endif -%}
  {%- endcapture -%}

  {%- style -%}
    #MilauraCartRewards-{{ section.id }} {
      padding: var(--milaura-spacing-md) 0 var(--milaura-spacing-lg);
    }

    #MilauraCartRewards-{{ section.id }} .milaura-cart-rewards__panel {
      position: relative;
      isolation: isolate;
      overflow: hidden;
      padding: 18px;
      border: 1px solid rgba(192, 160, 98, 0.22);
      border-radius: 20px;
      background:
        radial-gradient(circle at 12% 0%, rgba(230, 200, 139, 0.18), transparent 30%),
        linear-gradient(180deg, rgba(255, 253, 248, 0.98), rgba(255, 255, 255, 0.995));
      box-shadow: 0 16px 34px rgba(26, 26, 46, 0.07);
    }

    #MilauraCartRewards-{{ section.id }} .milaura-cart-rewards__panel::before {
      content: "";
      position: absolute;
      inset: 0;
      background:
        linear-gradient(120deg, transparent 0%, rgba(255, 255, 255, 0.48) 48%, transparent 74%),
        radial-gradient(circle at 92% 12%, rgba(192, 160, 98, 0.12), transparent 24%);
      opacity: 0.48;
      pointer-events: none;
      z-index: 0;
    }

    #MilauraCartRewards-{{ section.id }} .milaura-cart-rewards__header {
      display: grid;
      gap: 7px;
      margin-bottom: 13px;
      text-align: center;
      position: relative;
      z-index: 1;
    }

    #MilauraCartRewards-{{ section.id }} .milaura-cart-rewards__eyebrow {
      margin: 0;
      font-size: 0.72rem;
      font-weight: 800;
      letter-spacing: 0.08em;
      text-transform: uppercase;
      color: var(--milaura-gold-dark, #8F723A);
    }

    #MilauraCartRewards-{{ section.id }} .milaura-cart-rewards__title {
      margin: 0;
      font-family: var(--milaura-font-heading, 'Playfair Display', serif);
      font-size: clamp(1.45rem, 5vw, 2rem);
      line-height: 1.12;
      color: var(--milaura-text, #000);
    }

    #MilauraCartRewards-{{ section.id }} .milaura-cart-rewards__subtitle {
      max-width: 660px;
      margin: 0 auto;
      font-size: 0.95rem;
      line-height: 1.45;
      color: var(--milaura-text-light, #666);
    }

    #MilauraCartRewards-{{ section.id }} .milaura-cart-rewards__statusline {
      display: inline-flex;
      align-items: center;
      justify-content: center;
      gap: 8px;
      width: fit-content;
      max-width: 100%;
      margin: 6px auto 0;
      padding: 8px 13px;
      border-radius: 999px;
      border: 1px solid rgba(192, 160, 98, 0.14);
      background: rgba(26, 26, 46, 0.055);
      font-size: 0.82rem;
      font-weight: 800;
      color: #1a1a2e;
      text-wrap: balance;
    }

    #MilauraCartRewards-{{ section.id }} .milaura-cart-rewards__grid {
      position: relative;
      z-index: 1;
      display: grid;
      grid-template-columns: repeat(3, minmax(0, 1fr));
      gap: 12px;
    }

    #MilauraCartRewards-{{ section.id }} .milaura-cart-reward {
      position: relative;
      min-height: 186px;
      display: flex;
      flex-direction: column;
      justify-content: space-between;
      gap: 8px;
      padding: 15px 14px 13px;
      overflow: hidden;
      border: 1px solid rgba(143, 114, 58, 0.32);
      border-radius: 18px;
      background:
        radial-gradient(circle at 20% 0%, rgba(255, 255, 255, 0.44), transparent 30%),
        linear-gradient(145deg, #FFF0C2 0%, #D7B05D 48%, #8D6B2E 100%);
      color: inherit;
      cursor: pointer;
      text-align: center;
      box-shadow:
        inset 0 1px 0 rgba(255, 255, 255, 0.78),
        inset 0 -18px 34px rgba(72, 49, 15, 0.14),
        0 14px 24px rgba(26, 26, 46, 0.12);
      transform: translateY(0);
      transition: transform 220ms ease, box-shadow 220ms ease, border-color 220ms ease, filter 220ms ease, opacity 220ms ease;
    }

    #MilauraCartRewards-{{ section.id }} .milaura-cart-reward::before {
      content: "";
      position: absolute;
      inset: 0;
      background:
        linear-gradient(135deg, rgba(255, 255, 255, 0.32), transparent 35%),
        repeating-linear-gradient(120deg, rgba(255, 255, 255, 0.075) 0 1px, transparent 1px 12px);
      opacity: 0.88;
      pointer-events: none;
    }

    #MilauraCartRewards-{{ section.id }} .milaura-cart-reward::after {
      content: "";
      position: absolute;
      inset: 8px;
      border: 1px solid rgba(255, 255, 255, 0.34);
      border-radius: 13px;
      box-shadow: inset 0 0 0 1px rgba(98, 70, 26, 0.08);
      pointer-events: none;
      z-index: 1;
    }

    #MilauraCartRewards-{{ section.id }} .milaura-cart-reward.is-featured {
      border-color: rgba(26, 26, 46, 0.26);
      background:
        radial-gradient(circle at 20% 0%, rgba(255, 255, 255, 0.48), transparent 30%),
        linear-gradient(145deg, #FFF6DB 0%, #E4C274 42%, #A37424 100%);
      box-shadow:
        inset 0 1px 0 rgba(255, 255, 255, 0.8),
        inset 0 -18px 34px rgba(72, 49, 15, 0.12),
        0 16px 28px rgba(192, 160, 98, 0.2);
    }

    #MilauraCartRewards-{{ section.id }} .milaura-cart-reward:not(.is-locked):not(.is-revealed) {
      background:
        radial-gradient(circle at 18% 0%, rgba(230, 200, 139, 0.12), transparent 30%),
        linear-gradient(180deg, #ffffff 0%, #fffdf9 100%);
    }

    #MilauraCartRewards-{{ section.id }} .milaura-cart-reward.is-locked {
      cursor: default;
      opacity: 0.86;
      filter: grayscale(0.22) saturate(0.78);
      background:
        radial-gradient(circle at 20% 0%, rgba(255, 255, 255, 0.52), transparent 30%),
        linear-gradient(145deg, #F5E9CF 0%, #CFB77E 50%, #8E7A55 100%);
    }

    #MilauraCartRewards-{{ section.id }} .milaura-cart-reward.is-locked .milaura-cart-reward__hint {
      display: none;
    }

    #MilauraCartRewards-{{ section.id }} .milaura-cart-reward.is-locked .milaura-cart-reward__status {
      font-size: 0.78rem;
    }

    #MilauraCartRewards-{{ section.id }} .milaura-cart-reward.is-revealed {
      border-color: rgba(192, 160, 98, 0.34);
      background:
        radial-gradient(circle at 18% 0%, rgba(230, 200, 139, 0.12), transparent 30%),
        linear-gradient(180deg, #ffffff 0%, #fffdf9 100%);
      box-shadow:
        inset 0 1px 0 rgba(255, 255, 255, 0.94),
        inset 0 -12px 24px rgba(192, 160, 98, 0.045),
        0 12px 24px rgba(26, 26, 46, 0.075);
    }

    #MilauraCartRewards-{{ section.id }} .milaura-cart-reward.is-revealed::before {
      opacity: 0.12;
    }

    #MilauraCartRewards-{{ section.id }} .milaura-cart-reward.is-revealed::after {
      border-color: rgba(192, 160, 98, 0.16);
    }

    #MilauraCartRewards-{{ section.id }} .milaura-cart-reward__badge {
      position: absolute;
      top: 10px;
      left: 10px;
      right: auto;
      max-width: calc(100% - 58px);
      padding: 5px 10px;
      border-radius: 999px;
      border: 1px solid rgba(255, 255, 255, 0.24);
      background: rgba(26, 26, 46, 0.9);
      box-shadow: 0 5px 14px rgba(26, 26, 46, 0.13);
      font-size: 0.6rem;
      font-weight: 900;
      letter-spacing: 0.05em;
      text-transform: uppercase;
      color: var(--milaura-gold-light, #E6C88B);
      overflow: hidden;
      text-overflow: ellipsis;
      white-space: nowrap;
      z-index: 2;
    }

    #MilauraCartRewards-{{ section.id }} .milaura-cart-reward.is-featured .milaura-cart-reward__badge {
      background: #1a1a2e;
      color: var(--milaura-gold-light, #E6C88B);
    }

    #MilauraCartRewards-{{ section.id }} .milaura-cart-reward.is-revealed .milaura-cart-reward__badge {
      border-color: rgba(46, 125, 50, 0.16);
      background: rgba(46, 125, 50, 0.09);
      box-shadow: none;
      color: #2e7d32;
    }

    #MilauraCartRewards-{{ section.id }} .milaura-cart-reward__step {
      width: 38px;
      height: 38px;
      display: inline-flex;
      align-items: center;
      justify-content: center;
      margin: 25px auto 0;
      border-radius: 50%;
      border: 1px solid rgba(255, 255, 255, 0.54);
      background: rgba(255, 255, 255, 0.58);
      color: #1a1a2e;
      font-family: var(--milaura-font-heading, 'Playfair Display'), serif;
      font-weight: 900;
      box-shadow:
        inset 0 0 0 1px rgba(143, 114, 58, 0.18),
        0 8px 18px rgba(26, 26, 46, 0.12);
      z-index: 2;
    }

    #MilauraCartRewards-{{ section.id }} .milaura-cart-reward__step-svg {
      width: 21px;
      height: 21px;
      display: block;
      fill: none;
      stroke: currentColor;
      stroke-width: 2;
      stroke-linecap: round;
      stroke-linejoin: round;
    }

    #MilauraCartRewards-{{ section.id }} .milaura-cart-reward__lock {
      position: absolute;
      top: 10px;
      right: 10px;
      width: 31px;
      height: 31px;
      display: inline-flex;
      align-items: center;
      justify-content: center;
      border-radius: 50%;
      border: 1px solid rgba(143, 114, 58, 0.12);
      background: rgba(255, 255, 255, 0.86);
      color: #1a1a2e;
      font-size: 0.88rem;
      font-weight: 900;
      box-shadow: 0 6px 16px rgba(26, 26, 46, 0.11);
      z-index: 4;
      pointer-events: none;
    }

    #MilauraCartRewards-{{ section.id }} .milaura-cart-reward__lock-svg {
      width: 16px;
      height: 16px;
      display: block;
      fill: none;
      stroke: currentColor;
      stroke-width: 2.2;
      stroke-linecap: round;
      stroke-linejoin: round;
    }

    #MilauraCartRewards-{{ section.id }} .milaura-cart-reward__lock {
      display: none;
    }

    #MilauraCartRewards-{{ section.id }} .milaura-cart-reward__name {
      margin: 0;
      font-family: var(--milaura-font-heading, 'Playfair Display', serif);
      font-size: 1.02rem;
      font-weight: 700;
      line-height: 1.15;
      color: #1a1a2e;
      z-index: 2;
    }

    #MilauraCartRewards-{{ section.id }} .milaura-cart-reward__value {
      align-self: center;
      margin: 0;
      padding: 5px 9px;
      border: 1px solid rgba(26, 26, 46, 0.08);
      border-radius: 999px;
      background: rgba(255, 255, 255, 0.38);
      font-size: 0.76rem;
      font-weight: 900;
      color: #2C210F;
      z-index: 2;
    }

    #MilauraCartRewards-{{ section.id }} .milaura-cart-reward__hint,
    #MilauraCartRewards-{{ section.id }} .milaura-cart-reward__status {
      margin: 0;
      font-size: 0.74rem;
      line-height: 1.32;
      color: rgba(26, 26, 46, 0.72);
      z-index: 2;
    }

    #MilauraCartRewards-{{ section.id }} .milaura-cart-reward__status {
      min-height: 2em;
      padding-top: 6px;
      border-top: 1px solid rgba(26, 26, 46, 0.08);
      font-weight: 800;
      color: #1a1a2e;
      z-index: 2;
    }

    #MilauraCartRewards-{{ section.id }} .milaura-cart-reward__status.is-success {
      color: #2e7d32;
    }

    #MilauraCartRewards-{{ section.id }} .milaura-cart-reward__status.is-error {
      color: #9f2f2f;
    }

    #MilauraCartRewards-{{ section.id }} .milaura-cart-reward__reveal {
      display: none;
      position: relative;
      z-index: 2;
    }

    #MilauraCartRewards-{{ section.id }} .milaura-cart-reward.is-locked {
      min-height: 186px;
      justify-content: center;
      gap: 13px;
      padding: 24px 24px 21px;
    }

    #MilauraCartRewards-{{ section.id }} .milaura-cart-reward.is-locked .milaura-cart-reward__badge,
    #MilauraCartRewards-{{ section.id }} .milaura-cart-reward.is-locked .milaura-cart-reward__lock,
    #MilauraCartRewards-{{ section.id }} .milaura-cart-reward.is-locked .milaura-cart-reward__name,
    #MilauraCartRewards-{{ section.id }} .milaura-cart-reward.is-locked .milaura-cart-reward__value,
    #MilauraCartRewards-{{ section.id }} .milaura-cart-reward.is-locked .milaura-cart-reward__hint {
      display: none;
    }

    #MilauraCartRewards-{{ section.id }} .milaura-cart-reward.is-locked .milaura-cart-reward__step {
      width: 64px;
      height: 64px;
      margin: 0 auto;
      border-color: rgba(255, 255, 255, 0.48);
      background: rgba(255, 255, 255, 0.52);
      color: rgba(26, 26, 46, 0.72);
      box-shadow:
        inset 0 0 0 1px rgba(255, 255, 255, 0.46),
        0 12px 26px rgba(26, 26, 46, 0.14);
    }

    #MilauraCartRewards-{{ section.id }} .milaura-cart-reward.is-locked .milaura-cart-reward__step-svg {
      width: 31px;
      height: 31px;
      stroke-width: 1.8;
    }

    #MilauraCartRewards-{{ section.id }} .milaura-cart-reward.is-locked .milaura-cart-reward__status {
      max-width: 315px;
      min-height: 0;
      margin: 0 auto;
      padding: 0;
      border-top: 0;
      color: rgba(26, 26, 46, 0.78);
      font-size: 0.9rem;
      font-weight: 850;
      line-height: 1.38;
    }

    #MilauraCartRewards-{{ section.id }} .milaura-cart-reward:not(.is-locked):not(.is-revealed) .milaura-cart-reward__step {
      width: 46px;
      height: 46px;
      color: #1a1a2e;
      background: rgba(255, 255, 255, 0.62);
    }

    #MilauraCartRewards-{{ section.id }} .milaura-cart-reward.is-revealed {
      justify-content: center;
      gap: 10px;
      padding: 22px 20px 19px;
      cursor: default;
    }

    #MilauraCartRewards-{{ section.id }} .milaura-cart-reward.is-revealed .milaura-cart-reward__badge,
    #MilauraCartRewards-{{ section.id }} .milaura-cart-reward.is-revealed .milaura-cart-reward__lock,
    #MilauraCartRewards-{{ section.id }} .milaura-cart-reward.is-revealed .milaura-cart-reward__step,
    #MilauraCartRewards-{{ section.id }} .milaura-cart-reward.is-revealed .milaura-cart-reward__name,
    #MilauraCartRewards-{{ section.id }} .milaura-cart-reward.is-revealed .milaura-cart-reward__value,
    #MilauraCartRewards-{{ section.id }} .milaura-cart-reward.is-revealed .milaura-cart-reward__hint {
      display: none;
    }

    #MilauraCartRewards-{{ section.id }} .milaura-cart-reward.is-revealed .milaura-cart-reward__reveal {
      display: grid;
      place-items: center;
      gap: 6px;
      width: 100%;
    }

    #MilauraCartRewards-{{ section.id }} .milaura-cart-reward__reveal-logo {
      min-height: 32px;
      display: inline-flex;
      align-items: center;
      justify-content: center;
      margin-bottom: 2px;
    }

    #MilauraCartRewards-{{ section.id }} .milaura-cart-reward__logo-img {
      width: auto;
      max-width: 118px;
      max-height: 34px;
      object-fit: contain;
      display: block;
    }

    #MilauraCartRewards-{{ section.id }} .milaura-cart-reward__logo-text {
      font-family: var(--milaura-font-heading, 'Playfair Display', serif);
      font-size: 1.22rem;
      font-weight: 700;
      color: #1a1a2e;
    }

    #MilauraCartRewards-{{ section.id }} .milaura-cart-reward__won {
      display: inline-flex;
      align-items: baseline;
      justify-content: center;
      gap: 4px;
      color: #1a1a2e;
      font-size: 0.82rem;
      font-weight: 700;
      line-height: 1.2;
    }

    #MilauraCartRewards-{{ section.id }} .milaura-cart-reward__won strong {
      color: var(--milaura-gold-dark, #8F723A);
      font-weight: 950;
      letter-spacing: 0.05em;
    }

    #MilauraCartRewards-{{ section.id }} .milaura-cart-reward__prize {
      max-width: 100%;
      color: #1a1a2e;
      font-size: clamp(1.02rem, 1.6vw, 1.22rem);
      font-weight: 950;
      line-height: 1.12;
      letter-spacing: 0.04em;
      text-transform: uppercase;
      text-wrap: balance;
    }

    #MilauraCartRewards-{{ section.id }} .milaura-cart-reward.is-revealed .milaura-cart-reward__status {
      max-width: 360px;
      min-height: 0;
      margin: 2px auto 0;
      padding: 0;
      border-top: 0;
      color: rgba(26, 26, 46, 0.68);
      font-size: 0.82rem;
      font-weight: 750;
      line-height: 1.36;
    }

    #MilauraCartRewards-{{ section.id }} .milaura-cart-reward__canvas {
      position: absolute;
      inset: 0;
      width: 100%;
      height: 100%;
      display: block;
      touch-action: none;
      user-select: none;
      -webkit-user-select: none;
      -webkit-touch-callout: none;
      cursor: grab;
      z-index: 3;
    }

    #MilauraCartRewards-{{ section.id }} .milaura-cart-reward:focus-visible {
      outline: 3px solid rgba(143, 114, 58, 0.34);
      outline-offset: 3px;
    }

    @media (hover: hover) {
      #MilauraCartRewards-{{ section.id }} .milaura-cart-reward:not(.is-locked):hover {
        transform: translateY(-2px);
        border-color: rgba(143, 114, 58, 0.46);
        box-shadow:
          inset 0 1px 0 rgba(255, 255, 255, 0.82),
          inset 0 -18px 34px rgba(72, 49, 15, 0.12),
          0 18px 30px rgba(26, 26, 46, 0.14);
      }
    }

    #MilauraCartRewards-{{ section.id }} .milaura-cart-rewards__note {
      position: relative;
      z-index: 1;
      margin: 14px 0 0;
      padding-top: 12px;
      border-top: 1px solid rgba(192, 160, 98, 0.18);
      font-size: 0.82rem;
      line-height: 1.4;
      text-align: center;
      color: var(--milaura-text-light, #666);
    }

    @media screen and (max-width: 749px) {
      #MilauraCartRewards-{{ section.id }} .milaura-cart-rewards__panel {
        padding: 13px;
        border-radius: 17px;
      }

      #MilauraCartRewards-{{ section.id }} .milaura-cart-rewards__grid {
        grid-template-columns: 1fr;
        gap: 9px;
      }

      #MilauraCartRewards-{{ section.id }} .milaura-cart-reward {
        min-height: 154px;
        padding: 14px 13px 12px;
      }

      #MilauraCartRewards-{{ section.id }} .milaura-cart-reward__step {
        margin-top: 22px;
      }

      #MilauraCartRewards-{{ section.id }} .milaura-cart-reward__hint {
        display: none;
      }
    }
  {%- endstyle -%}

  <section
    id="MilauraCartRewards-{{ section.id }}"
    class="milaura-cart-rewards"
    data-section-id="{{ section.id }}"
    data-paid-subtotal-cents="{{ paid_cart_cents }}"
    data-cart-signature="{{ paid_cart_signature | escape }}"
    data-stale-reward-indexes="{{ stale_reward_indexes | escape }}"
  >
    <div class="page-width">
      <div class="milaura-cart-rewards__panel">
        <div class="milaura-cart-rewards__header">
          <p class="milaura-cart-rewards__eyebrow">{{ section.settings.eyebrow }}</p>
          <h2 class="milaura-cart-rewards__title">{{ section.settings.title }}</h2>
          <p class="milaura-cart-rewards__subtitle">{{ section.settings.subtitle }}</p>
          <p class="milaura-cart-rewards__statusline">
            {{ paid_cart_label }} dans votre panier · {{ unlocked_cards }}/3 carte{% if unlocked_cards > 1 %}s{% endif %} surprise{% if unlocked_cards > 1 %}s{% endif %} débloquée{% if unlocked_cards > 1 %}s{% endif %}
          </p>
        </div>

        <div class="milaura-cart-rewards__grid" aria-label="Cartes surprises MilAura">
          <button
            type="button"
            class="milaura-cart-reward{% if paid_cart_cents < reward_threshold_1_cents %} is-locked{% endif %}{% if card_1_active %} is-active{% endif %}"
            data-milaura-reward-card
            data-reward-index="1"
            data-threshold-cents="{{ reward_threshold_1_cents }}"
            data-discount-code="{{ section.settings.gift_1_discount_code | escape }}"
            data-unlocked="{% if paid_cart_cents >= reward_threshold_1_cents %}true{% else %}false{% endif %}"
            data-active="{% if card_1_active %}true{% else %}false{% endif %}"
            aria-disabled="{% if paid_cart_cents >= reward_threshold_1_cents %}false{% else %}true{% endif %}"
          >
            <span class="milaura-cart-reward__badge">{% if paid_cart_cents >= reward_threshold_1_cents %}Débloquée{% else %}Dès {{ reward_threshold_1_label }}{% endif %}</span>
            <span class="milaura-cart-reward__lock" aria-hidden="true">{% if paid_cart_cents >= reward_threshold_1_cents %}🔓{% else %}🔒{% endif %}</span>
            <span class="milaura-cart-reward__step" aria-hidden="true">{% if paid_cart_cents >= reward_threshold_1_cents %}{{ milaura_reward_open_lock_icon }}{% else %}{{ milaura_reward_closed_lock_icon }}{% endif %}</span>
            <span class="milaura-cart-reward__name">{{ section.settings.gift_1_name }}</span>
            <span class="milaura-cart-reward__value">{{ section.settings.gift_1_value }}</span>
            <span class="milaura-cart-reward__hint">{{ section.settings.gift_1_hint }}</span>
            <span class="milaura-cart-reward__reveal">
              <span class="milaura-cart-reward__reveal-logo">{{ milaura_reward_brand_logo }}</span>
              <span class="milaura-cart-reward__won">Votre avantage MilAura</span>
              <span class="milaura-cart-reward__prize">Livraison offerte au paiement</span>
            </span>
            <span class="milaura-cart-reward__status" data-reward-status>
              {%- if card_1_active -%}Les frais de port offerts seront appliqués au paiement.{%- elsif paid_cart_cents >= reward_threshold_1_cents -%}Grattez votre carte surprise.{%- else -%}Atteignez {{ reward_threshold_1_label }} de panier pour débloquer cette carte.{%- endif -%}
            </span>
          </button>

          <button
            type="button"
            class="milaura-cart-reward is-featured{% if paid_cart_cents < reward_threshold_2_cents %} is-locked{% endif %}{% if card_2_active %} is-active{% endif %}"
            data-milaura-reward-card
            data-reward-index="2"
            data-threshold-cents="{{ reward_threshold_2_cents }}"
            data-variant-id="{{ section.settings.gift_2_variant_id | escape }}"
            data-unlocked="{% if paid_cart_cents >= reward_threshold_2_cents %}true{% else %}false{% endif %}"
            data-active="{% if card_2_active %}true{% else %}false{% endif %}"
            aria-disabled="{% if paid_cart_cents >= reward_threshold_2_cents %}false{% else %}true{% endif %}"
          >
            <span class="milaura-cart-reward__badge">{% if paid_cart_cents >= reward_threshold_2_cents %}Débloquée{% else %}Dès {{ reward_threshold_2_label }}{% endif %}</span>
            <span class="milaura-cart-reward__lock" aria-hidden="true">{% if paid_cart_cents >= reward_threshold_2_cents %}🔓{% else %}🔒{% endif %}</span>
            <span class="milaura-cart-reward__step" aria-hidden="true">{% if paid_cart_cents >= reward_threshold_2_cents %}{{ milaura_reward_open_lock_icon }}{% else %}{{ milaura_reward_closed_lock_icon }}{% endif %}</span>
            <span class="milaura-cart-reward__name">{{ section.settings.gift_2_name }}</span>
            <span class="milaura-cart-reward__value">{{ section.settings.gift_2_value }}</span>
            <span class="milaura-cart-reward__hint">{{ section.settings.gift_2_hint }}</span>
            <span class="milaura-cart-reward__reveal">
              <span class="milaura-cart-reward__reveal-logo">{{ milaura_reward_brand_logo }}</span>
              <span class="milaura-cart-reward__won">Votre attention MilAura</span>
              <span class="milaura-cart-reward__prize">Cadeau MilAura offert</span>
            </span>
            <span class="milaura-cart-reward__status" data-reward-status>
              {%- if card_2_active -%}Votre cadeau MilAura est dans votre panier.{%- elsif paid_cart_cents >= reward_threshold_2_cents -%}Grattez votre carte surprise.{%- else -%}Atteignez {{ reward_threshold_2_label }} de panier pour débloquer cette carte.{%- endif -%}
            </span>
          </button>

          <button
            type="button"
            class="milaura-cart-reward{% if paid_cart_cents < reward_threshold_3_cents %} is-locked{% endif %}{% if card_3_active %} is-active{% endif %}"
            data-milaura-reward-card
            data-reward-index="3"
            data-threshold-cents="{{ reward_threshold_3_cents }}"
            data-discount-code="{{ section.settings.gift_3_discount_code | escape }}"
            data-unlocked="{% if paid_cart_cents >= reward_threshold_3_cents %}true{% else %}false{% endif %}"
            data-active="{% if card_3_active %}true{% else %}false{% endif %}"
            aria-disabled="{% if paid_cart_cents >= reward_threshold_3_cents %}false{% else %}true{% endif %}"
          >
            <span class="milaura-cart-reward__badge">{% if paid_cart_cents >= reward_threshold_3_cents %}Surprise été{% else %}Dès {{ reward_threshold_3_label }}{% endif %}</span>
            <span class="milaura-cart-reward__lock" aria-hidden="true">{% if paid_cart_cents >= reward_threshold_3_cents %}🔓{% else %}🔒{% endif %}</span>
            <span class="milaura-cart-reward__step" aria-hidden="true">{% if paid_cart_cents >= reward_threshold_3_cents %}{{ milaura_reward_open_lock_icon }}{% else %}{{ milaura_reward_closed_lock_icon }}{% endif %}</span>
            <span class="milaura-cart-reward__name">{{ section.settings.gift_3_name }}</span>
            <span class="milaura-cart-reward__value">{{ section.settings.gift_3_value }}</span>
            <span class="milaura-cart-reward__hint">{{ section.settings.gift_3_hint }}</span>
            <span class="milaura-cart-reward__reveal">
              <span class="milaura-cart-reward__reveal-logo">{{ milaura_reward_brand_logo }}</span>
              <span class="milaura-cart-reward__won">Votre avantage MilAura</span>
              <span class="milaura-cart-reward__prize">30 % de remise</span>
            </span>
            <span class="milaura-cart-reward__status" data-reward-status>
              {%- if card_3_active -%}Votre remise est appliquée au panier.{%- elsif paid_cart_cents >= reward_threshold_3_cents -%}Grattez votre carte surprise.{%- else -%}Atteignez {{ reward_threshold_3_label }} de panier pour débloquer cette carte.{%- endif -%}
            </span>
          </button>
        </div>

        <p class="milaura-cart-rewards__note">{{ section.settings.note }}</p>
      </div>
    </div>
  </section>

  <script>
    (function() {
      var root = document.getElementById('MilauraCartRewards-{{ section.id }}');
      if (!root) return;

      var CART_SIGNATURE = root.getAttribute('data-cart-signature') || 'cart';
      var CART_SUBTOTAL = root.getAttribute('data-paid-subtotal-cents') || '0';
      var STORAGE_KEY = 'milaura-cart-rewards-v3';
      var CLEAR_STORAGE_KEY = STORAGE_KEY + ':stale-clear:' + CART_SIGNATURE + ':' + CART_SUBTOTAL;
      var SCRATCH_THRESHOLD = 0.36;
      var SCRATCH_RADIUS = 34;
      var OPEN_LOCK_ICON = '<svg class="milaura-cart-reward__lock-svg" viewBox="0 0 24 24" aria-hidden="true"><rect x="3" y="11" width="18" height="10" rx="2"></rect><path d="M7 11V8a5 5 0 0 1 9.8-1.4"></path></svg>';
      var CLOSED_LOCK_ICON = '<svg class="milaura-cart-reward__lock-svg" viewBox="0 0 24 24" aria-hidden="true"><rect x="3" y="11" width="18" height="10" rx="2"></rect><path d="M7 11V8a5 5 0 0 1 10 0v3"></path></svg>';
      var cards = Array.prototype.slice.call(root.querySelectorAll('[data-milaura-reward-card]'));
      var revealed = readRevealedCards();

      function readRevealedCards() {
        try {
          var raw = sessionStorage.getItem(STORAGE_KEY);
          var parsed = raw ? JSON.parse(raw) : [];
          return new Set(Array.isArray(parsed) ? parsed : []);
        } catch (e) {
          return new Set();
        }
      }

      function persistRevealedCards() {
        try {
          sessionStorage.setItem(STORAGE_KEY, JSON.stringify(Array.from(revealed)));
        } catch (e) {
          /* ignore */
        }
      }

      function setStatus(card, message, state) {
        var status = card.querySelector('[data-reward-status]');
        if (!status) return;
        status.textContent = message || '';
        status.classList.remove('is-success', 'is-error');
        if (state === 'success') status.classList.add('is-success');
        if (state === 'error') status.classList.add('is-error');
      }

      function setLockIcon(card, isOpen) {
        var lock = card.querySelector('.milaura-cart-reward__lock');
        if (!lock) return;
        lock.innerHTML = isOpen ? OPEN_LOCK_ICON : CLOSED_LOCK_ICON;
      }

      function isMilAuraGiftItem(item) {
        if (!item) return false;
        var props = item.properties || {};
        return props._milaura_gift === 'true' ||
          (item.handle && item.handle.indexOf('cadeau-') === 0) ||
          (item.product_title && item.product_title.indexOf('Cadeau -') === 0);
      }

      function paidSubtotalCents(cart) {
        if (!cart || !cart.items) return 0;
        return cart.items.reduce(function(total, item) {
          if (isMilAuraGiftItem(item)) return total;
          return total + paidLinePriceCents(item);
        }, 0);
      }

      function paidLinePriceCents(item) {
        if (!item) return 0;
        if (item.final_line_price !== undefined && item.final_line_price !== null) {
          return Number(item.final_line_price) || 0;
        }
        if (item.line_price !== undefined && item.line_price !== null) {
          return Number(item.line_price) || 0;
        }
        return Number(item.original_line_price || 0) || 0;
      }

      function fetchCart() {
        return fetch('/cart.js').then(function(response) {
          return response.ok ? response.json() : null;
        });
      }

      function normalizeDiscountCode(code) {
        return String(code || '').trim().toUpperCase();
      }

      function uniqueDiscountCodes(codes) {
        var seen = {};
        return codes.filter(function(code) {
          var normalized = normalizeDiscountCode(code);
          if (!normalized || seen[normalized]) return false;
          seen[normalized] = true;
          return true;
        });
      }

      function discountPayloadFromCards(excludedIndexes, extraCard) {
        var excluded = excludedIndexes || [];
        var codes = [];
        cards.forEach(function(card) {
          var index = card.getAttribute('data-reward-index');
          if (excluded.indexOf(index) !== -1) return;
          if (card.getAttribute('data-active') !== 'true') return;
          var code = card.getAttribute('data-discount-code');
          if (code) codes.push(code);
        });
        if (extraCard && extraCard.getAttribute('data-discount-code')) {
          codes.push(extraCard.getAttribute('data-discount-code'));
        }
        return uniqueDiscountCodes(codes).join(',');
      }

      function discountCodeAccepted(cart, code) {
        if (!cart || !code) return false;
        var target = normalizeDiscountCode(code);
        var discountCodes = Array.isArray(cart.discount_codes) ? cart.discount_codes : [];
        var matchingCode = discountCodes.find(function(discount) {
          return normalizeDiscountCode(discount && discount.code) === target;
        });
        if (matchingCode) return matchingCode.applicable !== false;

        var cartLevelApplications = Array.isArray(cart.cart_level_discount_applications) ? cart.cart_level_discount_applications : [];
        return cartLevelApplications.some(function(application) {
          return normalizeDiscountCode((application && (application.title || application.code)) || '') === target;
        });
      }

      function discountAffectsCartTotal(cart) {
        if (!cart) return false;
        if ((Number(cart.total_discount || 0) || 0) > 0) return true;
        return (cart.items || []).some(function(item) {
          return (Number(item.total_discount || item.line_level_total_discount || 0) || 0) > 0;
        });
      }

      function refreshActiveDiscountCards(activeCards) {
        var activeCodes = discountPayloadFromCards([], null);
        if (!activeCodes) return fetchCart();
        return fetch('/cart/update.js', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ discount: activeCodes })
        }).then(function(response) {
          return response.ok ? response.json() : fetchCart();
        });
      }

      function removeCartLine(itemKey) {
        if (!itemKey) return Promise.resolve(null);
        return fetch('/cart/change.js', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ id: itemKey, quantity: 0 })
        }).then(function(response) {
          return response.ok ? response.json() : null;
        });
      }

      function clearStaleRewardState(staleCards) {
        if (!staleCards.length) return Promise.resolve(false);
        var staleIndexes = staleCards.map(function(card) {
          return card.getAttribute('data-reward-index');
        });
        var attributes = { 'Code promo MilAura': '' };
        staleIndexes.forEach(function(index) {
          attributes['Carte MilAura ' + index] = '';
        });

        var hasDiscountCard = staleCards.some(function(card) {
          return Boolean(card.getAttribute('data-discount-code'));
        });
        var staleVariantIds = staleCards
          .map(function(card) { return parseInt(card.getAttribute('data-variant-id'), 10); })
          .filter(function(variantId) { return Number.isFinite(variantId) && variantId > 0; });

        var payload = { attributes: attributes };
        if (hasDiscountCard) payload.discount = '';
        if (hasDiscountCard) {
          var remainingDiscountCodes = discountPayloadFromCards(staleIndexes, null);
          attributes['Code promo MilAura'] = remainingDiscountCodes;
          payload.discount = remainingDiscountCodes;
        }

        return fetch('/cart/update.js', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify(payload)
        })
        .then(function() {
          if (!staleVariantIds.length) return null;
          return fetchCart().then(function(cart) {
            var staleGiftLines = (cart && cart.items ? cart.items : []).filter(function(item) {
              return staleVariantIds.indexOf(item.variant_id) !== -1 && isMilAuraGiftItem(item);
            });
            return staleGiftLines.reduce(function(promise, item) {
              return promise.then(function() { return removeCartLine(item.key); });
            }, Promise.resolve());
          });
        })
        .then(function() {
          try { sessionStorage.setItem(CLEAR_STORAGE_KEY, '1'); } catch (e) { /* ignore */ }
          return true;
        });
      }

      function addGiftVariant(card) {
        var variantId = parseInt(card.getAttribute('data-variant-id'), 10);
        var thresholdCents = parseInt(card.getAttribute('data-threshold-cents'), 10) || 0;
        if (!variantId) return Promise.resolve({ type: 'gift', skipped: true });

        return fetchCart().then(function(cart) {
          if (paidSubtotalCents(cart) < thresholdCents) {
            throw new Error('threshold_not_met');
          }
          var alreadyInCart = cart && cart.items && cart.items.some(function(item) {
            return item.variant_id === variantId;
          });
          if (alreadyInCart) {
            return { type: 'gift', alreadyInCart: true };
          }
          return fetch('/cart/add.js', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({
              items: [{
                id: variantId,
                quantity: 1,
                properties: {
                  'Cadeau MilAura': 'Bracelet hématite offert',
                  'Statut': 'Offert',
                  '_milaura_gift': 'true',
                  '_milaura_gift_min_paid_cents': String(thresholdCents)
                }
              }]
            })
          }).then(function(response) {
            if (!response.ok) {
              return response.json().catch(function() { return {}; }).then(function(data) {
                throw new Error(data.description || data.message || 'cart_error');
              });
            }
            return { type: 'gift', added: true };
          });
        });
      }

      function applyDiscountCode(card) {
        var code = card.getAttribute('data-discount-code');
        var rewardIndex = card.getAttribute('data-reward-index');
        if (!code) return Promise.resolve({ type: 'discount', skipped: true });

        var discountPayload = discountPayloadFromCards([rewardIndex], card);
        var attributes = {};
        attributes['Code promo MilAura'] = discountPayload;
        attributes['Carte MilAura ' + rewardIndex] = code;
        return fetch('/cart/update.js', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({
            discount: discountPayload,
            attributes: attributes
          })
        })
        .then(function(response) {
          return response.json().catch(function() { return {}; }).then(function(cart) {
            if (!response.ok) {
              throw new Error((cart && (cart.description || cart.message)) || 'discount_update_failed');
            }
            if (!discountCodeAccepted(cart, code)) {
              var restoreDiscounts = discountPayloadFromCards([rewardIndex], null);
              var clearAttributes = {};
              clearAttributes['Carte MilAura ' + rewardIndex] = '';
              clearAttributes['Code promo MilAura'] = restoreDiscounts;
              return fetch('/cart/update.js', {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify({
                  discount: restoreDiscounts,
                  attributes: clearAttributes
                })
              }).then(function() {
                throw new Error('discount_not_applicable');
              });
            }
            return {
              type: 'discount',
              code: code,
              affectsCartTotal: discountAffectsCartTotal(cart)
            };
          });
        });
      }

      function activateReward(card) {
        var tasks = [];
        if (card.getAttribute('data-variant-id')) tasks.push(addGiftVariant(card));
        if (card.getAttribute('data-discount-code')) tasks.push(applyDiscountCode(card));

        if (!tasks.length) {
          setStatus(card, activeMessageForCard(card), 'success');
          return;
        }

        card.disabled = true;
        setStatus(card, 'Activation dans votre panier...', null);

        Promise.all(tasks)
          .then(function(results) {
            card.setAttribute('data-active', 'true');
            card.classList.add('is-active');
            var giftResult = results.find(function(result) { return result && result.type === 'gift'; });
            var discountResult = results.find(function(result) { return result && result.type === 'discount'; });
            if (giftResult || discountResult) {
              setStatus(card, activeMessageForCard(card), 'success');
            } else {
              setStatus(card, 'Avantage activé.', 'success');
            }
            window.setTimeout(function() {
              window.location.reload();
            }, 900);
          })
          .catch(function(error) {
            console.warn('MilAura reward activation failed:', error);
            revealed.delete(card.getAttribute('data-reward-index'));
            persistRevealedCards();
            card.disabled = false;
            setStatus(card, error && error.message === 'discount_not_applicable' ? 'Code non accepté par Shopify pour ce panier.' : 'Activation impossible pour le moment. Vous pouvez continuer votre commande.', 'error');
          });
      }

      function activeMessageForCard(card) {
        if (card.getAttribute('data-variant-id')) {
          return 'Votre cadeau MilAura est dans votre panier.';
        }
        if (card.getAttribute('data-reward-index') === '3') {
          return 'Votre remise est appliquée au panier.';
        }
        if (card.getAttribute('data-reward-index') === '1') {
          return 'Les frais de port offerts seront appliqués au paiement.';
        }
        if (card.getAttribute('data-discount-code')) {
          return 'Avantage déjà activé.';
        }
        return 'Avantage déjà activé.';
      }

      function revealCard(card, shouldActivate) {
        var index = card.getAttribute('data-reward-index');
        if (card.classList.contains('is-locked')) return;
        if (card.classList.contains('is-revealed') && shouldActivate) return;

        var canvas = card.querySelector('canvas');
        if (canvas) canvas.remove();

        card.classList.add('is-revealed');
        setLockIcon(card, true);
        revealed.add(index);
        persistRevealedCards();

        if (shouldActivate) {
          activateReward(card);
        } else if (card.getAttribute('data-active') === 'true') {
          setStatus(card, activeMessageForCard(card), 'success');
        }
      }

      function initCanvas(card) {
        var canvas = document.createElement('canvas');
        canvas.className = 'milaura-cart-reward__canvas';
        card.appendChild(canvas);

        function sizeCanvas() {
          var rect = card.getBoundingClientRect();
          var ratio = window.devicePixelRatio || 1;
          canvas.width = Math.max(1, Math.floor(rect.width * ratio));
          canvas.height = Math.max(1, Math.floor(rect.height * ratio));
          canvas.style.width = rect.width + 'px';
          canvas.style.height = rect.height + 'px';
          var ctx = canvas.getContext('2d');
          ctx.scale(ratio, ratio);
          paintOverlay(ctx, rect.width, rect.height);
          return ctx;
        }

        function paintOverlay(ctx, width, height) {
          var gradient = ctx.createLinearGradient(0, 0, width, height);
          gradient.addColorStop(0, '#F5D88B');
          gradient.addColorStop(0.52, '#D6AE59');
          gradient.addColorStop(1, '#9B762E');
          ctx.fillStyle = gradient;
          ctx.fillRect(0, 0, width, height);

          var glow = ctx.createRadialGradient(width * 0.22, height * 0.05, 0, width * 0.22, height * 0.05, width * 0.85);
          glow.addColorStop(0, 'rgba(255, 255, 255, 0.42)');
          glow.addColorStop(0.46, 'rgba(255, 255, 255, 0.08)');
          glow.addColorStop(1, 'rgba(255, 255, 255, 0)');
          ctx.fillStyle = glow;
          ctx.fillRect(0, 0, width, height);

          ctx.save();
          ctx.globalAlpha = 0.16;
          ctx.strokeStyle = '#FFFFFF';
          ctx.lineWidth = 1;
          for (var stripe = -height; stripe < width + height; stripe += 18) {
            ctx.beginPath();
            ctx.moveTo(stripe, height);
            ctx.lineTo(stripe + height, 0);
            ctx.stroke();
          }
          ctx.restore();

          ctx.save();
          ctx.strokeStyle = 'rgba(255, 255, 255, 0.36)';
          ctx.lineWidth = 1;
          roundedRect(ctx, 9, 9, width - 18, height - 18, 13);
          ctx.stroke();
          ctx.strokeStyle = 'rgba(72, 49, 15, 0.12)';
          roundedRect(ctx, 12, 12, width - 24, height - 24, 10);
          ctx.stroke();
          ctx.restore();

          var sealY = Math.max(44, height * 0.36);
          ctx.save();
          ctx.shadowColor = 'rgba(72, 49, 15, 0.2)';
          ctx.shadowBlur = 14;
          ctx.shadowOffsetY = 7;
          ctx.fillStyle = 'rgba(255, 255, 255, 0.34)';
          ctx.beginPath();
          ctx.arc(width / 2, sealY, 22, 0, Math.PI * 2);
          ctx.fill();
          ctx.shadowColor = 'transparent';
          ctx.strokeStyle = 'rgba(255, 255, 255, 0.46)';
          ctx.lineWidth = 1.5;
          ctx.beginPath();
          ctx.arc(width / 2, sealY, 17, 0, Math.PI * 2);
          ctx.stroke();
          drawCanvasLock(ctx, width / 2, sealY, true);
          ctx.restore();

          var pillWidth = Math.min(width - 42, 196);
          var pillX = (width - pillWidth) / 2;
          var pillY = Math.min(height - 62, sealY + 32);
          ctx.save();
          ctx.fillStyle = 'rgba(255, 255, 255, 0.28)';
          roundedRect(ctx, pillX, pillY, pillWidth, 44, 22);
          ctx.fill();
          ctx.strokeStyle = 'rgba(255, 255, 255, 0.28)';
          ctx.lineWidth = 1;
          roundedRect(ctx, pillX + 1, pillY + 1, pillWidth - 2, 42, 21);
          ctx.stroke();
          ctx.fillStyle = 'rgba(255, 255, 255, 0.92)';
          ctx.font = '900 14px Lato, sans-serif';
          ctx.textAlign = 'center';
          ctx.textBaseline = 'middle';
          ctx.fillText('GRATTEZ ICI', width / 2, pillY + 19);
          ctx.fillStyle = 'rgba(255, 255, 255, 0.72)';
          ctx.font = '800 9px Lato, sans-serif';
          ctx.fillText('VOTRE CARTE SURPRISE MILAURA', width / 2, pillY + 33);
          ctx.restore();
        }

        function drawCanvasLock(ctx, x, y, isOpen) {
          ctx.save();
          ctx.strokeStyle = 'rgba(26, 26, 46, 0.58)';
          ctx.lineWidth = 2.2;
          ctx.lineCap = 'round';
          ctx.lineJoin = 'round';
          roundedRect(ctx, x - 10, y - 2, 20, 15, 4);
          ctx.stroke();
          ctx.beginPath();
          if (isOpen) {
            ctx.moveTo(x - 7, y - 3);
            ctx.bezierCurveTo(x - 11, y - 16, x + 4, y - 21, x + 10, y - 10);
          } else {
            ctx.moveTo(x - 7, y - 3);
            ctx.bezierCurveTo(x - 7, y - 16, x + 7, y - 16, x + 7, y - 3);
          }
          ctx.stroke();
          ctx.beginPath();
          ctx.moveTo(x, y + 4);
          ctx.lineTo(x, y + 7);
          ctx.stroke();
          ctx.restore();
        }

        function roundedRect(ctx, x, y, width, height, radius) {
          var safeRadius = Math.min(radius, width / 2, height / 2);
          ctx.beginPath();
          ctx.moveTo(x + safeRadius, y);
          ctx.lineTo(x + width - safeRadius, y);
          ctx.quadraticCurveTo(x + width, y, x + width, y + safeRadius);
          ctx.lineTo(x + width, y + height - safeRadius);
          ctx.quadraticCurveTo(x + width, y + height, x + width - safeRadius, y + height);
          ctx.lineTo(x + safeRadius, y + height);
          ctx.quadraticCurveTo(x, y + height, x, y + height - safeRadius);
          ctx.lineTo(x, y + safeRadius);
          ctx.quadraticCurveTo(x, y, x + safeRadius, y);
          ctx.closePath();
        }

        var ctx = sizeCanvas();
        var scratching = false;
        var checkPending = false;
        var lastScratchPos = null;

        function position(event) {
          var rect = canvas.getBoundingClientRect();
          var source = event;
          if (event.touches && event.touches.length) source = event.touches[0];
          if (event.changedTouches && event.changedTouches.length) source = event.changedTouches[0];
          return {
            x: source.clientX - rect.left,
            y: source.clientY - rect.top
          };
        }

        function scratch(pos) {
          ctx.globalCompositeOperation = 'destination-out';
          if (lastScratchPos) {
            var dx = pos.x - lastScratchPos.x;
            var dy = pos.y - lastScratchPos.y;
            var distance = Math.sqrt((dx * dx) + (dy * dy));
            var steps = Math.max(1, Math.ceil(distance / (SCRATCH_RADIUS * 0.55)));
            for (var step = 1; step <= steps; step += 1) {
              eraseAt({
                x: lastScratchPos.x + (dx * step / steps),
                y: lastScratchPos.y + (dy * step / steps)
              });
            }
          } else {
            eraseAt(pos);
          }
          ctx.globalCompositeOperation = 'source-over';
          lastScratchPos = pos;

          if (!checkPending) {
            checkPending = true;
            requestAnimationFrame(function() {
              checkPending = false;
              checkReveal(card, canvas, ctx);
            });
          }
        }

        function eraseAt(pos) {
          ctx.beginPath();
          ctx.arc(pos.x, pos.y, SCRATCH_RADIUS, 0, Math.PI * 2);
          ctx.fill();
        }

        canvas.addEventListener('pointerdown', function(event) {
          event.preventDefault();
          scratching = true;
          lastScratchPos = null;
          try { canvas.setPointerCapture(event.pointerId); } catch (e) { /* ignore */ }
          scratch(position(event));
        });

        canvas.addEventListener('pointermove', function(event) {
          if (!scratching) return;
          event.preventDefault();
          scratch(position(event));
        });

        canvas.addEventListener('pointerup', function(event) {
          scratching = false;
          lastScratchPos = null;
          try { canvas.releasePointerCapture(event.pointerId); } catch (e) { /* ignore */ }
        });

        canvas.addEventListener('pointercancel', function() {
          scratching = false;
          lastScratchPos = null;
        });

        canvas.addEventListener('touchstart', function(event) {
          event.preventDefault();
          scratching = true;
          lastScratchPos = null;
          scratch(position(event));
        }, { passive: false });

        canvas.addEventListener('touchmove', function(event) {
          if (!scratching) return;
          event.preventDefault();
          scratch(position(event));
        }, { passive: false });

        canvas.addEventListener('touchend', function() {
          scratching = false;
          lastScratchPos = null;
        }, { passive: true });

        canvas.addEventListener('touchcancel', function() {
          scratching = false;
          lastScratchPos = null;
        }, { passive: true });

        window.addEventListener('resize', function() {
          if (!card.classList.contains('is-revealed') && canvas.isConnected) {
            ctx = sizeCanvas();
          }
        });
      }

      function checkReveal(card, canvas, ctx) {
        if (card.classList.contains('is-revealed')) return;
        var width = canvas.width;
        var height = canvas.height;
        var imageData;
        try {
          imageData = ctx.getImageData(0, 0, width, height);
        } catch (e) {
          return;
        }

        var pixels = imageData.data;
        var transparent = 0;
        var total = width * height;
        for (var i = 3; i < pixels.length; i += 24) {
          if (pixels[i] < 10) transparent += 6;
        }

        if (transparent / total >= SCRATCH_THRESHOLD) {
          revealCard(card, true);
        }
      }

      var staleCards = [];
      var staleFromLiquid = (root.getAttribute('data-stale-reward-indexes') || '')
        .split(',')
        .map(function(index) { return index.trim(); })
        .filter(Boolean);
      cards.forEach(function(card) {
        var index = card.getAttribute('data-reward-index');
        var isActive = card.getAttribute('data-active') === 'true';
        if (staleFromLiquid.indexOf(index) !== -1) {
          staleCards.push(card);
        }
      });

      if (staleCards.length) {
        var alreadyCleared = false;
        try { alreadyCleared = sessionStorage.getItem(CLEAR_STORAGE_KEY) === '1'; } catch (e) { /* ignore */ }
        if (!alreadyCleared) {
          clearStaleRewardState(staleCards).then(function(changed) {
            if (changed) window.location.reload();
          });
          return;
        }
      }

      function initialiseCards() {
        cards.forEach(function(card) {
        var index = card.getAttribute('data-reward-index');
        var isUnlocked = card.getAttribute('data-unlocked') === 'true';
        var isActive = card.getAttribute('data-active') === 'true';

        if (!isUnlocked) {
          setLockIcon(card, false);
          return;
        }
        card.classList.remove('is-locked');
        if (isActive) {
          revealCard(card, false);
        } else {
          card.setAttribute('data-active', 'false');
          card.classList.remove('is-active', 'is-revealed');
          setLockIcon(card, true);
          initCanvas(card);
        }

        card.addEventListener('keydown', function(event) {
          if (event.key !== 'Enter' && event.key !== ' ') return;
          event.preventDefault();
          revealCard(card, true);
        });
        });
      }

      var activeDiscountCards = cards.filter(function(card) {
        return card.getAttribute('data-active') === 'true' && Boolean(card.getAttribute('data-discount-code'));
      });
      if (activeDiscountCards.length) {
        refreshActiveDiscountCards(activeDiscountCards).then(function(cart) {
          var rejectedCards = cart ? activeDiscountCards.filter(function(card) {
            return !discountCodeAccepted(cart, card.getAttribute('data-discount-code'));
          }) : [];
          if (!rejectedCards.length) {
            initialiseCards();
            return;
          }
          clearStaleRewardState(rejectedCards).then(function(changed) {
            if (changed) window.location.reload();
          });
        }).catch(function() {
          initialiseCards();
        });
        return;
      }

      initialiseCards();
    })();
  </script>
{%- endif -%}

