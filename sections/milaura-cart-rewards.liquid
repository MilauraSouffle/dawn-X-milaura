{%- comment -%}
  MILAURA CART REWARDS
  Cartes a gratter panier. Non bloquant pour le paiement.
{%- endcomment -%}

{%- if cart.item_count > 0 -%}
  {%- liquid
    assign reward_threshold_1_cents = section.settings.threshold_1 | default: 20 | times: 100
    assign reward_threshold_2_cents = section.settings.threshold_2 | default: 50 | times: 100
    assign reward_threshold_3_cents = section.settings.threshold_3 | default: 80 | times: 100
    assign reward_threshold_1_label = reward_threshold_1_cents | money_without_trailing_zeros | remove: '€' | strip | append: ' €'
    assign reward_threshold_2_label = reward_threshold_2_cents | money_without_trailing_zeros | remove: '€' | strip | append: ' €'
    assign reward_threshold_3_label = reward_threshold_3_cents | money_without_trailing_zeros | remove: '€' | strip | append: ' €'
    assign paid_cart_cents = 0
    assign paid_cart_signature = ''
    assign gift_2_variant_id_num = section.settings.gift_2_variant_id | plus: 0
    assign gift_2_in_cart = false
    assign card_1_attribute = ''
    assign card_3_attribute = ''

    for attribute in cart.attributes
      if attribute.first == 'Carte MilAura 1'
        assign card_1_attribute = attribute.last
      endif
      if attribute.first == 'Carte MilAura 3'
        assign card_3_attribute = attribute.last
      endif
    endfor

    for item in cart.items
      assign is_milaura_gift = false
      if item.product.tags contains 'milaura-gift' or item.product.title contains 'Cadeau -'
        assign is_milaura_gift = true
      endif
      for property in item.properties
        if property.first == '_milaura_gift' and property.last == 'true'
          assign is_milaura_gift = true
        endif
      endfor

      if is_milaura_gift
        if gift_2_variant_id_num > 0 and item.variant_id == gift_2_variant_id_num
          assign gift_2_in_cart = true
        endif
      else
        assign paid_cart_cents = paid_cart_cents | plus: item.original_line_price
        assign paid_cart_signature = paid_cart_signature | append: item.variant_id | append: ':' | append: item.quantity | append: ';'
      endif
    endfor

    assign paid_cart_label = paid_cart_cents | money_without_currency | append: ' €'

    assign unlocked_cards = 0
    if paid_cart_cents >= reward_threshold_1_cents
      assign unlocked_cards = 1
    endif
    if paid_cart_cents >= reward_threshold_2_cents
      assign unlocked_cards = 2
    endif
    if paid_cart_cents >= reward_threshold_3_cents
      assign unlocked_cards = 3
    endif

    assign stale_reward_indexes = ''
    assign card_1_code_matched = false
    assign card_3_code_matched = false
    assign card_1_discount_applied = false
    assign card_3_discount_applied = false
    if card_1_attribute == section.settings.gift_1_discount_code and section.settings.gift_1_discount_code != blank
      assign card_1_code_matched = true
    endif
    if card_3_attribute == section.settings.gift_3_discount_code and section.settings.gift_3_discount_code != blank
      assign card_3_code_matched = true
    endif
    for discount_application in cart.cart_level_discount_applications
      if discount_application.title == section.settings.gift_1_discount_code and section.settings.gift_1_discount_code != blank
        assign card_1_discount_applied = true
      endif
      if discount_application.title == section.settings.gift_3_discount_code and section.settings.gift_3_discount_code != blank
        assign card_3_discount_applied = true
      endif
    endfor

    assign card_1_active = false
    assign card_2_active = false
    assign card_3_active = false
    if card_1_code_matched or card_1_discount_applied
      assign card_1_reward_applied = true
    else
      assign card_1_reward_applied = false
    endif
    if card_3_code_matched or card_3_discount_applied
      assign card_3_reward_applied = true
    else
      assign card_3_reward_applied = false
    endif
    if card_1_reward_applied and paid_cart_cents >= reward_threshold_1_cents
      assign card_1_active = true
    elsif card_1_reward_applied
      assign stale_reward_indexes = stale_reward_indexes | append: '1,'
    endif
    if gift_2_in_cart and paid_cart_cents >= reward_threshold_2_cents
      assign card_2_active = true
    elsif gift_2_in_cart
      assign stale_reward_indexes = stale_reward_indexes | append: '2,'
    endif
    if card_3_reward_applied and paid_cart_cents >= reward_threshold_3_cents
      assign card_3_active = true
    elsif card_3_reward_applied
      assign stale_reward_indexes = stale_reward_indexes | append: '3,'
    endif
  -%}

  {%- style -%}
    #MilauraCartRewards-{{ section.id }} {
      padding: var(--milaura-spacing-md) 0 var(--milaura-spacing-lg);
    }

    #MilauraCartRewards-{{ section.id }} .milaura-cart-rewards__panel {
      position: relative;
      overflow: hidden;
      padding: 22px;
      border: 1px solid rgba(192, 160, 98, 0.24);
      border-radius: 18px;
      background:
        radial-gradient(circle at 10% 0%, rgba(230, 200, 139, 0.22), transparent 28%),
        linear-gradient(180deg, rgba(255, 252, 245, 0.97), rgba(255, 255, 255, 0.99));
      box-shadow: 0 18px 44px rgba(26, 26, 46, 0.08);
    }

    #MilauraCartRewards-{{ section.id }} .milaura-cart-rewards__panel::before {
      content: "";
      position: absolute;
      inset: 0;
      background: linear-gradient(120deg, transparent 0%, rgba(255, 255, 255, 0.58) 45%, transparent 68%);
      opacity: 0.34;
      transform: translateX(-70%) skewX(-14deg);
      animation: milaura-cart-rewards-sheen 6s ease-in-out infinite;
      pointer-events: none;
    }

    @keyframes milaura-cart-rewards-sheen {
      0%, 44% { transform: translateX(-70%) skewX(-14deg); opacity: 0; }
      58% { opacity: 0.42; }
      100% { transform: translateX(76%) skewX(-14deg); opacity: 0; }
    }

    #MilauraCartRewards-{{ section.id }} .milaura-cart-rewards__header {
      display: grid;
      gap: 8px;
      margin-bottom: 16px;
      text-align: center;
      position: relative;
      z-index: 1;
    }

    #MilauraCartRewards-{{ section.id }} .milaura-cart-rewards__eyebrow {
      margin: 0;
      font-size: 0.72rem;
      font-weight: 800;
      letter-spacing: 0.08em;
      text-transform: uppercase;
      color: var(--milaura-gold-dark, #8F723A);
    }

    #MilauraCartRewards-{{ section.id }} .milaura-cart-rewards__title {
      margin: 0;
      font-family: var(--milaura-font-heading, 'Playfair Display', serif);
      font-size: clamp(1.45rem, 5vw, 2rem);
      line-height: 1.12;
      color: var(--milaura-text, #000);
    }

    #MilauraCartRewards-{{ section.id }} .milaura-cart-rewards__subtitle {
      max-width: 660px;
      margin: 0 auto;
      font-size: 0.95rem;
      line-height: 1.45;
      color: var(--milaura-text-light, #666);
    }

    #MilauraCartRewards-{{ section.id }} .milaura-cart-rewards__statusline {
      display: inline-flex;
      align-items: center;
      justify-content: center;
      gap: 8px;
      width: fit-content;
      margin: 6px auto 0;
      padding: 8px 12px;
      border-radius: 999px;
      background: rgba(26, 26, 46, 0.07);
      font-size: 0.82rem;
      font-weight: 800;
      color: #1a1a2e;
    }

    #MilauraCartRewards-{{ section.id }} .milaura-cart-rewards__grid {
      position: relative;
      z-index: 1;
      display: grid;
      grid-template-columns: repeat(3, minmax(0, 1fr));
      gap: 14px;
    }

    #MilauraCartRewards-{{ section.id }} .milaura-cart-reward {
      position: relative;
      min-height: 218px;
      display: flex;
      flex-direction: column;
      justify-content: space-between;
      gap: 10px;
      padding: 18px 15px 15px;
      overflow: hidden;
      border: 1px solid rgba(143, 114, 58, 0.36);
      border-radius: 14px;
      background:
        radial-gradient(circle at 20% 0%, rgba(255, 255, 255, 0.36), transparent 28%),
        linear-gradient(145deg, #FFF3CF 0%, #D8B568 48%, #8F723A 100%);
      color: inherit;
      cursor: pointer;
      text-align: center;
      box-shadow:
        inset 0 1px 0 rgba(255, 255, 255, 0.72),
        0 18px 32px rgba(26, 26, 46, 0.14);
      transform: translateY(0);
      transition: transform 220ms ease, box-shadow 220ms ease, filter 220ms ease, opacity 220ms ease;
    }

    #MilauraCartRewards-{{ section.id }} .milaura-cart-reward::before {
      content: "";
      position: absolute;
      inset: 0;
      background:
        linear-gradient(135deg, rgba(255, 255, 255, 0.26), transparent 34%),
        repeating-linear-gradient(90deg, rgba(255, 255, 255, 0.08) 0 1px, transparent 1px 11px);
      pointer-events: none;
    }

    #MilauraCartRewards-{{ section.id }} .milaura-cart-reward.is-featured {
      border: 1px solid rgba(26, 26, 46, 0.3);
      background:
        radial-gradient(circle at 20% 0%, rgba(255, 255, 255, 0.38), transparent 28%),
        linear-gradient(145deg, #FFF8DF 0%, #E6C88B 42%, #A67828 100%);
      box-shadow:
        inset 0 1px 0 rgba(255, 255, 255, 0.76),
        0 22px 38px rgba(192, 160, 98, 0.22);
    }

    #MilauraCartRewards-{{ section.id }} .milaura-cart-reward.is-locked {
      cursor: default;
      opacity: 0.58;
      filter: grayscale(0.42) saturate(0.72);
    }

    #MilauraCartRewards-{{ section.id }} .milaura-cart-reward.is-revealed {
      border-color: rgba(76, 175, 80, 0.42);
      box-shadow: 0 10px 24px rgba(76, 175, 80, 0.1);
    }

    #MilauraCartRewards-{{ section.id }} .milaura-cart-reward__badge {
      position: absolute;
      top: 12px;
      left: 12px;
      right: auto;
      padding: 5px 9px;
      border-radius: 999px;
      background: rgba(26, 26, 46, 0.88);
      font-size: 0.62rem;
      font-weight: 900;
      letter-spacing: 0.05em;
      text-transform: uppercase;
      color: var(--milaura-gold-light, #E6C88B);
      z-index: 2;
    }

    #MilauraCartRewards-{{ section.id }} .milaura-cart-reward.is-featured .milaura-cart-reward__badge {
      background: #1a1a2e;
      color: var(--milaura-gold-light, #E6C88B);
    }

    #MilauraCartRewards-{{ section.id }} .milaura-cart-reward__step {
      width: 34px;
      height: 34px;
      display: inline-flex;
      align-items: center;
      justify-content: center;
      margin: 28px auto 0;
      border-radius: 50%;
      background: rgba(26, 26, 46, 0.94);
      color: var(--milaura-gold-light, #E6C88B);
      font-family: var(--milaura-font-heading, 'Playfair Display'), serif;
      font-weight: 900;
      z-index: 2;
    }

    #MilauraCartRewards-{{ section.id }} .milaura-cart-reward__lock {
      position: absolute;
      top: 12px;
      right: 12px;
      width: 30px;
      height: 30px;
      display: inline-flex;
      align-items: center;
      justify-content: center;
      border-radius: 50%;
      background: rgba(255, 255, 255, 0.84);
      color: #1a1a2e;
      font-size: 0.88rem;
      font-weight: 900;
      z-index: 4;
      pointer-events: none;
    }

    #MilauraCartRewards-{{ section.id }} .milaura-cart-reward__lock-svg {
      width: 16px;
      height: 16px;
      display: block;
      fill: none;
      stroke: currentColor;
      stroke-width: 2.2;
      stroke-linecap: round;
      stroke-linejoin: round;
    }

    #MilauraCartRewards-{{ section.id }} .milaura-cart-reward__name {
      margin: 0;
      font-family: var(--milaura-font-heading, 'Playfair Display', serif);
      font-size: 1.08rem;
      font-weight: 700;
      line-height: 1.2;
      color: #1a1a2e;
      z-index: 2;
    }

    #MilauraCartRewards-{{ section.id }} .milaura-cart-reward__value {
      margin: 0;
      font-size: 0.84rem;
      font-weight: 900;
      color: #2C210F;
      z-index: 2;
    }

    #MilauraCartRewards-{{ section.id }} .milaura-cart-reward__hint,
    #MilauraCartRewards-{{ section.id }} .milaura-cart-reward__status {
      margin: 0;
      font-size: 0.78rem;
      line-height: 1.35;
      color: rgba(26, 26, 46, 0.72);
      z-index: 2;
    }

    #MilauraCartRewards-{{ section.id }} .milaura-cart-reward__status {
      min-height: 2.1em;
      font-weight: 800;
      color: #1a1a2e;
      z-index: 2;
    }

    #MilauraCartRewards-{{ section.id }} .milaura-cart-reward__status.is-success {
      color: #2e7d32;
    }

    #MilauraCartRewards-{{ section.id }} .milaura-cart-reward__status.is-error {
      color: #9f2f2f;
    }

    #MilauraCartRewards-{{ section.id }} .milaura-cart-reward__canvas {
      position: absolute;
      inset: 0;
      width: 100%;
      height: 100%;
      display: block;
      touch-action: none;
      user-select: none;
      -webkit-user-select: none;
      -webkit-touch-callout: none;
      cursor: grab;
      z-index: 3;
    }

    #MilauraCartRewards-{{ section.id }} .milaura-cart-rewards__note {
      position: relative;
      z-index: 1;
      margin: 14px 0 0;
      padding-top: 12px;
      border-top: 1px solid rgba(192, 160, 98, 0.18);
      font-size: 0.82rem;
      line-height: 1.4;
      text-align: center;
      color: var(--milaura-text-light, #666);
    }

    @media screen and (max-width: 749px) {
      #MilauraCartRewards-{{ section.id }} .milaura-cart-rewards__panel {
        padding: 15px;
      }

      #MilauraCartRewards-{{ section.id }} .milaura-cart-rewards__grid {
        grid-template-columns: 1fr;
        gap: 10px;
      }

      #MilauraCartRewards-{{ section.id }} .milaura-cart-reward {
        min-height: 168px;
      }
    }
  {%- endstyle -%}

  <section
    id="MilauraCartRewards-{{ section.id }}"
    class="milaura-cart-rewards"
    data-section-id="{{ section.id }}"
    data-paid-subtotal-cents="{{ paid_cart_cents }}"
    data-cart-signature="{{ paid_cart_signature | escape }}"
    data-stale-reward-indexes="{{ stale_reward_indexes | escape }}"
  >
    <div class="page-width">
      <div class="milaura-cart-rewards__panel">
        <div class="milaura-cart-rewards__header">
          <p class="milaura-cart-rewards__eyebrow">{{ section.settings.eyebrow }}</p>
          <h2 class="milaura-cart-rewards__title">{{ section.settings.title }}</h2>
          <p class="milaura-cart-rewards__subtitle">{{ section.settings.subtitle }}</p>
          <p class="milaura-cart-rewards__statusline">
            {{ paid_cart_label }} dans votre panier · {{ unlocked_cards }}/3 carte{% if unlocked_cards > 1 %}s{% endif %} débloquée{% if unlocked_cards > 1 %}s{% endif %}
          </p>
        </div>

        <div class="milaura-cart-rewards__grid" aria-label="Cartes cadeaux MilAura">
          <button
            type="button"
            class="milaura-cart-reward{% if paid_cart_cents < reward_threshold_1_cents %} is-locked{% endif %}{% if card_1_active %} is-active{% endif %}"
            data-milaura-reward-card
            data-reward-index="1"
            data-threshold-cents="{{ reward_threshold_1_cents }}"
            data-discount-code="{{ section.settings.gift_1_discount_code | escape }}"
            data-unlocked="{% if paid_cart_cents >= reward_threshold_1_cents %}true{% else %}false{% endif %}"
            data-active="{% if card_1_active %}true{% else %}false{% endif %}"
            aria-disabled="{% if paid_cart_cents >= reward_threshold_1_cents %}false{% else %}true{% endif %}"
          >
            <span class="milaura-cart-reward__badge">{% if paid_cart_cents >= reward_threshold_1_cents %}Débloquée{% else %}Dès {{ reward_threshold_1_label }}{% endif %}</span>
            <span class="milaura-cart-reward__lock" aria-hidden="true">{% if paid_cart_cents >= reward_threshold_1_cents %}🔓{% else %}🔒{% endif %}</span>
            <span class="milaura-cart-reward__step">M</span>
            <span class="milaura-cart-reward__name">{{ section.settings.gift_1_name }}</span>
            <span class="milaura-cart-reward__value">{{ section.settings.gift_1_value }}</span>
            <span class="milaura-cart-reward__hint">{{ section.settings.gift_1_hint }}</span>
            <span class="milaura-cart-reward__status" data-reward-status>
              {%- if card_1_active -%}Avantage préparé pour le paiement.{%- elsif paid_cart_cents >= reward_threshold_1_cents -%}Grattez pour révéler.{%- else -%}Atteignez {{ reward_threshold_1_label }} de panier.{%- endif -%}
            </span>
          </button>

          <button
            type="button"
            class="milaura-cart-reward is-featured{% if paid_cart_cents < reward_threshold_2_cents %} is-locked{% endif %}{% if card_2_active %} is-active{% endif %}"
            data-milaura-reward-card
            data-reward-index="2"
            data-threshold-cents="{{ reward_threshold_2_cents }}"
            data-variant-id="{{ section.settings.gift_2_variant_id | escape }}"
            data-unlocked="{% if paid_cart_cents >= reward_threshold_2_cents %}true{% else %}false{% endif %}"
            data-active="{% if card_2_active %}true{% else %}false{% endif %}"
            aria-disabled="{% if paid_cart_cents >= reward_threshold_2_cents %}false{% else %}true{% endif %}"
          >
            <span class="milaura-cart-reward__badge">{% if paid_cart_cents >= reward_threshold_2_cents %}Débloquée{% else %}Dès {{ reward_threshold_2_label }}{% endif %}</span>
            <span class="milaura-cart-reward__lock" aria-hidden="true">{% if paid_cart_cents >= reward_threshold_2_cents %}🔓{% else %}🔒{% endif %}</span>
            <span class="milaura-cart-reward__step">M</span>
            <span class="milaura-cart-reward__name">{{ section.settings.gift_2_name }}</span>
            <span class="milaura-cart-reward__value">{{ section.settings.gift_2_value }}</span>
            <span class="milaura-cart-reward__hint">{{ section.settings.gift_2_hint }}</span>
            <span class="milaura-cart-reward__status" data-reward-status>
              {%- if card_2_active -%}Cadeau déjà dans votre panier.{%- elsif paid_cart_cents >= reward_threshold_2_cents -%}Grattez pour révéler.{%- else -%}Atteignez {{ reward_threshold_2_label }} de panier.{%- endif -%}
            </span>
          </button>

          <button
            type="button"
            class="milaura-cart-reward{% if paid_cart_cents < reward_threshold_3_cents %} is-locked{% endif %}{% if card_3_active %} is-active{% endif %}"
            data-milaura-reward-card
            data-reward-index="3"
            data-threshold-cents="{{ reward_threshold_3_cents }}"
            data-discount-code="{{ section.settings.gift_3_discount_code | escape }}"
            data-unlocked="{% if paid_cart_cents >= reward_threshold_3_cents %}true{% else %}false{% endif %}"
            data-active="{% if card_3_active %}true{% else %}false{% endif %}"
            aria-disabled="{% if paid_cart_cents >= reward_threshold_3_cents %}false{% else %}true{% endif %}"
          >
            <span class="milaura-cart-reward__badge">{% if paid_cart_cents >= reward_threshold_3_cents %}Surprise été{% else %}Dès {{ reward_threshold_3_label }}{% endif %}</span>
            <span class="milaura-cart-reward__lock" aria-hidden="true">{% if paid_cart_cents >= reward_threshold_3_cents %}🔓{% else %}🔒{% endif %}</span>
            <span class="milaura-cart-reward__step">M</span>
            <span class="milaura-cart-reward__name">{{ section.settings.gift_3_name }}</span>
            <span class="milaura-cart-reward__value">{{ section.settings.gift_3_value }}</span>
            <span class="milaura-cart-reward__hint">{{ section.settings.gift_3_hint }}</span>
            <span class="milaura-cart-reward__status" data-reward-status>
              {%- if card_3_active -%}Surprise préparée pour le paiement.{%- elsif paid_cart_cents >= reward_threshold_3_cents -%}Grattez pour révéler.{%- else -%}Atteignez {{ reward_threshold_3_label }} de panier.{%- endif -%}
            </span>
          </button>
        </div>

        <p class="milaura-cart-rewards__note">{{ section.settings.note }}</p>
      </div>
    </div>
  </section>

  <script>
    (function() {
      var root = document.getElementById('MilauraCartRewards-{{ section.id }}');
      if (!root) return;

      var CART_SIGNATURE = root.getAttribute('data-cart-signature') || 'cart';
      var CART_SUBTOTAL = root.getAttribute('data-paid-subtotal-cents') || '0';
      var STORAGE_KEY = 'milaura-cart-rewards-v2:' + CART_SIGNATURE + ':' + CART_SUBTOTAL;
      var CLEAR_STORAGE_KEY = STORAGE_KEY + ':stale-clear';
      var SCRATCH_THRESHOLD = 0.48;
      var SCRATCH_RADIUS = 28;
      var OPEN_LOCK_ICON = '<svg class="milaura-cart-reward__lock-svg" viewBox="0 0 24 24" aria-hidden="true"><rect x="3" y="11" width="18" height="10" rx="2"></rect><path d="M7 11V8a5 5 0 0 1 9.8-1.4"></path></svg>';
      var CLOSED_LOCK_ICON = '<svg class="milaura-cart-reward__lock-svg" viewBox="0 0 24 24" aria-hidden="true"><rect x="3" y="11" width="18" height="10" rx="2"></rect><path d="M7 11V8a5 5 0 0 1 10 0v3"></path></svg>';
      var cards = Array.prototype.slice.call(root.querySelectorAll('[data-milaura-reward-card]'));
      var revealed = readRevealedCards();

      function readRevealedCards() {
        try {
          var raw = sessionStorage.getItem(STORAGE_KEY);
          var parsed = raw ? JSON.parse(raw) : [];
          return new Set(Array.isArray(parsed) ? parsed : []);
        } catch (e) {
          return new Set();
        }
      }

      function persistRevealedCards() {
        try {
          sessionStorage.setItem(STORAGE_KEY, JSON.stringify(Array.from(revealed)));
        } catch (e) {
          /* ignore */
        }
      }

      function setStatus(card, message, state) {
        var status = card.querySelector('[data-reward-status]');
        if (!status) return;
        status.textContent = message || '';
        status.classList.remove('is-success', 'is-error');
        if (state === 'success') status.classList.add('is-success');
        if (state === 'error') status.classList.add('is-error');
      }

      function setLockIcon(card, isOpen) {
        var lock = card.querySelector('.milaura-cart-reward__lock');
        if (!lock) return;
        lock.innerHTML = isOpen ? OPEN_LOCK_ICON : CLOSED_LOCK_ICON;
      }

      function isMilAuraGiftItem(item) {
        if (!item) return false;
        var props = item.properties || {};
        return props._milaura_gift === 'true' ||
          (item.handle && item.handle.indexOf('cadeau-') === 0) ||
          (item.product_title && item.product_title.indexOf('Cadeau -') === 0);
      }

      function paidSubtotalCents(cart) {
        if (!cart || !cart.items) return 0;
        return cart.items.reduce(function(total, item) {
          if (isMilAuraGiftItem(item)) return total;
          return total + (Number(item.original_line_price || item.final_line_price || item.line_price || 0) || 0);
        }, 0);
      }

      function fetchCart() {
        return fetch('/cart.js').then(function(response) {
          return response.ok ? response.json() : null;
        });
      }

      function removeCartLine(itemKey) {
        if (!itemKey) return Promise.resolve(null);
        return fetch('/cart/change.js', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ id: itemKey, quantity: 0 })
        }).then(function(response) {
          return response.ok ? response.json() : null;
        });
      }

      function clearStaleRewardState(staleCards) {
        if (!staleCards.length) return Promise.resolve(false);
        var staleIndexes = staleCards.map(function(card) {
          return card.getAttribute('data-reward-index');
        });
        var attributes = { 'Code promo MilAura': '' };
        staleIndexes.forEach(function(index) {
          attributes['Carte MilAura ' + index] = '';
        });

        var hasDiscountCard = staleCards.some(function(card) {
          return Boolean(card.getAttribute('data-discount-code'));
        });
        var staleVariantIds = staleCards
          .map(function(card) { return parseInt(card.getAttribute('data-variant-id'), 10); })
          .filter(function(variantId) { return Number.isFinite(variantId) && variantId > 0; });

        var payload = { attributes: attributes };
        if (hasDiscountCard) payload.discount = '';

        return fetch('/cart/update.js', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify(payload)
        })
        .then(function() {
          if (!staleVariantIds.length) return null;
          return fetchCart().then(function(cart) {
            var staleGiftLines = (cart && cart.items ? cart.items : []).filter(function(item) {
              return staleVariantIds.indexOf(item.variant_id) !== -1 && isMilAuraGiftItem(item);
            });
            return staleGiftLines.reduce(function(promise, item) {
              return promise.then(function() { return removeCartLine(item.key); });
            }, Promise.resolve());
          });
        })
        .then(function() {
          try { sessionStorage.setItem(CLEAR_STORAGE_KEY, '1'); } catch (e) { /* ignore */ }
          return true;
        });
      }

      function addGiftVariant(card) {
        var variantId = parseInt(card.getAttribute('data-variant-id'), 10);
        var thresholdCents = parseInt(card.getAttribute('data-threshold-cents'), 10) || 0;
        if (!variantId) return Promise.resolve({ type: 'gift', skipped: true });

        return fetchCart().then(function(cart) {
          if (paidSubtotalCents(cart) < thresholdCents) {
            throw new Error('threshold_not_met');
          }
          var alreadyInCart = cart && cart.items && cart.items.some(function(item) {
            return item.variant_id === variantId;
          });
          if (alreadyInCart) {
            return { type: 'gift', alreadyInCart: true };
          }
          return fetch('/cart/add.js', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({
              items: [{
                id: variantId,
                quantity: 1,
                properties: {
                  'Cadeau MilAura': 'Bracelet hématite offert',
                  'Statut': 'Offert',
                  '_milaura_gift': 'true',
                  '_milaura_gift_min_paid_cents': String(thresholdCents)
                }
              }]
            })
          }).then(function(response) {
            if (!response.ok) {
              return response.json().catch(function() { return {}; }).then(function(data) {
                throw new Error(data.description || data.message || 'cart_error');
              });
            }
            return { type: 'gift', added: true };
          });
        });
      }

      function applyDiscountCode(card) {
        var code = card.getAttribute('data-discount-code');
        var rewardIndex = card.getAttribute('data-reward-index');
        if (!code) return Promise.resolve({ type: 'discount', skipped: true });

        var attributes = {};
        attributes['Code promo MilAura'] = code;
        attributes['Carte MilAura ' + rewardIndex] = code;
        return fetch('/cart/update.js', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({
            discount: code,
            attributes: attributes
          })
        })
        .then(function() {
          return { type: 'discount', code: code };
        });
      }

      function activateReward(card) {
        var tasks = [];
        if (card.getAttribute('data-variant-id')) tasks.push(addGiftVariant(card));
        if (card.getAttribute('data-discount-code')) tasks.push(applyDiscountCode(card));

        if (!tasks.length) {
          setStatus(card, 'Carte révélée.', 'success');
          return;
        }

        card.disabled = true;
        setStatus(card, 'Activation dans votre panier...', null);

        Promise.all(tasks)
          .then(function(results) {
            card.setAttribute('data-active', 'true');
            card.classList.add('is-active');
            var giftResult = results.find(function(result) { return result && result.type === 'gift'; });
            var discountResult = results.find(function(result) { return result && result.type === 'discount'; });
            if (giftResult && giftResult.alreadyInCart) {
              setStatus(card, 'Cadeau déjà dans votre panier.', 'success');
            } else if (giftResult && giftResult.added) {
              setStatus(card, 'Cadeau ajouté au panier.', 'success');
            } else if (discountResult && discountResult.code) {
              setStatus(card, 'Remise préparée pour le paiement.', 'success');
            } else {
              setStatus(card, 'Avantage activé.', 'success');
            }
            window.setTimeout(function() {
              window.location.reload();
            }, 900);
          })
          .catch(function(error) {
            console.warn('MilAura reward activation failed:', error);
            revealed.delete(card.getAttribute('data-reward-index'));
            persistRevealedCards();
            card.disabled = false;
            setStatus(card, 'Activation impossible pour le moment. Vous pouvez continuer votre commande.', 'error');
          });
      }

      function activeMessageForCard(card) {
        if (card.getAttribute('data-variant-id')) {
          return 'Cadeau déjà dans votre panier.';
        }
        if (card.getAttribute('data-reward-index') === '3') {
          return 'Meilleure remise préparée pour le paiement.';
        }
        return 'Avantage déjà activé.';
      }

      function revealCard(card, shouldActivate) {
        var index = card.getAttribute('data-reward-index');
        if (card.classList.contains('is-locked')) return;
        if (card.classList.contains('is-revealed') && shouldActivate) return;

        var canvas = card.querySelector('canvas');
        if (canvas) canvas.remove();

        card.classList.add('is-revealed');
        setLockIcon(card, true);
        revealed.add(index);
        persistRevealedCards();

        if (shouldActivate) {
          activateReward(card);
        } else if (card.getAttribute('data-active') === 'true') {
          setStatus(card, activeMessageForCard(card), 'success');
        }
      }

      function initCanvas(card) {
        var canvas = document.createElement('canvas');
        canvas.className = 'milaura-cart-reward__canvas';
        card.appendChild(canvas);

        function sizeCanvas() {
          var rect = card.getBoundingClientRect();
          var ratio = window.devicePixelRatio || 1;
          canvas.width = Math.max(1, Math.floor(rect.width * ratio));
          canvas.height = Math.max(1, Math.floor(rect.height * ratio));
          canvas.style.width = rect.width + 'px';
          canvas.style.height = rect.height + 'px';
          var ctx = canvas.getContext('2d');
          ctx.scale(ratio, ratio);
          paintOverlay(ctx, rect.width, rect.height);
          return ctx;
        }

        function paintOverlay(ctx, width, height) {
          var gradient = ctx.createLinearGradient(0, 0, width, height);
          gradient.addColorStop(0, '#E6C88B');
          gradient.addColorStop(1, '#C0A062');
          ctx.fillStyle = gradient;
          ctx.fillRect(0, 0, width, height);
          ctx.fillStyle = 'rgba(26, 26, 46, 0.16)';
          ctx.beginPath();
          ctx.arc(width / 2, height / 2 - 19, 19, 0, Math.PI * 2);
          ctx.fill();
          ctx.fillStyle = 'rgba(255, 255, 255, 0.88)';
          ctx.font = '700 22px Lato, sans-serif';
          ctx.textAlign = 'center';
          ctx.textBaseline = 'middle';
          ctx.fillText('🔓', width / 2, height / 2 - 20);
          ctx.fillStyle = 'rgba(255, 255, 255, 0.82)';
          ctx.font = '800 16px Lato, sans-serif';
          ctx.fillText('Grattez ici', width / 2, height / 2 + 18);
        }

        var ctx = sizeCanvas();
        var scratching = false;
        var checkPending = false;

        function position(event) {
          var rect = canvas.getBoundingClientRect();
          var source = event;
          if (event.touches && event.touches.length) source = event.touches[0];
          if (event.changedTouches && event.changedTouches.length) source = event.changedTouches[0];
          return {
            x: source.clientX - rect.left,
            y: source.clientY - rect.top
          };
        }

        function scratch(pos) {
          ctx.globalCompositeOperation = 'destination-out';
          ctx.beginPath();
          ctx.arc(pos.x, pos.y, SCRATCH_RADIUS, 0, Math.PI * 2);
          ctx.fill();
          ctx.globalCompositeOperation = 'source-over';

          if (!checkPending) {
            checkPending = true;
            requestAnimationFrame(function() {
              checkPending = false;
              checkReveal(card, canvas, ctx);
            });
          }
        }

        canvas.addEventListener('pointerdown', function(event) {
          event.preventDefault();
          scratching = true;
          try { canvas.setPointerCapture(event.pointerId); } catch (e) { /* ignore */ }
          scratch(position(event));
        });

        canvas.addEventListener('pointermove', function(event) {
          if (!scratching) return;
          event.preventDefault();
          scratch(position(event));
        });

        canvas.addEventListener('pointerup', function(event) {
          scratching = false;
          try { canvas.releasePointerCapture(event.pointerId); } catch (e) { /* ignore */ }
        });

        canvas.addEventListener('pointercancel', function() {
          scratching = false;
        });

        canvas.addEventListener('touchstart', function(event) {
          event.preventDefault();
          scratching = true;
          scratch(position(event));
        }, { passive: false });

        canvas.addEventListener('touchmove', function(event) {
          if (!scratching) return;
          event.preventDefault();
          scratch(position(event));
        }, { passive: false });

        canvas.addEventListener('touchend', function() {
          scratching = false;
        }, { passive: true });

        canvas.addEventListener('touchcancel', function() {
          scratching = false;
        }, { passive: true });

        window.addEventListener('resize', function() {
          if (!card.classList.contains('is-revealed') && canvas.isConnected) {
            ctx = sizeCanvas();
          }
        });
      }

      function checkReveal(card, canvas, ctx) {
        if (card.classList.contains('is-revealed')) return;
        var width = canvas.width;
        var height = canvas.height;
        var imageData;
        try {
          imageData = ctx.getImageData(0, 0, width, height);
        } catch (e) {
          return;
        }

        var pixels = imageData.data;
        var transparent = 0;
        var total = width * height;
        for (var i = 3; i < pixels.length; i += 24) {
          if (pixels[i] < 10) transparent += 6;
        }

        if (transparent / total >= SCRATCH_THRESHOLD) {
          revealCard(card, true);
        }
      }

      var staleCards = [];
      var staleFromLiquid = (root.getAttribute('data-stale-reward-indexes') || '')
        .split(',')
        .map(function(index) { return index.trim(); })
        .filter(Boolean);
      cards.forEach(function(card) {
        var index = card.getAttribute('data-reward-index');
        var isActive = card.getAttribute('data-active') === 'true';
        if (staleFromLiquid.indexOf(index) !== -1 || (isActive && !revealed.has(index))) {
          staleCards.push(card);
        }
      });

      if (staleCards.length) {
        var alreadyCleared = false;
        try { alreadyCleared = sessionStorage.getItem(CLEAR_STORAGE_KEY) === '1'; } catch (e) { /* ignore */ }
        if (!alreadyCleared) {
          clearStaleRewardState(staleCards).then(function(changed) {
            if (changed) window.location.reload();
          });
          return;
        }
      }

      cards.forEach(function(card) {
        var index = card.getAttribute('data-reward-index');
        var isUnlocked = card.getAttribute('data-unlocked') === 'true';
        var isActive = card.getAttribute('data-active') === 'true';

        if (!isUnlocked) {
          setLockIcon(card, false);
          return;
        }
        card.classList.remove('is-locked');
        if (isActive && revealed.has(index)) {
          revealCard(card, false);
        } else {
          card.setAttribute('data-active', 'false');
          card.classList.remove('is-active', 'is-revealed');
          setLockIcon(card, true);
          initCanvas(card);
        }

        card.addEventListener('keydown', function(event) {
          if (event.key !== 'Enter' && event.key !== ' ') return;
          event.preventDefault();
          revealCard(card, true);
        });
      });
    })();
  </script>
{%- endif -%}

