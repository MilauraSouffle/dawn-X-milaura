    { "type": "header", "content": "--- SECTION 2 : Atelier ---" },
    { "type": "text", "id": "s2_kicker", "label": "Kicker", "default": "Notre atelier" },
    { "type": "text", "id": "s2_title", "label": "Titre", "default": "Fabrique a la main en Lorraine" },
    { "type": "richtext", "id": "s2_content", "label": "Contenu" },
    { "type": "image_picker", "id": "s2_image", "label": "Image (atelier)" },
    { "type": "header", "content": "--- SECTION 3 : Pierres ---" },
    { "type": "text", "id": "s3_kicker", "label": "Kicker", "default": "Nos pierres" },
    { "type": "text", "id": "s3_title", "label": "Titre", "default": "Selectionnees avec exigence, certifiees avec soin" },
    { "type": "richtext", "id": "s3_content", "label": "Contenu" },
    { "type": "image_picker", "id": "s3_image", "label": "Image (pierres)" },
