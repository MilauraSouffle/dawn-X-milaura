    { "type": "text", "id": "s4_title", "label": "Titre", "default": "Ce en quoi nous croyons" },
    { "type": "text", "id": "v1_icon", "label": "Icone valeur 1", "default": "💎" },
    { "type": "text", "id": "v1_title", "label": "Titre valeur 1", "default": "Authenticite" },
    { "type": "text", "id": "v1_text", "label": "Texte valeur 1", "default": "Pierres 100% naturelles, jamais de synthese. Nous privilegions la transparence sur l'origine et la qualite de chaque gemme." },
    { "type": "text", "id": "v2_icon", "label": "Icone valeur 2", "default": "🇫🇷" },
    { "type": "text", "id": "v2_title", "label": "Titre valeur 2", "default": "Artisanat francais" },
    { "type": "text", "id": "v2_text", "label": "Texte valeur 2", "default": "Nos bougies sont concues et coulees a la main dans notre atelier de Montigny-les-Metz." },
    { "type": "text", "id": "v3_icon", "label": "Icone valeur 3", "default": "🌿" },
    { "type": "text", "id": "v3_title", "label": "Titre valeur 3", "default": "Naturel et responsable" },
    { "type": "text", "id": "v3_text", "label": "Texte valeur 3", "default": "Cire vegetale, huiles essentielles, emballages recycles. Des choix conscients a chaque etape." },
    { "type": "text", "id": "v4_icon", "label": "Icone valeur 4", "default": "✨" },
    { "type": "text", "id": "v4_title", "label": "Titre valeur 4", "default": "Bien-etre emotionnel" },
    { "type": "text", "id": "v4_text", "label": "Texte valeur 4", "default": "Chaque produit est pense comme un compagnon de votre quotidien, un veritable outil de reconnexion a soi." },
    { "type": "header", "content": "--- CTA ---" },
    { "type": "text", "id": "cta_title", "label": "Titre CTA", "default": "Trouvez la pierre qui vous ressemble" },
