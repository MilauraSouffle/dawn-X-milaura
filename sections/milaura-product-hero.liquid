  .milaura-reward-preview__title {
    margin: 0 0 6px;
    color: var(--milaura-text, #000);
    font-family: 'Playfair Display', serif;
    font-size: 1.22rem;
    font-weight: 700;
    line-height: 1.12;
  }

  .milaura-reward-preview__text {
    margin: 0;
    color: #555;
    font-family: 'Lato', sans-serif;
    font-size: 0.86rem;
    line-height: 1.38;
