        {%- comment -%} Le HTML scratch et le bundle sont desormais dans GROUPE 3 (col droite, ordre : bundle -> scratch -> CTA). Ce wrapper conserve uniquement le script JS qui les pilote. {%- endcomment -%}

        <script>
        (function() {
          'use strict';

          var sid = '{{ section.id }}';
          var container = document.getElementById('milaura-hero-scratch-' + sid);
          if (!container) return;

          /* ===== CONSTANTS ===== */
          var GOLD_1 = {{ section.settings.scratch_overlay_color_start | default: '#E6C88B' | json }};
          var GOLD_2 = {{ section.settings.scratch_overlay_color_end | default: '#C0A062' | json }};
          var PROGRESS_EMPTY_TEXT = {{ section.settings.progress_empty_text | default: 'Ajoutez ce produit au panier pour débloquer votre première carte surprise.' | json }};
          var PROGRESS_ONE_TEXT = {{ section.settings.progress_one_text | default: '1 carte surprise prête dans le panier.' | json }};
          var PROGRESS_MANY_TEMPLATE = {{ section.settings.progress_many_text | json }};
          if (!PROGRESS_MANY_TEMPLATE) PROGRESS_MANY_TEMPLATE = '[count] cartes surprises prêtes dans le panier.';
          var CUSTOMER_LOGGED_IN = {% if customer %}true{% else %}false{% endif %};
          var REVEAL_THRESHOLD = 0.55;
          var SCRATCH_RADIUS = 22;

          /* ===== STATE ===== */
          var revealedGifts = new Set();
          var gifts = [];

          /* ===== PARSE DOM ===== */
          var cardEls = container.querySelectorAll('.milaura-scratch-card');
          var counterEl = document.getElementById('milaura-scratch-counter-' + sid);
          var pillEl = document.getElementById('milaura-scratch-pill-' + sid);
          var pillTextEl = document.getElementById('milaura-scratch-pill-text-' + sid);
          var popupEl = document.getElementById('milaura-gift-popup-' + sid);
          var popupCardEl = popupEl ? popupEl.querySelector('.milaura-gift-popup__card') : null;
          var popupCloseEl = popupEl ? popupEl.querySelector('.milaura-gift-popup__close') : null;
          var popupBurstEl = popupEl ? popupEl.querySelector('.milaura-gift-popup__burst') : null;
          var popupTitleEl = popupEl ? popupEl.querySelector('.milaura-gift-popup__title') : null;
          var popupTextEl = popupEl ? popupEl.querySelector('.milaura-gift-popup__text') : null;
          var popupStatusEl = popupEl ? popupEl.querySelector('.milaura-gift-popup__status') : null;
          var popupNoteEl = popupEl ? popupEl.querySelector('.milaura-gift-popup__note') : null;
          var popupNextButton = document.getElementById('milaura-gift-popup-next-' + sid);
          var popupCartLink = document.getElementById('milaura-gift-popup-cart-' + sid);
          var popupShopLink = document.getElementById('milaura-gift-popup-shop-' + sid);
          var progressFillEl = document.getElementById('milaura-cart-progress-fill-' + sid);
          var progressTextEl = document.getElementById('milaura-cart-progress-text-' + sid);

          cardEls.forEach(function(el) {
            gifts.push({
              el: el,
              index: parseInt(el.dataset.giftIndex, 10),
              name: el.dataset.giftName,
              value: el.dataset.giftValue,
              icon: el.dataset.giftIcon,
              variantId: parseInt(el.dataset.giftVariantId, 10) || null,
              discountCode: el.dataset.giftDiscountCode,
              popupTitle: el.dataset.giftPopupTitle,
              popupText: el.dataset.giftPopupText,
              canvasReady: false
            });
          });

          try { sessionStorage.removeItem('milaura-scratch-v4-' + sid); } catch (e) { /* ignore */ }
          revealedGifts = new Set();

          /* ===== CART PROGRESSION ===== */
          var bundleEl = document.getElementById('milaura-bundle-selector-' + sid);
          var tierEls = bundleEl ? bundleEl.querySelectorAll('.milaura-bundle-tier') : [];
          var selectedTierIndex = 0;
          var cartItemCount = 0;

          function currentUnlockedCount() {
            if (!tierEls || tierEls.length === 0) return gifts.length;
            var unlocked = 0;
            tierEls.forEach(function(tier) {
              var threshold = parseInt(tier.getAttribute('data-tier-pieces'), 10) || 0;
              var cards = parseInt(tier.getAttribute('data-cards-unlocked'), 10) || 0;
              if (cartItemCount >= threshold) unlocked = Math.max(unlocked, cards);
            });
            return Math.max(0, Math.min(gifts.length, unlocked));
          }

          function isMilAuraGiftCartItem(item) {
            if (!item) return false;
            var props = item.properties || {};
            return props._milaura_gift === 'true' ||
              (item.handle && item.handle.indexOf('cadeau-') === 0) ||
              (item.product_title && item.product_title.indexOf('Cadeau -') === 0);
          }

          function cartProgressItemCount(cart) {
            if (!cart || !cart.items) return 0;
            return cart.items.reduce(function(total, item) {
              return isMilAuraGiftCartItem(item) ? total : total + item.quantity;
            }, 0);
          }

          function cartPaidSubtotalCents(cart) {
            if (!cart || !cart.items) return 0;
            return cart.items.reduce(function(total, item) {
              if (isMilAuraGiftCartItem(item)) return total;
              if (item.final_line_price !== undefined && item.final_line_price !== null) {
                return total + (Number(item.final_line_price) || 0);
              }
              if (item.line_price !== undefined && item.line_price !== null) {
                return total + (Number(item.line_price) || 0);
              }
              return total + (Number(item.original_line_price || 0) || 0);
            }, 0);
          }

          function requiredCartCountForGift(gift) {
            if (!gift) return 1;
            var fallback = Math.max(1, (parseInt(gift.index, 10) || 0) + 1);
            var required = null;
            if (tierEls && tierEls.length) {
              tierEls.forEach(function(tier) {
                var threshold = parseInt(tier.getAttribute('data-tier-pieces'), 10) || 0;
                var cards = parseInt(tier.getAttribute('data-cards-unlocked'), 10) || 0;
                if (threshold > 0 && cards > gift.index) {
                  required = required === null ? threshold : Math.min(required, threshold);
                }
              });
            }
            return required || fallback;
          }

          function minPaidItemsForGiftCartItem(item) {
            var props = item && item.properties ? item.properties : {};
            var explicit = parseInt(props._milaura_gift_min_paid_items, 10);
            if (explicit > 0) return explicit;
            var matchingGift = gifts.find(function(gift) {
              return gift.variantId && item && item.variant_id === gift.variantId;
            });
            if (matchingGift) return requiredCartCountForGift(matchingGift);
            return 1;
          }

          function minPaidCentsForGiftCartItem(item) {
            var props = item && item.properties ? item.properties : {};
            var explicit = parseInt(props._milaura_gift_min_paid_cents, 10);
            return explicit > 0 ? explicit : 0;
          }

          function removeCartLine(itemKey) {
            return fetch('/cart/change.js', {
              method: 'POST',
              headers: { 'Content-Type': 'application/json' },
              body: JSON.stringify({ id: itemKey, quantity: 0 })
            }).then(function(r) { return r.ok ? r.json() : null; });
          }

          function cleanupIneligibleCartGifts(cart) {
            if (!cart || !cart.items) return Promise.resolve({ cart: cart, removed: false });
            var paidCount = cartProgressItemCount(cart);
            var paidSubtotal = cartPaidSubtotalCents(cart);
            var ineligibleGifts = cart.items.filter(function(item) {
              if (!isMilAuraGiftCartItem(item)) return false;
              var requiredCents = minPaidCentsForGiftCartItem(item);
              if (requiredCents > 0) return paidSubtotal < requiredCents;
              return paidCount < minPaidItemsForGiftCartItem(item);
            });
            if (!ineligibleGifts.length) {
              return Promise.resolve({ cart: cart, removed: false });
            }
            return ineligibleGifts.reduce(function(promise, item) {
              return promise.then(function() { return removeCartLine(item.key); });
            }, Promise.resolve())
            .then(fetchCart)
            .then(function(nextCart) {
              return { cart: nextCart || cart, removed: true };
            });
          }

          function cleanupRevealedGiftsForCart(cart) {
            var paidCount = cartProgressItemCount(cart);
            gifts.forEach(function(gift) {
              if (paidCount < requiredCartCountForGift(gift) && revealedGifts.has(gift.index)) {
                revealedGifts.delete(gift.index);
              }
            });
          }

          function cartContainsGiftVariant(cart, gift) {
            return Boolean(cart && cart.items && gift && gift.variantId && cart.items.some(function(item) {
              return item.variant_id === gift.variantId;
            }));
          }

          function updateProgressFromCart() {
            if (!tierEls || tierEls.length === 0) return;
            var unlocked = currentUnlockedCount();
            selectedTierIndex = Math.max(0, Math.min(tierEls.length - 1, unlocked > 0 ? unlocked - 1 : 0));
            tierEls.forEach(function(tier, i) {
              var threshold = parseInt(tier.getAttribute('data-tier-pieces'), 10) || (i + 1);
              tier.classList.toggle('is-complete', cartItemCount >= threshold);
              tier.classList.toggle('is-current', cartItemCount === threshold);
              tier.classList.toggle('is-locked', cartItemCount < threshold);
            });
            if (progressFillEl) {
              progressFillEl.style.width = gifts.length ? ((unlocked / gifts.length) * 100) + '%' : '0%';
            }
            if (progressTextEl) {
	              if (unlocked <= 0) {
	                progressTextEl.textContent = PROGRESS_EMPTY_TEXT;
	              } else if (unlocked === 1) {
	                progressTextEl.textContent = PROGRESS_ONE_TEXT;
	              } else {
                progressTextEl.textContent = PROGRESS_MANY_TEMPLATE.replace('[count]', unlocked);
	              }
            }
          }

          function refreshCartProgress() {
            return fetch('/cart.js')
              .then(function(r) { return r.ok ? r.json() : null; })
              .then(function(cart) {
                return cleanupIneligibleCartGifts(cart);
              })
              .then(function(result) {
                var cart = result ? result.cart : null;
                cartItemCount = cartProgressItemCount(cart);
                previewCartSubtotalCents = cartPaidSubtotalCents(cart);
                cleanupRevealedGiftsForCart(cart);
                if (cart) updateCartSurfaces(cart);
                updateProgressFromCart();
                updateRewardPreview();
                updateLockedCards();
              })
              .catch(function() {
                cartItemCount = 0;
                previewCartSubtotalCents = 0;
                updateProgressFromCart();
                updateRewardPreview();
                updateLockedCards();
              });
          }

          function updateLockedCards() {
            var unlocked = currentUnlockedCount();
            gifts.forEach(function(gift, i) {
              var card = gift.el;
              if (i < unlocked) {
                /* Carte deverrouillee par le tier courant */
                if (card.classList.contains('is-locked')) {
                  card.classList.remove('is-locked');
                }
                /* Si carte deja revelee precedemment, conserver l'etat reveal */
                if (revealedGifts.has(i)) {
                  if (!card.classList.contains('is-revealed')) {
                    card.classList.add('is-revealed');
                  }
                  return;
                }
                /* Sinon, initialiser le canvas si necessaire */
                if (!gift.canvasReady && !card.querySelector('canvas')) {
                  initCanvas(card, gift);
                }
              } else {
                /* Carte au-dela du tier courant : RESET complet (verrouillee + non revelee) */
                if (revealedGifts.has(i)) revealedGifts.delete(i);
                card.classList.add('is-locked');
                card.classList.remove('is-revealed');
                var existingCanvas = card.querySelector('canvas');
                if (existingCanvas) existingCanvas.remove();
                gift.canvasReady = false;
              }
            });
            updateCounter();
            /* Hide / re-show the reveal pill in coherence with the new state */
            syncPillToState();
          }

          function syncPillToState() {
            if (!pillEl || !pillTextEl) return;
            if (revealedGifts.size === 0) {
              pillEl.classList.remove('is-visible');
              pillTextEl.textContent = '';
              return;
            }
            /* Liste de tous les cadeaux reveles et encore debloques par le tier courant */
            var unlocked = currentUnlockedCount();
            var validGifts = [];
            gifts.forEach(function(g, i) {
              if (i < unlocked && revealedGifts.has(i)) {
                validGifts.push(g.name);
              }
            });
            if (validGifts.length === 0) {
              pillEl.classList.remove('is-visible');
              pillTextEl.textContent = '';
              return;
            }
            var pillTitle = validGifts.length === 1
              ? 'Bravo, votre cadeau est activé'
              : 'Bravo, vos ' + validGifts.length + ' cadeaux sont activés';
            var pillSubtitle = validGifts.length === 1
              ? 'Votre carte reste visible ici comme rappel pendant vos achats.'
              : 'Vos cartes restent visibles ici comme rappel pendant vos achats.';
            pillTextEl.innerHTML =
              '<span class="milaura-scratch-pill-icon" aria-hidden="true">✓</span>' +
              '<span class="milaura-scratch-pill-copy">' +
                '<strong>' + pillTitle + '</strong>' +
                '<span>' + pillSubtitle + '</span>' +
              '</span>';
            pillEl.classList.add('is-visible');
          }

          function bindTierSelector() {
            if (!tierEls || tierEls.length === 0) return;
            updateProgressFromCart();
          }

          /* ===== CTA BUNDLE-AWARE ===== */
          var ctaButton = document.getElementById('milaura-hero-cta-bundle-' + sid);
          var ctaPriceEl = document.getElementById('milaura-hero-cta-price-' + sid);
          var ctaVariantId = ctaButton ? parseInt(ctaButton.getAttribute('data-variant-id'), 10) : null;
          var unitPriceCents = ctaButton ? parseInt(ctaButton.getAttribute('data-unit-price-cents'), 10) : {{ product.selected_or_first_available_variant.price }};
          var qtyInputEl = document.getElementById('milaura-bundle-qty-' + sid);
          var qtyCapsuleEl = qtyInputEl ? qtyInputEl.closest('.milaura-bundle-qty') : null;
          var qtyMinusBtn = qtyCapsuleEl ? qtyCapsuleEl.querySelector('[data-milaura-qty-minus]') : null;
          var qtyPlusBtn = qtyCapsuleEl ? qtyCapsuleEl.querySelector('[data-milaura-qty-plus]') : null;
          var cartConfirmEl = document.getElementById('milaura-cart-confirm-' + sid);
          var rewardPreviewEl = document.getElementById('milaura-reward-preview-' + sid);
          var rewardPreviewCards = rewardPreviewEl ? Array.prototype.slice.call(rewardPreviewEl.querySelectorAll('[data-reward-preview-card]')) : [];
          var rewardPreviewStatusEl = rewardPreviewEl ? rewardPreviewEl.querySelector('[data-reward-preview-status]') : null;
          var rewardPreviewFillEl = rewardPreviewEl ? rewardPreviewEl.querySelector('[data-reward-preview-fill]') : null;
          var rewardThresholds = rewardPreviewEl ? [
            parseInt(rewardPreviewEl.getAttribute('data-reward-threshold-1'), 10) || 2000,
            parseInt(rewardPreviewEl.getAttribute('data-reward-threshold-2'), 10) || 5000,
            parseInt(rewardPreviewEl.getAttribute('data-reward-threshold-3'), 10) || 8000
          ] : [2000, 5000, 8000];
          var previewCartSubtotalCents = 0;

          function formatPrice(cents) {
            try {
              return new Intl.NumberFormat('fr-FR', { style: 'currency', currency: '{{ cart.currency.iso_code | default: shop.currency }}' }).format(cents / 100);
            } catch (e) {
              return (cents / 100).toFixed(2).replace('.', ',') + ' €';
            }
          }

          function getSelectedQuantity() {
            var raw = qtyInputEl ? parseInt(qtyInputEl.value, 10) : 1;
            if (!Number.isFinite(raw) || raw < 1) return 1;
            return raw;
          }

          function unlockedPreviewCards(cents) {
            if (cents >= rewardThresholds[2]) return 3;
            if (cents >= rewardThresholds[1]) return 2;
            if (cents >= rewardThresholds[0]) return 1;
            return 0;
          }

          function nextPreviewThreshold(cents) {
            for (var i = 0; i < rewardThresholds.length; i += 1) {
              if (cents < rewardThresholds[i]) {
                return { index: i + 1, remaining: rewardThresholds[i] - cents };
              }
            }
            return null;
          }

          function previewProgressPercent(cents) {
            var max = rewardThresholds[2] || 8000;
            return Math.max(0, Math.min(100, Math.round((cents / max) * 100)));
          }

          function updateRewardPreview() {
            if (!rewardPreviewEl) return;
            var projectedSubtotal = previewCartSubtotalCents + ((unitPriceCents || {{ product.selected_or_first_available_variant.price }}) * getSelectedQuantity());
            var unlocked = unlockedPreviewCards(projectedSubtotal);
            var next = nextPreviewThreshold(projectedSubtotal);

            rewardPreviewCards.forEach(function(card) {
              var index = parseInt(card.getAttribute('data-reward-preview-card'), 10);
              var isUnlocked = index <= unlocked;
              card.classList.toggle('is-unlocked', isUnlocked);
              card.classList.toggle('is-locked', !isUnlocked);
              var lock = card.querySelector('.milaura-reward-preview__lock');
              if (lock) lock.textContent = isUnlocked ? '🔓' : '🔒';
            });

            if (rewardPreviewFillEl) {
              rewardPreviewFillEl.style.width = previewProgressPercent(projectedSubtotal) + '%';
            }

            if (!rewardPreviewStatusEl) return;
            if (unlocked >= 3) {
              rewardPreviewStatusEl.textContent = 'Avec ce produit : 3 cartes surprises débloquées.';
            } else if (unlocked === 2) {
              rewardPreviewStatusEl.textContent = next
                ? 'Avec ce produit : 2 cartes surprises débloquées. Encore ' + formatPrice(next.remaining) + ' pour la Surprise été.'
                : 'Avec ce produit : 2 cartes surprises débloquées.';
            } else if (unlocked === 1) {
              rewardPreviewStatusEl.textContent = next
                ? 'Avec ce produit : 1 carte surprise débloquée. Encore ' + formatPrice(next.remaining) + ' pour la suivante.'
                : 'Avec ce produit : 1 carte surprise débloquée.';
            } else {
              rewardPreviewStatusEl.textContent = next
                ? 'Encore ' + formatPrice(next.remaining) + ' pour votre première carte surprise.'
                : 'Votre première carte surprise MilAura vous attend.';
            }
          }

          function setSelectedQuantity(value) {
            var next = parseInt(value, 10);
            if (!Number.isFinite(next) || next < 1) next = 1;
            if (qtyInputEl) qtyInputEl.value = String(next);
            updateCtaButton();
          }

          function updateCtaButton() {
            var quantity = getSelectedQuantity();
            if (ctaPriceEl) {
              ctaPriceEl.textContent = formatPrice((unitPriceCents || {{ product.selected_or_first_available_variant.price }}) * quantity);
            }
            updateRewardPreview();
            document.dispatchEvent(new CustomEvent('milaura:product-quantity-change', {
              detail: { quantity: quantity }
            }));
          }

          function setBadge(el, count) {
            if (!el) return;
            if (count > 0) {
              el.textContent = count;
              el.style.display = 'flex';
            } else {
              el.style.display = 'none';
            }
          }

          function ensureDesktopNavBadge(count) {
            document.querySelectorAll('.nav-cart-icon #cart-icon-bubble').forEach(function(holder) {
              var existing = holder.querySelector('.nav-cart-count');
              if (!existing && count > 0) {
                existing = document.createElement('span');
                existing.className = 'nav-cart-count';
                holder.appendChild(existing);
              }
              setBadge(existing, count);
            });
          }

          function updateCartSurfaces(cart) {
            if (!cart || typeof cart.item_count !== 'number') return;
            var count = cart.item_count;
            ensureDesktopNavBadge(count);
            document.querySelectorAll('.nav-cart-count, .nav-mobile-cart-count').forEach(function(el) {
              setBadge(el, count);
            });
            document.querySelectorAll('.cart-count-bubble span[aria-hidden], [data-cart-count]').forEach(function(el) {
              el.textContent = count;
            });
            var dockBadge = document.getElementById('milaura-dock-badge');
            setBadge(dockBadge, count);
            document.dispatchEvent(new CustomEvent('cart:updated', { detail: cart }));
            window.dispatchEvent(new CustomEvent('cart:updated', { detail: cart }));
          }

          function fetchCart() {
            return fetch('/cart.js')
              .then(function(r) { return r.ok ? r.json() : null; });
          }

          function setCartAttributes(attrs) {
            return fetch('/cart/update.js', {
              method: 'POST',
              headers: { 'Content-Type': 'application/json' },
              body: JSON.stringify({ attributes: attrs })
            }).catch(function() { return null; });
          }

          function applyDiscountCode(code) {
            if (!code) return Promise.resolve({ type: 'discount', skipped: true });
            return fetch('/discount/' + encodeURIComponent(code) + '?redirect=/cart', {
              method: 'GET',
              credentials: 'include'
            })
            .then(function() {
              return setCartAttributes({
                'Code promo MilAura': code
              });
            })
            .then(function() {
              return { type: 'discount', code: code };
            });
          }

          function cartDrawerSectionsPayload() {
            var cartDrawer = document.querySelector('cart-drawer');
            if (!cartDrawer || typeof cartDrawer.getSectionsToRender !== 'function') return null;
            return {
              sections: cartDrawer.getSectionsToRender().map(function(section) { return section.id; }),
              sections_url: window.location.pathname
            };
          }

          function renderCartDrawerFromResponse(response) {
            var cartDrawer = document.querySelector('cart-drawer');
            if (!cartDrawer || typeof cartDrawer.renderContents !== 'function') return false;
            if (!response || !response.sections) return false;
            cartDrawer.renderContents(response);
            return true;
          }

          function rememberCartConfirm() {
            try {
              sessionStorage.setItem('milaura-cart-confirm-' + sid, String(Date.now()));
            } catch (e) {
              /* ignore */
            }
          }

          function showCartConfirm() {
            if (!cartConfirmEl) return;
            rememberCartConfirm();
            cartConfirmEl.hidden = false;
            window.clearTimeout(cartConfirmEl._milauraTimer);
            cartConfirmEl._milauraTimer = window.setTimeout(function() {
              cartConfirmEl.hidden = true;
            }, 7000);
          }

          function restoreRecentCartConfirm() {
            if (!cartConfirmEl) return;
            try {
              var timestamp = parseInt(sessionStorage.getItem('milaura-cart-confirm-' + sid), 10);
              if (timestamp && Date.now() - timestamp < 7000) {
                showCartConfirm();
              }
            } catch (e) {
              /* ignore */
            }
          }

          function addGiftVariantIfNeeded(gift) {
            if (!gift || !gift.variantId) return Promise.resolve({ type: 'gift', skipped: true });
            var requiredPaidItems = requiredCartCountForGift(gift);
            return fetchCart()
              .then(cleanupIneligibleCartGifts)
              .then(function(result) {
                var cart = result ? result.cart : null;
                var paidItemCount = cartProgressItemCount(cart);
                if (paidItemCount < requiredPaidItems) {
                  throw new Error('gift_threshold_not_met');
                }
                var alreadyInCart = cartContainsGiftVariant(cart, gift);
                if (alreadyInCart) {
                  return { type: 'gift', alreadyInCart: true, gift: gift };
                }
                return addCartItems([{
                  id: gift.variantId,
                  quantity: 1,
                  properties: {
                    'Cadeau MilAura': gift.name || 'Cadeau offert',
                    'Statut': 'Offert',
                    '_milaura_gift': 'true',
                    '_milaura_gift_min_paid_items': String(requiredPaidItems)
                  }
                }]).then(function() {
                  return { type: 'gift', added: true, gift: gift };
                });
              })
              .then(function(result) {
                return refreshCartProgress().then(function() { return result; });
              });
          }

          function activateGift(gift) {
            var tasks = [];
            if (gift && gift.variantId) tasks.push(addGiftVariantIfNeeded(gift));
            if (gift && gift.discountCode) tasks.push(applyDiscountCode(gift.discountCode));
            if (!tasks.length) return Promise.resolve([]);
            return Promise.all(tasks);
          }

          function addCartItems(items) {
            var payload = { items: items };
            var drawerPayload = cartDrawerSectionsPayload();
            if (drawerPayload && drawerPayload.sections && drawerPayload.sections.length) {
              payload.sections = drawerPayload.sections;
              payload.sections_url = drawerPayload.sections_url;
            }
            return fetch('/cart/add.js', {
              method: 'POST',
              headers: { 'Content-Type': 'application/json' },
              body: JSON.stringify(payload)
            }).then(function(r) {
              if (!r.ok) {
                return r.json().catch(function() { return {}; }).then(function(data) {
                  throw new Error(data.description || data.message || 'cart_error');
                });
              }
              return r.json();
            });
          }

          function bundleAddToCart() {
            if (!ctaVariantId || !ctaButton) return;
            if (ctaButton.disabled) return;

            ctaButton.disabled = true;
            var labelEl = ctaButton.querySelector('.milaura-cta-label');
            var originalLabel = labelEl ? labelEl.textContent : 'Ajouter au panier';
            if (labelEl) labelEl.textContent = 'Ajout en cours...';

            var mainItem = {
              id: ctaVariantId,
              quantity: getSelectedQuantity(),
              properties: {
                'Avantages panier': 'Produit ajouté depuis la fiche MilAura'
              }
            };

            addCartItems([mainItem])
            .then(function(response) {
              rememberCartConfirm();
              var drawerOpened = renderCartDrawerFromResponse(response);
              return refreshCartProgress().then(function() {
                return drawerOpened;
              });
            })
            .then(function(drawerOpened) {
              if (labelEl) labelEl.textContent = 'Ajouté au panier';
              showCartConfirm();
              window.setTimeout(function() {
                ctaButton.disabled = false;
                if (labelEl) labelEl.textContent = originalLabel;
              }, 1800);
            })
            .catch(function(error) {
              console.error('MilAura add to cart failed:', error);
              ctaButton.disabled = false;
              if (labelEl) labelEl.textContent = originalLabel;
            });
          }

          if (ctaButton) {
            ctaButton.addEventListener('click', bundleAddToCart);
          }
          if (qtyMinusBtn) {
            qtyMinusBtn.addEventListener('click', function(event) {
              event.preventDefault();
              event.stopPropagation();
              setSelectedQuantity(getSelectedQuantity() - 1);
            });
          }
          if (qtyPlusBtn) {
            qtyPlusBtn.addEventListener('click', function(event) {
              event.preventDefault();
              event.stopPropagation();
              setSelectedQuantity(getSelectedQuantity() + 1);
            });
          }
          if (qtyInputEl) {
            qtyInputEl.addEventListener('change', function() {
              setSelectedQuantity(qtyInputEl.value);
            });
            qtyInputEl.addEventListener('blur', function() {
              setSelectedQuantity(qtyInputEl.value);
            });
            qtyInputEl.addEventListener('input', updateCtaButton);
          }
          updateCtaButton();
          restoreRecentCartConfirm();
          document.addEventListener('cart:updated', function(event) {
            if (!event.detail) return;
            previewCartSubtotalCents = cartPaidSubtotalCents(event.detail);
            updateRewardPreview();
          });
          window.addEventListener('cart:updated', function(event) {
            if (!event.detail) return;
            previewCartSubtotalCents = cartPaidSubtotalCents(event.detail);
            updateRewardPreview();
          });

          /* ===== INIT CARDS ===== */
          function initAllCards() {
            gifts.forEach(function(gift, i) {
              var card = gift.el;
              populateContent(card, gift);
              card.classList.add('is-locked');
              card.classList.remove('is-revealed');
            });
            updateCounter();
            updateCtaButton();
            bindTierSelector();
            refreshCartProgress();
          }

          function populateContent(card, gift) {
            var content = card.querySelector('.milaura-scratch-card-content');
            content.querySelector('.milaura-scratch-card-icon').textContent = gift.icon;
            content.querySelector('.milaura-scratch-card-name').textContent = gift.name;
            var valueEl = content.querySelector('.milaura-scratch-card-value');
            if (valueEl) valueEl.textContent = gift.value;
          }

          /* ===== CANVAS SCRATCH ENGINE ===== */
          function initCanvas(card, gift) {
            var existing = card.querySelector('canvas');
            if (existing) existing.remove();

            var canvas = document.createElement('canvas');
            var w = card.offsetWidth || 130;
            var h = card.offsetHeight || 150;
            canvas.width = w;
            canvas.height = h;
            canvas.style.width = w + 'px';
            canvas.style.height = h + 'px';
            card.appendChild(canvas);

            var ctx = canvas.getContext('2d');

            /* Gold gradient fill */
            var gradient = ctx.createLinearGradient(0, 0, w, h);
            gradient.addColorStop(0, GOLD_1);
            gradient.addColorStop(1, GOLD_2);
            ctx.fillStyle = gradient;
            ctx.fillRect(0, 0, w, h);

            /* Draw unlocked hint */
            ctx.fillStyle = 'rgba(255, 255, 255, 0.35)';
            ctx.font = 'bold 2rem sans-serif';
            ctx.textAlign = 'center';
            ctx.textBaseline = 'middle';
            ctx.fillText('🔓', w / 2, h / 2);

            gift.canvasReady = true;

            /* Scratch interaction state */
            var isScratching = false;
            var checkPending = false;

            function getPos(e) {
              var rect = canvas.getBoundingClientRect();
              var cx, cy;
              if (e.touches && e.touches.length > 0) {
                cx = e.touches[0].clientX;
                cy = e.touches[0].clientY;
              } else {
                cx = e.clientX;
                cy = e.clientY;
              }
              return {
                x: (cx - rect.left) * (canvas.width / rect.width),
                y: (cy - rect.top) * (canvas.height / rect.height)
              };
            }

            function doScratch(pos) {
              ctx.globalCompositeOperation = 'destination-out';
              ctx.beginPath();
              ctx.arc(pos.x, pos.y, SCRATCH_RADIUS, 0, Math.PI * 2);
              ctx.fill();
              ctx.globalCompositeOperation = 'source-over';

              if (!checkPending) {
                checkPending = true;
                requestAnimationFrame(function() {
                  checkPending = false;
                  checkReveal(card, gift, canvas, ctx);
                });
              }
            }

            function onStart(e) {
              if (card.classList.contains('is-revealed') || card.classList.contains('is-locked')) return;
              isScratching = true;
              doScratch(getPos(e));
            }

            function onMove(e) {
              if (!isScratching || card.classList.contains('is-revealed') || card.classList.contains('is-locked')) return;
              e.preventDefault();
              doScratch(getPos(e));
            }

            function onEnd() {
              isScratching = false;
            }

            /* Touch */
            canvas.addEventListener('touchstart', onStart, { passive: true });
            canvas.addEventListener('touchmove', onMove, { passive: false });
            canvas.addEventListener('touchend', onEnd, { passive: true });
            canvas.addEventListener('touchcancel', onEnd, { passive: true });

            /* Mouse */
            canvas.addEventListener('mousedown', onStart);
            canvas.addEventListener('mousemove', onMove);
            canvas.addEventListener('mouseup', onEnd);
            canvas.addEventListener('mouseleave', onEnd);
          }

          /* ===== REVEAL CHECK ===== */
          function checkReveal(card, gift, canvas, ctx) {
            if (revealedGifts.has(gift.index)) return;

            var w = canvas.width;
            var h = canvas.height;
            var imageData;
            try {
              imageData = ctx.getImageData(0, 0, w, h);
            } catch (e) { return; }

            var pixels = imageData.data;
            var total = w * h;
            var transparent = 0;

            /* Sample every 4th pixel for performance */
            for (var i = 3; i < pixels.length; i += 16) {
              if (pixels[i] < 10) transparent++;
            }
            transparent *= 4;

            if (transparent / total >= REVEAL_THRESHOLD) {
              revealCard(card, gift);
            }
          }

          function popupCopyForGift(gift) {
            return {
              title: gift.popupTitle || gift.name || {{ section.settings.popup_fallback_title | default: 'Vous avez gagné' | json }},
              text: gift.popupText || gift.value || {{ section.settings.popup_fallback_text | default: 'Votre cadeau est activé automatiquement.' | json }},
              icon: gift.icon || '✨'
            };
          }

          function nextScratchCard() {
            return container.querySelector('.milaura-scratch-card:not(.is-locked):not(.is-revealed)');
          }

          function showEl(el, show) {
            if (!el) return;
            el.hidden = !show;
          }

          function updatePopupActions() {
            var hasRemainingCards = Boolean(nextScratchCard());
            showEl(popupNextButton, hasRemainingCards);
            showEl(popupCartLink, true);
            showEl(popupShopLink, !hasRemainingCards);
            if (popupNextButton) {
              popupNextButton.classList.toggle('milaura-gift-popup__primary', hasRemainingCards);
              popupNextButton.classList.toggle('milaura-gift-popup__secondary', !hasRemainingCards);
            }
            if (popupCartLink) {
              popupCartLink.classList.toggle('milaura-gift-popup__primary', !hasRemainingCards);
              popupCartLink.classList.toggle('milaura-gift-popup__secondary', hasRemainingCards);
            }
          }

          function setPopupActivationState(state, message) {
            if (!popupStatusEl) return;
            popupStatusEl.classList.remove('is-success', 'is-error');
            if (!state) {
              popupStatusEl.hidden = true;
              popupStatusEl.textContent = '';
            } else {
              popupStatusEl.hidden = false;
              popupStatusEl.textContent = message || '';
              if (state === 'success') popupStatusEl.classList.add('is-success');
              if (state === 'error') popupStatusEl.classList.add('is-error');
            }
            [popupNextButton].forEach(function(button) {
              if (!button) return;
              button.disabled = state === 'loading';
            });
            if (popupCartLink) {
              popupCartLink.classList.toggle('is-disabled', state === 'loading');
              popupCartLink.setAttribute('aria-disabled', state === 'loading' ? 'true' : 'false');
            }
            if (popupShopLink) {
              popupShopLink.classList.toggle('is-disabled', state === 'loading');
              popupShopLink.setAttribute('aria-disabled', state === 'loading' ? 'true' : 'false');
            }
          }

          function popupNoteForGift(gift) {
            if (!gift) return '';
            if (gift.variantId) {
              return 'Le cadeau apparaît comme une ligne panier à 0 €. Si vous ne le voyez pas, ouvrez le panier pour forcer la synchronisation.';
            }
            if (gift.discountCode) {
              if (CUSTOMER_LOGGED_IN) {
                return 'Votre compte MilAura est connecté. Le code sera vérifié au moment du paiement selon les conditions Shopify.';
              }
              return 'Déjà cliente ? Connectez-vous au moment du paiement pour retrouver vos informations. Le code est transmis automatiquement, sans inscription dans cette fenêtre.';
            }
            return '';
          }

          function activationLoadingMessage(gift) {
            if (gift && gift.variantId) return 'Ajout du cadeau offert au panier...';
            if (gift && gift.discountCode) return 'Préparation du code ' + gift.discountCode + '...';
            return 'Activation de votre cadeau...';
          }

          function activationSuccessMessage(gift, results) {
            if (!gift) return 'Cadeau activé.';
            var giftResult = (results || []).find(function(result) { return result && result.type === 'gift'; });
            var discountResult = (results || []).find(function(result) { return result && result.type === 'discount'; });
            if (giftResult && giftResult.alreadyInCart) return 'Ce cadeau est déjà dans votre panier à 0 €.';
            if (giftResult && giftResult.added) return 'Cadeau ajouté au panier à 0 €. Vous pouvez le vérifier dans votre panier.';
            if (discountResult && discountResult.code) return 'Code ' + discountResult.code + ' enregistré. Il sera vérifié au moment du paiement.';
            return 'Cadeau activé.';
          }

          function openGiftPopup(gift) {
            if (!popupEl) return;
            var newsletterPopup = document.getElementById('milaura-popup-overlay');
            if (newsletterPopup && newsletterPopup.classList.contains('active')) {
              newsletterPopup.classList.remove('active');
              document.body.style.overflow = '';
            }
            var copy = popupCopyForGift(gift);
            if (popupBurstEl) popupBurstEl.textContent = copy.icon;
            if (popupTitleEl) popupTitleEl.textContent = copy.title;
            if (popupTextEl) popupTextEl.textContent = copy.text;
            if (popupNoteEl) {
              var note = popupNoteForGift(gift);
              popupNoteEl.textContent = note;
              popupNoteEl.hidden = !note;
            }
            updatePopupActions();
            setPopupActivationState(null, '');
            popupEl.hidden = false;
            document.documentElement.classList.add('milaura-gift-popup-open');
            if (popupCardEl) popupCardEl.focus();
          }

          function closeGiftPopup() {
            if (!popupEl) return;
            popupEl.hidden = true;
            document.documentElement.classList.remove('milaura-gift-popup-open');
          }

          if (popupCloseEl) {
            popupCloseEl.addEventListener('click', closeGiftPopup);
          }
          if (popupEl) {
            popupEl.addEventListener('click', function(e) {
              if (e.target === popupEl) closeGiftPopup();
            });
          }
          document.addEventListener('keydown', function(e) {
            if (e.key === 'Escape' && popupEl && !popupEl.hidden) closeGiftPopup();
          });

          if (popupNextButton) {
            popupNextButton.addEventListener('click', function() {
              var nextCard = nextScratchCard();
              closeGiftPopup();
              if (nextCard) {
                nextCard.scrollIntoView({ behavior: 'smooth', block: 'center' });
              }
            });
          }

          /* ===== REVEAL CARD ===== */
          function revealCard(card, gift) {
            if (revealedGifts.has(gift.index)) return;

            revealedGifts.add(gift.index);

            /* Remove canvas */
            var canvas = card.querySelector('canvas');
            if (canvas) canvas.remove();
            gift.canvasReady = false;

            card.classList.add('is-revealed');
            updateCounter();
            /* Affiche la liste cumulee de tous les cadeaux reveles + anime */
            syncPillToState();
            if (pillEl) {
              pillEl.classList.remove('is-visible');
              void pillEl.offsetWidth;
              pillEl.classList.add('is-visible');
            }
            openGiftPopup(gift);
            setPopupActivationState('loading', activationLoadingMessage(gift));
            activateGift(gift)
              .then(function(results) {
                return refreshCartProgress().then(function() { return results; });
              })
              .then(function(results) {
                setPopupActivationState('success', activationSuccessMessage(gift, results));
                updatePopupActions();
              })
              .catch(function(error) {
                console.warn('MilAura gift activation failed:', error);
                setPopupActivationState('error', 'Activation impossible pour le moment. Le cadeau reste révélé, mais Shopify a refusé l’ajout automatique.');
              });
          }

          /* ===== COUNTER ===== */
          function updateCounter() {
            var total = gifts.length;
            var revealed = revealedGifts.size;
            if (counterEl) {
              counterEl.textContent = revealed + '/' + total + ' RÉVÉLÉS';
            }
          }

          /* ===== INIT ===== */
          initAllCards();
          window.addEventListener('pageshow', function() {
            refreshCartProgress();
          });
          document.addEventListener('visibilitychange', function() {
            if (!document.hidden) refreshCartProgress();
          });
        })();
        </script>
      {%- endif -%}

    </div>
    <!-- Fin milaura-hero-wrapper -->

