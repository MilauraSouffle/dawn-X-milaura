  .milaura-spotlight-image {
    width: 100%;
    height: 100%;
    object-fit: contain;
    object-position: center center;
  }

  .milaura-hotspot {
    position: absolute;
    transform: translate(-50%, -50%);
    z-index: 2;
  }

  .milaura-hotspot-btn {
    position: relative;
    width: 32px;
    height: 32px;
    border-radius: 50%;
    background: var(--milaura-gold, #C0A062);
    border: 2px solid #fff;
    color: #fff;
    display: flex;
    align-items: center;
    justify-content: center;
