    }

    .milaura-scratch-counter {
      font-size: 0.66rem;
      padding: 4px 9px;
      margin-left: 0;
    }

    .milaura-scratch-card-icon {
      font-size: 1.35rem;
      margin-bottom: 5px;
    }

    .milaura-scratch-card-name {
      font-size: clamp(0.62rem, 2.35vw, 0.72rem);
