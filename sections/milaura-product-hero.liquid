    display: grid;
    gap: 10px;
  }

  .milaura-reward-preview__deck {
    position: relative;
    height: 88px;
  }

  .milaura-reward-preview__card {
    position: absolute;
    top: 10px;
    width: 74px;
    height: 88px;
    display: grid;
    place-items: center;
    border: 1px solid rgba(143, 114, 58, 0.34);
    border-radius: 11px;
    background:
      linear-gradient(135deg, #FFF6DA 0%, #D7B362 48%, #8F723A 100%);
