{%- comment %}
  Metafield badges removed - keeping only variant bubbles
  Original metafields (scent_notes, stone_benefits) can still be used
  for recommendations/classification elsewhere
{%- endcomment %}

{% style %}
  .section-{{ section.id }}-padding {
    padding-top: {{ section.settings.padding_top | times: 0.75 | round: 0 }}px;
    padding-bottom: {{ section.settings.padding_bottom | times: 0.75 | round: 0 }}px;
  }

  @media screen and (min-width: 750px) {
    .section-{{ section.id }}-padding {
      padding-top: {{ section.settings.padding_top }}px;
      padding-bottom: {{ section.settings.padding_bottom }}px;
    }
  }

  /* TABLETTE + DESKTOP : padding interne seulement, espacement gere par milaura.css */
  @media screen and (min-width: 750px) {
    .section-{{ section.id }}-padding {
      padding-top: 0;
      padding-bottom: 0;
    }
  }

  /* ===========================================
     LAYOUT GENERAL
     =========================================== */
  .milaura-hero-wrapper {
    display: flex;
    flex-direction: column;
    gap: 16px;
    width: 100%;
    max-width: 100%;
    overflow-x: visible; /* FIX: permettre au cadre doré d'être visible */
    padding: 0 16px;
    box-sizing: border-box;
  }

  /* TABLETTE : Resserrer les espacements + fix cadre */
  @media screen and (min-width: 750px) and (max-width: 989px) {
    .milaura-hero-wrapper {
      gap: 6px; /* Écart minimal entre les groupes */
      padding: 0 20px; /* FIX: padding augmenté pour que le cadre respire */
      overflow: visible; /* FIX: cadre visible */
    }

    .milaura-hero-header-group {
      margin-bottom: 0;
      padding-top: 0;
      padding-bottom: 4px;
    }

    /* Volume Bundle - en-têtes intégrés */
    .volume-section-title {
      margin: 0 0 10px 0;
    }

    .milaura-volume-grid {
      margin-top: 8px; /* Plus besoin d'espace pour badges flottants */
    }

    .volume-card {
      padding: 0; /* Géré par les sous-éléments */
    }

    .volume-card-badge {
      font-size: 9px;
      min-height: 32px; /* Même hauteur fixe */
      padding: 4px 8px;
    }

    .volume-left {
      padding: 12px 8px 3px;
    }

    .volume-price {
      padding: 3px 8px 12px;
    }
  }

  /* --- GROUPE 1: Header (mobile order 2 : apres la galerie) --- */
  .milaura-hero-header-group {
    order: 2;
    text-align: center;
    width: 100%;
  }

  /* --- GROUPE 2: Media Gallery (mobile order 1 : en premier) --- */
  .milaura-hero-gallery-column {
    order: 1;
    width: 100%;
    max-width: 100%;
    margin-bottom: 16px;
    overflow: hidden;
    border-radius: 12px;
    box-sizing: border-box;
  }

  /* Container pour positionner l'overlay sur l'image principale */
  .milaura-hero-gallery-column slider-component {
    position: relative;
    display: block;
    width: 100%;
    overflow: hidden;
  }

  /* Slider Mobile — Override Dawn's component-slider defaults */
  .product__media-list {
    display: flex;
    gap: 0;
    overflow-x: auto;
    scroll-snap-type: x mandatory;
    scroll-padding-left: 0;
    padding: 0;
    margin: 0;
    list-style: none;
    -webkit-overflow-scrolling: touch;
    scrollbar-width: none; /* Firefox */
    width: 100%;
  }

  .product__media-list::after {
    content: none; /* Remove Dawn's 1.5rem spacer */
  }

  .product__media-list::-webkit-scrollbar {
    display: none; /* Chrome/Safari */
  }

  .product__media-item {
    flex: 0 0 100%;
    min-width: 100%;
    max-width: 100%;
    scroll-snap-align: center;
    overflow: hidden;
    position: relative;
    box-sizing: border-box;
  }

  .product-media-container {
    position: relative;
    width: 100%;
    padding-top: 100%; /* Carré par défaut */
    background: var(--milaura-beige, #FDFBF7);
    overflow: hidden; /* FIX: clip image to border-radius on all corners */
    border-radius: 12px;
  }

  .product-media-container img,
  .product-media-container video,
  .product-media-container iframe {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center center;
  }

  /* Mobile & Tablette: image entière visible et centrée */
  @media screen and (max-width: 989px) {
    .product-media-container img {
      object-fit: contain;
      object-position: center center;
    }
  }

  /* Fleches Navigation (Mobile/Tablette) */
  .slider-button {
    position: absolute;
    top: 50%;
    transform: translateY(-50%);
    z-index: 10;
    width: 40px;
    height: 40px;
    border-radius: 50%;
    border: none;
    background: rgba(255, 255, 255, 0.85);
    backdrop-filter: blur(8px);
    -webkit-backdrop-filter: blur(8px);
    box-shadow: 0 2px 12px rgba(0, 0, 0, 0.1);
    color: var(--milaura-gold-dark, #8F723A);
    cursor: pointer;
    display: flex;
    align-items: center;
    justify-content: center;
    transition: all 0.25s ease;
    padding: 0;
  }
  .slider-button:hover {
    background: rgba(255, 255, 255, 0.95);
    box-shadow: 0 4px 16px rgba(192, 160, 98, 0.3);
    transform: translateY(-50%) scale(1.05);
  }
  .slider-button:active {
    transform: translateY(-50%) scale(0.95);
  }
  .slider-button[disabled] {
    opacity: 0.3;
    cursor: default;
    pointer-events: none;
  }
  .slider-button--prev {
    left: 10px;
  }
  .slider-button--next {
    right: 10px;
  }

  /* Pagination Mobile (Dots) */
  .slider-buttons {
    display: flex;
    justify-content: center;
    align-items: center;
    gap: 8px;
    margin-top: 10px;
    margin-bottom: 10px;
  }

  .slider-counter__link--dots {
    background: none;
    border: none;
    padding: 4px;
    cursor: pointer;
    -webkit-tap-highlight-color: transparent;
  }

  .slider-counter__link--dots .dot {
    width: 8px;
    height: 8px;
    border-radius: 50%;
    background: #e0e0e0;
    transition: all 0.3s;
    display: block;
  }

  .slider-counter__link--active .dot {
    background: var(--milaura-gold);
    transform: scale(1.3);
  }

  /* --- BADGES METAFIELDS PRODUIT --- */
  .milaura-meta-badges {
    display: flex;
    flex-wrap: wrap;
    gap: 8px;
    padding: 12px 0 0;
  }

  .milaura-meta-badge {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    background: rgba(255, 255, 255, 0.8);
    backdrop-filter: blur(8px);
    -webkit-backdrop-filter: blur(8px);
    border: 1px solid rgba(192, 160, 98, 0.2);
    border-radius: 30px;
    padding: 6px 14px;
    font-family: 'Lato', sans-serif;
    font-size: 0.8rem;
    font-weight: 600;
    color: var(--milaura-text);
    letter-spacing: 0.3px;
    text-transform: capitalize;
    white-space: nowrap;
  }

  .milaura-meta-badge svg {
    flex-shrink: 0;
    color: var(--milaura-gold);
  }

  .milaura-meta-badge--gold {
    background: linear-gradient(135deg, rgba(192, 160, 98, 0.15), rgba(230, 200, 139, 0.15));
    border-color: rgba(192, 160, 98, 0.35);
    color: var(--milaura-gold-dark);
  }

  .milaura-meta-badge--gold svg {
    color: var(--milaura-gold);
  }

  @media screen and (max-width: 480px) {
    .milaura-meta-badges {
      gap: 6px;
    }
    .milaura-meta-badge {
      padding: 5px 10px;
      font-size: 0.72rem;
    }
    .milaura-meta-badge svg {
      width: 12px;
      height: 12px;
    }
  }

  /* --- GROUPE 3: Actions --- */
  .milaura-hero-actions-group {
    order: 3;
    width: 100%;
  }

  /* DESKTOP MEDIA GRID (≥ 990px) */
  @media screen and (min-width: 990px) {
    .milaura-hero-wrapper {
      display: grid;
      grid-template-columns: 1fr 0.8fr;
      grid-template-areas:
        "gallery header"
        "gallery video-bubble"
        "gallery actions"
        "scratch scratch";
      gap: 16px;
      padding: 0 16px;
      overflow: visible;
      align-items: start;
    }

    .milaura-video-bubble-wrapper {
      grid-area: video-bubble;
      /* No justify-self: center — wrapper stretches to fill grid column.
         Bubble is centered via flex justify-content on the wrapper. */
    }

    .milaura-hero-header-group {
      grid-area: header;
      text-align: left;
      position: static !important;
      background: transparent !important;
      border: none !important;
      padding: 0 !important;
      margin-bottom: 0;
    }

    .milaura-hero-actions-group {
      grid-area: actions;
      position: sticky;
      top: calc(var(--header-height, 80px) + 20px);
      background: rgba(255, 255, 255, 0.6);
      backdrop-filter: blur(10px);
      border: 1px solid rgba(192, 160, 98, 0.1);
      border-radius: 16px;
      padding: 18px 20px; /* Équilibré */
    }

    /* Grille Media Desktop */
    .milaura-hero-gallery-column {
      grid-area: gallery;
      margin: 0;
      overflow: visible;
      border-radius: 0;
    }

    .product__media-list {
      display: flex;
      flex-wrap: wrap;
      gap: 10px;
      overflow: visible;
      scroll-snap-type: none;
      padding: 0;
    }

    /* Image principale : pleine largeur */
    .product__media-item:first-child {
      flex: 0 0 100%;
      width: 100%;
    }

    .product__media-item:first-child .product-media-container {
      padding-top: 100%;
      border-radius: 16px;
      border: 1px solid rgba(0,0,0,0.05);
    }

    /* Miniatures : petites, en ligne */
    .product__media-item:not(:first-child) {
      flex: 0 0 auto;
      width: auto;
      min-width: 0;
      max-width: none;
    }

    .product__media-item:not(:first-child) .product-media-container {
      padding-top: 0;
      width: 80px;
      height: 80px;
      border-radius: 10px;
      border: 2px solid transparent;
      position: relative;
      overflow: hidden;
      background: var(--milaura-beige, #FDFBF7);
    }

    .product__media-item:not(:first-child) .product-media-container img {
      position: absolute;
      top: 0; left: 0;
      width: 100%;
      height: 100%;
      object-fit: cover;
    }

    /* Spotlight slide: hidden on desktop (uses external thumb instead) */
    .product__media-item--spotlight {
      /* Visible on mobile via carousel, hidden on desktop via JS-injected style */
    }

    .product__media-item--spotlight .milaura-hotspot {
      display: none; /* Hide hotspots in thumbnail mode on desktop */
    }

    .slider-buttons {
      display: none;
    }

    .slider-button {
      display: none;
    }

    /* Desktop Zoom on hover */
    .product__media-item:first-child .product-media-container {
      cursor: zoom-in;
    }

    .product__media-item:first-child .product-media-container.is-zoomed {
      cursor: zoom-out;
    }

    .product__media-item:first-child .product-media-container.is-zoomed img {
      transform: scale(2.2);
      transform-origin: var(--zoom-x, 50%) var(--zoom-y, 50%);
      transition: transform-origin 0.05s ease-out;
    }

    /* Desktop Clickable Thumbnails */
    .product__media-item:not(:first-child) .product-media-container {
      cursor: pointer;
      transition: box-shadow 0.3s ease, border-color 0.3s ease;
    }

    .product__media-item:not(:first-child) .product-media-container:hover {
      border-color: var(--milaura-gold);
      box-shadow: 0 4px 16px rgba(192, 160, 98, 0.25);
    }

    /* Desktop pills : reste sur la grid area "meta" (1 ligne centree au-dessus de la galerie).
       Refonte 2026-05-28 : retrait du flotting badges sur la photo, plus fiable + lisible. */
    .milaura-meta-badge {
      padding: 7px 16px;
      font-size: 0.85rem;
      box-shadow: 0 2px 12px rgba(192, 160, 98, 0.12);
    }

  }

  /* AVIS */
  .rating-badge {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    margin-bottom: 12px;
    text-decoration: none !important;
    color: var(--milaura-text) !important;
  }

  .rating-badge .stars {
    color: #D4A843 !important; /* Doré plus foncé pour meilleur contraste */
    font-size: 16px;
    letter-spacing: -1px;
    text-shadow: 0 1px 2px rgba(0, 0, 0, 0.15); /* Ombre légère pour lisibilité */
  }

  .rating-badge .rating-text {
    opacity: 0.7;
    font-size: 13px;
    color: inherit;
  }

  /* TYPOGRAPHIE */
  .milaura-product__title {
    font-family: var(--milaura-font-heading);
    font-size: {{ section.settings.title_size_mobile }}px;
    margin-bottom: 8px;
    font-weight: 600;
    color: {{ section.settings.title_color }};
  }
  @media screen and (min-width: 990px) {
    .milaura-product__title { font-size: {{ section.settings.title_size_desktop }}rem; }
  }

  .milaura-product__price {
    font-size: {{ section.settings.price_size }}px;
    font-weight: 700;
    color: {{ section.settings.price_color }};
  }

  .milaura-product__price .price-item--sale {
    font-size: calc({{ section.settings.price_size }}px * 1.15);
    font-weight: 800;
  }

  .milaura-product__price .price-item--regular.price-item--last {
    opacity: 0.6;
    text-decoration: line-through;
  }

  /* --- Social Proof --- */
  /* --- Bloc Trust unifie (certificat + reassurance) --- */
  .milaura-trust-block {
    background: linear-gradient(135deg, rgba(253, 251, 247, 0.95), rgba(242, 232, 213, 0.6));
    border: 1px solid rgba(192, 160, 98, 0.25);
    border-radius: 16px;
    padding: 16px;
    margin-bottom: 16px;
    margin-top: 8px;
  }

  .milaura-trust-layout {
    display: flex;
    gap: 16px;
    align-items: flex-start;
  }

  .milaura-trust-cert-wrap {
    flex-shrink: 0;
    display: flex;
    flex-direction: column;
    gap: 6px;
    align-items: center;
  }

  .milaura-trust-main-img {
    width: 110px;
    height: auto;
    border-radius: 10px;
    border: 1px solid rgba(192, 160, 98, 0.3);
    box-shadow: 0 4px 16px rgba(0, 0, 0, 0.08);
    object-fit: cover;
  }

  .milaura-trust-cert-img {
    width: 80px;
    height: auto;
    border-radius: 6px;
    border: 1px solid rgba(192, 160, 98, 0.2);
    box-shadow: 0 2px 8px rgba(0, 0, 0, 0.06);
    opacity: 0.9;
  }

  .milaura-trust-points {
    display: flex;
    flex-direction: column;
    gap: 8px;
    flex: 1;
  }

  .milaura-trust-point {
    display: flex;
    align-items: flex-start;
    gap: 8px;
    font-family: 'Lato', sans-serif;
    font-size: 0.85rem;
    color: #333;
    line-height: 1.4;
  }

  .milaura-trust-point .milaura-trust-icon {
    flex-shrink: 0;
    font-size: 0.9rem;
    margin-top: 1px;
  }

  .milaura-trust-point:first-child {
    font-weight: 700;
    font-size: 0.9rem;
    color: #1a1a1a;
  }

  /* --- Promo Badge (notre badge custom) --- */
  .milaura-promo-badge {
    display: inline-block;
    background: linear-gradient(135deg, #1a1a2e, #2d2d44);
    color: var(--milaura-gold-light, #E6C88B);
    font-size: 0.95rem;
    font-weight: 700;
    padding: 6px 16px;
    border-radius: 10px;
    vertical-align: middle;
    font-family: 'Lato', sans-serif;
    letter-spacing: 0.5px;
  }

  /* --- Prix : tout en ligne (prix barre + prix sale + Promotion + -30%) ---
     IMPORTANT : ne pas forcer display sur .price__regular / .price__sale,
     Dawn gere le hide automatiquement quand .price--on-sale est present. */
  .milaura-hero-wrapper [id^="price-"] {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: 10px;
    margin-bottom: var(--milaura-spacing-sm, 12px);
  }
  .milaura-hero-wrapper [id^="price-"] > .price {
    display: inline-flex;
    align-items: center;
    flex-wrap: wrap;
    gap: 10px;
  }
  .milaura-hero-wrapper [id^="price-"] .price__container {
    display: inline-flex;
    flex-wrap: wrap;
    align-items: center;
    gap: 10px;
  }
  /* Quand on est en sale, hide .price__regular (Dawn-style) */
  .milaura-hero-wrapper [id^="price-"] .price--on-sale .price__regular {
    display: none !important;
  }
  /* .price__sale en sale : flex wrap inline */
  .milaura-hero-wrapper [id^="price-"] .price__sale {
    align-items: center;
    flex-wrap: wrap;
    gap: 8px;
    margin: 0;
  }
  .milaura-hero-wrapper [id^="price-"] .price-item {
    display: inline-block;
    margin: 0;
  }
  .milaura-hero-wrapper [id^="price-"] .price__sale .price-item--regular {
    font-size: 1rem;
    opacity: 0.6;
  }
  .milaura-hero-wrapper [id^="price-"] .price__sale s.price-item--regular {
    font-size: 1rem;
    opacity: 0.6;
    text-decoration: line-through;
  }
  .milaura-hero-wrapper [id^="price-"] .price-item--sale {
    font-weight: 800;
    font-size: 1.4rem;
    color: var(--milaura-gold, #C0A062);
  }
  /* Badges Promotion + -30% inline (a cote du prix) */
  .milaura-hero-wrapper [id^="price-"] .badge.price__badge-sale,
  .milaura-hero-wrapper [id^="price-"] .price__badge-sale {
    display: inline-flex !important;
    align-items: center;
    margin: 0 !important;
    line-height: 1;
    font-size: 0.75rem;
    padding: 5px 10px;
  }
  .milaura-hero-wrapper [id^="price-"] .milaura-promo-badge {
    display: inline-flex;
    align-items: center;
    margin: 0;
    font-size: 0.75rem;
    padding: 5px 10px;
  }
  @media (max-width: 480px) {
    .milaura-hero-wrapper [id^="price-"] .badge.price__badge-sale,
    .milaura-hero-wrapper [id^="price-"] .price__badge-sale,
    .milaura-hero-wrapper [id^="price-"] .milaura-promo-badge {
      font-size: 0.7rem;
      padding: 4px 8px;
    }
    .milaura-hero-wrapper [id^="price-"] .price-item--sale {
      font-size: 1.25rem;
    }
    .milaura-hero-wrapper [id^="price-"] .price__sale s.price-item--regular {
      font-size: 0.85rem;
    }
  }
  /* Hide sold-out badge sauf si sold out */
  .milaura-hero-wrapper [id^="price-"] .price__badge-sold-out {
    display: none;
  }
  .milaura-hero-wrapper [id^="price-"] .price--sold-out .price__badge-sold-out {
    display: inline-flex !important;
  }

  /* --- Override Dawn sale badge to match our blue + gold text --- */
  .milaura-hero-wrapper .badge.price__badge-sale,
  .milaura-hero-wrapper .price__badge-sale {
    background: linear-gradient(135deg, #1a1a2e, #2d2d44) !important;
    color: var(--milaura-gold-light, #E6C88B) !important;
    border: none !important;
    font-size: 0.95rem;
    font-weight: 700;
    padding: 6px 16px;
    border-radius: 10px;
    font-family: 'Lato', sans-serif;
    letter-spacing: 0.5px;
  }

  /* --- Payment Icons --- */
  .milaura-hero-wrapper .milaura-payment-icons {
    display: flex;
    align-items: center;
    justify-content: flex-start;
    gap: 6px;
    margin-top: 10px;
    opacity: 0.55;
    list-style: none;
    padding: 0;
    flex-wrap: wrap;
  }

  .milaura-hero-wrapper .milaura-payment-icon {
    display: inline-flex;
  }

  .milaura-hero-wrapper .milaura-payment-icon svg {
    width: 38px;
    height: 24px;
  }

  /* --- Responsive: center on mobile --- */
  @media screen and (max-width: 749px) {
    .milaura-payment-icons {
      justify-content: center;
    }

    .milaura-trust-block {
      padding: 12px;
    }

    .milaura-trust-layout {
      flex-direction: column;
      align-items: center;
      text-align: center;
      gap: 12px;
    }

    .milaura-trust-cert-wrap {
      flex-direction: row;
      gap: 8px;
    }

    .milaura-trust-main-img {
      width: 100px;
    }

    .milaura-trust-cert-img {
      width: 65px;
    }

    .milaura-trust-point {
      justify-content: center;
      font-size: 0.82rem;
    }
  }

  /* ===========================================
     VOLUME BUNDLE - Design Premium 2026
     Cartes avec en-têtes colorés intégrés
     =========================================== */

  .volume-section-title {
    font-family: var(--milaura-font-heading);
    font-size: 15px;
    font-weight: 600;
    color: var(--milaura-text);
    margin: 0 0 12px 0;
    text-align: center;
  }

  .milaura-volume-grid {
    display: flex;
    gap: 8px;
    margin: 0 0 12px 0;
  }

  .volume-card {
    flex: 1;
    position: relative;
    display: flex;
    flex-direction: column;
    align-items: center;
    padding: 0; /* En-tête intégré - padding géré par sous-éléments */
    border: 1.5px solid #E8E4DE;
    border-radius: 12px;
    background: #FFFFFF;
    cursor: pointer;
    transition: all 0.25s cubic-bezier(0.4, 0, 0.2, 1);
    overflow: hidden; /* Important pour l'en-tête intégré */
  }

  .volume-card:hover {
    border-color: rgba(192, 160, 98, 0.5);
    transform: translateY(-2px);
    box-shadow: 0 6px 20px rgba(192, 160, 98, 0.12);
  }

  .volume-card.is-selected {
    border-color: var(--milaura-gold);
    background: linear-gradient(165deg, #FFFDF8 0%, #FFF9EE 100%);
    box-shadow: 0 4px 16px rgba(192, 160, 98, 0.18);
  }

  /* EN-TÊTE INTÉGRÉ - Design 2026 */
  /* Le badge est maintenant un header intégré en haut de la carte */
  /* Hauteur fixe pour uniformité (basée sur 2 lignes de texte) */
  .volume-card-badge {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 100%;
    min-height: 38px; /* Hauteur fixe pour 2 lignes */
