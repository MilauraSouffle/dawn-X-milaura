    box-shadow: 0 5px 14px rgba(192, 160, 98, 0.2);
  }

  .milaura-gallery-story__karine--mobile .milaura-gallery-story__karine-content {
    flex: 1;
    min-width: 0;
  }

  .milaura-gallery-story__karine--mobile .milaura-gallery-story__quote {
    font-family: 'Playfair Display', serif;
    font-size: 0.84rem;
    font-style: italic;
    line-height: 1.45;
    color: var(--milaura-text, #000);
    margin: 0 0 8px;
  }

  .milaura-gallery-story__karine--mobile .milaura-gallery-story__signature {
    font-family: 'Dancing Script', cursive;
    font-size: 1.5rem;
    line-height: 1;
    color: var(--milaura-gold-dark, #8F723A);
    margin: 0 0 1px;
    transform: rotate(-2deg);
    transform-origin: left center;
  }

  .milaura-gallery-story__karine--mobile .milaura-gallery-story__author {
    font-family: 'Lato', sans-serif;
    font-size: 0.62rem;
    color: var(--milaura-gold-dark, #8F723A);
    letter-spacing: 1.1px;
    text-transform: uppercase;
    margin: 0;
    font-weight: 600;
  }

  .milaura-info-block .milaura-hero-social {
    margin-bottom: 0;
  }
  @media (max-width: 768px) {
    .milaura-info-block {
      margin-top: var(--milaura-spacing-sm, 12px);
      padding-top: var(--milaura-spacing-sm, 12px);
    }
    .milaura-info-description {
      font-size: 0.82rem;
    }
    .milaura-gallery-story__karine--mobile {
      padding: 12px;
      gap: 10px;
    }
  }

  .milaura-bundle-atc-row {
    display: flex;
    align-items: stretch;
    gap: 10px;
    width: 100%;
    margin-top: var(--milaura-spacing-md, 18px);
  }

  .milaura-bundle-atc-row .milaura-bundle-qty {
    align-self: stretch;
    flex: 0 0 104px !important;
    width: 104px !important;
    min-width: 104px !important;
    max-width: 104px !important;
    height: auto !important;
    min-height: 64px !important;
    border-radius: 16px !important;
  }

  /* CTA bundle-aware : premium gold avec icone panier + shimmer, texte NOIR */
  .milaura-hero-cta-bundle {
    position: relative;
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 14px;
    flex: 1 1 auto;
    width: auto;
    min-width: 0;
    padding: 18px 28px;
    margin-top: 0;
    background: linear-gradient(135deg, #8F723A 0%, #C0A062 45%, #E6C88B 100%);
    color: #000000;
    border: none;
    border-radius: 16px;
    font-family: var(--milaura-font-heading, 'Playfair Display'), serif;
    font-size: 1.1rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 1.5px;
    cursor: pointer;
    box-shadow:
      0 12px 30px rgba(192, 160, 98, 0.35),
      0 2px 6px rgba(143, 114, 58, 0.25),
      inset 0 1px 0 rgba(255, 255, 255, 0.25);
    overflow: hidden;
    transition: transform 0.25s ease, box-shadow 0.25s ease;
    isolation: isolate;
  }

  /* Shimmer band qui glisse au hover */
  .milaura-hero-cta-bundle::before {
    content: '';
    position: absolute;
    inset: 0;
    background: linear-gradient(
      120deg,
      transparent 0%,
      transparent 35%,
      rgba(255, 255, 255, 0.45) 50%,
      transparent 65%,
      transparent 100%
    );
    transform: translateX(-100%);
    transition: transform 0.9s ease;
    pointer-events: none;
    z-index: 1;
  }

  .milaura-hero-cta-bundle:hover::before {
    transform: translateX(100%);
  }

  .milaura-hero-cta-bundle:hover {
    transform: translateY(-2px);
    box-shadow:
      0 18px 40px rgba(192, 160, 98, 0.45),
      0 4px 10px rgba(143, 114, 58, 0.3),
      inset 0 1px 0 rgba(255, 255, 255, 0.35);
  }

  .milaura-hero-cta-bundle:active {
    transform: translateY(0);
  }

  .milaura-hero-cta-bundle:disabled {
    opacity: 0.7;
    cursor: not-allowed;
    transform: none;
  }

  .milaura-hero-cta-bundle > * {
    position: relative;
    z-index: 2;
  }

  .milaura-cta-icon {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 28px;
    height: 28px;
    flex-shrink: 0;
  }

  .milaura-cta-icon svg {
    width: 100%;
    height: 100%;
    stroke: #000000;
    fill: none;
    stroke-width: 2;
    filter: drop-shadow(0 1px 1px rgba(255, 255, 255, 0.25));
  }

  .milaura-cta-label {
    flex: 1;
    text-align: center;
    white-space: nowrap;
  }

  .milaura-cta-price {
    font-weight: 800;
    font-size: 1.15rem;
    color: #000000;
    background: rgba(0, 0, 0, 0.08);
    padding: 6px 14px;
    border-radius: 10px;
    backdrop-filter: blur(2px);
    flex-shrink: 0;
  }

  @media screen and (max-width: 749px) {
    .milaura-bundle-atc-row {
      gap: 8px;
    }

    .milaura-bundle-atc-row .milaura-bundle-qty {
      flex-basis: 92px !important;
      width: 92px !important;
      min-width: 92px !important;
      max-width: 92px !important;
      min-height: 56px !important;
      border-radius: 15px !important;
    }

    .milaura-hero-cta-bundle {
      gap: 8px;
      padding: 14px 10px;
      border-radius: 15px;
      font-size: 0.78rem;
      letter-spacing: 1px;
      min-height: 56px;
    }

    .milaura-cta-icon {
      width: 23px;
      height: 23px;
    }

    .milaura-cta-price {
      font-size: 0.9rem;
      padding: 6px 9px;
      border-radius: 9px;
    }
  }

  @media screen and (max-width: 374px) {
    .milaura-bundle-atc-row .milaura-bundle-qty {
      flex-basis: 84px !important;
      width: 84px !important;
      min-width: 84px !important;
      max-width: 84px !important;
    }

    .milaura-hero-cta-bundle {
      gap: 6px;
      padding-inline: 8px;
      font-size: 0.72rem;
      letter-spacing: 0.7px;
    }

    .milaura-cta-icon {
      display: none;
    }
  }

  /* Phrase reassurance sous CTA supprimee (cf user request 2026-05-28) */
  .milaura-hero-cta-reassurance { display: none; }

  /* Desktop : grid avec social + meta full width + gallery/rightcol (header + actions ensembles).
     Refonte 2026-05-28 evening : header + actions wrappes ensemble pour eviter le trou vertical. */
  @media screen and (min-width: 990px) {
    .milaura-hero-wrapper {
      grid-template-areas:
        "social   social"
        "meta     meta"
        "gallery  rightcol" !important;
      grid-template-rows: auto auto auto !important;
      align-items: start;
      row-gap: 12px;
    }

    .milaura-hero-rightcol {
      grid-area: rightcol;
      display: flex;
      flex-direction: column;
      gap: 18px;
      align-self: start;
      position: sticky;
      top: calc(var(--header-height, 80px) + 20px);
    }

    .milaura-hero-header-group {
      grid-area: auto !important;
      position: static !important;
      background: transparent !important;
      border: none !important;
      padding: 0 !important;
      margin: 0;
      text-align: left;
    }

    .milaura-hero-actions-group {
      grid-area: auto !important;
      position: static !important;
      align-self: stretch;
      gap: 12px;
    }

    .milaura-video-bubble-wrapper {
      display: none;
    }

    /* Pills metafield : 1 ligne centree au-dessus de la galerie, plus de absolute */
    .milaura-meta-badges {
      position: static;
      padding: 0;
      pointer-events: auto;
    }
  }

  /* ===========================================
     GALLERY STORY (desktop only) : description + Karine signature
     Affiche sous la galerie pour exploiter le vide gauche et humaniser.
     =========================================== */
  .milaura-gallery-story {
    display: none;
  }

  @media screen and (min-width: 990px) {
    .milaura-gallery-story {
      display: block;
      margin-top: 32px;
      padding-top: 32px;
      border-top: 1px solid rgba(192, 160, 98, 0.2);
    }

    .milaura-gallery-story__description {
      font-family: 'Lato', sans-serif;
      font-size: 0.95rem;
      line-height: 1.7;
      color: var(--milaura-text, #000);
    }

    .milaura-gallery-story__description p {
      margin: 0 0 12px;
      display: inline;
    }

    .milaura-gallery-story__read-more {
      display: inline;
      margin-left: 4px;
      color: var(--milaura-gold-dark, #8F723A);
      font-weight: 600;
      text-decoration: none;
      border-bottom: 1px solid rgba(143, 114, 58, 0.4);
      transition: color 0.18s ease, border-color 0.18s ease;
      white-space: nowrap;
    }

    .milaura-gallery-story__read-more:hover {
      color: var(--milaura-gold, #C0A062);
      border-bottom-color: var(--milaura-gold, #C0A062);
    }

    .milaura-gallery-story__karine {
      display: flex;
      align-items: center;
      gap: 18px;
      margin-top: 28px;
      padding-top: 24px;
      border-top: 1px solid rgba(192, 160, 98, 0.2);
    }

    .milaura-gallery-story__karine-img {
      flex-shrink: 0;
      width: 88px;
      height: 88px;
      border-radius: 50%;
      object-fit: cover;
      border: 2px solid var(--milaura-gold, #C0A062);
      box-shadow: 0 6px 18px rgba(192, 160, 98, 0.22);
    }

    .milaura-gallery-story__karine-content {
      flex: 1;
      min-width: 0;
    }

    .milaura-gallery-story__quote {
      font-family: 'Playfair Display', serif;
      font-size: 0.98rem;
      font-style: italic;
      line-height: 1.55;
      color: var(--milaura-text, #000);
      margin: 0 0 10px;
    }

    .milaura-gallery-story__signature {
      font-family: 'Dancing Script', cursive;
      font-size: 1.9rem;
      line-height: 1;
      color: var(--milaura-gold-dark, #8F723A);
      margin: 0 0 2px;
      transform: rotate(-2deg);
      transform-origin: left center;
    }

    .milaura-gallery-story__author {
      font-family: 'Lato', sans-serif;
      font-size: 0.68rem;
      color: var(--milaura-gold-dark, #8F723A);
      letter-spacing: 1.4px;
      text-transform: uppercase;
      margin: 0;
      font-weight: 600;
    }

    /* Sur desktop, on cache la description dans l'info-block (col droite) : elle est maintenant dans gallery story */
    .milaura-hero-actions-group .milaura-info-block {
      display: none;
    }
  }

  /* Mobile : compact + galerie max 60vh */
  @media screen and (max-width: 768px) {
    .milaura-hero-social {
      padding: 10px 14px;
      gap: 10px;
    }
    .milaura-hero-social-text {
      font-size: 0.75rem;
    }
    .milaura-hero-cta-bundle {
      padding: 14px 10px;
      font-size: 0.78rem;
    }
    .milaura-hero-cta-reassurance {
      font-size: 0.65rem;
    }
    .product__media-wrapper,
    .milaura-hero-gallery,
    .product-media-container {
      max-height: 60vh;
    }
  }
{% endstyle %}

<script src="{{ 'product-info.js' | asset_url }}" defer="defer"></script>
<script src="{{ 'product-form.js' | asset_url }}" defer="defer"></script>

<div class="page-width section-{{ section.id }}-padding">
  <product-info id="ProductInfo-{{ section.id }}" data-section="{{ section.id }}" data-url="{{ product.url }}">
    <div class="milaura-hero-wrapper">
      {%- comment -%} GROUPE 1 HEADER deplace dans .milaura-hero-rightcol (avec actions group) pour eviter le trou vertical sur desktop. Refonte 2026-05-28 evening. {%- endcomment -%}

      {%- comment -%} Bulle social proof au-dessus de la galerie (refonte 2026-05-28, demande user mobile).
        Le nombre de client(e)s varie par produit via calcul deterministe base sur product.id (entre 12 et 141). {%- endcomment -%}
      {%- if section.settings.show_social_proof -%}
        {%- assign months_fr = "janvier,fevrier,mars,avril,mai,juin,juillet,aout,septembre,octobre,novembre,decembre" | split: "," -%}
        {%- assign month_idx = "now" | date: "%-m" | minus: 1 -%}
        {%- assign month_fr = months_fr[month_idx] -%}
        {%- assign year_fr = "now" | date: "%Y" -%}
        {%- comment -%} Calcul deterministe : meme produit = meme nombre, varie entre 12 et 141. {%- endcomment -%}
        {%- assign social_count_raw = product.id | default: 0 | modulo: 130 -%}
        {%- assign social_count = social_count_raw | plus: 12 -%}
        <div class="milaura-hero-social milaura-hero-social--top">
          <div class="milaura-hero-stars" aria-label="5 etoiles sur 5">
            <span aria-hidden="true">&#9733;&#9733;&#9733;&#9733;&#9733;</span>
          </div>
          <p class="milaura-hero-social-text">
            Ce produit a deja fait le bonheur de
            <strong>+ de {{ social_count }} client(e)s</strong>
            en {{ month_fr }} {{ year_fr }}
          </p>
        </div>
      {%- endif -%}

      {%- comment -%} Badges metafield : calcul ici, rendu dans le header produit apres la galerie. {%- endcomment -%}
      {%- assign badge_energy = product.metafields.milaura.energy_handle -%}
      {%- assign badge_stone = product.metafields.milaura.stone_handle -%}
      {%- assign badge_vertus = product.metafields.milaura.vertus -%}
      {%- assign badge_quality = product.metafields.milaura.qualite -%}
      {%- assign has_meta_badges = false -%}
      {%- if badge_energy != blank or badge_stone != blank or badge_vertus != blank or badge_quality != blank -%}
        {%- assign has_meta_badges = true -%}
      {%- endif -%}

      <!--
        ============================================
        GROUPE 2: GALERIE MEDIA (MODERNE)
        ============================================
      -->
      <div class="milaura-hero-gallery-column">
        <slider-component class="slider-mobile-gutter">
          <ul id="Slider-{{ section.id }}" class="product__media-list list-unstyled slider slider--mobile" role="list">
            {%- if product.media.size == 0 -%}
              <li id="Slide-{{ section.id }}-1" class="product__media-item slider__slide">
                <div class="product-media-container">
                  {{ 'product-1' | placeholder_svg_tag: 'placeholder-svg' }}
                </div>
              </li>
            {%- endif -%}

            {%- for media in product.media -%}
              <li
                id="Slide-{{ section.id }}-{{ forloop.index }}"
                class="product__media-item slider__slide{% if media.media_type != 'image' %} product__media-item--video{% endif %}"
                data-media-id="{{ section.id }}-{{ media.id }}"
              >
                <div class="product-media-container">
                  {% case media.media_type %}
                    {% when 'image' %}
                      {%- if forloop.first -%}
                        {{
                          media
                          | image_url: width: 1200
                          | image_tag:
                            loading: 'eager',
                            fetchpriority: 'high',
                            class: 'image-magnify-hover',
                            sizes: '(min-width: 1200px) 600px, 100vw'
                        }}
                      {%- else -%}
                        {{
                          media
                          | image_url: width: 1200
                          | image_tag:
                            loading: 'lazy',
                            class: 'image-magnify-hover',
                            sizes: '(min-width: 1200px) 600px, 100vw'
                        }}
                      {%- endif -%}

                    {% when 'external_video' %}
                      {% assign video_class = 'js-youtube' %}
                      {% if media.host == 'vimeo' %}{% assign video_class = 'js-vimeo' %}{% endif %}
                      {{
                        media
                        | external_video_url: autoplay: true, loop: true, playlist: media.external_id
                        | external_video_tag: class: video_class, loading: 'lazy'
                      }}

                    {% when 'video' %}
                      {{
                        media
                        | video_tag: image_size: '1200x', autoplay: true, loop: true, controls: true, preload: 'none'
                      }}

                    {% when 'model' %}
                      {{ media | model_viewer_tag }}
                  {% endcase %}
                </div>
              </li>
            {%- endfor -%}

            {%- comment -%} ========== SPOTLIGHT SLIDE ========== {%- endcomment -%}
            {%- assign extra_slides_count = 0 -%}
            {%- if section.settings.show_spotlight and section.settings.spotlight_image != blank -%}
              {%- assign spotlight_index = product.media.size | plus: 1 -%}
              <li
                id="Slide-{{ section.id }}-{{ spotlight_index }}"
                class="product__media-item slider__slide product__media-item--spotlight"
                data-media-id="{{ section.id }}-spotlight"
              >
                <div class="product-media-container milaura-spotlight-slide-wrapper">
                  <div class="milaura-spotlight-container">
                    {{
                      section.settings.spotlight_image
                      | image_url: width: 1200
                      | image_tag: loading: 'lazy', class: 'milaura-spotlight-image', sizes: '(min-width: 1200px) 600px, 100vw'
                    }}
                    {%- for i in (1..3) -%}
                      {%- assign title_key = 'spotlight_' | append: i | append: '_title' -%}
                      {%- assign desc_key = 'spotlight_' | append: i | append: '_desc' -%}
                      {%- assign x_key = 'spotlight_' | append: i | append: '_x' -%}
                      {%- assign y_key = 'spotlight_' | append: i | append: '_y' -%}
                      {%- assign hs_title = section.settings[title_key] -%}
                      {%- assign hs_desc = section.settings[desc_key] -%}
                      {%- assign hs_x = section.settings[x_key] -%}
                      {%- assign hs_y = section.settings[y_key] -%}
                      {%- if hs_title != blank -%}
                        <div
                          class="milaura-hotspot"
                          style="left: {{ hs_x }}%; top: {{ hs_y }}%;"
                          data-index="{{ i }}"
                        >
                          <button class="milaura-hotspot-btn" aria-label="Voir le detail : {{ hs_title | escape }}">
                            <span class="milaura-hotspot-pulse"></span>
                            <span class="milaura-hotspot-inner">+</span>
                          </button>
                          <div class="milaura-hotspot-tooltip">
                            <div class="milaura-hotspot-tooltip-content">
                              <h4>{{ hs_title }}</h4>
                              <div class="rte">{{ hs_desc }}</div>
                            </div>
                          </div>
                        </div>
                      {%- endif -%}
                    {%- endfor -%}
                  </div>
                </div>
              </li>
              {%- assign extra_slides_count = extra_slides_count | plus: 1 -%}
            {%- endif -%}

            {%- comment -%} ========== VIDEO SLIDE (mobile carousel only, hidden desktop) ========== {%- endcomment -%}
            {%- if section.settings.show_video_slide and section.settings.video_url != blank -%}
              {%- assign video_slide_index = product.media.size | plus: extra_slides_count | plus: 1 -%}
              <li
                id="Slide-{{ section.id }}-{{ video_slide_index }}"
                class="product__media-item slider__slide product__media-item--video-slide"
                data-media-id="{{ section.id }}-video"
              >
                <div class="product-media-container milaura-video-main-container" data-video-url="{{ section.settings.video_url }}">
                  {%- if section.settings.video_poster != blank -%}
                    {{ section.settings.video_poster | image_url: width: 1200 | image_tag: loading: 'lazy', class: 'milaura-video-main-poster' }}
                    <button class="milaura-video-main-play" aria-label="Lire la video">
                      <svg width="56" height="56" viewBox="0 0 56 56" fill="none"><circle cx="28" cy="28" r="28" fill="rgba(0,0,0,0.45)"/><path d="M22 17L40 28L22 39V17Z" fill="white"/></svg>
                    </button>
                  {%- else -%}
                    <div class="milaura-video-main-placeholder">
                      <svg width="56" height="56" viewBox="0 0 56 56" fill="none"><circle cx="28" cy="28" r="28" fill="rgba(192,160,98,0.2)"/><path d="M22 17L40 28L22 39V17Z" fill="var(--milaura-gold, #C0A062)"/></svg>
                    </div>
                  {%- endif -%}
                </div>
              </li>
            {%- endif -%}

          </ul>

          <!-- Navigation Fleches (Mobile/Tablette) -->
          {%- assign total_slides = product.media.size -%}
          {%- if section.settings.show_spotlight and section.settings.spotlight_image != blank -%}
            {%- assign total_slides = total_slides | plus: 1 -%}
          {%- endif -%}
          {%- if section.settings.show_video_slide and section.settings.video_url != blank -%}
            {%- assign total_slides = total_slides | plus: 1 -%}
          {%- endif -%}
          {%- if total_slides > 1 -%}
            <button
              type="button"
              class="slider-button slider-button--prev no-js-hidden"
              name="previous"
              aria-label="Diapositive précédente"
              aria-controls="Slider-{{ section.id }}"
            >
              <svg viewBox="0 0 24 24" width="20" height="20" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="15 18 9 12 15 6"></polyline></svg>
            </button>
            <button
              type="button"
              class="slider-button slider-button--next no-js-hidden"
              name="next"
              aria-label="Diapositive suivante"
              aria-controls="Slider-{{ section.id }}"
            >
              <svg viewBox="0 0 24 24" width="20" height="20" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="9 18 15 12 9 6"></polyline></svg>
            </button>
          {%- endif -%}

          <!-- Pagination Dots (Mobile/Tablette) -->
          <div class="slider-buttons no-js-hidden{% if total_slides < 2 %} hidden{% endif %}">
            {%- for media in product.media -%}
              <button
                type="button"
                class="slider-counter__link slider-counter__link--dots link{% if forloop.first %} slider-counter__link--active{% endif %}"
                aria-label="Diapositive {{ forloop.index }}"
                aria-controls="Slide-{{ section.id }}-{{ forloop.index }}"
                data-slide-index="{{ forloop.index0 }}"
              >
                <span class="dot"></span>
              </button>
            {%- endfor -%}
            {%- if section.settings.show_spotlight and section.settings.spotlight_image != blank -%}
              {%- assign spotlight_dot_index = product.media.size -%}
              <button
                type="button"
                class="slider-counter__link slider-counter__link--dots link"
                aria-label="Spotlight"
                aria-controls="Slide-{{ section.id }}-{{ spotlight_dot_index | plus: 1 }}"
                data-slide-index="{{ spotlight_dot_index }}"
              >
                <span class="dot dot--spotlight"></span>
              </button>
            {%- endif -%}
            {%- if section.settings.show_video_slide and section.settings.video_url != blank -%}
              {%- assign video_dot_index = product.media.size | plus: extra_slides_count -%}
              <button
                type="button"
                class="slider-counter__link slider-counter__link--dots link"
                aria-label="Video"
                aria-controls="Slide-{{ section.id }}-{{ video_dot_index | plus: 1 }}"
                data-slide-index="{{ video_dot_index }}"
              >
                <span class="dot dot--video"></span>
              </button>
            {%- endif -%}
          </div>

          <!-- Thumbnail strip (mobile only) -->
          <div class="milaura-thumb-strip no-js-hidden">
            {%- for media in product.media -%}
              <button
                type="button"
                class="milaura-thumb-strip__item{% if forloop.first %} is-active{% endif %}"
                aria-label="{{ media.alt | default: product.title | escape }}"
                data-slide-index="{{ forloop.index0 }}"
              >
                {{ media | image_url: width: 160 | image_tag: loading: 'lazy', class: 'milaura-thumb-strip__img' }}
              </button>
            {%- endfor -%}
            {%- if section.settings.show_spotlight and section.settings.spotlight_image != blank -%}
              <button
                type="button"
                class="milaura-thumb-strip__item milaura-thumb-strip__item--spotlight"
                aria-label="Spotlight"
                data-slide-index="{{ product.media.size }}"
              >
                {{ section.settings.spotlight_image | image_url: width: 160 | image_tag: loading: 'lazy', class: 'milaura-thumb-strip__img' }}
              </button>
            {%- endif -%}
            {%- if section.settings.show_video_slide and section.settings.video_url != blank -%}
              {%- assign video_thumb_index = product.media.size | plus: extra_slides_count -%}
              <button
                type="button"
                class="milaura-thumb-strip__item milaura-thumb-strip__item--video"
                aria-label="Video"
                data-slide-index="{{ video_thumb_index }}"
                data-video-url="{{ section.settings.video_url }}"
              >
                {%- if section.settings.video_poster != blank -%}
                  {{ section.settings.video_poster | image_url: width: 160 | image_tag: loading: 'lazy', class: 'milaura-thumb-strip__img' }}
                {%- endif -%}
                <div class="milaura-thumb-strip__video-overlay">
                  <svg width="24" height="24" viewBox="0 0 24 24" fill="none"><circle cx="12" cy="12" r="12" fill="rgba(0,0,0,0.4)"/><path d="M10 7L18 12L10 17V7Z" fill="white"/></svg>
                </div>
              </button>
            {%- endif -%}
          </div>

          {%- comment -%} Overlay variantes supprimé — les variantes sont gérées dans la zone d'achat {%- endcomment -%}
        </slider-component>

        {%- comment -%} ========== SPOTLIGHT DESKTOP THUMBNAIL (outside slider) ========== {%- endcomment -%}
        {%- if section.settings.show_spotlight and section.settings.spotlight_image != blank -%}
          <div class="milaura-spotlight-desktop-thumb" data-spotlight-slide="Slide-{{ section.id }}-{{ product.media.size | plus: 1 }}">
            <div class="milaura-spotlight-desktop-thumb__img-wrap">
              {{
                section.settings.spotlight_image
                | image_url: width: 200
                | image_tag: loading: 'lazy', class: 'milaura-spotlight-desktop-thumb__img'
              }}
            </div>
          </div>
        {%- endif -%}

        {%- comment -%} Badges metafield + bulle social proof restent dans grid area dediee. Description + Karine signature rendues ci-dessous (desktop only). {%- endcomment -%}

        {%- comment -%} ==========================================
          GALLERY STORY (desktop only) : description complete + signature Karine.
          Affiche sous la galerie pour exploiter le vide gauche et humaniser la marque.
          Sur mobile, ce bloc est cache (la description reste dans l'info-block apres CTA).
          ========================================== {%- endcomment -%}
        <div class="milaura-gallery-story">
          {%- if section.settings.show_description and product.description != blank -%}
            <div class="milaura-gallery-story__description rte">
              {{ product.description | strip_html | truncatewords: 25 }}
              <a href="#ProductTabs" class="milaura-gallery-story__read-more" id="readMoreLinkGallery-{{ section.id }}">Lire la suite &rarr;</a>
            </div>
            <script>
              (function () {
                var link = document.getElementById('readMoreLinkGallery-{{ section.id }}');
                if (!link) return;
                link.addEventListener('click', function (e) {
                  e.preventDefault();
                  var target = document.getElementById('ProductTabs');
                  if (target) {
                    var headerHeight = parseInt(getComputedStyle(document.documentElement).getPropertyValue('--header-height')) || 80;
                    var targetPosition = target.getBoundingClientRect().top + window.pageYOffset - headerHeight - 20;
                    window.scrollTo({ top: targetPosition, behavior: 'smooth' });
                  }
                });
              })();
            </script>
          {%- endif -%}

          {%- if section.settings.show_karine_block -%}
            <div class="milaura-gallery-story__karine">
              {%- if section.settings.karine_image != blank -%}
                <img class="milaura-gallery-story__karine-img"
                     src="{{ section.settings.karine_image | image_url: width: 220 }}"
                     alt="Karine, fondatrice Mil'Aura"
                     width="88" height="88" loading="lazy">
              {%- endif -%}
              <div class="milaura-gallery-story__karine-content">
                <p class="milaura-gallery-story__quote">{%- if section.settings.karine_quote != blank -%}{{ section.settings.karine_quote }}{%- else -%}Je sélectionne chaque pierre avec soin. Origine contrôlée, qualité vérifiée avec rigueur, avant d'arriver dans nos ateliers.{%- endif -%}</p>
                <p class="milaura-gallery-story__signature">Karine</p>
                <p class="milaura-gallery-story__author">Fondatrice Mil'Aura</p>
              </div>
            </div>
          {%- endif -%}
        </div>
      </div>

      <!--
        ============================================
        VIDEO BUBBLE (floating, between header & actions on desktop)
        ============================================
      -->
      {%- if section.settings.show_video_slide and section.settings.video_url != blank -%}
        <div class="milaura-video-bubble-wrapper">
          <div class="milaura-video-bubble" data-video-url="{{ section.settings.video_url }}">
            {%- if section.settings.video_poster != blank -%}
              <div class="milaura-video-bubble__poster">
                {{ section.settings.video_poster | image_url: width: 400 | image_tag: loading: 'lazy', class: 'milaura-video-bubble__poster-img' }}
                <button class="milaura-video-bubble__play" aria-label="Lire la video">
                  <svg width="36" height="36" viewBox="0 0 36 36" fill="none">
                    <circle cx="18" cy="18" r="18" fill="rgba(0,0,0,0.4)"/>
                    <path d="M14 11L26 18L14 25V11Z" fill="white"/>
                  </svg>
                </button>
              </div>
            {%- else -%}
              <div class="milaura-video-bubble__poster milaura-video-bubble__poster--empty">
                <svg width="36" height="36" viewBox="0 0 36 36" fill="none">
                  <circle cx="18" cy="18" r="18" fill="rgba(192,160,98,0.15)"/>
                  <path d="M14 11L26 18L14 25V11Z" fill="var(--milaura-gold, #C0A062)"/>
                </svg>
                <span class="milaura-video-bubble__label">Video</span>
              </div>
            {%- endif -%}
          </div>
        </div>
      {%- endif -%}

      <!--
        ============================================
        RIGHT COL WRAPPER (HEADER + ACTIONS)
        Sur desktop : assigne a grid-area: rightcol, flex column.
        Evite le trou vertical entre header et actions du au row-spanning de la galerie.
        Refonte 2026-05-28 evening.
        ============================================
      -->
      <div class="milaura-hero-rightcol">
        <!--
          ============================================
          GROUPE 1: HEADER (titre + prix + badge promo)
          ============================================
        -->
        <div class="milaura-hero-header-group">
          {%- if section.settings.show_vendor -%}
            <div class="product__vendor caption-with-letter-spacing">{{ product.vendor }}</div>
          {%- endif -%}

          {%- if has_meta_badges -%}
            {%- assign shown_meta_badges = 0 -%}
            <div class="milaura-meta-badges milaura-meta-badges--product">
              {%- if badge_stone != blank and shown_meta_badges < 3 -%}
                {%- assign shown_meta_badges = shown_meta_badges | plus: 1 -%}
                <span class="milaura-meta-badge">
                  <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                    <path d="M12 2L2 7l10 5 10-5-10-5zM2 17l10 5 10-5M2 12l10 5 10-5"/>
                  </svg>
                  {{ badge_stone }}
                </span>
              {%- endif -%}
              {%- if badge_energy != blank and shown_meta_badges < 3 -%}
                {%- assign shown_meta_badges = shown_meta_badges | plus: 1 -%}
                <span class="milaura-meta-badge">
                  <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                    <path d="M13 2L3 14h9l-1 8 10-12h-9l1-8z"/>
                  </svg>
                  {{ badge_energy }}
                </span>
              {%- endif -%}
              {%- if badge_vertus != blank and shown_meta_badges < 3 -%}
                {%- assign shown_meta_badges = shown_meta_badges | plus: 1 -%}
                {%- assign badge_vertus_size = badge_vertus | strip_html | size -%}
                <span class="milaura-meta-badge milaura-meta-badge--vertus{% if badge_vertus_size > 36 %} milaura-meta-badge--vertus-scroll{% endif %}">
                  <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                    <path d="M20.84 4.61a5.5 5.5 0 0 0-7.78 0L12 5.67l-1.06-1.06a5.5 5.5 0 0 0-7.78 7.78l1.06 1.06L12 21.23l7.78-7.78 1.06-1.06a5.5 5.5 0 0 0 0-7.78z"/>
                  </svg>
                  <span class="milaura-meta-badge__marquee">
                    <span class="milaura-meta-badge__marquee-inner">
                      <span>{{ badge_vertus }}</span>
                      <span class="milaura-meta-badge__marquee-copy" aria-hidden="true">{{ badge_vertus }}</span>
                    </span>
                  </span>
                </span>
              {%- endif -%}
              {%- if badge_quality != blank and shown_meta_badges < 3 -%}
                <span class="milaura-meta-badge milaura-meta-badge--gold">
                  <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                    <path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/>
                  </svg>
                  {{ badge_quality }}
                </span>
              {%- endif -%}
            </div>
          {%- endif -%}

          <h1 class="milaura-product__title">{{ product.title | escape }}</h1>

          <div class="no-js-hidden" id="price-{{ section.id }}" role="status">
            {%- assign hero_price_variant = product.selected_or_first_available_variant -%}
            {%- render 'price',
              product: product,
              use_variant: true,
              show_badges: true,
              price_class: 'milaura-product__price'
            -%}
            {%- if hero_price_variant.compare_at_price > hero_price_variant.price -%}
              {%- assign discount = hero_price_variant.compare_at_price | minus: hero_price_variant.price | times: 100 | divided_by: hero_price_variant.compare_at_price -%}
              <span class="milaura-promo-badge">-{{ discount }}%</span>
            {%- endif -%}
          </div>
        </div>

        <!--
          ============================================
          GROUPE 3: ACTIONS (bundle + scratch + CTA)
          ============================================
        -->
        <div class="milaura-hero-actions-group">
        <!-- Note: Variant Picker was here, moved to gallery above -->

        <!-- Volume Offer Block -->
        {%- for block in section.blocks -%}
          {%- if block.type == 'volume_offer' -%}
            {% if block.settings.title != blank %}
              <h3 class="volume-section-title">{{ block.settings.title }}</h3>
            {% endif %}
            <div
              class="milaura-volume-grid"
              role="radiogroup"
              aria-label="Choisir une offre volume"
              {{ block.shopify_attributes }}
            >
              <!-- Option 1: Standard -->
              <div
                class="volume-card"
                role="radio"
                aria-checked="false"
                tabindex="0"
                onclick="selectVolume(1, this)"
                onkeydown="if(event.key==='Enter'||event.key===' '){event.preventDefault();selectVolume(1, this);}"
              >
                {% if block.settings.opt1_badge != blank %}
                  <span class="volume-card-badge">{{ block.settings.opt1_badge }}</span>
                {% endif %}
                <div class="volume-left">
                  <div class="volume-text">
                    <h5>{{ block.settings.opt1_label | default: '1×' }}</h5>
                    <p>{{ block.settings.opt1_sub | default: 'Standard' }}</p>
                  </div>
                </div>
                <div class="volume-price">{{ product.price | money }}</div>
              </div>

              <!-- Option 2: Populaire (sélectionné par défaut) -->
              <div
                class="volume-card is-selected"
                role="radio"
                aria-checked="true"
                tabindex="0"
                onclick="selectVolume(2, this)"
                onkeydown="if(event.key==='Enter'||event.key===' '){event.preventDefault();selectVolume(2, this);}"
              >
                {% if block.settings.opt2_badge != blank %}
                  <span class="volume-card-badge">{{ block.settings.opt2_badge }}</span>
                {% endif %}
                <div class="volume-left">
                  <div class="volume-text">
                    <h5>{{ block.settings.opt2_label | default: '2×' }}</h5>
                    <p>{{ block.settings.opt2_sub | default: '-10%' }}</p>
                  </div>
                </div>
                <div class="volume-price">
                  {%- assign price2 = product.price | times: 2 | times: 0.9 -%}
                  {{ price2 | money }}
                </div>
              </div>

              <!-- Option 3: Meilleure offre -->
              <div
                class="volume-card"
                role="radio"
                aria-checked="false"
                tabindex="0"
                onclick="selectVolume(3, this)"
                onkeydown="if(event.key==='Enter'||event.key===' '){event.preventDefault();selectVolume(3, this);}"
              >
                {% if block.settings.opt3_badge != blank %}
                  <span class="volume-card-badge">{{ block.settings.opt3_badge }}</span>
                {% endif %}
                <div class="volume-left">
                  <div class="volume-text">
                    <h5>{{ block.settings.opt3_label | default: '3×' }}</h5>
                    <p>{{ block.settings.opt3_sub | default: '-20%' }}</p>
                  </div>
