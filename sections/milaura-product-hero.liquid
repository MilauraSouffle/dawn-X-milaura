  }

  /* Bouton PRIORITAIRE */
  .milaura-add-btn {
    flex: 1;
    min-height: 48px; /* Hauteur standard CTA */
    border: none;
    cursor: pointer;
    white-space: nowrap !important;
    /* Style géré par .milaura-btn-gold global */
  }
  .milaura-add-btn:disabled { background: #ccc !important; cursor: not-allowed; box-shadow: none !important; }

  /* --- LUXE QUANTITY CAPSULE (Milaura Custom) --- */
  /* Reset complet des styles Dawn pour le sélecteur quantité */
  .milaura-quantity-capsule,
  .milaura-quantity-capsule.quantity-input {
    flex: 0 0 100px !important;
    width: 100px !important;
    min-width: 100px !important;
    max-width: 100px !important;
    height: 44px !important;
    min-height: 44px !important;
    background: #FFFFFF !important;
    border: 1px solid #E5E5E5 !important;
    border-radius: 50px !important;
    display: flex !important;
    align-items: center !important;
    justify-content: space-between !important;
    padding: 0 6px !important;
    transition: all 0.3s ease;
    box-sizing: border-box !important;
  }

  .milaura-quantity-capsule:hover {
    border-color: #C0A062 !important;
    box-shadow: 0 4px 12px rgba(192, 160, 98, 0.1);
  }

  /* Reset before/after pseudo-elements de Dawn */
  .milaura-quantity-capsule::before,
  .milaura-quantity-capsule::after,
  .milaura-quantity-capsule .quantity::before,
  .milaura-quantity-capsule .quantity::after {
    display: none !important;
    content: none !important;
  }

  .milaura-quantity-btn,
  .milaura-quantity-capsule button {
    width: 28px !important;
    height: 28px !important;
    min-width: 28px !important;
    max-width: 28px !important;
    border: none !important;
    background: transparent !important;
    cursor: pointer;
    display: flex !important;
    align-items: center !important;
    justify-content: center !important;
    color: #1a1a1a !important;
    transition: color 0.2s;
    padding: 0 !important;
    margin: 0 !important;
    font-size: 14px !important;
    flex-shrink: 0 !important;
  }

  .milaura-quantity-btn:hover,
  .milaura-quantity-capsule button:hover {
    color: #C0A062 !important;
    background: transparent !important;
  }

  .milaura-quantity-input,
  .milaura-quantity-capsule input {
    width: 32px !important;
    min-width: 32px !important;
    max-width: 32px !important;
    height: 100% !important;
    border: none !important;
    background: transparent !important;
    text-align: center !important;
    font-size: 14px !important;
    font-weight: 600 !important;
    color: #1a1a1a !important;
    padding: 0 !important;
    margin: 0 !important;
    -moz-appearance: textfield !important;
    box-shadow: none !important;
  }

  .milaura-quantity-input::-webkit-outer-spin-button,
  .milaura-quantity-input::-webkit-inner-spin-button,
  .milaura-quantity-capsule input::-webkit-outer-spin-button,
  .milaura-quantity-capsule input::-webkit-inner-spin-button {
    -webkit-appearance: none !important;
    margin: 0 !important;
  }

  .milaura-quantity-input:focus,
  .milaura-quantity-capsule input:focus {
    outline: none !important;
    box-shadow: none !important;
    background: transparent !important;
  }

  /* Mobile: encore plus compact */
  @media screen and (max-width: 480px) {
