  .product-form__quantity .quantity__button {
    width: 24px !important;
    height: 24px !important;
    color: var(--milaura-gold) !important;
    font-size: 14px !important;
    padding: 0 !important;
    background: transparent !important;
    display: flex !important;
    align-items: center;
