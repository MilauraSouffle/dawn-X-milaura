<script>
  (function () {
    const isDesktop = () => window.matchMedia('(min-width: 990px)').matches;

    /* ============================
     1. ZOOM ON HOVER (Desktop only)
     Click to toggle zoom, mouse tracks transform-origin
     ============================ */
    function initZoom() {
      const mainContainer = document.querySelector('.product__media-item:first-child .product-media-container');
      if (!mainContainer) return;

      mainContainer.addEventListener('click', function (e) {
        if (!isDesktop()) return;
        this.classList.toggle('is-zoomed');
      });

      mainContainer.addEventListener('mousemove', function (e) {
        if (!isDesktop() || !this.classList.contains('is-zoomed')) return;
        const rect = this.getBoundingClientRect();
        const x = ((e.clientX - rect.left) / rect.width) * 100;
        const y = ((e.clientY - rect.top) / rect.height) * 100;
        this.style.setProperty('--zoom-x', x + '%');
        this.style.setProperty('--zoom-y', y + '%');
      });

      mainContainer.addEventListener('mouseleave', function () {
        this.classList.remove('is-zoomed');
      });
    }

    /* ============================
     2. CLICKABLE THUMBNAILS (Desktop)
     Click a thumbnail to swap it with main image
     ============================ */
    function initThumbnails() {
      const mediaList = document.querySelector('.product__media-list');
      if (!mediaList) return;

      const items = mediaList.querySelectorAll('.product__media-item');
      if (items.length < 2) return;

      items.forEach(function (item, index) {
        if (index === 0) return; // Skip main image
        // Skip spotlight and video slides (handled separately)
        if (item.classList.contains('product__media-item--spotlight') || item.classList.contains('product__media-item--video-slide')) return;

        item.querySelector('.product-media-container').addEventListener('click', function (e) {
          if (!isDesktop()) return;
          e.preventDefault();

          const firstItem = items[0];
          const clickedItem = item;

          // Swap the image sources
          const mainImg = firstItem.querySelector('img.image-magnify-hover');
          const thumbImg = clickedItem.querySelector('img.image-magnify-hover');
          if (!mainImg || !thumbImg) return;

          // Swap src and srcset
          const tmpSrc = mainImg.src;
          const tmpSrcset = mainImg.srcset || '';
          const tmpAlt = mainImg.alt || '';

          mainImg.src = thumbImg.src;
          mainImg.srcset = thumbImg.srcset || '';
          mainImg.alt = thumbImg.alt || '';

          thumbImg.src = tmpSrc;
          thumbImg.srcset = tmpSrcset;
          thumbImg.alt = tmpAlt;

          // Remove zoom state
          firstItem.querySelector('.product-media-container').classList.remove('is-zoomed');
        });
      });
    }

    /* ============================
     3. DOTS + SLIDER SYNC (Mobile)
     Dots click → scroll to slide
     Scroll → highlight active dot
     ============================ */
    function initSliderNav() {
      var sliderComp = document.querySelector('.milaura-hero-gallery-column slider-component');
      if (!sliderComp) return;

      var slider = sliderComp.querySelector('[id^="Slider-"]');
      var dots = sliderComp.querySelectorAll('.slider-counter__link--dots');
      var slides = sliderComp.querySelectorAll('.product__media-item');

      if (!slider || dots.length < 2 || slides.length < 2) return;

      /* Dot click → scroll to slide */
      dots.forEach(function(dot) {
        dot.addEventListener('click', function(e) {
          e.preventDefault();
          var idx = parseInt(this.getAttribute('data-slide-index'), 10);
          if (isNaN(idx) || !slides[idx]) return;
          slider.scrollTo({ left: slides[idx].offsetLeft, behavior: 'smooth' });
        });
      });

      /* Scroll → update active dot */
      function updateActiveDot() {
        if (isDesktop()) return;
        var scrollLeft = slider.scrollLeft;
        var containerWidth = slider.clientWidth;
        var activeIndex = 0;
        var minDist = Infinity;

        slides.forEach(function(slide, i) {
          var center = slide.offsetLeft + slide.clientWidth / 2;
          var dist = Math.abs(center - (scrollLeft + containerWidth / 2));
          if (dist < minDist) {
            minDist = dist;
            activeIndex = i;
          }
        });

        dots.forEach(function(dot, i) {
          dot.classList.toggle('slider-counter__link--active', i === activeIndex);
        });
      }

      var scrollTimer;
      slider.addEventListener('scroll', function() {
        clearTimeout(scrollTimer);
        scrollTimer = setTimeout(updateActiveDot, 50);
      }, { passive: true });

      /* Set initial state */
      updateActiveDot();
    }

    /* Init on DOM ready */
    if (document.readyState === 'loading') {
      document.addEventListener('DOMContentLoaded', init);
    } else {
      init();
    }

    /* ============================
     4. SPOTLIGHT HOTSPOTS (Click toggle)
     On mobile: tooltip is moved to body to escape overflow/transform issues
     ============================ */
    function initSpotlightHotspots() {
      var hotspots = document.querySelectorAll('.milaura-hotspot');
      if (!hotspots.length) return;

      // Create mobile overlay container (appended to body to escape all overflow)
      var mobileOverlay = document.createElement('div');
      mobileOverlay.className = 'milaura-hotspot-mobile-overlay';
      mobileOverlay.style.cssText = 'display:none;position:fixed;bottom:80px;left:16px;right:16px;z-index:99999;pointer-events:auto;';
      mobileOverlay.innerHTML = '<div class="milaura-hotspot-mobile-overlay__card"></div>';
      document.body.appendChild(mobileOverlay);
      var overlayCard = mobileOverlay.querySelector('.milaura-hotspot-mobile-overlay__card');

      hotspots.forEach(function(hotspot) {
        var btn = hotspot.querySelector('.milaura-hotspot-btn');
        if (!btn) return;
        btn.addEventListener('click', function(e) {
          e.preventDefault();
          e.stopPropagation();

          var wasActive = hotspot.classList.contains('is-active');

          // Close all
          hotspots.forEach(function(h) { h.classList.remove('is-active'); });
          mobileOverlay.style.display = 'none';

          if (wasActive) return;

          hotspot.classList.add('is-active');

          // On mobile: show tooltip in body overlay instead
          if (!isDesktop()) {
            var tooltip = hotspot.querySelector('.milaura-hotspot-tooltip-content');
            if (tooltip) {
              overlayCard.innerHTML = tooltip.innerHTML;
              mobileOverlay.style.display = 'block';
            }
          }
        });
      });

      document.addEventListener('click', function(e) {
        if (mobileOverlay.contains(e.target)) return;
        hotspots.forEach(function(h) { h.classList.remove('is-active'); });
        mobileOverlay.style.display = 'none';
      });
    }

    /* ============================
     5. VIDEO BUBBLE (Click -> expand to 16:9 iframe)
     ============================ */
    function initVideoSlide() {
      var bubbles = document.querySelectorAll('.milaura-video-bubble');
      bubbles.forEach(function(bubble) {
        bubble.addEventListener('click', function() {
          var url = bubble.getAttribute('data-video-url');
          if (!url) return;
          var embedUrl = parseVideoUrl(url);
          if (!embedUrl) return;

          // Expand bubble to 16:9 player
          bubble.classList.add('milaura-video-bubble--playing');
          bubble.innerHTML = '<iframe src="' + embedUrl + '" allow="autoplay; fullscreen; picture-in-picture" allowfullscreen loading="lazy"></iframe>';
        });
      });
    }

    /* ============================
     6. MOBILE THUMBNAIL STRIP
     Click -> scroll to that slide
     Video thumbnail autoplay
     ============================ */
    function initMobileThumbStrip() {
      var strip = document.querySelector('.milaura-thumb-strip');
      if (!strip) return;

      var sliderComp = document.querySelector('.milaura-hero-gallery-column slider-component');
      if (!sliderComp) return;

      var slider = sliderComp.querySelector('[id^="Slider-"]');
      var slides = sliderComp.querySelectorAll('.product__media-item');
      var dots = sliderComp.querySelectorAll('.slider-counter__link--dots');
      var thumbs = strip.querySelectorAll('.milaura-thumb-strip__item');
      if (!slider || !slides.length || !thumbs.length) return;

      /* Click thumbnail → scroll to slide + update active states */
      thumbs.forEach(function(thumb) {
        thumb.addEventListener('click', function(e) {
          e.preventDefault();
          var idx = parseInt(this.getAttribute('data-slide-index'), 10);
          if (isNaN(idx) || !slides[idx]) return;

          /* If clicking video thumbnail, inject iframe into the video slide */
          if (thumb.classList.contains('milaura-thumb-strip__item--video')) {
            var videoSlide = slides[idx];
            var container = videoSlide ? videoSlide.querySelector('.milaura-video-main-container') : null;
            if (container && !container.querySelector('iframe')) {
              var url = container.getAttribute('data-video-url') || thumb.getAttribute('data-video-url');
              if (url) {
                var embedUrl = parseVideoUrl(url);
                if (embedUrl) {
                  container.innerHTML = '<iframe src="' + embedUrl + '" allow="autoplay; fullscreen; picture-in-picture" allowfullscreen style="position:absolute;top:0;left:0;width:100%;height:100%;border:none;border-radius:16px;"></iframe>';
                }
              }
            }
          }

          slider.scrollTo({ left: slides[idx].offsetLeft, behavior: 'smooth' });

          /* Update active thumb */
          thumbs.forEach(function(t) { t.classList.remove('is-active'); });
          thumb.classList.add('is-active');

          /* Update dots */
          dots.forEach(function(dot, i) {
            dot.classList.toggle('slider-counter__link--active', i === idx);
          });
        });
      });

      /* Sync thumb strip with scroll */
      var scrollTimer2;
      slider.addEventListener('scroll', function() {
        clearTimeout(scrollTimer2);
        scrollTimer2 = setTimeout(function() {
          if (isDesktop()) return;
          var scrollLeft = slider.scrollLeft;
          var containerWidth = slider.clientWidth;
          var activeIndex = 0;
          var minDist = Infinity;
          slides.forEach(function(slide, i) {
            var center = slide.offsetLeft + slide.clientWidth / 2;
            var dist = Math.abs(center - (scrollLeft + containerWidth / 2));
            if (dist < minDist) { minDist = dist; activeIndex = i; }
          });
          thumbs.forEach(function(t, i) {
            t.classList.toggle('is-active', i === activeIndex);
          });
        }, 50);
      }, { passive: true });

      /* Video thumbnail autoplay (small muted iframe) */
      var videoThumb = strip.querySelector('.milaura-thumb-strip__item--video');
      if (videoThumb) {
        var videoUrl = videoThumb.getAttribute('data-video-url');
        if (videoUrl) {
          var autoplayUrl = parseVideoUrl(videoUrl, true);
          if (autoplayUrl) {
            var iframe = document.createElement('iframe');
            iframe.src = autoplayUrl;
            iframe.allow = 'autoplay; encrypted-media';
            iframe.setAttribute('loading', 'lazy');
            iframe.setAttribute('tabindex', '-1');
            videoThumb.insertBefore(iframe, videoThumb.querySelector('.milaura-thumb-strip__video-overlay'));
            videoThumb.classList.add('has-autoplay');
          }
        }
      }
    }

    /* Video slide play button handler (mobile carousel) */
    function initVideoSlidePlay() {
      var playBtns = document.querySelectorAll('.milaura-video-main-play');
      playBtns.forEach(function(btn) {
        btn.addEventListener('click', function(e) {
          e.preventDefault();
          var container = btn.closest('.milaura-video-main-container');
          if (!container || container.querySelector('iframe')) return;
          var url = container.getAttribute('data-video-url');
          if (!url) return;
          var embedUrl = parseVideoUrl(url);
          if (!embedUrl) return;
          container.innerHTML = '<iframe src="' + embedUrl + '" allow="autoplay; fullscreen; picture-in-picture" allowfullscreen style="position:absolute;top:0;left:0;width:100%;height:100%;border:none;border-radius:16px;"></iframe>';
        });
      });
    }

    /* Parse YouTube/Vimeo URL to embed URL */
    function parseVideoUrl(url, muted) {
      var embedUrl = '';
      if (url.indexOf('youtube.com') !== -1 || url.indexOf('youtu.be') !== -1) {
        var match = url.match(/(?:youtube\.com\/(?:watch\?v=|embed\/|shorts\/)|youtu\.be\/)([^&\s?]+)/);
        if (match) {
          embedUrl = 'https://www.youtube.com/embed/' + match[1] + '?autoplay=1&rel=0';
          if (muted) embedUrl += '&mute=1&loop=1&playlist=' + match[1] + '&controls=0&showinfo=0&modestbranding=1';
        }
      } else if (url.indexOf('vimeo.com') !== -1) {
        var vimeoMatch = url.match(/vimeo\.com\/(\d+)/);
        if (vimeoMatch) {
          embedUrl = 'https://player.vimeo.com/video/' + vimeoMatch[1] + '?autoplay=1';
          if (muted) embedUrl += '&muted=1&loop=1&background=1';
        }
      }
      return embedUrl;
    }

    /* ============================
     7. SPOTLIGHT DESKTOP THUMBNAIL
     Move outside slider into thumbnail row + click to swap
     ============================ */
    function initSpotlightDesktop() {
      var desktopThumb = document.querySelector('.milaura-spotlight-desktop-thumb');
      if (!desktopThumb) return;

      var mediaList = document.querySelector('.product__media-list');
      if (!mediaList) return;

      // On desktop, move the spotlight thumbnail into the media list (as last child)
      // so it appears in the flex thumbnail row naturally
      function positionSpotlight() {
        if (isDesktop()) {
          if (desktopThumb.parentElement !== mediaList) {
            mediaList.appendChild(desktopThumb);
          }
        } else {
          // On mobile, move it back outside (hidden via CSS anyway)
          var galleryCol = document.querySelector('.milaura-hero-gallery-column');
          if (galleryCol && desktopThumb.parentElement !== galleryCol) {
            galleryCol.appendChild(desktopThumb);
          }
        }
      }

      positionSpotlight();
      window.addEventListener('resize', positionSpotlight);

      // Hide the spotlight <li> inside the slider on desktop
      var spotlightSlide = document.querySelector('.product__media-item--spotlight');
      if (spotlightSlide) {
        // Add CSS to hide it on desktop only (mobile still uses it)
        spotlightSlide.style.cssText += ';';
        var style = document.createElement('style');
        style.textContent = '@media(min-width:990px){.product__media-item--spotlight{display:none!important;}}';
        document.head.appendChild(style);
      }

      // Click handler: swap spotlight image with main image
      desktopThumb.addEventListener('click', function() {
        if (!isDesktop()) return;

        var firstItem = mediaList.querySelector('.product__media-item:first-child');
        if (!firstItem) return;
        var mainImg = firstItem.querySelector('img.image-magnify-hover');
        var spotlightImg = desktopThumb.querySelector('.milaura-spotlight-desktop-thumb__img');
        if (!mainImg || !spotlightImg) return;

        var tmpSrc = mainImg.src;
        var tmpSrcset = mainImg.srcset || '';
        var tmpAlt = mainImg.alt || '';

        mainImg.src = spotlightImg.src;
        mainImg.srcset = spotlightImg.srcset || '';
        mainImg.alt = spotlightImg.alt || 'Spotlight';

        spotlightImg.src = tmpSrc;
        spotlightImg.srcset = tmpSrcset;
        spotlightImg.alt = tmpAlt;

        firstItem.querySelector('.product-media-container').classList.remove('is-zoomed');
      });
    }

    function init() {
      initZoom();
      initThumbnails();
      initSliderNav();
      initSpotlightHotspots();
      initVideoSlide();
      initVideoSlidePlay();
      initMobileThumbStrip();
      initSpotlightDesktop();
    }
  })();
</script>

