  /* Lien "Lire la suite" - Style doré */
  .read-more-link {
    display: inline-block;
    margin-top: 8px;
    color: var(--milaura-gold, #C0A062) !important;
    font-weight: 600;
    font-size: 14px;
    text-decoration: none;
    transition: all 0.3s ease;
    cursor: pointer;
  }

  .read-more-link:hover {
    color: var(--milaura-gold-dark, #8F723A) !important;
    text-decoration: underline;
  }

  /* ===========================================
     SPOTLIGHT SLIDE — Hotspots interactifs
     =========================================== */
  .milaura-spotlight-slide-wrapper {
    position: relative;
    overflow: visible;
  }

  .milaura-spotlight-container {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
  }

  .milaura-spotlight-image {
    width: 100%;
    height: 100%;
    object-fit: contain;
    object-position: center center;
  }

  .milaura-hotspot {
    position: absolute;
    transform: translate(-50%, -50%);
    z-index: 2;
  }

  .milaura-hotspot-btn {
    position: relative;
    width: 32px;
    height: 32px;
    border-radius: 50%;
    background: var(--milaura-gold, #C0A062);
    border: 2px solid #fff;
    color: #fff;
    display: flex;
    align-items: center;
    justify-content: center;
    cursor: pointer;
    box-shadow: 0 4px 10px rgba(0,0,0,0.15);
    transition: transform 0.3s ease;
    padding: 0;
    z-index: 3;
  }

  .milaura-hotspot:hover .milaura-hotspot-btn,
  .milaura-hotspot.is-active .milaura-hotspot-btn {
    transform: scale(1.15);
    background: var(--milaura-gold-dark, #8F723A);
  }

  .milaura-hotspot-inner {
    font-size: 14px;
    line-height: 1;
    font-weight: bold;
  }

  .milaura-hotspot-pulse {
    position: absolute;
    top: 0; left: 0;
    width: 100%; height: 100%;
    border-radius: 50%;
    background: var(--milaura-gold, #C0A062);
    animation: hotspotPulse 2s infinite cubic-bezier(0.4, 0, 0.2, 1);
    z-index: -1;
  }

  @keyframes hotspotPulse {
    0% { transform: scale(1); opacity: 0.8; }
    100% { transform: scale(2.2); opacity: 0; }
  }

  .milaura-hotspot-tooltip {
    position: absolute;
    bottom: calc(100% + 15px);
    left: 50%;
    transform: translateX(-50%) translateY(10px);
    width: 240px;
    background: rgba(255, 255, 255, 0.97);
    backdrop-filter: blur(12px);
    -webkit-backdrop-filter: blur(12px);
    border: 1px solid rgba(192, 160, 98, 0.2);
    border-radius: 12px;
    box-shadow: 0 10px 25px rgba(0,0,0,0.1);
    opacity: 0;
    visibility: hidden;
    transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
    z-index: 4;
    pointer-events: none;
  }

  .milaura-hotspot-tooltip::after {
    content: '';
    position: absolute;
    top: 100%;
    left: 50%;
    transform: translateX(-50%);
    border-width: 8px;
    border-style: solid;
    border-color: rgba(255, 255, 255, 0.97) transparent transparent transparent;
  }

  .milaura-hotspot-tooltip-content {
    padding: 16px;
    text-align: center;
  }

  .milaura-hotspot-tooltip h4 {
    margin: 0 0 8px 0;
    font-family: var(--milaura-font-heading);
    font-size: 15px;
    font-weight: 600;
    color: var(--milaura-text, #000);
  }

  .milaura-hotspot-tooltip .rte p {
    margin: 0;
    font-family: var(--milaura-font-body);
    font-size: 13px;
    line-height: 1.4;
    color: var(--milaura-text-light, #666);
  }

  .milaura-hotspot:hover .milaura-hotspot-tooltip,
  .milaura-hotspot.is-active .milaura-hotspot-tooltip {
    opacity: 1;
    visibility: visible;
    transform: translateX(-50%) translateY(0);
    pointer-events: auto;
  }

  /* Mobile: hide CSS tooltip (JS overlay used instead) */
  @media screen and (max-width: 989px) {
    .milaura-hotspot-tooltip {
      display: none !important;
    }
  }

  /* Mobile overlay card (appended to body via JS) */
  .milaura-hotspot-mobile-overlay__card {
    background: rgba(255, 255, 255, 0.97);
    backdrop-filter: blur(12px);
    -webkit-backdrop-filter: blur(12px);
    border: 1px solid rgba(192, 160, 98, 0.2);
    border-radius: 12px;
    box-shadow: 0 10px 25px rgba(0, 0, 0, 0.1);
    padding: 16px;
    text-align: center;
    max-height: 40vh;
    overflow-y: auto;
  }

  .milaura-hotspot-mobile-overlay__card h4 {
    margin: 0 0 8px 0;
    font-family: var(--milaura-font-heading);
    font-size: 15px;
    font-weight: 600;
    color: var(--milaura-text, #000);
  }

  .milaura-hotspot-mobile-overlay__card .rte p,
  .milaura-hotspot-mobile-overlay__card p {
    margin: 0;
    font-family: var(--milaura-font-body);
    font-size: 13px;
    line-height: 1.5;
    color: var(--milaura-text-light, #666);
  }

  /* Tablette: tooltip position ajustee */
  @media screen and (min-width: 750px) and (max-width: 989px) {
    .milaura-hotspot-mobile-overlay {
      left: 10% !important;
      right: 10% !important;
    }
  }

  /* ===========================================
     VIDEO BUBBLE — Bulle flottante
     =========================================== */
  .milaura-video-bubble-wrapper {
    display: flex;
    justify-content: center;
    align-items: center;
    padding: 12px 0;
  }

  .milaura-video-bubble {
    width: 140px;
    height: 140px;
    border-radius: 50%;
    overflow: hidden;
    position: relative;
    cursor: pointer;
    box-shadow: 0 8px 30px rgba(192, 160, 98, 0.3);
    border: 3px solid rgba(192, 160, 98, 0.4);
    transition: transform 0.3s ease, box-shadow 0.3s ease;
    flex-shrink: 0;
  }

  .milaura-video-bubble:hover {
    transform: scale(1.05);
    box-shadow: 0 12px 40px rgba(192, 160, 98, 0.45);
    border-color: var(--milaura-gold, #C0A062);
  }

  .milaura-video-bubble__poster {
    width: 100%;
    height: 100%;
    position: relative;
    display: flex;
    align-items: center;
    justify-content: center;
    background: var(--milaura-beige, #FDFBF7);
  }

  .milaura-video-bubble__poster-img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .milaura-video-bubble__play {
    position: absolute;
    top: 50%; left: 50%;
    transform: translate(-50%, -50%);
    background: none;
    border: none;
    cursor: pointer;
    transition: transform 0.3s ease;
    z-index: 2;
  }

  .milaura-video-bubble:hover .milaura-video-bubble__play {
    transform: translate(-50%, -50%) scale(1.1);
  }

  .milaura-video-bubble__poster--empty {
    flex-direction: column;
    gap: 6px;
  }

  .milaura-video-bubble__label {
    font-family: var(--milaura-font-body);
    font-size: 11px;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: var(--milaura-text-light, #666);
  }

  /* Bulle video iframe (apres clic) */
  .milaura-video-bubble--playing {
    width: 100%;
    height: 0;
    padding-top: 56.25%;
    border-radius: 16px;
    border: 1px solid rgba(192, 160, 98, 0.2);
  }

  .milaura-video-bubble--playing iframe {
    position: absolute;
    top: 0; left: 0;
    width: 100%;
    height: 100%;
    border: none;
    border-radius: 16px;
  }

  /* Mobile : bulle plus petite, centree */
  @media screen and (max-width: 749px) {
    .milaura-video-bubble {
      width: 90px;
      height: 90px;
    }
  }

  /* Desktop : bulle plus grande, bien centree */
  @media screen and (min-width: 990px) {
    .milaura-video-bubble-wrapper {
      padding: 4px 0;
    }

    .milaura-video-bubble {
      width: 180px;
      height: 180px;
      border-width: 3px;
    }

    .milaura-video-bubble--playing {
      width: 100%;
      height: 0;
      padding-top: 56.25%;
      border-radius: 16px;
    }
  }

  /* Dot spotlight & video */
  .dot--spotlight {
    background: var(--milaura-gold, #C0A062) !important;
  }

  .dot--video {
    background: #E74C3C !important;
  }

  /* ===========================================
     VIDEO SLIDE — Main carousel (mobile)
     =========================================== */
  .milaura-video-main-container {
    display: flex;
    align-items: center;
    justify-content: center;
    background: var(--milaura-beige, #FDFBF7);
  }

  .milaura-video-main-poster {
    position: absolute;
    top: 0; left: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .milaura-video-main-play {
    position: absolute;
    top: 50%; left: 50%;
    transform: translate(-50%, -50%);
    background: none;
    border: none;
    cursor: pointer;
    z-index: 2;
    transition: transform 0.3s ease;
  }

  .milaura-video-main-play:hover {
    transform: translate(-50%, -50%) scale(1.1);
  }

  .milaura-video-main-placeholder {
    position: absolute;
    top: 0; left: 0;
    width: 100%;
    height: 100%;
    display: flex;
    align-items: center;
    justify-content: center;
    background: var(--milaura-beige, #FDFBF7);
  }

  /* ===========================================
     VIDEO SLIDE — Desktop hidden, mobile visible
     =========================================== */
  @media screen and (min-width: 990px) {
    .product__media-item--video-slide {
      display: none !important;
    }
  }

  /* Video bubble — hidden on mobile (uses slide instead) */
  @media screen and (max-width: 989px) {
    .milaura-video-bubble-wrapper {
      display: none !important;
    }
  }

  /* ===========================================
     MOBILE THUMBNAIL STRIP
     =========================================== */
  .milaura-thumb-strip {
    display: flex;
    gap: 8px;
    overflow-x: auto;
    -webkit-overflow-scrolling: touch;
    scrollbar-width: none;
    padding: 10px 4px 4px;
    justify-content: center;
    flex-wrap: nowrap;
  }

  .milaura-thumb-strip::-webkit-scrollbar {
    display: none;
  }

  .milaura-thumb-strip__item {
    flex: 0 0 auto;
    width: 56px;
    height: 56px;
    border-radius: 8px;
    overflow: hidden;
    border: 2px solid transparent;
    background: var(--milaura-beige, #FDFBF7);
    cursor: pointer;
    position: relative;
    padding: 0;
    transition: border-color 0.2s ease, box-shadow 0.2s ease;
  }

  .milaura-thumb-strip__item.is-active {
    border-color: var(--milaura-gold, #C0A062);
    box-shadow: 0 2px 8px rgba(192, 160, 98, 0.3);
  }

  .milaura-thumb-strip__img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }

  .milaura-thumb-strip__item--video {
    position: relative;
  }

  .milaura-thumb-strip__video-overlay {
    position: absolute;
    top: 0; left: 0;
    width: 100%;
    height: 100%;
    display: flex;
    align-items: center;
    justify-content: center;
    background: rgba(0, 0, 0, 0.15);
    pointer-events: none;
  }

  .milaura-thumb-strip__item--video iframe {
    position: absolute;
    top: 0; left: 0;
    width: 100%;
    height: 100%;
    border: none;
    pointer-events: none;
  }

  .milaura-thumb-strip__item--video.has-autoplay .milaura-thumb-strip__video-overlay {
    background: transparent;
  }

  .milaura-thumb-strip__item--video.has-autoplay .milaura-thumb-strip__video-overlay svg {
    opacity: 0;
    transition: opacity 0.2s ease;
  }

  .milaura-thumb-strip__item--video:hover .milaura-thumb-strip__video-overlay svg {
    opacity: 1;
  }

  /* Desktop : hide thumb strip (thumbnails are already inline) */
  @media screen and (min-width: 990px) {
    .milaura-thumb-strip {
      display: none;
    }
  }

  /* ===========================================
     SPOTLIGHT DESKTOP THUMBNAIL (outside slider)
     =========================================== */
  .milaura-spotlight-desktop-thumb {
    display: none; /* Hidden on mobile — mobile uses carousel slide */
  }

  @media screen and (min-width: 990px) {
    .milaura-spotlight-desktop-thumb {
      display: inline-block;
      cursor: pointer;
      transition: box-shadow 0.3s ease, border-color 0.3s ease;
    }

    .milaura-spotlight-desktop-thumb__img-wrap {
      width: 80px;
      height: 80px;
      border-radius: 10px;
      overflow: hidden;
      border: 2px solid rgba(192, 160, 98, 0.3);
      position: relative;
      background: var(--milaura-beige, #FDFBF7);
    }

    .milaura-spotlight-desktop-thumb:hover .milaura-spotlight-desktop-thumb__img-wrap {
      border-color: var(--milaura-gold, #C0A062);
      box-shadow: 0 4px 16px rgba(192, 160, 98, 0.25);
    }

    .milaura-spotlight-desktop-thumb__img {
      width: 100%;
      height: 100%;
      object-fit: cover;
      display: block;
    }
  }

  @media (prefers-reduced-motion: reduce) {
    *, *::before, *::after {
      transition: none !important;
      animation: none !important;
    }
  }

  /* ===========================================
     SCRATCH-TO-REVEAL (Cartes a gratter) - Premium
     =========================================== */

  /* Wrapper grid-area pour le scratch complet */
  .milaura-scratch-zone {
    grid-area: scratch;
    width: 100%;
  }

  /* ===========================================
     BUNDLE SELECTOR (au-dessus du scratch)
     =========================================== */
  .milaura-bundle-selector {
    width: 100%;
    margin-bottom: 20px;
    background: linear-gradient(180deg, rgba(255, 252, 245, 0.88), rgba(255, 255, 255, 0.95));
    border: 1px solid rgba(192, 160, 98, 0.18);
    border-radius: 16px;
    padding: 16px;
    box-shadow: 0 8px 24px rgba(26, 26, 46, 0.06);
  }

  .milaura-bundle-header {
    text-align: center;
    margin-bottom: 14px;
  }

  .milaura-bundle-title {
    font-family: 'Playfair Display', serif;
    font-size: 1.34rem;
    font-weight: 600;
    color: var(--milaura-text, #000);
    margin: 0 0 7px;
    line-height: 1.2;
  }

  .milaura-bundle-subtitle {
    font-family: 'Lato', sans-serif;
    font-size: 0.92rem;
    color: #555;
    margin: 0 auto;
    line-height: 1.38;
    max-width: 540px;
  }

  .milaura-bundle-tiers {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 10px;
    position: relative;
  }

  .milaura-bundle-tier {
    background: #fff;
    border: 2px solid rgba(192, 160, 98, 0.18);
    border-radius: 14px;
    padding: 14px 8px 12px;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: space-between;
    text-align: center;
    cursor: default;
    position: relative;
    transition: border-color 0.2s ease, background 0.2s ease, box-shadow 0.2s ease, transform 0.2s ease;
    min-height: 130px;
  }

  .milaura-bundle-tier.is-complete,
  .milaura-bundle-tier.is-current {
    background: linear-gradient(180deg, #FFFCF5, var(--milaura-beige, #FDFBF7));
    border-color: var(--milaura-gold, #C0A062);
    box-shadow: 0 6px 18px rgba(192, 160, 98, 0.18);
  }

  .milaura-bundle-tier.is-current {
    transform: translateY(-2px);
  }

  .milaura-bundle-tier.is-locked {
    opacity: 0.7;
  }

  .milaura-bundle-badge {
    position: absolute;
    top: -10px;
    left: 50%;
    transform: translateX(-50%);
    background: linear-gradient(135deg, #1a1a2e, #2d2d44);
    color: var(--milaura-gold-light, #E6C88B);
    font-family: 'Lato', sans-serif;
    font-size: 0.58rem;
    font-weight: 700;
    padding: 4px 10px;
    border-radius: 10px;
    letter-spacing: 0.5px;
    text-transform: uppercase;
    white-space: nowrap;
    box-shadow: 0 3px 8px rgba(26, 26, 46, 0.25);
  }

  .milaura-bundle-tier-left {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 6px;
    width: 100%;
  }

  .milaura-bundle-tier-icon {
    width: 40px;
    height: 40px;
    background: var(--milaura-beige, #FDFBF7);
    border-radius: 10px;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 1.4rem;
    flex-shrink: 0;
    transition: background 0.2s ease;
  }

  .milaura-bundle-tier.is-complete .milaura-bundle-tier-icon,
  .milaura-bundle-tier.is-current .milaura-bundle-tier-icon {
    background: #fff;
    box-shadow: 0 2px 6px rgba(192, 160, 98, 0.18);
  }

  .milaura-bundle-tier-text {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 2px;
  }

  .milaura-bundle-tier-label {
    font-family: 'Playfair Display', serif;
    font-size: 1.1rem;
    font-weight: 700;
    color: var(--milaura-text, #000);
    line-height: 1.15;
  }

  .milaura-bundle-tier-sub {
    font-family: 'Lato', sans-serif;
    font-size: 0.8rem;
    color: var(--milaura-gold-dark, #8F723A);
    font-style: italic;
    line-height: 1.25;
    margin-top: 3px;
  }

  .milaura-bundle-tier-price {
    text-align: center;
    margin-top: 8px;
  }

  .milaura-bundle-tier-current {
    font-family: 'Lato', sans-serif;
    font-size: 1.15rem;
    font-weight: 800;
    color: var(--milaura-text, #000);
    line-height: 1.1;
  }

  .milaura-bundle-tier-current::before {
    content: 'Palier ';
    font-weight: 600;
    color: var(--milaura-gold-dark, #8F723A);
  }

  .milaura-bundle-tier-compare {
    font-family: 'Lato', sans-serif;
    font-size: 0.7rem;
    color: #aaa;
    text-decoration: line-through;
    margin-top: 1px;
  }

  .milaura-cart-progress {
    margin-top: 14px;
    padding: 12px 12px 10px;
    border-radius: 14px;
    background: rgba(255, 255, 255, 0.66);
    border: 1px solid rgba(26, 26, 46, 0.08);
  }

  .milaura-cart-progress__track {
    width: 100%;
    height: 8px;
    border-radius: 999px;
    overflow: hidden;
    background: rgba(26, 26, 46, 0.1);
    box-shadow: inset 0 1px 2px rgba(26, 26, 46, 0.08);
  }

  .milaura-cart-progress__fill {
    display: block;
    width: 0%;
    height: 100%;
    border-radius: inherit;
    background: linear-gradient(90deg, {{ section.settings.progress_color_start | default: '#4C6780' }} 0%, {{ section.settings.progress_color_mid | default: '#1a1a2e' }} 58%, {{ section.settings.progress_color_end | default: '#C0A062' }} 100%);
    box-shadow: 0 0 12px rgba(26, 26, 46, 0.28);
    transition: width 0.35s ease;
  }

  .milaura-cart-progress__text {
    margin: 8px 0 0;
    font-family: 'Lato', sans-serif;
    font-size: 0.78rem;
    font-weight: 800;
    line-height: 1.3;
    color: #1a1a2e;
    text-align: center;
  }

  @media screen and (max-width: 749px) {
    .milaura-bundle-tiers {
      gap: 8px;
    }
    .milaura-bundle-tier {
      padding: 14px 8px 12px;
      min-height: 135px;
    }
    .milaura-bundle-tier-icon {
      width: 36px;
      height: 36px;
      font-size: 1.2rem;
    }
    .milaura-bundle-tier-label {
      font-size: 0.98rem;
    }
    .milaura-bundle-tier-sub {
      font-size: 0.72rem;
    }
    .milaura-bundle-tier-current {
      font-size: 1rem;
    }
    .milaura-bundle-tier-compare {
      font-size: 0.72rem;
    }
    .milaura-bundle-badge {
      font-size: 0.58rem;
      padding: 4px 10px;
    }
    .milaura-bundle-title {
      font-size: 1.2rem;
    }
    .milaura-bundle-subtitle {
      font-size: 0.82rem;
      line-height: 1.32;
    }
    .milaura-cart-progress {
      margin-top: 12px;
      padding: 10px 10px 9px;
    }
    .milaura-cart-progress__text {
      font-size: 0.72rem;
    }
  }

  .milaura-offer-contrast {
    width: 100%;
    margin-bottom: 18px;
    padding: 16px;
    border: 1px solid rgba(192, 160, 98, 0.2);
    border-radius: 12px;
    background: linear-gradient(180deg, rgba(255, 252, 245, 0.94), rgba(255, 255, 255, 0.98));
    box-shadow: 0 8px 24px rgba(26, 26, 46, 0.06);
  }

  .milaura-offer-contrast__header {
    text-align: center;
    margin-bottom: 14px;
  }

  .milaura-offer-contrast__eyebrow {
    margin: 0 0 6px;
    font-family: 'Lato', sans-serif;
    font-size: 0.72rem;
    font-weight: 800;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--milaura-gold-dark, #8F723A);
  }

  .milaura-offer-contrast__title {
    margin: 0 0 7px;
    font-family: 'Playfair Display', serif;
    font-size: 1.28rem;
    font-weight: 700;
    line-height: 1.18;
    color: var(--milaura-text, #000);
  }

  .milaura-offer-contrast__subtitle {
    max-width: 560px;
    margin: 0 auto;
    font-family: 'Lato', sans-serif;
    font-size: 0.9rem;
    line-height: 1.4;
    color: #555;
  }

  .milaura-offer-contrast__grid {
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: 9px;
  }

  .milaura-offer-contrast__card {
    position: relative;
    min-height: 138px;
    display: flex;
    flex-direction: column;
    justify-content: space-between;
    gap: 8px;
    padding: 12px 10px;
    border: 1px solid rgba(26, 26, 46, 0.12);
    border-radius: 8px;
    background: #fff;
    text-align: center;
  }

  .milaura-offer-contrast__card--featured {
    border: 2px solid var(--milaura-gold, #C0A062);
    background: linear-gradient(180deg, #fffaf0, #ffffff);
    box-shadow: 0 10px 24px rgba(192, 160, 98, 0.16);
    transform: translateY(-2px);
  }

  .milaura-offer-contrast__step {
    width: 32px;
    height: 32px;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    margin: 0 auto;
    border-radius: 50%;
    background: #1a1a2e;
    color: #fff;
    font-family: 'Lato', sans-serif;
    font-weight: 900;
    font-size: 0.95rem;
  }

  .milaura-offer-contrast__card--featured .milaura-offer-contrast__step {
    background: var(--milaura-gold, #C0A062);
  }

  .milaura-offer-contrast__badge {
    position: absolute;
    top: -10px;
    left: 50%;
    transform: translateX(-50%);
    padding: 4px 9px;
    border-radius: 999px;
    background: #1a1a2e;
    color: var(--milaura-gold-light, #E6C88B);
    font-family: 'Lato', sans-serif;
    font-size: 0.58rem;
    font-weight: 900;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    white-space: nowrap;
  }

  .milaura-offer-contrast__label {
    margin: 0;
    font-family: 'Playfair Display', serif;
    font-size: 1rem;
    font-weight: 700;
    line-height: 1.15;
    color: var(--milaura-text, #000);
  }

  .milaura-offer-contrast__reward {
    margin: 0;
    font-family: 'Lato', sans-serif;
    font-size: 0.78rem;
    font-weight: 800;
    line-height: 1.3;
    color: var(--milaura-gold-dark, #8F723A);
  }

  .milaura-offer-contrast__note {
    margin: 0;
    padding-top: 9px;
    border-top: 1px solid rgba(192, 160, 98, 0.2);
    font-family: 'Lato', sans-serif;
    font-size: 0.76rem;
    line-height: 1.35;
    color: #666;
  }

  .milaura-offer-contrast__hidden-engine {
    display: none !important;
  }

  .milaura-reward-preview {
    position: relative;
    width: 100%;
    margin-bottom: 16px;
    padding: 16px;
    overflow: hidden;
    border: 1px solid rgba(192, 160, 98, 0.22);
    border-radius: 16px;
    background:
      radial-gradient(circle at 88% 12%, rgba(230, 200, 139, 0.24), transparent 28%),
      linear-gradient(145deg, rgba(255, 255, 255, 0.96), rgba(255, 250, 240, 0.92));
    box-shadow: 0 14px 34px rgba(26, 26, 46, 0.08);
  }

  .milaura-reward-preview::before {
    content: "";
    position: absolute;
    inset: 0;
    background:
      linear-gradient(120deg, transparent 0%, rgba(255, 255, 255, 0.64) 42%, transparent 68%);
    opacity: 0.54;
    transform: translateX(-62%) skewX(-14deg);
    animation: milaura-reward-preview-sheen 5.4s ease-in-out infinite;
    pointer-events: none;
  }

  @keyframes milaura-reward-preview-sheen {
    0%, 42% { transform: translateX(-62%) skewX(-14deg); opacity: 0; }
    58% { opacity: 0.58; }
    100% { transform: translateX(72%) skewX(-14deg); opacity: 0; }
