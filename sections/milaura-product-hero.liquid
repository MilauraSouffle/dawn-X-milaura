    .milaura-quantity-capsule input {
      width: 28px !important;
      min-width: 28px !important;
      font-size: 13px !important;
    }
  }

  /* ===========================================
     TRUST BADGES - Design Premium 2026
     =========================================== */
  .milaura-trust-badges {
    margin-top: 16px; /* FIX: réduit de 28px à 16px */
    padding-top: 14px; /* FIX: réduit de 20px à 14px */
