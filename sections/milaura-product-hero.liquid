{%- comment %}
  Metafield badges removed - keeping only variant bubbles
  Original metafields (scent_notes, stone_benefits) can still be used
  for recommendations/classification elsewhere
{%- endcomment %}

{% style %}
  .section-{{ section.id }}-padding {
    padding-top: {{ section.settings.padding_top | times: 0.75 | round: 0 }}px;
    padding-bottom: {{ section.settings.padding_bottom | times: 0.75 | round: 0 }}px;
  }

  @media screen and (min-width: 750px) {
    .section-{{ section.id }}-padding {
      padding-top: {{ section.settings.padding_top }}px;
      padding-bottom: {{ section.settings.padding_bottom }}px;
    }
  }

  /* TABLETTE + DESKTOP : padding interne seulement, espacement gere par milaura.css */
  @media screen and (min-width: 750px) {
    .section-{{ section.id }}-padding {
      padding-top: 0;
      padding-bottom: 0;
    }
  }

  /* ===========================================
     LAYOUT GENERAL
     =========================================== */
  .milaura-hero-wrapper {
    display: flex;
    flex-direction: column;
    gap: 16px;
    width: 100%;
    max-width: 100%;
    overflow-x: visible; /* FIX: permettre au cadre doré d'être visible */
    padding: 16px 16px; /* Marge top/bottom pour aerer le contenu vs cadre dore */
    box-sizing: border-box;
  }

  /* TABLETTE : Resserrer les espacements + fix cadre */
  @media screen and (min-width: 750px) and (max-width: 989px) {
    .milaura-hero-wrapper {
      gap: 6px; /* Écart minimal entre les groupes */
      padding: 18px 20px; /* Marge top/bottom pour aerer + padding lateral cadre */
      overflow: visible; /* FIX: cadre visible */
    }

    .milaura-hero-header-group {
      margin-bottom: 0;
      padding-top: 0;
      padding-bottom: 4px;
    }

    /* Volume Bundle - en-têtes intégrés */
    .volume-section-title {
      margin: 0 0 10px 0;
    }

    .milaura-volume-grid {
      margin-top: 8px; /* Plus besoin d'espace pour badges flottants */
    }

    .volume-card {
      padding: 0; /* Géré par les sous-éléments */
    }

    .volume-card-badge {
      font-size: 9px;
      min-height: 32px; /* Même hauteur fixe */
      padding: 4px 8px;
    }

    .volume-left {
      padding: 12px 8px 3px;
    }

    .volume-price {
      padding: 3px 8px 12px;
    }
  }

  /* --- GROUPE 1: Header (mobile order 2 : apres la galerie) --- */
  .milaura-hero-header-group {
    order: 2;
    text-align: center;
    width: 100%;
  }

  /* --- GROUPE 2: Media Gallery (mobile order 1 : en premier) --- */
  .milaura-hero-gallery-column {
    order: 1;
    width: 100%;
    max-width: 100%;
    margin-bottom: 8px;
    overflow: hidden;
    border-radius: 12px;
    box-sizing: border-box;
  }

  /* Container pour positionner l'overlay sur l'image principale */
  .milaura-hero-gallery-column slider-component {
    position: relative;
    display: block;
    width: 100%;
    overflow: hidden;
  }

  /* Slider Mobile — Override Dawn's component-slider defaults */
  .product__media-list {
    display: flex;
    gap: 0;
    overflow-x: auto;
    scroll-snap-type: x mandatory;
    scroll-padding-left: 0;
    padding: 0;
    margin: 0;
    list-style: none;
    -webkit-overflow-scrolling: touch;
    scrollbar-width: none; /* Firefox */
    width: 100%;
  }

  .product__media-list::after {
    content: none; /* Remove Dawn's 1.5rem spacer */
  }

  .product__media-list::-webkit-scrollbar {
    display: none; /* Chrome/Safari */
  }

  .product__media-item {
    flex: 0 0 100%;
    min-width: 100%;
    max-width: 100%;
    scroll-snap-align: center;
    overflow: hidden;
    position: relative;
    box-sizing: border-box;
  }

  .product-media-container {
    position: relative;
    width: 100%;
    padding-top: 100%; /* Carré par défaut */
    background: var(--milaura-beige, #FDFBF7);
    overflow: hidden; /* FIX: clip image to border-radius on all corners */
    border-radius: 12px;
  }

  .product-media-container img,
  .product-media-container video,
  .product-media-container iframe {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center center;
  }

  /* Mobile & Tablette: image entière visible et centrée */
  @media screen and (max-width: 989px) {
    .product-media-container img {
      object-fit: contain;
      object-position: center center;
    }
  }

  /* Fleches Navigation (Mobile/Tablette) */
  .slider-button {
    position: absolute;
    top: 50%;
    transform: translateY(-50%);
    z-index: 10;
    width: 40px;
    height: 40px;
    border-radius: 50%;
    border: none;
    background: rgba(255, 255, 255, 0.85);
    backdrop-filter: blur(8px);
    -webkit-backdrop-filter: blur(8px);
    box-shadow: 0 2px 12px rgba(0, 0, 0, 0.1);
    color: var(--milaura-gold-dark, #8F723A);
    cursor: pointer;
    display: flex;
    align-items: center;
    justify-content: center;
    transition: all 0.25s ease;
    padding: 0;
  }
  .slider-button:hover {
    background: rgba(255, 255, 255, 0.95);
    box-shadow: 0 4px 16px rgba(192, 160, 98, 0.3);
    transform: translateY(-50%) scale(1.05);
  }
  .slider-button:active {
    transform: translateY(-50%) scale(0.95);
  }
  .slider-button[disabled] {
    opacity: 0.3;
    cursor: default;
    pointer-events: none;
  }
  .slider-button--prev {
    left: 10px;
  }
  .slider-button--next {
    right: 10px;
  }

  /* Pagination Mobile (Dots) */
  .slider-buttons {
    display: flex;
    justify-content: center;
    align-items: center;
    gap: 8px;
    margin-top: 10px;
    margin-bottom: 10px;
  }

  .slider-counter__link--dots {
    background: none;
    border: none;
    padding: 4px;
    cursor: pointer;
    -webkit-tap-highlight-color: transparent;
  }

  .slider-counter__link--dots .dot {
    width: 8px;
    height: 8px;
    border-radius: 50%;
    background: #e0e0e0;
    transition: all 0.3s;
    display: block;
  }

  .slider-counter__link--active .dot {
    background: var(--milaura-gold);
    transform: scale(1.3);
  }

  /* --- BADGES METAFIELDS PRODUIT --- */
  .milaura-meta-badges {
    display: flex;
    flex-wrap: wrap;
    gap: 8px;
    padding: 0;
  }

  .milaura-meta-badges--product {
    justify-content: center;
    align-items: center;
    row-gap: 6px;
    margin: 0 0 12px;
  }

  .milaura-meta-badge {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    background: rgba(255, 255, 255, 0.8);
    backdrop-filter: blur(8px);
    -webkit-backdrop-filter: blur(8px);
    border: 1px solid rgba(192, 160, 98, 0.2);
    border-radius: 30px;
    padding: 6px 14px;
    font-family: 'Lato', sans-serif;
    font-size: 0.8rem;
    font-weight: 600;
    color: var(--milaura-text);
    letter-spacing: 0.3px;
    text-transform: capitalize;
    white-space: nowrap;
  }

  .milaura-meta-badge svg {
    flex-shrink: 0;
    color: var(--milaura-gold);
  }

  .milaura-meta-badge--gold {
    background: linear-gradient(135deg, rgba(192, 160, 98, 0.15), rgba(230, 200, 139, 0.15));
    border-color: rgba(192, 160, 98, 0.35);
    color: var(--milaura-gold-dark);
  }

  .milaura-meta-badge--gold svg {
    color: var(--milaura-gold);
  }

  .milaura-meta-badge__marquee-copy {
    display: none;
  }

  @keyframes milauraVertusMarquee {
    to {
      transform: translateX(calc(-50% - 12px));
    }
  }

  @media screen and (max-width: 749px) {
    .milaura-meta-badges--product {
      max-width: 100%;
      overflow: hidden;
    }

    .milaura-meta-badges--product .milaura-meta-badge--vertus {
      max-width: min(100%, calc(100vw - 32px));
      overflow: hidden;
      box-sizing: border-box;
      justify-content: flex-start;
    }

    .milaura-meta-badge--vertus .milaura-meta-badge__marquee {
      display: block;
      flex: 1 1 auto;
      min-width: 0;
      overflow: hidden;
      text-overflow: ellipsis;
      -webkit-mask-image: linear-gradient(90deg, transparent 0, #000 12px, #000 calc(100% - 18px), transparent 100%);
      mask-image: linear-gradient(90deg, transparent 0, #000 12px, #000 calc(100% - 18px), transparent 100%);
    }

    .milaura-meta-badge--vertus-scroll .milaura-meta-badge__marquee-inner {
      display: inline-flex;
      width: max-content;
      gap: 24px;
      animation: milauraVertusMarquee 18s linear infinite;
    }

    .milaura-meta-badge--vertus-scroll .milaura-meta-badge__marquee-copy {
      display: inline;
    }
  }

  @media screen and (max-width: 749px) and (prefers-reduced-motion: reduce) {
    .milaura-meta-badge--vertus-scroll .milaura-meta-badge__marquee {
      overflow-x: auto;
      -webkit-overflow-scrolling: touch;
      scrollbar-width: none;
    }

    .milaura-meta-badge--vertus-scroll .milaura-meta-badge__marquee::-webkit-scrollbar {
      display: none;
    }

    .milaura-meta-badge--vertus-scroll .milaura-meta-badge__marquee-inner {
      animation: none;
      transform: none;
    }

    .milaura-meta-badge--vertus-scroll .milaura-meta-badge__marquee-copy {
      display: none;
    }
  }

  @media screen and (max-width: 480px) {
    .milaura-meta-badges--product {
      gap: 6px;
      margin-bottom: 10px;
    }
    .milaura-meta-badge {
      padding: 5px 10px;
      font-size: 0.72rem;
    }
    .milaura-meta-badge svg {
      width: 12px;
      height: 12px;
    }
  }

  /* --- GROUPE 3: Actions --- */
  .milaura-hero-actions-group {
    order: 3;
    width: 100%;
  }

  /* RIGHT COL WRAPPER : sur mobile, display:contents laisse header+actions
     etre direct children du wrapper flex et garder leurs orders (2 et 3).
     Sur desktop, override en display:flex via grid-area rightcol. */
  .milaura-hero-rightcol {
    display: contents;
  }

  /* DESKTOP MEDIA GRID (≥ 990px) */
  @media screen and (min-width: 990px) {
    .milaura-hero-wrapper {
      display: grid;
      grid-template-columns: 1fr 0.8fr;
      grid-template-areas:
        "gallery header"
        "gallery video-bubble"
        "gallery actions"
        "scratch scratch";
      gap: 16px;
      padding: 22px 16px; /* Marge top/bottom desktop pour aerer vs cadre dore */
      overflow: visible;
      align-items: start;
    }

    .milaura-video-bubble-wrapper {
      grid-area: video-bubble;
      /* No justify-self: center — wrapper stretches to fill grid column.
         Bubble is centered via flex justify-content on the wrapper. */
    }

    .milaura-hero-header-group {
      grid-area: header;
      text-align: left;
      position: static !important;
      background: transparent !important;
      border: none !important;
      padding: 0 !important;
      margin-bottom: 0;
    }

    .milaura-hero-actions-group {
      grid-area: actions;
      position: sticky;
      top: calc(var(--header-height, 80px) + 20px);
      background: rgba(255, 255, 255, 0.6);
      backdrop-filter: blur(10px);
      border: 1px solid rgba(192, 160, 98, 0.1);
      border-radius: 16px;
      padding: 18px 20px; /* Équilibré */
    }

    /* Grille Media Desktop */
    .milaura-hero-gallery-column {
      grid-area: gallery;
      margin: 0;
      overflow: visible;
      border-radius: 0;
    }

    .product__media-list {
      display: flex;
      flex-wrap: wrap;
      gap: 10px;
      overflow: visible;
      scroll-snap-type: none;
      padding: 0;
    }

    /* Image principale : pleine largeur */
    .product__media-item:first-child {
      flex: 0 0 100%;
      width: 100%;
    }

    .product__media-item:first-child .product-media-container {
      padding-top: 100%;
      border-radius: 16px;
      border: 1px solid rgba(0,0,0,0.05);
    }

    /* Miniatures : petites, en ligne */
    .product__media-item:not(:first-child) {
      flex: 0 0 auto;
      width: auto;
      min-width: 0;
      max-width: none;
    }

    .product__media-item:not(:first-child) .product-media-container {
      padding-top: 0;
      width: 80px;
      height: 80px;
      border-radius: 10px;
      border: 2px solid transparent;
      position: relative;
      overflow: hidden;
      background: var(--milaura-beige, #FDFBF7);
    }

    .product__media-item:not(:first-child) .product-media-container img {
      position: absolute;
      top: 0; left: 0;
      width: 100%;
      height: 100%;
      object-fit: cover;
    }

    /* Spotlight slide: hidden on desktop (uses external thumb instead) */
    .product__media-item--spotlight {
      /* Visible on mobile via carousel, hidden on desktop via JS-injected style */
    }

    .product__media-item--spotlight .milaura-hotspot {
      display: none; /* Hide hotspots in thumbnail mode on desktop */
    }

    .slider-buttons {
      display: none;
    }

    .slider-button {
      display: none;
    }

    /* Desktop Zoom on hover */
    .product__media-item:first-child .product-media-container {
      cursor: zoom-in;
    }

    .product__media-item:first-child .product-media-container.is-zoomed {
      cursor: zoom-out;
    }

    .product__media-item:first-child .product-media-container.is-zoomed img {
      transform: scale(2.2);
      transform-origin: var(--zoom-x, 50%) var(--zoom-y, 50%);
      transition: transform-origin 0.05s ease-out;
    }

    /* Desktop Clickable Thumbnails */
    .product__media-item:not(:first-child) .product-media-container {
      cursor: pointer;
      transition: box-shadow 0.3s ease, border-color 0.3s ease;
    }

    .product__media-item:not(:first-child) .product-media-container:hover {
      border-color: var(--milaura-gold);
      box-shadow: 0 4px 16px rgba(192, 160, 98, 0.25);
    }

    /* Desktop pills : reste sur la grid area "meta" (1 ligne centree au-dessus de la galerie).
       Refonte 2026-05-28 : retrait du flotting badges sur la photo, plus fiable + lisible. */
    .milaura-meta-badge {
      padding: 7px 16px;
      font-size: 0.85rem;
      box-shadow: 0 2px 12px rgba(192, 160, 98, 0.12);
    }

  }

  /* AVIS */
  .rating-badge {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    margin-bottom: 12px;
    text-decoration: none !important;
    color: var(--milaura-text) !important;
  }

  .rating-badge .stars {
    color: #D4A843 !important; /* Doré plus foncé pour meilleur contraste */
    font-size: 16px;
    letter-spacing: -1px;
    text-shadow: 0 1px 2px rgba(0, 0, 0, 0.15); /* Ombre légère pour lisibilité */
  }

  .rating-badge .rating-text {
    opacity: 0.7;
    font-size: 13px;
    color: inherit;
  }

  /* TYPOGRAPHIE */
  .milaura-product__title {
    font-family: var(--milaura-font-heading);
    font-size: {{ section.settings.title_size_mobile }}px;
    margin: 0 0 10px;
    font-weight: 600;
    color: {{ section.settings.title_color }};
    line-height: 1.12;
  }
  @media screen and (min-width: 990px) {
    .milaura-product__title { font-size: {{ section.settings.title_size_desktop }}rem; }
  }

  .milaura-product__price {
    font-size: {{ section.settings.price_size }}px;
    font-weight: 700;
    color: {{ section.settings.price_color }};
  }

  .milaura-product__price .price-item--sale {
    font-size: calc({{ section.settings.price_size }}px * 1.15);
    font-weight: 800;
  }

  .milaura-product__price .price-item--regular.price-item--last {
    opacity: 0.6;
    text-decoration: line-through;
  }

  /* --- Social Proof --- */
  /* --- Bloc Trust unifie (certificat + reassurance) --- */
  .milaura-trust-block {
    background: linear-gradient(135deg, rgba(253, 251, 247, 0.95), rgba(242, 232, 213, 0.6));
    border: 1px solid rgba(192, 160, 98, 0.25);
    border-radius: 16px;
    padding: 16px;
    margin-bottom: 16px;
    margin-top: 8px;
  }

  .milaura-trust-layout {
    display: flex;
    gap: 16px;
    align-items: flex-start;
  }

  .milaura-trust-cert-wrap {
    flex-shrink: 0;
    display: flex;
    flex-direction: column;
    gap: 6px;
    align-items: center;
  }

  .milaura-trust-main-img {
    width: 110px;
    height: auto;
    border-radius: 10px;
    border: 1px solid rgba(192, 160, 98, 0.3);
    box-shadow: 0 4px 16px rgba(0, 0, 0, 0.08);
    object-fit: cover;
  }

  .milaura-trust-cert-img {
    width: 80px;
    height: auto;
    border-radius: 6px;
    border: 1px solid rgba(192, 160, 98, 0.2);
    box-shadow: 0 2px 8px rgba(0, 0, 0, 0.06);
    opacity: 0.9;
  }

  .milaura-trust-points {
    display: flex;
    flex-direction: column;
    gap: 8px;
    flex: 1;
  }

  .milaura-trust-point {
    display: flex;
    align-items: flex-start;
    gap: 8px;
    font-family: 'Lato', sans-serif;
    font-size: 0.85rem;
    color: #333;
    line-height: 1.4;
  }

  .milaura-trust-point .milaura-trust-icon {
    flex-shrink: 0;
    font-size: 0.9rem;
    margin-top: 1px;
  }

  .milaura-trust-point:first-child {
    font-weight: 700;
    font-size: 0.9rem;
    color: #1a1a1a;
  }

  /* --- Promo Badge (notre badge custom) --- */
  .milaura-promo-badge {
    display: inline-block;
    background: linear-gradient(135deg, #1a1a2e, #2d2d44);
    color: var(--milaura-gold-light, #E6C88B);
    font-size: 0.95rem;
    font-weight: 700;
    padding: 6px 16px;
    border-radius: 10px;
    vertical-align: middle;
    font-family: 'Lato', sans-serif;
    letter-spacing: 0.5px;
  }

  /* --- Prix : tout en ligne (prix barre + prix sale + Promotion + -30%) ---
     IMPORTANT : ne pas forcer display sur .price__regular / .price__sale,
     Dawn gere le hide automatiquement quand .price--on-sale est present. */
  .milaura-hero-wrapper [id^="price-"] {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: 10px;
    margin-bottom: var(--milaura-spacing-sm, 12px);
  }
  .milaura-hero-wrapper [id^="price-"] > .price {
    display: inline-flex;
    align-items: center;
    flex-wrap: wrap;
    gap: 10px;
  }
  .milaura-hero-wrapper [id^="price-"] .price__container {
    display: inline-flex;
    flex-wrap: wrap;
    align-items: center;
    gap: 10px;
  }
  /* Quand on est en sale, hide .price__regular (Dawn-style) */
  .milaura-hero-wrapper [id^="price-"] .price--on-sale .price__regular {
    display: none !important;
  }
  .milaura-hero-wrapper [id^="price-"] .price:not(.price--on-sale) .price__sale,
  .milaura-hero-wrapper [id^="price-"] .price:not(.price--on-sale) .price__badge-sale {
    display: none !important;
  }

  .milaura-hero-wrapper [id^="price-"] .price.price--on-sale .price__sale {
    display: flex !important;
    align-items: center;
    flex-wrap: wrap;
    gap: 8px;
    margin: 0;
  }
  .milaura-hero-wrapper [id^="price-"] .price-item {
    display: inline-block;
    margin: 0;
  }
  .milaura-hero-wrapper [id^="price-"] .price__sale .price-item--regular {
    font-size: 1rem;
    opacity: 0.6;
  }
  .milaura-hero-wrapper [id^="price-"] .price__sale s.price-item--regular {
    font-size: 1rem;
    opacity: 0.6;
    text-decoration: line-through;
  }
  .milaura-hero-wrapper [id^="price-"] .price-item--sale {
    font-weight: 800;
    font-size: 1.4rem;
    color: var(--milaura-gold, #C0A062);
  }
  /* Badges Promotion + -30% inline (a cote du prix) */
  .milaura-hero-wrapper [id^="price-"] .badge.price__badge-sale,
  .milaura-hero-wrapper [id^="price-"] .price__badge-sale {
    align-items: center;
    margin: 0 !important;
    line-height: 1;
    font-size: 0.75rem;
    padding: 5px 10px;
  }

  .milaura-hero-wrapper [id^="price-"] .price.price--on-sale .price__badge-sale {
    display: inline-flex !important;
  }
  .milaura-hero-wrapper [id^="price-"] .milaura-promo-badge {
    display: inline-flex;
    align-items: center;
    margin: 0;
    font-size: 0.75rem;
    padding: 5px 10px;
  }
  @media (max-width: 480px) {
    .milaura-hero-wrapper [id^="price-"] .badge.price__badge-sale,
    .milaura-hero-wrapper [id^="price-"] .price__badge-sale,
    .milaura-hero-wrapper [id^="price-"] .milaura-promo-badge {
      font-size: 0.7rem;
      padding: 4px 8px;
    }
    .milaura-hero-wrapper [id^="price-"] .price-item--sale {
      font-size: 1.25rem;
    }
    .milaura-hero-wrapper [id^="price-"] .price__sale s.price-item--regular {
      font-size: 1rem;
    }
  }
  /* Hide sold-out badge sauf si sold out */
  .milaura-hero-wrapper [id^="price-"] .price__badge-sold-out {
    display: none;
  }
  .milaura-hero-wrapper [id^="price-"] .price--sold-out .price__badge-sold-out {
    display: inline-flex !important;
  }

  /* --- Override Dawn sale badge to match our blue + gold text --- */
  .milaura-hero-wrapper .badge.price__badge-sale,
  .milaura-hero-wrapper .price__badge-sale {
    background: linear-gradient(135deg, #1a1a2e, #2d2d44) !important;
    color: var(--milaura-gold-light, #E6C88B) !important;
    border: none !important;
    font-size: 0.95rem;
    font-weight: 700;
    padding: 6px 16px;
    border-radius: 10px;
    font-family: 'Lato', sans-serif;
    letter-spacing: 0.5px;
  }

  /* Bloc prix propre : prix principal lisible, annexes en second niveau */
  .milaura-hero-header-group [id^="price-"] {
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    gap: 6px;
    margin: 0 0 18px;
    text-align: center;
  }

  .milaura-hero-header-group [id^="price-"] > .price,
  .milaura-hero-header-group [id^="price-"] .price__container {
    display: flex !important;
    align-items: baseline;
    justify-content: center;
    flex-wrap: wrap;
    gap: 7px;
    margin: 0;
  }

  .milaura-hero-header-group [id^="price-"] .price__regular,
  .milaura-hero-header-group [id^="price-"] .price__sale {
    align-items: baseline;
    justify-content: center;
    flex-wrap: wrap;
    gap: 7px;
    margin: 0;
  }

  .milaura-hero-header-group [id^="price-"] .price:not(.price--on-sale) .price__regular {
    display: flex !important;
  }

  .milaura-hero-header-group [id^="price-"] .price:not(.price--on-sale) .price__sale,
  .milaura-hero-header-group [id^="price-"] .price:not(.price--on-sale) .price__badge-sale,
  .milaura-hero-header-group [id^="price-"] .price:not(.price--on-sale) + .milaura-promo-badge {
    display: none !important;
  }

  .milaura-hero-header-group [id^="price-"] .price.price--on-sale .price__regular {
    display: none !important;
  }

  .milaura-hero-header-group [id^="price-"] .price.price--on-sale .price__sale {
    display: flex !important;
  }

  .milaura-hero-header-group [id^="price-"] .price.price--on-sale .price__badge-sale {
    display: inline-flex !important;
  }

  .milaura-hero-header-group [id^="price-"] .price-item {
    margin: 0;
    letter-spacing: 0;
    line-height: 1;
  }

  .milaura-hero-header-group [id^="price-"] .price-item--sale,
  .milaura-hero-header-group [id^="price-"] .price-item--regular:not(s) {
    font-family: 'Lato', sans-serif;
    font-size: 2rem;
    font-weight: 900;
    color: var(--milaura-gold, #C0A062);
  }

  .milaura-hero-header-group [id^="price-"] s.price-item--regular,
  .milaura-hero-header-group [id^="price-"] .price__sale .price-item--regular {
    font-size: 1.08rem;
    font-weight: 700;
    color: #8b8b8b;
    opacity: 0.72;
    text-decoration-thickness: 1px;
  }

  .milaura-hero-header-group [id^="price-"] .milaura-promo-badge {
    display: inline-flex !important;
  }

  .milaura-hero-header-group [id^="price-"] .badge.price__badge-sale,
  .milaura-hero-header-group [id^="price-"] .price__badge-sale,
  .milaura-hero-header-group [id^="price-"] .milaura-promo-badge {
    align-items: center;
    justify-content: center;
    width: fit-content;
    margin: 0;
    padding: 6px 11px;
    font-size: 0.68rem;
    font-weight: 900;
    line-height: 1;
    border-radius: 999px;
    letter-spacing: 0.4px;
    text-transform: none;
  }

  .milaura-hero-header-group [id^="price-"] .milaura-promo-badge {
    background: #1a1a2e;
    color: #E6C88B;
  }

  @media screen and (min-width: 990px) {
    .milaura-meta-badges--product {
      justify-content: flex-start;
      margin-bottom: 14px;
    }

    .milaura-hero-header-group [id^="price-"] {
      align-items: flex-start;
      text-align: left;
    }

    .milaura-hero-header-group [id^="price-"] > .price,
    .milaura-hero-header-group [id^="price-"] .price__container,
    .milaura-hero-header-group [id^="price-"] .price__sale,
    .milaura-hero-header-group [id^="price-"] .price__regular {
      justify-content: flex-start;
    }

    .milaura-hero-header-group [id^="price-"] .price-item--sale,
    .milaura-hero-header-group [id^="price-"] .price-item--regular:not(s) {
      font-size: 2.15rem;
    }

    .milaura-hero-header-group [id^="price-"] s.price-item--regular,
    .milaura-hero-header-group [id^="price-"] .price__sale .price-item--regular {
      font-size: 1.16rem;
    }
  }

  /* --- Payment Icons --- */
  .milaura-hero-wrapper .milaura-payment-icons {
    display: flex;
    align-items: center;
    justify-content: flex-start;
    gap: 6px;
    margin-top: 10px;
    opacity: 0.55;
    list-style: none;
    padding: 0;
    flex-wrap: wrap;
  }

  .milaura-hero-wrapper .milaura-payment-icon {
    display: inline-flex;
  }

  .milaura-hero-wrapper .milaura-payment-icon svg {
    width: 38px;
    height: 24px;
  }

  /* --- Responsive: center on mobile --- */
  @media screen and (max-width: 749px) {
    .milaura-payment-icons {
      justify-content: center;
    }

    .milaura-trust-block {
      padding: 12px;
    }

    .milaura-trust-layout {
      flex-direction: column;
      align-items: center;
      text-align: center;
      gap: 12px;
    }

    .milaura-trust-cert-wrap {
      flex-direction: row;
