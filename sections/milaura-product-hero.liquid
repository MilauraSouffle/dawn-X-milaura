      justify-content: center;
      font-size: 0.82rem;
    }
  }

  /* ===========================================
     VOLUME BUNDLE - Design Premium 2026
     Cartes avec en-têtes colorés intégrés
     =========================================== */

  .volume-section-title {
    font-family: var(--milaura-font-heading);
    font-size: 15px;
    font-weight: 600;
    color: var(--milaura-text);
    margin: 0 0 12px 0;
    text-align: center;
  }

  .milaura-volume-grid {
    display: flex;
    gap: 8px;
    margin: 0 0 12px 0;
  }

  .volume-card {
    flex: 1;
    position: relative;
    display: flex;
    flex-direction: column;
    align-items: center;
    padding: 0; /* En-tête intégré - padding géré par sous-éléments */
    border: 1.5px solid #E8E4DE;
    border-radius: 12px;
    background: #FFFFFF;
    cursor: pointer;
    transition: all 0.25s cubic-bezier(0.4, 0, 0.2, 1);
    overflow: hidden; /* Important pour l'en-tête intégré */
  }

  .volume-card:hover {
    border-color: rgba(192, 160, 98, 0.5);
    transform: translateY(-2px);
    box-shadow: 0 6px 20px rgba(192, 160, 98, 0.12);
  }

  .volume-card.is-selected {
    border-color: var(--milaura-gold);
    background: linear-gradient(165deg, #FFFDF8 0%, #FFF9EE 100%);
    box-shadow: 0 4px 16px rgba(192, 160, 98, 0.18);
  }

  /* EN-TÊTE INTÉGRÉ - Design 2026 */
  /* Le badge est maintenant un header intégré en haut de la carte */
  /* Hauteur fixe pour uniformité (basée sur 2 lignes de texte) */
  .volume-card-badge {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 100%;
    min-height: 38px; /* Hauteur fixe pour 2 lignes */
    background: linear-gradient(135deg, #8B5CF6 0%, #A78BFA 100%);
    color: #FFFFFF;
    font-size: 11px;
    font-weight: 700;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    text-align: center;
    padding: 4px 8px;
    margin: 0;
    border-radius: 0; /* Intégré dans la carte */
    line-height: 1.3;
  }

  /* Contenu de la carte */
  .volume-left {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 2px;
    width: 100%;
    padding: 12px 8px 4px;
  }

  /* Carte SANS badge : ajouter du padding-top */
  .volume-card:not(:has(.volume-card-badge)) .volume-left {
    padding-top: 16px;
  }

  /* Prix en bas de carte */
  .volume-price {
    padding: 4px 8px 12px;
    font-size: 15px;
    font-weight: 700;
    color: var(--milaura-text);
  }

  .volume-card.is-selected .volume-price {
    color: var(--milaura-gold-dark, #8F723A);
  }

  .volume-check {
    display: none; /* On cache le radio circle, le style de carte suffit */
  }

  .volume-text {
    text-align: center;
  }

  .volume-text h5 {
    font-size: 14px;
    font-weight: 600;
    color: var(--milaura-text);
    margin: 0;
    line-height: 1.2;
  }

  .volume-text p {
    font-size: 13px;
    color: #888;
    margin: 2px 0 0 0;
    font-weight: 500;
  }

  .volume-card.is-selected .volume-text p {
    color: var(--milaura-gold-dark, #8F723A);
  }

  /* Mobile: légèrement plus compact */
  @media screen and (max-width: 480px) {
    .milaura-volume-grid {
      gap: 6px;
    }

    .volume-card {
      padding: 0; /* Géré par les sous-éléments - en-tête intégré */
      border-radius: 10px;
    }

    .volume-card-badge {
      font-size: 10px;
      min-height: 34px; /* Hauteur fixe mobile */
      padding: 3px 6px;
    }

    .volume-left {
      padding: 10px 6px 2px;
    }

    .volume-price {
      padding: 2px 6px 10px;
      font-size: 14px;
    }

    .volume-text h5 {
      font-size: 13px;
    }

    .volume-text p {
      font-size: 12px;
    }
  }

  /* Animation sélection */
  .volume-card.is-selected::after {
    content: '';
    position: absolute;
    inset: -1px;
    border-radius: 12px;
    background: linear-gradient(135deg, rgba(192, 160, 98, 0.15), transparent);
    pointer-events: none;
    opacity: 0;
    animation: selectPulse 0.4s ease-out forwards;
  }

  @keyframes selectPulse {
    0% { opacity: 1; transform: scale(1); }
    100% { opacity: 0; transform: scale(1.05); }
  }

  /* --- FIX BUY ROW (Quantité + Bouton) --- */
  .milaura-buy-row {
    display: flex;
    gap: 10px;
    margin-top: 14px; /* FIX: réduit de 20px à 14px */
    align-items: center;
    flex-wrap: wrap; /* FIX: permettre le wrap sur mobile si nécessaire */
  }

  /* DESKTOP: Espacements ÉQUILIBRÉS - tout visible sans scroll */
  @media screen and (min-width: 990px) {
    /* === ESPACEMENT ENTRE LES GROUPES === */
    .milaura-buy-row {
      margin-top: 14px;
      margin-bottom: 0;
    }

    /* Volume Bundle - en-têtes intégrés Desktop */
    .volume-section-title {
      margin: 0 0 10px 0;
      font-size: 14px;
      font-weight: 500;
    }

    .milaura-volume-grid {
      gap: 10px;
      margin-top: 8px; /* Plus besoin d'espace pour badges flottants */
      margin-bottom: 0;
    }

    .volume-card {
      padding: 0; /* Géré par les sous-éléments */
      border-radius: 12px;
    }

    .volume-card-badge {
      font-size: 10px;
      min-height: 36px; /* Hauteur fixe desktop */
      padding: 4px 12px;
    }

    .volume-left {
      padding: 14px 10px 4px;
    }

    .volume-text h5 {
      font-size: 14px;
      font-weight: 600;
    }

    .volume-text p {
      font-size: 12px;
      margin-top: 3px;
      color: #666;
    }

    .volume-price {
      font-size: 16px;
      padding: 4px 10px 14px;
      font-weight: 700;
    }

    /* CTA button - légèrement plus compact pour compenser */
    .milaura-add-btn {
      min-height: 46px;
      padding: 12px 24px;
      font-size: 13px;
    }

    /* Quantity selector */
    .milaura-quantity-capsule {
      height: 44px !important;
      min-height: 44px !important;
    }

    /* Réassurance - plus compact pour compenser */
    .milaura-trust-badges {
      margin-top: 12px;
    }
  }

  /* PLEIN ÉCRAN (≥1400px): Encore plus compact pour tout voir */
  @media screen and (min-width: 1400px) {
    .milaura-hero-wrapper {
      grid-template-columns: 1fr 0.7fr; /* Colonne droite encore plus étroite */
      max-width: 1400px;
