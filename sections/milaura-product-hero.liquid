  .milaura-reward-preview__card:nth-child(1) {
    left: 0;
    transform: rotate(-8deg);
  }

  .milaura-reward-preview__card:nth-child(2) {
    left: 42px;
    transform: translateY(-6px);
    z-index: 2;
  }

  .milaura-reward-preview__card:nth-child(3) {
    left: 84px;
    transform: rotate(8deg);
  }

  .milaura-reward-preview__seal {
    width: 34px;
    height: 34px;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    border-radius: 50%;
    background: rgba(26, 26, 46, 0.92);
    color: var(--milaura-gold-light, #E6C88B);
    font-family: 'Playfair Display', serif;
    font-size: 1.08rem;
    font-weight: 800;
    line-height: 1;
  }

  .milaura-reward-preview__lock {
    position: absolute;
    right: 7px;
    bottom: 7px;
    width: 22px;
    height: 22px;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    border-radius: 50%;
    background: rgba(255, 255, 255, 0.84);
    color: #1a1a2e;
    font-size: 0.72rem;
    font-weight: 900;
  }

  .milaura-reward-preview__card.is-locked {
    filter: grayscale(0.36);
    opacity: 0.62;
  }

  .milaura-reward-preview__card.is-unlocked {
    animation: milaura-reward-card-breathe 3.8s ease-in-out infinite;
  }

  @keyframes milaura-reward-card-breathe {
    0%, 100% { box-shadow: inset 0 1px 0 rgba(255, 255, 255, 0.72), 0 12px 24px rgba(26, 26, 46, 0.16); }
    50% { box-shadow: inset 0 1px 0 rgba(255, 255, 255, 0.82), 0 16px 32px rgba(192, 160, 98, 0.28); }
  }

  .milaura-reward-preview__mini {
    position: relative;
    height: 8px;
    overflow: hidden;
    border-radius: 999px;
    background: rgba(26, 26, 46, 0.08);
  }

  .milaura-reward-preview__fill {
    display: block;
    width: 0%;
    height: 100%;
    border-radius: inherit;
    background: linear-gradient(90deg, #D8B568, #F7DCA5, #B78A35);
    transition: width 420ms cubic-bezier(0.22, 1, 0.36, 1);
  }

  .milaura-cart-confirm {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 12px;
    width: 100%;
    margin-top: 10px;
    padding: 11px 12px;
    border: 1px solid rgba(76, 175, 80, 0.28);
    border-radius: 8px;
    background: rgba(76, 175, 80, 0.08);
    color: #1f4d32;
    font-family: 'Lato', sans-serif;
    font-size: 0.82rem;
    line-height: 1.35;
  }

  .milaura-cart-confirm[hidden] {
    display: none;
  }

  .milaura-cart-confirm__text {
    margin: 0;
    font-weight: 800;
  }

  .milaura-cart-confirm__link {
    flex: 0 0 auto;
    color: #1a1a2e;
    font-weight: 900;
    text-decoration: underline;
    text-underline-offset: 3px;
  }

  @media screen and (max-width: 749px) {
    .milaura-offer-contrast {
      padding: 14px;
    }

    .milaura-offer-contrast__title {
      font-size: 1.14rem;
    }

    .milaura-offer-contrast__subtitle {
      font-size: 0.82rem;
    }

    .milaura-offer-contrast__grid {
      gap: 7px;
    }

    .milaura-offer-contrast__card {
      min-height: 134px;
      padding: 11px 7px;
    }

    .milaura-offer-contrast__step {
      width: 29px;
      height: 29px;
      font-size: 0.86rem;
    }

    .milaura-offer-contrast__label {
      font-size: 0.88rem;
    }

    .milaura-offer-contrast__reward,
    .milaura-offer-contrast__note {
      font-size: 0.7rem;
    }

    .milaura-cart-confirm {
      flex-direction: column;
      align-items: flex-start;
      gap: 5px;
      font-size: 0.78rem;
    }

    .milaura-reward-preview {
      padding: 14px;
      border-radius: 14px;
    }

    .milaura-reward-preview__inner {
      grid-template-columns: minmax(0, 1fr) 122px;
      gap: 10px;
    }

    .milaura-reward-preview__title {
      font-size: 1.08rem;
    }

    .milaura-reward-preview__text {
      font-size: 0.78rem;
    }

    .milaura-reward-preview__status {
      font-size: 0.68rem;
    }

    .milaura-reward-preview__deck {
      height: 74px;
    }

    .milaura-reward-preview__card {
      width: 58px;
      height: 72px;
      border-radius: 9px;
    }

    .milaura-reward-preview__card:nth-child(2) {
      left: 32px;
    }

    .milaura-reward-preview__card:nth-child(3) {
      left: 64px;
    }

    .milaura-reward-preview__seal {
      width: 28px;
      height: 28px;
      font-size: 0.92rem;
    }

    .milaura-reward-preview__lock {
      width: 19px;
      height: 19px;
      font-size: 0.62rem;
    }
  }

  /* Separateur elegant */
  .milaura-scratch-divider {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 14px;
    padding: 18px 0 14px;
    width: 100%;
    margin-top: 2px;
  }

  .milaura-scratch-divider::before,
  .milaura-scratch-divider::after {
    content: '';
    flex: 1;
    max-width: 80px;
    height: 1px;
    background: linear-gradient(90deg, transparent, var(--milaura-gold, #C0A062), transparent);
  }

  .milaura-scratch-divider-text {
    font-family: 'Lato', sans-serif;
    font-size: 0.95rem;
    font-weight: 700;
    letter-spacing: 2px;
    text-transform: uppercase;
    color: var(--milaura-gold, #C0A062);
    white-space: normal;
    text-align: center;
    padding: 0 8px;
  }

  /* Conteneur scratch : sans cadre/padding, les cartes flottent libres */
  .milaura-hero-scratch {
    width: 100%;
    background: transparent;
    border: none;
    box-shadow: none;
    padding: 0;
    margin: 0 0 24px;
    box-sizing: border-box;
    position: relative;
    overflow: visible;
  }

  /* Header : titre + badge compteur */
  .milaura-scratch-header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    margin-bottom: 14px;
  }

  .milaura-scratch-title {
    font-family: 'Playfair Display', serif;
    font-style: italic;
    font-size: 1.1rem;
    font-weight: 600;
    color: var(--milaura-text, #000);
    margin: 0;
    line-height: 1.3;
  }

  .milaura-scratch-counter {
    display: inline-block;
    font-family: 'Lato', sans-serif;
    font-size: 0.75rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.5px;
    background: #F2E8D5;
    color: var(--milaura-gold-dark, #8F723A);
    padding: 4px 12px;
    border-radius: 20px;
    white-space: nowrap;
    flex-shrink: 0;
    margin-left: 12px;
  }

  /* Grille des cartes : 3 cols comme le bundle tiers au-dessus */
  .milaura-scratch-cards {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    align-items: stretch;
    gap: 12px;
    margin-bottom: 0;
  }

  /* Carte individuelle : grid 1fr donne la width, height fixe pour matcher bundle tier */
  .milaura-scratch-card {
    width: 100%;
    height: 130px;
    border-radius: 14px;
    position: relative;
    overflow: hidden;
    isolation: isolate;
    cursor: pointer;
    transition: box-shadow 0.25s ease;
  }

  .milaura-scratch-card-content {
    position: absolute;
    inset: 0;
    z-index: 1;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    text-align: center;
    background: #fff;
    border: 1.5px solid rgba(192, 160, 98, 0.2);
    border-radius: inherit;
    padding: 10px 8px;
    transition: border-color 0.3s ease, background 0.3s ease;
    pointer-events: none;
  }

  .milaura-scratch-card-icon {
    font-size: 1.8rem;
    margin-bottom: 6px;
    line-height: 1;
    opacity: 0;
    transition: opacity 0.3s ease;
  }

  .milaura-scratch-card-name {
    font-family: 'Lato', sans-serif;
    font-size: 0.8rem;
    font-weight: 700;
    color: #333;
    line-height: 1.3;
    text-align: center;
    opacity: 0;
    transition: opacity 0.3s ease;
  }

  .milaura-scratch-card-value {
    font-family: 'Lato', sans-serif;
    font-size: 0.75rem;
    color: var(--milaura-gold, #C0A062);
    margin-top: 4px;
    font-weight: 600;
    opacity: 0;
    transition: opacity 0.3s ease;
  }

  .milaura-scratch-card-value:empty {
    display: none;
  }

  /* Canvas overlay */
  .milaura-scratch-card canvas {
    position: absolute;
    inset: 0;
    width: 100% !important;
    height: 100% !important;
    display: block;
    border-radius: inherit;
    z-index: 2;
    touch-action: none;
    cursor: pointer;
  }

  /* Etat revele */
  .milaura-scratch-card.is-revealed canvas {
    display: none;
  }

  .milaura-scratch-card.is-revealed .milaura-scratch-card-content {
    border-color: rgba(192, 160, 98, 0.6);
    background: linear-gradient(180deg, #FFFCF5 0%, #FFFFFF 100%);
    box-shadow: inset 0 0 0 1px rgba(230, 200, 139, 0.26), 0 8px 22px rgba(192, 160, 98, 0.14);
  }

  .milaura-scratch-card.is-revealed .milaura-scratch-card-icon,
  .milaura-scratch-card.is-revealed .milaura-scratch-card-name,
  .milaura-scratch-card.is-revealed .milaura-scratch-card-value {
    opacity: 1;
  }

  .milaura-scratch-card-badge {
    position: absolute;
    top: 8px;
    right: 8px;
    z-index: 2;
    display: none;
    font-family: 'Lato', sans-serif;
    font-size: 0.58rem;
    font-weight: 900;
    letter-spacing: 0.5px;
    text-transform: uppercase;
    line-height: 1;
    color: #7A5D27;
    background: #F2E8D5;
    border: 1px solid rgba(192, 160, 98, 0.34);
    border-radius: 999px;
    padding: 5px 7px;
    box-shadow: 0 4px 10px rgba(192, 160, 98, 0.16);
  }

  .milaura-scratch-card.is-revealed .milaura-scratch-card-badge {
    display: inline-flex;
  }

  .milaura-scratch-card:not(.is-locked):not(.is-revealed)::after {
    content: '{{ section.settings.unlocked_card_label | default: "Carte débloquée, grattez ici" }}';
    white-space: normal;
    position: absolute;
    left: 50%;
    bottom: 12px;
    transform: translateX(-50%);
    z-index: 3;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    min-width: min(86%, 132px);
    padding: 6px 9px;
    border-radius: 999px;
    background: {{ section.settings.unlocked_badge_bg | default: '#1a1a2e' }};
    color: {{ section.settings.unlocked_badge_text | default: '#ffffff' }};
    font-family: 'Lato', sans-serif;
    font-size: 0.64rem;
    font-weight: 900;
    line-height: 1.15;
    letter-spacing: 0;
    text-align: center;
    pointer-events: none;
    box-shadow: 0 6px 16px rgba(26, 26, 46, 0.22);
  }

  .milaura-scratch-card[data-gift-index="2"].is-revealed .milaura-scratch-card-content {
    border-color: rgba(26, 26, 46, 0.7);
    background: linear-gradient(145deg, #1a1a2e 0%, #2d2d44 100%);
    box-shadow: 0 10px 26px rgba(26, 26, 46, 0.2), inset 0 0 0 1px rgba(230, 200, 139, 0.25);
  }

  .milaura-scratch-card[data-gift-index="2"].is-revealed .milaura-scratch-card-icon,
  .milaura-scratch-card[data-gift-index="2"].is-revealed .milaura-scratch-card-name {
    color: #fff;
  }

  .milaura-scratch-card[data-gift-index="2"].is-revealed .milaura-scratch-card-value {
    color: #E6C88B;
  }

  .milaura-scratch-card[data-gift-index="2"].is-revealed .milaura-scratch-card-badge {
    color: #1a1a2e;
    background: #E6C88B;
    border-color: rgba(255, 255, 255, 0.25);
  }

  /* Etat verrouille : cadenas gris, non grattable */
  .milaura-scratch-card.is-locked {
    cursor: not-allowed;
  }

  .milaura-scratch-card.is-locked::before {
    content: '';
    position: absolute;
    inset: 0;
    background: linear-gradient(135deg, #d8d8d8, #b8b8b8);
    border-radius: inherit;
    z-index: 3;
  }

  .milaura-scratch-card.is-locked::after {
    content: '';
    position: absolute;
    top: 50%;
    left: 50%;
    transform: translate(-50%, -50%);
    width: 32px;
    height: 32px;
    background-image: url("data:image/svg+xml;utf8,<svg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 24 24' fill='none' stroke='white' stroke-width='2' stroke-linecap='round' stroke-linejoin='round'><rect x='3' y='11' width='18' height='11' rx='2' ry='2'/><path d='M7 11V7a5 5 0 0 1 10 0v4'/></svg>");
    background-repeat: no-repeat;
    background-position: center;
    background-size: contain;
    opacity: 0.85;
    z-index: 4;
    pointer-events: none;
  }

  /* Pill de confirmation */
  .milaura-scratch-pill {
    display: none;
    margin-top: 14px;
    text-align: left;
  }

  .milaura-scratch-pill.is-visible {
    display: block;
  }

  @keyframes milauraScratchPillIn {
    0% { opacity: 0; transform: translateY(8px); }
    100% { opacity: 1; transform: translateY(0); }
  }

  .milaura-scratch-pill-inner {
    display: flex;
    align-items: center;
    gap: 10px;
    width: 100%;
    background: linear-gradient(135deg, #FFF8E8 0%, #E6C88B 100%);
    color: #1a1a2e;
    font-family: 'Lato', sans-serif;
    font-size: 0.82rem;
    font-weight: 800;
    border-radius: 14px;
    padding: 12px 14px;
    line-height: 1.32;
    max-width: 100%;
    word-wrap: break-word;
    border: 1.5px solid rgba(192, 160, 98, 0.52);
    box-shadow: 0 8px 22px rgba(192, 160, 98, 0.22);
    animation: milauraScratchPillIn 0.4s ease-out;
  }

  .milaura-scratch-pill-icon {
    width: 30px;
    height: 30px;
    border-radius: 999px;
    background: #1a1a2e;
    color: #E6C88B;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    flex: 0 0 auto;
    font-size: 1rem;
    font-weight: 900;
    box-shadow: 0 4px 12px rgba(26, 26, 46, 0.18);
  }

  .milaura-scratch-pill-copy {
    display: flex;
    flex-direction: column;
    gap: 2px;
    min-width: 0;
  }

  .milaura-scratch-pill-copy strong {
    display: block;
    font-size: 0.86rem;
    line-height: 1.2;
  }

  .milaura-scratch-pill-copy span {
    display: block;
    color: rgba(26, 26, 46, 0.76);
    font-size: 0.74rem;
    font-weight: 700;
    line-height: 1.3;
  }

  .milaura-gift-popup {
    position: fixed;
    inset: 0;
    z-index: 2147483000;
    display: grid;
    place-items: center;
    padding: max(18px, env(safe-area-inset-top)) 18px max(18px, env(safe-area-inset-bottom));
    background: rgba(13, 17, 28, 0.58);
    backdrop-filter: blur(14px);
    -webkit-backdrop-filter: blur(14px);
    overflow: hidden;
  }

  .milaura-gift-popup-open {
    overflow: hidden;
  }

  .milaura-gift-popup-open #milaura-dock,
  .milaura-gift-popup-open #MilauraStickyBarSection,
  .milaura-gift-popup-open #milaura-popup-overlay,
  .milaura-gift-popup-open #milaura-bubble-trigger,
  .milaura-gift-popup-open #milaura-bubble-label {
    opacity: 0;
    visibility: hidden;
    pointer-events: none;
  }

  .milaura-gift-popup[hidden] {
    display: none;
  }

  .milaura-gift-popup__card {
    width: min(456px, 100%);
    max-height: calc(100dvh - 36px - env(safe-area-inset-top) - env(safe-area-inset-bottom));
    background:
      linear-gradient(180deg, rgba(255, 251, 241, 0.98), #ffffff 42%),
      #ffffff;
    border: 1px solid rgba(230, 200, 139, 0.54);
    border-radius: 18px;
    box-shadow: 0 28px 90px rgba(13, 17, 28, 0.34);
    color: #1a1a2e;
    overflow: hidden;
    position: relative;
    outline: none;
  }

  .milaura-gift-popup__handle {
    display: none;
  }

  .milaura-gift-popup__body {
    display: flex;
    flex-direction: column;
    gap: 16px;
    padding: 24px;
    max-height: inherit;
    overflow-y: auto;
    overscroll-behavior: contain;
  }

  .milaura-gift-popup__close {
    position: absolute;
    top: 12px;
    right: 12px;
    width: 40px;
    height: 40px;
    border: 1px solid rgba(26, 26, 46, 0.12);
    border-radius: 999px;
    background: rgba(255, 255, 255, 0.92);
    color: #1a1a2e;
    font-size: 1.35rem;
    line-height: 1;
    cursor: pointer;
    z-index: 2;
    box-shadow: 0 10px 26px rgba(26, 26, 46, 0.12);
  }

  .milaura-gift-popup__reward {
    display: grid;
    grid-template-columns: 64px minmax(0, 1fr);
    gap: 14px;
    align-items: center;
    padding-right: 36px;
  }

  .milaura-gift-popup__burst {
    width: 64px;
    height: 64px;
    border-radius: 18px;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    background: linear-gradient(135deg, #fff6d7 0%, #e6c88b 58%, #b8944f 100%);
    color: #1a1a2e;
    font-size: 2rem;
    box-shadow: 0 14px 32px rgba(192, 160, 98, 0.28);
    animation: milauraGiftPop 0.34s cubic-bezier(.2,.8,.2,1);
  }

  @keyframes milauraGiftPop {
    0% { opacity: 0; transform: scale(0.86) translateY(4px); }
    100% { opacity: 1; transform: scale(1) translateY(0); }
  }

  .milaura-gift-popup__eyebrow {
    margin: 0 0 5px;
    font-family: 'Lato', sans-serif;
    font-size: 0.72rem;
    font-weight: 900;
    text-transform: uppercase;
    letter-spacing: 1.2px;
    color: var(--milaura-gold-dark, #8F723A);
  }

  .milaura-gift-popup__title {
    margin: 0;
    font-family: 'Playfair Display', serif;
    font-size: clamp(1.55rem, 3vw, 2rem);
    line-height: 1.05;
    color: #1a1a2e;
  }

  .milaura-gift-popup__text {
    margin: 0;
    font-family: 'Lato', sans-serif;
    font-size: 0.95rem;
    line-height: 1.5;
    color: #3e3e48;
  }

  .milaura-gift-popup__status {
    margin: 0;
    padding: 12px 14px;
    border-radius: 14px;
    background: rgba(76, 103, 128, 0.09);
    border: 1px solid rgba(76, 103, 128, 0.18);
    color: var(--milaura-blue, #4C6780);
    font-family: 'Lato', sans-serif;
    font-size: 0.82rem;
    font-weight: 900;
    line-height: 1.35;
  }

  .milaura-gift-popup__status[hidden] {
    display: none;
  }

  .milaura-gift-popup__status.is-success {
    background: rgba(48, 116, 79, 0.09);
    border-color: rgba(48, 116, 79, 0.22);
    color: #2e714d;
  }

  .milaura-gift-popup__status.is-error {
    background: rgba(138, 64, 52, 0.09);
    border-color: rgba(138, 64, 52, 0.2);
    color: #8a4034;
  }

  .milaura-gift-popup__note {
    margin: 0;
    padding: 12px 14px;
    border-radius: 14px;
    background: #FDFBF7;
    border: 1px solid rgba(192, 160, 98, 0.22);
    font-family: 'Lato', sans-serif;
    font-size: 0.82rem;
    line-height: 1.45;
    color: rgba(26, 26, 46, 0.78);
  }

  .milaura-gift-popup__note[hidden] {
    display: none;
  }

  .milaura-gift-popup__actions {
    display: grid;
    grid-template-columns: 1fr;
    gap: 9px;
  }

  .milaura-gift-popup__primary,
  .milaura-gift-popup__secondary {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    min-height: 46px;
    padding: 0 18px;
    border-radius: 999px;
    font-family: 'Lato', sans-serif;
    font-size: 0.86rem;
    font-weight: 900;
    line-height: 1.1;
    text-decoration: none;
    border: 0;
    cursor: pointer;
    letter-spacing: 0;
  }

  .milaura-gift-popup__primary[hidden],
  .milaura-gift-popup__secondary[hidden] {
    display: none;
  }

  .milaura-gift-popup__primary {
    background: #1a1a2e;
    color: #E6C88B;
  }

  .milaura-gift-popup__secondary {
    background: rgba(255, 255, 255, 0.72);
    color: #1a1a2e;
    border: 1px solid rgba(192, 160, 98, 0.28);
  }

  .milaura-gift-popup__primary:disabled,
  .milaura-gift-popup__secondary:disabled,
  .milaura-gift-popup__secondary.is-disabled {
    opacity: 0.54;
    cursor: wait;
    pointer-events: none;
  }

  @media screen and (max-width: 749px) {
    .milaura-gift-popup {
      align-items: end;
      place-items: end center;
      padding: max(10px, env(safe-area-inset-top)) 8px max(10px, env(safe-area-inset-bottom));
    }

    .milaura-gift-popup__card {
      width: min(100%, 430px);
      max-height: calc(100dvh - 26px - env(safe-area-inset-top) - env(safe-area-inset-bottom));
      border-radius: 24px;
      animation: milauraGiftSheetIn 0.28s cubic-bezier(.2,.8,.2,1);
    }

    .milaura-gift-popup__handle {
      display: block;
      width: 42px;
      height: 4px;
      border-radius: 999px;
      background: rgba(26, 26, 46, 0.16);
      margin: 10px auto 0;
    }

    .milaura-gift-popup__body {
      gap: 13px;
      padding: 16px 16px 18px;
    }

    .milaura-gift-popup__close {
      top: 12px;
      right: 12px;
      width: 38px;
      height: 38px;
      box-shadow: 0 8px 18px rgba(26, 26, 46, 0.12);
    }

    .milaura-gift-popup__reward {
      grid-template-columns: 52px minmax(0, 1fr);
      gap: 12px;
      padding-right: 42px;
    }

    .milaura-gift-popup__burst {
      width: 52px;
      height: 52px;
      border-radius: 16px;
      font-size: 1.55rem;
    }

    .milaura-gift-popup__title {
      font-size: clamp(1.28rem, 5.6vw, 1.62rem);
      line-height: 1.08;
    }

    .milaura-gift-popup__text {
      font-size: 0.86rem;
      line-height: 1.42;
    }

    .milaura-gift-popup__status,
    .milaura-gift-popup__note {
      padding: 10px 12px;
      font-size: 0.76rem;
      line-height: 1.34;
    }

    .milaura-gift-popup__actions {
      gap: 8px;
    }
  }

  @keyframes milauraGiftSheetIn {
    0% { transform: translateY(18px); opacity: 0; }
    100% { transform: translateY(0); opacity: 1; }
  }

  /* Desktop (>= 750px) - grid 3 cols, taille auto, ratio carre */
  @media screen and (min-width: 750px) {
    .milaura-scratch-cards {
      gap: 14px;
    }

    .milaura-hero-scratch {
      margin-bottom: 26px;
    }

    .milaura-scratch-divider::before,
    .milaura-scratch-divider::after {
      max-width: 120px;
    }
  }

  /* Mobile (< 750px) - meme taille que les bundle tiers (auto via grid 1fr) */
  @media screen and (max-width: 749px) {
    .milaura-bundle-selector {
      margin-bottom: 18px;
    }

    .milaura-scratch-divider {
      padding: 16px 0 12px;
      margin-top: 4px;
    }

    .milaura-scratch-header {
      align-items: flex-start;
      gap: 10px;
