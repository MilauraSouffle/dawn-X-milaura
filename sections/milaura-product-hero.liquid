    border-bottom: 1px solid rgba(143, 114, 58, 0.35);
  }
  .milaura-info-description .read-more-link:hover {
    color: var(--milaura-gold, #C0A062);
    border-bottom-color: var(--milaura-gold, #C0A062);
  }

  .milaura-gallery-story__karine--mobile {
    display: flex;
    align-items: center;
    gap: 12px;
    margin-top: 2px;
    padding: 14px;
    border: 1px solid rgba(192, 160, 98, 0.22);
    border-radius: 16px;
    background: linear-gradient(135deg, rgba(255, 255, 255, 0.92), rgba(253, 248, 239, 0.78));
