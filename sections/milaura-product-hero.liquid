  /* Video bubble — hidden on mobile (uses slide instead) */
  @media screen and (max-width: 989px) {
    .milaura-video-bubble-wrapper {
      display: none !important;
    }
  }

  /* ===========================================
     MOBILE THUMBNAIL STRIP
     =========================================== */
  .milaura-thumb-strip {
    display: flex;
    gap: 8px;
    overflow-x: auto;
    -webkit-overflow-scrolling: touch;
    scrollbar-width: none;
    padding: 10px 4px 4px;
    justify-content: center;
    flex-wrap: nowrap;
  }

  .milaura-thumb-strip::-webkit-scrollbar {
    display: none;
  }

  .milaura-thumb-strip__item {
    flex: 0 0 auto;
    width: 56px;
    height: 56px;
    border-radius: 8px;
    overflow: hidden;
    border: 2px solid transparent;
    background: var(--milaura-beige, #FDFBF7);
    cursor: pointer;
    position: relative;
    padding: 0;
    transition: border-color 0.2s ease, box-shadow 0.2s ease;
  }

  .milaura-thumb-strip__item.is-active {
    border-color: var(--milaura-gold, #C0A062);
    box-shadow: 0 2px 8px rgba(192, 160, 98, 0.3);
  }

  .milaura-thumb-strip__img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }

  .milaura-thumb-strip__item--video {
    position: relative;
  }

  .milaura-thumb-strip__video-overlay {
    position: absolute;
    top: 0; left: 0;
    width: 100%;
    height: 100%;
    display: flex;
    align-items: center;
    justify-content: center;
    background: rgba(0, 0, 0, 0.15);
    pointer-events: none;
  }

  .milaura-thumb-strip__item--video iframe {
    position: absolute;
    top: 0; left: 0;
    width: 100%;
    height: 100%;
    border: none;
    pointer-events: none;
  }

  .milaura-thumb-strip__item--video.has-autoplay .milaura-thumb-strip__video-overlay {
    background: transparent;
  }

  .milaura-thumb-strip__item--video.has-autoplay .milaura-thumb-strip__video-overlay svg {
    opacity: 0;
    transition: opacity 0.2s ease;
  }

  .milaura-thumb-strip__item--video:hover .milaura-thumb-strip__video-overlay svg {
    opacity: 1;
  }

  /* Desktop : hide thumb strip (thumbnails are already inline) */
  @media screen and (min-width: 990px) {
    .milaura-thumb-strip {
      display: none;
    }
  }

  /* ===========================================
     SPOTLIGHT DESKTOP THUMBNAIL (outside slider)
     =========================================== */
  .milaura-spotlight-desktop-thumb {
    display: none; /* Hidden on mobile — mobile uses carousel slide */
  }

  @media screen and (min-width: 990px) {
    .milaura-spotlight-desktop-thumb {
      display: inline-block;
      cursor: pointer;
      transition: box-shadow 0.3s ease, border-color 0.3s ease;
    }

    .milaura-spotlight-desktop-thumb__img-wrap {
      width: 80px;
      height: 80px;
      border-radius: 10px;
      overflow: hidden;
      border: 2px solid rgba(192, 160, 98, 0.3);
      position: relative;
      background: var(--milaura-beige, #FDFBF7);
    }

    .milaura-spotlight-desktop-thumb:hover .milaura-spotlight-desktop-thumb__img-wrap {
      border-color: var(--milaura-gold, #C0A062);
      box-shadow: 0 4px 16px rgba(192, 160, 98, 0.25);
    }

    .milaura-spotlight-desktop-thumb__img {
      width: 100%;
      height: 100%;
      object-fit: cover;
      display: block;
    }
  }

  @media (prefers-reduced-motion: reduce) {
    *, *::before, *::after {
      transition: none !important;
      animation: none !important;
    }
  }

  /* ===========================================
     SCRATCH-TO-REVEAL (Cartes a gratter) - Premium
     =========================================== */

  /* Wrapper grid-area pour le scratch complet */
  .milaura-scratch-zone {
    grid-area: scratch;
    width: 100%;
  }

  /* ===========================================
     BUNDLE SELECTOR (au-dessus du scratch)
     =========================================== */
  .milaura-bundle-selector {
    width: 100%;
    margin-bottom: 24px;
  }

  .milaura-bundle-header {
    text-align: center;
    margin-bottom: 16px;
  }

  .milaura-bundle-title {
    font-family: 'Playfair Display', serif;
    font-size: 1.55rem;
    font-weight: 600;
    color: var(--milaura-text, #000);
    margin: 0 0 6px;
    line-height: 1.2;
  }

  .milaura-bundle-subtitle {
    font-family: 'Lato', sans-serif;
    font-size: 0.95rem;
    color: #555;
    margin: 0;
    line-height: 1.4;
  }

  .milaura-bundle-tiers {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 10px;
  }

  .milaura-bundle-tier {
    background: #fff;
    border: 2px solid rgba(192, 160, 98, 0.18);
    border-radius: 14px;
    padding: 14px 8px 12px;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: space-between;
    text-align: center;
    cursor: pointer;
    position: relative;
    transition: border-color 0.2s ease, background 0.2s ease, box-shadow 0.2s ease, transform 0.2s ease;
    min-height: 130px;
  }

  .milaura-bundle-tier:hover {
    border-color: rgba(192, 160, 98, 0.4);
    transform: translateY(-2px);
  }

  .milaura-bundle-tier.is-selected {
    background: linear-gradient(180deg, #FFFCF5, var(--milaura-beige, #FDFBF7));
    border-color: var(--milaura-gold, #C0A062);
    box-shadow: 0 6px 18px rgba(192, 160, 98, 0.18);
  }

  .milaura-bundle-badge {
    position: absolute;
    top: -10px;
    left: 50%;
    transform: translateX(-50%);
    background: linear-gradient(135deg, #1a1a2e, #2d2d44);
    color: var(--milaura-gold-light, #E6C88B);
    font-family: 'Lato', sans-serif;
    font-size: 0.58rem;
    font-weight: 700;
    padding: 4px 10px;
    border-radius: 10px;
    letter-spacing: 0.5px;
    text-transform: uppercase;
    white-space: nowrap;
    box-shadow: 0 3px 8px rgba(26, 26, 46, 0.25);
  }

  .milaura-bundle-tier-left {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 6px;
    width: 100%;
  }

  .milaura-bundle-tier-icon {
    width: 40px;
    height: 40px;
    background: var(--milaura-beige, #FDFBF7);
    border-radius: 10px;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 1.4rem;
    flex-shrink: 0;
    transition: background 0.2s ease;
  }

  .milaura-bundle-tier.is-selected .milaura-bundle-tier-icon {
    background: #fff;
    box-shadow: 0 2px 6px rgba(192, 160, 98, 0.18);
  }

  .milaura-bundle-tier-text {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 2px;
  }

  .milaura-bundle-tier-label {
    font-family: 'Playfair Display', serif;
    font-size: 1.1rem;
    font-weight: 700;
    color: var(--milaura-text, #000);
    line-height: 1.15;
  }

  .milaura-bundle-tier-sub {
    font-family: 'Lato', sans-serif;
    font-size: 0.8rem;
    color: var(--milaura-gold-dark, #8F723A);
    font-style: italic;
    line-height: 1.25;
    margin-top: 3px;
  }

  .milaura-bundle-tier-price {
    text-align: center;
    margin-top: 8px;
  }

  .milaura-bundle-tier-current {
    font-family: 'Lato', sans-serif;
    font-size: 1.15rem;
    font-weight: 800;
    color: var(--milaura-text, #000);
    line-height: 1.1;
  }

  .milaura-bundle-tier-compare {
    font-family: 'Lato', sans-serif;
    font-size: 0.7rem;
    color: #aaa;
    text-decoration: line-through;
    margin-top: 1px;
  }

  @media screen and (max-width: 749px) {
    .milaura-bundle-tiers {
      gap: 8px;
    }
    .milaura-bundle-tier {
      padding: 14px 8px 12px;
      min-height: 135px;
    }
    .milaura-bundle-tier-icon {
      width: 36px;
      height: 36px;
      font-size: 1.2rem;
    }
    .milaura-bundle-tier-label {
      font-size: 0.98rem;
    }
    .milaura-bundle-tier-sub {
      font-size: 0.72rem;
    }
    .milaura-bundle-tier-current {
      font-size: 1rem;
    }
    .milaura-bundle-tier-compare {
      font-size: 0.72rem;
    }
    .milaura-bundle-badge {
      font-size: 0.58rem;
      padding: 4px 10px;
    }
    .milaura-bundle-title {
      font-size: 1.35rem;
    }
    .milaura-bundle-subtitle {
      font-size: 0.88rem;
    }
  }

  /* Separateur elegant */
  .milaura-scratch-divider {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 14px;
    padding: 20px 0;
    width: 100%;
  }

  .milaura-scratch-divider::before,
  .milaura-scratch-divider::after {
    content: '';
    flex: 1;
    max-width: 80px;
    height: 1px;
    background: linear-gradient(90deg, transparent, var(--milaura-gold, #C0A062), transparent);
  }

  .milaura-scratch-divider-text {
    font-family: 'Lato', sans-serif;
    font-size: 0.95rem;
    font-weight: 700;
    letter-spacing: 2px;
    text-transform: uppercase;
    color: var(--milaura-gold, #C0A062);
    white-space: normal;
    text-align: center;
    padding: 0 8px;
  }

  /* Conteneur scratch : sans cadre/padding, les cartes flottent libres */
  .milaura-hero-scratch {
    width: 100%;
    background: transparent;
    border: none;
    box-shadow: none;
    padding: 0;
    box-sizing: border-box;
    position: relative;
    overflow: visible;
  }

  /* Header : titre + badge compteur */
  .milaura-scratch-header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    margin-bottom: 12px;
  }

  .milaura-scratch-title {
    font-family: 'Playfair Display', serif;
    font-style: italic;
    font-size: 1.1rem;
    font-weight: 600;
    color: var(--milaura-text, #000);
    margin: 0;
    line-height: 1.3;
  }

  .milaura-scratch-counter {
    display: inline-block;
    font-family: 'Lato', sans-serif;
    font-size: 0.75rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.5px;
    background: #F2E8D5;
    color: var(--milaura-gold-dark, #8F723A);
    padding: 4px 12px;
    border-radius: 20px;
    white-space: nowrap;
    flex-shrink: 0;
    margin-left: 12px;
  }

  /* Grille des cartes : 3 cols comme le bundle tiers au-dessus */
  .milaura-scratch-cards {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 10px;
    margin-bottom: 0;
  }

  /* Carte individuelle : grid 1fr donne la width, height fixe pour matcher bundle tier */
  .milaura-scratch-card {
    width: 100%;
    height: 130px;
    border-radius: 14px;
    position: relative;
    overflow: visible;
    cursor: pointer;
    transition: transform 0.3s ease;
  }

  .milaura-scratch-card-content {
    position: absolute;
    inset: 0;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    text-align: center;
    background: #fff;
    border: 1.5px solid rgba(192, 160, 98, 0.2);
    border-radius: 16px;
    padding: 10px 8px;
    transition: border-color 0.3s ease, background 0.3s ease;
  }

  .milaura-scratch-card-icon {
    font-size: 1.8rem;
    margin-bottom: 6px;
    line-height: 1;
    opacity: 0;
    transition: opacity 0.3s ease;
  }

  .milaura-scratch-card-name {
    font-family: 'Lato', sans-serif;
    font-size: 0.8rem;
    font-weight: 700;
    color: #333;
    line-height: 1.3;
    text-align: center;
    opacity: 0;
    transition: opacity 0.3s ease;
  }

  .milaura-scratch-card-value {
    font-family: 'Lato', sans-serif;
    font-size: 0.75rem;
    color: var(--milaura-gold, #C0A062);
    margin-top: 4px;
    font-weight: 600;
    opacity: 0;
    transition: opacity 0.3s ease;
  }

  /* Canvas overlay */
  .milaura-scratch-card canvas {
    position: absolute;
    inset: 0;
    border-radius: 16px;
    z-index: 2;
    touch-action: none;
    cursor: pointer;
  }

  /* Etat revele */
  .milaura-scratch-card.is-revealed canvas {
    display: none;
  }

  .milaura-scratch-card.is-revealed .milaura-scratch-card-content {
    border-color: rgba(192, 160, 98, 0.3);
    background: #fff;
  }

  .milaura-scratch-card.is-revealed .milaura-scratch-card-icon,
  .milaura-scratch-card.is-revealed .milaura-scratch-card-name,
  .milaura-scratch-card.is-revealed .milaura-scratch-card-value {
    opacity: 1;
  }

  /* Etat verrouille : cadenas gris, non grattable */
  .milaura-scratch-card.is-locked {
    cursor: not-allowed;
  }

  .milaura-scratch-card.is-locked::before {
    content: '';
    position: absolute;
    inset: 0;
    background: linear-gradient(135deg, #d8d8d8, #b8b8b8);
    border-radius: 16px;
    z-index: 3;
  }

  .milaura-scratch-card.is-locked::after {
    content: '';
    position: absolute;
    top: 50%;
    left: 50%;
    transform: translate(-50%, -50%);
    width: 32px;
    height: 32px;
    background-image: url("data:image/svg+xml;utf8,<svg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 24 24' fill='none' stroke='white' stroke-width='2' stroke-linecap='round' stroke-linejoin='round'><rect x='3' y='11' width='18' height='11' rx='2' ry='2'/><path d='M7 11V7a5 5 0 0 1 10 0v4'/></svg>");
    background-repeat: no-repeat;
    background-position: center;
    background-size: contain;
    opacity: 0.85;
    z-index: 4;
    pointer-events: none;
  }

  /* Animation bounce au reveal */
  @keyframes milauraScratchBounce {
    0% { transform: scale(1); }
    40% { transform: scale(1.05); }
    100% { transform: scale(1); }
  }

  .milaura-scratch-card.is-bouncing {
    animation: milauraScratchBounce 0.4s ease-out;
  }

  /* Confetti */
  @keyframes milauraScratchConfetti {
    0% { transform: translateY(-20px) rotate(0deg); opacity: 1; }
    100% { transform: translateY(120px) rotate(720deg); opacity: 0; }
  }

  .milaura-scratch-confetti {
    position: absolute;
    width: 7px;
    height: 7px;
    border-radius: 50%;
    animation: milauraScratchConfetti 1.2s ease-out forwards;
    pointer-events: none;
    z-index: 10;
  }

  /* Pill de confirmation */
  .milaura-scratch-pill {
    display: none;
    margin-top: 16px;
    text-align: center;
  }

  .milaura-scratch-pill.is-visible {
    display: block;
  }

  @keyframes milauraScratchPillIn {
    0% { opacity: 0; transform: translateY(8px); }
    100% { opacity: 1; transform: translateY(0); }
  }

  .milaura-scratch-pill-inner {
    display: inline-block;
    background: linear-gradient(135deg, #1a1a2e, #2d2d44);
    color: #E6C88B;
    font-family: 'Lato', sans-serif;
    font-size: 0.8rem;
    font-weight: 600;
    border-radius: 20px;
    padding: 10px 18px;
    line-height: 1.4;
    max-width: 100%;
    word-wrap: break-word;
    box-shadow: 0 6px 18px rgba(26, 26, 46, 0.22);
    animation: milauraScratchPillIn 0.4s ease-out;
  }

  /* Desktop (>= 750px) - grid 3 cols, taille auto, ratio carre */
  @media screen and (min-width: 750px) {
    .milaura-scratch-cards {
      gap: 14px;
    }

    .milaura-scratch-divider::before,
    .milaura-scratch-divider::after {
      max-width: 120px;
    }
  }

  /* Mobile (< 750px) - meme taille que les bundle tiers (auto via grid 1fr) */
  @media screen and (max-width: 749px) {
    .milaura-scratch-cards {
      gap: 8px;
    }

    .milaura-scratch-card {
      height: 120px;
    }

    .milaura-scratch-title {
      font-size: 1rem;
    }

    .milaura-scratch-card-icon {
      font-size: 1.6rem;
    }

    .milaura-scratch-card-name {
      font-size: 0.75rem;
    }

    .milaura-scratch-card-value {
      font-size: 0.7rem;
    }

    .milaura-hero-scratch {
      padding: 12px;
    }
  }

  /* Petit mobile (< 380px) */
  @media screen and (max-width: 379px) {
    .milaura-scratch-cards {
      gap: 6px;
    }

    .milaura-scratch-card {
      height: 105px;
    }

    .milaura-scratch-card-icon {
      font-size: 1.4rem;
    }

    .milaura-scratch-card-name {
      font-size: 0.7rem;
    }
  }

  /* ============================================
     SOCIAL PROOF BLOCK + DESCRIPTION COMPACT + CTA BUNDLE-AWARE
     Refonte 2026-05-28 : col droite simplifiee
     ============================================ */
  .milaura-hero-social {
    display: flex;
    align-items: center;
    gap: 12px;
    padding: 12px 18px;
    background: linear-gradient(135deg, #1a1a2e, #2d2d44);
    border-radius: 14px;
    border: 1px solid rgba(192, 160, 98, 0.35);
    margin-bottom: var(--milaura-spacing-sm);
    box-shadow: 0 6px 18px rgba(26, 26, 46, 0.18);
  }

  /* Variante : bulle social au-dessus de la galerie (mobile : tout premier element) */
  .milaura-hero-social--top {
    order: 0;
    width: 100%;
    margin-top: 14px;
    margin-bottom: 10px;
  }
  @media screen and (min-width: 990px) {
    .milaura-hero-social--top {
      grid-area: social;
      margin-top: 0;
      margin-bottom: 4px;
    }
  }

  /* Variante : badges metafield entre bulle bleue et galerie (mobile sur 1 ligne, centres) */
  .milaura-meta-badges--top {
    order: 0;
    width: 100%;
    display: flex;
    justify-content: center;
    align-items: center;
    flex-wrap: nowrap;
    gap: 6px;
    margin: 4px 0 12px;
    overflow-x: auto;
    scrollbar-width: none;
    -ms-overflow-style: none;
  }
  .milaura-meta-badges--top::-webkit-scrollbar { display: none; }
  .milaura-meta-badges--top .milaura-meta-badge {
    flex-shrink: 0;
  }
  @media screen and (min-width: 990px) {
    .milaura-meta-badges--top {
      grid-area: meta;
      margin: 0 0 8px;
    }
  }

  .milaura-hero-stars {
    font-size: 1.15rem;
    color: var(--milaura-gold-light, #E6C88B);
    letter-spacing: 2px;
    flex-shrink: 0;
    line-height: 1;
    text-shadow: 0 1px 2px rgba(0, 0, 0, 0.25);
  }

  .milaura-hero-social-text {
    font-size: 0.82rem;
    line-height: 1.4;
    color: var(--milaura-gold-light, #E6C88B);
    margin: 0;
  }

  .milaura-hero-social-text strong {
    color: #FFFFFF;
    font-weight: 700;
  }

  /* Info block (apres CTA) : description + badges metafield + bulle social */
  .milaura-info-block {
    margin-top: var(--milaura-spacing-md, 18px);
    padding-top: var(--milaura-spacing-md, 18px);
    border-top: 1px solid rgba(192, 160, 98, 0.18);
    display: flex;
    flex-direction: column;
    gap: var(--milaura-spacing-sm, 12px);
  }
  .milaura-info-description {
    font-size: 0.85rem;
    line-height: 1.55;
    color: var(--milaura-text, #000);
  }
  .milaura-info-description .read-more-link {
    color: var(--milaura-gold-dark, #8F723A);
    font-weight: 600;
    text-decoration: none;
    border-bottom: 1px solid rgba(143, 114, 58, 0.35);
  }
  .milaura-info-description .read-more-link:hover {
    color: var(--milaura-gold, #C0A062);
    border-bottom-color: var(--milaura-gold, #C0A062);
  }
  .milaura-info-block .milaura-hero-social {
    margin-bottom: 0;
  }
  @media (max-width: 768px) {
    .milaura-info-block {
      margin-top: var(--milaura-spacing-sm, 12px);
      padding-top: var(--milaura-spacing-sm, 12px);
    }
    .milaura-info-description {
      font-size: 0.82rem;
    }
  }

  /* CTA bundle-aware : premium gold avec icone panier + shimmer, texte NOIR */
  .milaura-hero-cta-bundle {
    position: relative;
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 14px;
    width: 100%;
    padding: 18px 28px;
    margin-top: var(--milaura-spacing-md, 18px);
    background: linear-gradient(135deg, #8F723A 0%, #C0A062 45%, #E6C88B 100%);
    color: #000000;
    border: none;
    border-radius: 16px;
    font-family: var(--milaura-font-heading, 'Playfair Display'), serif;
    font-size: 1.1rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 1.5px;
    cursor: pointer;
    box-shadow:
      0 12px 30px rgba(192, 160, 98, 0.35),
      0 2px 6px rgba(143, 114, 58, 0.25),
      inset 0 1px 0 rgba(255, 255, 255, 0.25);
    overflow: hidden;
    transition: transform 0.25s ease, box-shadow 0.25s ease;
    isolation: isolate;
  }

  /* Shimmer band qui glisse au hover */
  .milaura-hero-cta-bundle::before {
    content: '';
    position: absolute;
    inset: 0;
    background: linear-gradient(
      120deg,
      transparent 0%,
      transparent 35%,
      rgba(255, 255, 255, 0.45) 50%,
      transparent 65%,
      transparent 100%
    );
    transform: translateX(-100%);
    transition: transform 0.9s ease;
    pointer-events: none;
    z-index: 1;
  }

  .milaura-hero-cta-bundle:hover::before {
    transform: translateX(100%);
  }

  .milaura-hero-cta-bundle:hover {
    transform: translateY(-2px);
    box-shadow:
      0 18px 40px rgba(192, 160, 98, 0.45),
      0 4px 10px rgba(143, 114, 58, 0.3),
      inset 0 1px 0 rgba(255, 255, 255, 0.35);
  }

  .milaura-hero-cta-bundle:active {
    transform: translateY(0);
  }

  .milaura-hero-cta-bundle:disabled {
    opacity: 0.7;
    cursor: not-allowed;
    transform: none;
  }

  .milaura-hero-cta-bundle > * {
    position: relative;
    z-index: 2;
  }

  .milaura-cta-icon {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 28px;
    height: 28px;
    flex-shrink: 0;
  }

  .milaura-cta-icon svg {
    width: 100%;
    height: 100%;
    stroke: #000000;
    fill: none;
    stroke-width: 2;
    filter: drop-shadow(0 1px 1px rgba(255, 255, 255, 0.25));
  }

  .milaura-cta-label {
    flex: 1;
    text-align: center;
  }

  .milaura-cta-price {
    font-weight: 800;
    font-size: 1.15rem;
    color: #000000;
    background: rgba(0, 0, 0, 0.08);
    padding: 6px 14px;
    border-radius: 10px;
    backdrop-filter: blur(2px);
    flex-shrink: 0;
  }

  /* Phrase reassurance sous CTA supprimee (cf user request 2026-05-28) */
  .milaura-hero-cta-reassurance { display: none; }

  /* Desktop : grid avec social + meta full width + gallery/rightcol (header + actions ensembles).
     Refonte 2026-05-28 evening : header + actions wrappes ensemble pour eviter le trou vertical. */
  @media screen and (min-width: 990px) {
    .milaura-hero-wrapper {
      grid-template-areas:
        "social   social"
        "meta     meta"
        "gallery  rightcol" !important;
      grid-template-rows: auto auto auto !important;
      align-items: start;
      row-gap: 12px;
    }

    .milaura-hero-rightcol {
      grid-area: rightcol;
      display: flex;
      flex-direction: column;
      gap: 18px;
      align-self: start;
      position: sticky;
      top: calc(var(--header-height, 80px) + 20px);
    }

    .milaura-hero-header-group {
      grid-area: auto !important;
      position: static !important;
      background: transparent !important;
      border: none !important;
      padding: 0 !important;
      margin: 0;
      text-align: left;
    }

    .milaura-hero-actions-group {
      grid-area: auto !important;
      position: static !important;
      align-self: stretch;
      gap: 12px;
    }

    .milaura-video-bubble-wrapper {
      display: none;
    }

    /* Pills metafield : 1 ligne centree au-dessus de la galerie, plus de absolute */
    .milaura-meta-badges {
      position: static;
      padding: 0;
      pointer-events: auto;
    }
  }

  /* ===========================================
     GALLERY STORY (desktop only) : description + Karine signature
     Affiche sous la galerie pour exploiter le vide gauche et humaniser.
     =========================================== */
  .milaura-gallery-story {
    display: none;
  }

  @media screen and (min-width: 990px) {
    .milaura-gallery-story {
      display: block;
      margin-top: 32px;
      padding-top: 32px;
      border-top: 1px solid rgba(192, 160, 98, 0.2);
    }

    .milaura-gallery-story__description {
      font-family: 'Lato', sans-serif;
      font-size: 0.95rem;
      line-height: 1.7;
      color: var(--milaura-text, #000);
    }

    .milaura-gallery-story__description p {
      margin: 0 0 12px;
      display: inline;
    }

    .milaura-gallery-story__read-more {
      display: inline;
      margin-left: 4px;
      color: var(--milaura-gold-dark, #8F723A);
      font-weight: 600;
      text-decoration: none;
      border-bottom: 1px solid rgba(143, 114, 58, 0.4);
      transition: color 0.18s ease, border-color 0.18s ease;
      white-space: nowrap;
    }

    .milaura-gallery-story__read-more:hover {
      color: var(--milaura-gold, #C0A062);
      border-bottom-color: var(--milaura-gold, #C0A062);
    }

    .milaura-gallery-story__karine {
      display: flex;
      align-items: center;
      gap: 18px;
      margin-top: 28px;
      padding-top: 24px;
      border-top: 1px solid rgba(192, 160, 98, 0.2);
    }

    .milaura-gallery-story__karine-img {
      flex-shrink: 0;
      width: 88px;
      height: 88px;
      border-radius: 50%;
      object-fit: cover;
      border: 2px solid var(--milaura-gold, #C0A062);
      box-shadow: 0 6px 18px rgba(192, 160, 98, 0.22);
    }

    .milaura-gallery-story__karine-content {
      flex: 1;
      min-width: 0;
    }

    .milaura-gallery-story__quote {
      font-family: 'Playfair Display', serif;
      font-size: 0.98rem;
      font-style: italic;
      line-height: 1.55;
      color: var(--milaura-text, #000);
      margin: 0 0 10px;
    }

    .milaura-gallery-story__signature {
      font-family: 'Dancing Script', cursive;
      font-size: 1.9rem;
      line-height: 1;
      color: var(--milaura-gold-dark, #8F723A);
      margin: 0 0 2px;
      transform: rotate(-2deg);
      transform-origin: left center;
    }

    .milaura-gallery-story__author {
      font-family: 'Lato', sans-serif;
      font-size: 0.68rem;
      color: var(--milaura-gold-dark, #8F723A);
      letter-spacing: 1.4px;
      text-transform: uppercase;
      margin: 0;
      font-weight: 600;
    }

    /* Sur desktop, on cache la description dans l'info-block (col droite) : elle est maintenant dans gallery story */
    .milaura-hero-actions-group .milaura-info-block {
      display: none;
    }
  }

  /* Mobile : compact + galerie max 60vh */
  @media screen and (max-width: 768px) {
    .milaura-hero-social {
      padding: 10px 14px;
      gap: 10px;
    }
    .milaura-hero-social-text {
      font-size: 0.75rem;
    }
    .milaura-hero-cta-bundle {
      padding: 14px 20px;
      font-size: 0.95rem;
    }
    .milaura-hero-cta-reassurance {
      font-size: 0.65rem;
    }
    .product__media-wrapper,
    .milaura-hero-gallery,
    .product-media-container {
      max-height: 60vh;
    }
  }
{% endstyle %}

<script src="{{ 'product-info.js' | asset_url }}" defer="defer"></script>
<script src="{{ 'product-form.js' | asset_url }}" defer="defer"></script>

<div class="page-width section-{{ section.id }}-padding">
  <product-info id="ProductInfo-{{ section.id }}" data-section="{{ section.id }}" data-url="{{ product.url }}">
    <div class="milaura-hero-wrapper">
      {%- comment -%} GROUPE 1 HEADER deplace dans .milaura-hero-rightcol (avec actions group) pour eviter le trou vertical sur desktop. Refonte 2026-05-28 evening. {%- endcomment -%}

      {%- comment -%} Bulle social proof au-dessus de la galerie (refonte 2026-05-28, demande user mobile).
        Le nombre de client(e)s varie par produit via calcul deterministe base sur product.id (entre 12 et 141). {%- endcomment -%}
      {%- if section.settings.show_social_proof -%}
        {%- assign months_fr = "janvier,fevrier,mars,avril,mai,juin,juillet,aout,septembre,octobre,novembre,decembre" | split: "," -%}
        {%- assign month_idx = "now" | date: "%-m" | minus: 1 -%}
        {%- assign month_fr = months_fr[month_idx] -%}
        {%- assign year_fr = "now" | date: "%Y" -%}
        {%- comment -%} Calcul deterministe : meme produit = meme nombre, varie entre 12 et 141. {%- endcomment -%}
        {%- assign social_count_raw = product.id | default: 0 | modulo: 130 -%}
        {%- assign social_count = social_count_raw | plus: 12 -%}
        <div class="milaura-hero-social milaura-hero-social--top">
          <div class="milaura-hero-stars" aria-label="5 etoiles sur 5">
            <span aria-hidden="true">&#9733;&#9733;&#9733;&#9733;&#9733;</span>
          </div>
          <p class="milaura-hero-social-text">
            Ce produit a deja fait le bonheur de
            <strong>+ de {{ social_count }} client(e)s</strong>
            en {{ month_fr }} {{ year_fr }}
          </p>
        </div>
      {%- endif -%}

      {%- comment -%} Badges metafield entre bulle bleue et galerie (refonte 2026-05-28, mobile sur 1 ligne) {%- endcomment -%}
      {%- assign badge_energy = product.metafields.milaura.energy_handle -%}
      {%- assign badge_stone = product.metafields.milaura.stone_handle -%}
      {%- assign badge_vertus = product.metafields.milaura.vertus -%}
      {%- assign badge_quality = product.metafields.milaura.qualite -%}
      {%- assign has_meta_badges = false -%}
      {%- if badge_energy != blank or badge_stone != blank or badge_vertus != blank or badge_quality != blank -%}
        {%- assign has_meta_badges = true -%}
      {%- endif -%}
      {%- if has_meta_badges -%}
        <div class="milaura-meta-badges milaura-meta-badges--top">
          {%- if badge_stone != blank -%}
            <span class="milaura-meta-badge">
              <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                <path d="M12 2L2 7l10 5 10-5-10-5zM2 17l10 5 10-5M2 12l10 5 10-5"/>
              </svg>
              {{ badge_stone }}
            </span>
          {%- endif -%}
          {%- if badge_energy != blank -%}
            <span class="milaura-meta-badge">
              <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                <path d="M13 2L3 14h9l-1 8 10-12h-9l1-8z"/>
              </svg>
              {{ badge_energy }}
            </span>
          {%- endif -%}
          {%- if badge_vertus != blank -%}
            <span class="milaura-meta-badge">
              <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                <path d="M20.84 4.61a5.5 5.5 0 0 0-7.78 0L12 5.67l-1.06-1.06a5.5 5.5 0 0 0-7.78 7.78l1.06 1.06L12 21.23l7.78-7.78 1.06-1.06a5.5 5.5 0 0 0 0-7.78z"/>
              </svg>
              {{ badge_vertus }}
            </span>
          {%- endif -%}
          {%- if badge_quality != blank -%}
            <span class="milaura-meta-badge milaura-meta-badge--gold">
              <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                <path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/>
              </svg>
              {{ badge_quality }}
            </span>
          {%- endif -%}
        </div>
      {%- endif -%}

      <!--
        ============================================
        GROUPE 2: GALERIE MEDIA (MODERNE)
        ============================================
      -->
      <div class="milaura-hero-gallery-column">
        <slider-component class="slider-mobile-gutter">
          <ul id="Slider-{{ section.id }}" class="product__media-list list-unstyled slider slider--mobile" role="list">
            {%- if product.media.size == 0 -%}
              <li id="Slide-{{ section.id }}-1" class="product__media-item slider__slide">
                <div class="product-media-container">
                  {{ 'product-1' | placeholder_svg_tag: 'placeholder-svg' }}
                </div>
              </li>
            {%- endif -%}

            {%- for media in product.media -%}
              <li
                id="Slide-{{ section.id }}-{{ forloop.index }}"
                class="product__media-item slider__slide{% if media.media_type != 'image' %} product__media-item--video{% endif %}"
                data-media-id="{{ section.id }}-{{ media.id }}"
              >
                <div class="product-media-container">
                  {% case media.media_type %}
                    {% when 'image' %}
                      {%- if forloop.first -%}
                        {{
                          media
                          | image_url: width: 1200
                          | image_tag:
                            loading: 'eager',
                            fetchpriority: 'high',
                            class: 'image-magnify-hover',
                            sizes: '(min-width: 1200px) 600px, 100vw'
                        }}
                      {%- else -%}
                        {{
                          media
                          | image_url: width: 1200
                          | image_tag:
                            loading: 'lazy',
                            class: 'image-magnify-hover',
                            sizes: '(min-width: 1200px) 600px, 100vw'
                        }}
                      {%- endif -%}

                    {% when 'external_video' %}
                      {% assign video_class = 'js-youtube' %}
                      {% if media.host == 'vimeo' %}{% assign video_class = 'js-vimeo' %}{% endif %}
                      {{
                        media
                        | external_video_url: autoplay: true, loop: true, playlist: media.external_id
                        | external_video_tag: class: video_class, loading: 'lazy'
                      }}

                    {% when 'video' %}
                      {{
                        media
                        | video_tag: image_size: '1200x', autoplay: true, loop: true, controls: true, preload: 'none'
                      }}

                    {% when 'model' %}
                      {{ media | model_viewer_tag }}
                  {% endcase %}
                </div>
              </li>
            {%- endfor -%}

            {%- comment -%} ========== SPOTLIGHT SLIDE ========== {%- endcomment -%}
            {%- assign extra_slides_count = 0 -%}
            {%- if section.settings.show_spotlight and section.settings.spotlight_image != blank -%}
              {%- assign spotlight_index = product.media.size | plus: 1 -%}
              <li
                id="Slide-{{ section.id }}-{{ spotlight_index }}"
                class="product__media-item slider__slide product__media-item--spotlight"
                data-media-id="{{ section.id }}-spotlight"
              >
                <div class="product-media-container milaura-spotlight-slide-wrapper">
                  <div class="milaura-spotlight-container">
                    {{
                      section.settings.spotlight_image
                      | image_url: width: 1200
                      | image_tag: loading: 'lazy', class: 'milaura-spotlight-image', sizes: '(min-width: 1200px) 600px, 100vw'
                    }}
                    {%- for i in (1..3) -%}
                      {%- assign title_key = 'spotlight_' | append: i | append: '_title' -%}
                      {%- assign desc_key = 'spotlight_' | append: i | append: '_desc' -%}
                      {%- assign x_key = 'spotlight_' | append: i | append: '_x' -%}
                      {%- assign y_key = 'spotlight_' | append: i | append: '_y' -%}
                      {%- assign hs_title = section.settings[title_key] -%}
                      {%- assign hs_desc = section.settings[desc_key] -%}
                      {%- assign hs_x = section.settings[x_key] -%}
                      {%- assign hs_y = section.settings[y_key] -%}
                      {%- if hs_title != blank -%}
                        <div
                          class="milaura-hotspot"
                          style="left: {{ hs_x }}%; top: {{ hs_y }}%;"
                          data-index="{{ i }}"
                        >
                          <button class="milaura-hotspot-btn" aria-label="Voir le detail : {{ hs_title | escape }}">
                            <span class="milaura-hotspot-pulse"></span>
                            <span class="milaura-hotspot-inner">+</span>
                          </button>
                          <div class="milaura-hotspot-tooltip">
                            <div class="milaura-hotspot-tooltip-content">
                              <h4>{{ hs_title }}</h4>
                              <div class="rte">{{ hs_desc }}</div>
                            </div>
                          </div>
                        </div>
                      {%- endif -%}
                    {%- endfor -%}
                  </div>
                </div>
              </li>
              {%- assign extra_slides_count = extra_slides_count | plus: 1 -%}
            {%- endif -%}

            {%- comment -%} ========== VIDEO SLIDE (mobile carousel only, hidden desktop) ========== {%- endcomment -%}
            {%- if section.settings.show_video_slide and section.settings.video_url != blank -%}
              {%- assign video_slide_index = product.media.size | plus: extra_slides_count | plus: 1 -%}
              <li
                id="Slide-{{ section.id }}-{{ video_slide_index }}"
                class="product__media-item slider__slide product__media-item--video-slide"
                data-media-id="{{ section.id }}-video"
              >
                <div class="product-media-container milaura-video-main-container" data-video-url="{{ section.settings.video_url }}">
                  {%- if section.settings.video_poster != blank -%}
                    {{ section.settings.video_poster | image_url: width: 1200 | image_tag: loading: 'lazy', class: 'milaura-video-main-poster' }}
                    <button class="milaura-video-main-play" aria-label="Lire la video">
                      <svg width="56" height="56" viewBox="0 0 56 56" fill="none"><circle cx="28" cy="28" r="28" fill="rgba(0,0,0,0.45)"/><path d="M22 17L40 28L22 39V17Z" fill="white"/></svg>
                    </button>
                  {%- else -%}
                    <div class="milaura-video-main-placeholder">
                      <svg width="56" height="56" viewBox="0 0 56 56" fill="none"><circle cx="28" cy="28" r="28" fill="rgba(192,160,98,0.2)"/><path d="M22 17L40 28L22 39V17Z" fill="var(--milaura-gold, #C0A062)"/></svg>
                    </div>
                  {%- endif -%}
                </div>
              </li>
            {%- endif -%}

          </ul>

          <!-- Navigation Fleches (Mobile/Tablette) -->
          {%- assign total_slides = product.media.size -%}
          {%- if section.settings.show_spotlight and section.settings.spotlight_image != blank -%}
            {%- assign total_slides = total_slides | plus: 1 -%}
          {%- endif -%}
          {%- if section.settings.show_video_slide and section.settings.video_url != blank -%}
            {%- assign total_slides = total_slides | plus: 1 -%}
          {%- endif -%}
          {%- if total_slides > 1 -%}
            <button
              type="button"
              class="slider-button slider-button--prev no-js-hidden"
              name="previous"
              aria-label="Diapositive précédente"
              aria-controls="Slider-{{ section.id }}"
            >
              <svg viewBox="0 0 24 24" width="20" height="20" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="15 18 9 12 15 6"></polyline></svg>
            </button>
            <button
              type="button"
              class="slider-button slider-button--next no-js-hidden"
              name="next"
              aria-label="Diapositive suivante"
              aria-controls="Slider-{{ section.id }}"
            >
              <svg viewBox="0 0 24 24" width="20" height="20" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="9 18 15 12 9 6"></polyline></svg>
            </button>
          {%- endif -%}

          <!-- Pagination Dots (Mobile/Tablette) -->
          <div class="slider-buttons no-js-hidden{% if total_slides < 2 %} hidden{% endif %}">
            {%- for media in product.media -%}
              <button
                type="button"
                class="slider-counter__link slider-counter__link--dots link{% if forloop.first %} slider-counter__link--active{% endif %}"
                aria-label="Diapositive {{ forloop.index }}"
                aria-controls="Slide-{{ section.id }}-{{ forloop.index }}"
                data-slide-index="{{ forloop.index0 }}"
              >
                <span class="dot"></span>
              </button>
            {%- endfor -%}
            {%- if section.settings.show_spotlight and section.settings.spotlight_image != blank -%}
              {%- assign spotlight_dot_index = product.media.size -%}
              <button
                type="button"
                class="slider-counter__link slider-counter__link--dots link"
                aria-label="Spotlight"
                aria-controls="Slide-{{ section.id }}-{{ spotlight_dot_index | plus: 1 }}"
                data-slide-index="{{ spotlight_dot_index }}"
              >
                <span class="dot dot--spotlight"></span>
              </button>
            {%- endif -%}
            {%- if section.settings.show_video_slide and section.settings.video_url != blank -%}
              {%- assign video_dot_index = product.media.size | plus: extra_slides_count -%}
              <button
                type="button"
                class="slider-counter__link slider-counter__link--dots link"
                aria-label="Video"
                aria-controls="Slide-{{ section.id }}-{{ video_dot_index | plus: 1 }}"
                data-slide-index="{{ video_dot_index }}"
              >
                <span class="dot dot--video"></span>
              </button>
            {%- endif -%}
          </div>

          <!-- Thumbnail strip (mobile only) -->
          <div class="milaura-thumb-strip no-js-hidden">
            {%- for media in product.media -%}
              <button
                type="button"
                class="milaura-thumb-strip__item{% if forloop.first %} is-active{% endif %}"
                aria-label="{{ media.alt | default: product.title | escape }}"
                data-slide-index="{{ forloop.index0 }}"
              >
                {{ media | image_url: width: 160 | image_tag: loading: 'lazy', class: 'milaura-thumb-strip__img' }}
              </button>
            {%- endfor -%}
            {%- if section.settings.show_spotlight and section.settings.spotlight_image != blank -%}
              <button
                type="button"
                class="milaura-thumb-strip__item milaura-thumb-strip__item--spotlight"
                aria-label="Spotlight"
                data-slide-index="{{ product.media.size }}"
              >
                {{ section.settings.spotlight_image | image_url: width: 160 | image_tag: loading: 'lazy', class: 'milaura-thumb-strip__img' }}
              </button>
            {%- endif -%}
            {%- if section.settings.show_video_slide and section.settings.video_url != blank -%}
              {%- assign video_thumb_index = product.media.size | plus: extra_slides_count -%}
              <button
                type="button"
                class="milaura-thumb-strip__item milaura-thumb-strip__item--video"
                aria-label="Video"
                data-slide-index="{{ video_thumb_index }}"
                data-video-url="{{ section.settings.video_url }}"
              >
                {%- if section.settings.video_poster != blank -%}
                  {{ section.settings.video_poster | image_url: width: 160 | image_tag: loading: 'lazy', class: 'milaura-thumb-strip__img' }}
                {%- endif -%}
                <div class="milaura-thumb-strip__video-overlay">
                  <svg width="24" height="24" viewBox="0 0 24 24" fill="none"><circle cx="12" cy="12" r="12" fill="rgba(0,0,0,0.4)"/><path d="M10 7L18 12L10 17V7Z" fill="white"/></svg>
                </div>
              </button>
            {%- endif -%}
          </div>

          {%- comment -%} Overlay variantes supprimé — les variantes sont gérées dans la zone d'achat {%- endcomment -%}
        </slider-component>

        {%- comment -%} ========== SPOTLIGHT DESKTOP THUMBNAIL (outside slider) ========== {%- endcomment -%}
        {%- if section.settings.show_spotlight and section.settings.spotlight_image != blank -%}
          <div class="milaura-spotlight-desktop-thumb" data-spotlight-slide="Slide-{{ section.id }}-{{ product.media.size | plus: 1 }}">
            <div class="milaura-spotlight-desktop-thumb__img-wrap">
              {{
                section.settings.spotlight_image
                | image_url: width: 200
                | image_tag: loading: 'lazy', class: 'milaura-spotlight-desktop-thumb__img'
              }}
            </div>
          </div>
        {%- endif -%}

        {%- comment -%} Badges metafield + bulle social proof restent dans grid area dediee. Description + Karine signature rendues ci-dessous (desktop only). {%- endcomment -%}

        {%- comment -%} ==========================================
          GALLERY STORY (desktop only) : description complete + signature Karine.
          Affiche sous la galerie pour exploiter le vide gauche et humaniser la marque.
          Sur mobile, ce bloc est cache (la description reste dans l'info-block apres CTA).
          ========================================== {%- endcomment -%}
        <div class="milaura-gallery-story">
          {%- if section.settings.show_description and product.description != blank -%}
            <div class="milaura-gallery-story__description rte">
              {{ product.description | strip_html | truncatewords: 25 }}
              <a href="#ProductTabs" class="milaura-gallery-story__read-more" id="readMoreLinkGallery-{{ section.id }}">Lire la suite &rarr;</a>
            </div>
            <script>
              (function () {
                var link = document.getElementById('readMoreLinkGallery-{{ section.id }}');
                if (!link) return;
                link.addEventListener('click', function (e) {
                  e.preventDefault();
                  var target = document.getElementById('ProductTabs');
                  if (target) {
                    var headerHeight = parseInt(getComputedStyle(document.documentElement).getPropertyValue('--header-height')) || 80;
                    var targetPosition = target.getBoundingClientRect().top + window.pageYOffset - headerHeight - 20;
                    window.scrollTo({ top: targetPosition, behavior: 'smooth' });
                  }
                });
              })();
            </script>
          {%- endif -%}

          {%- if section.settings.show_karine_block -%}
            <div class="milaura-gallery-story__karine">
              {%- if section.settings.karine_image != blank -%}
                <img class="milaura-gallery-story__karine-img"
                     src="{{ section.settings.karine_image | image_url: width: 220 }}"
                     alt="Karine, fondatrice Mil'Aura"
                     width="88" height="88" loading="lazy">
              {%- endif -%}
              <div class="milaura-gallery-story__karine-content">
                <p class="milaura-gallery-story__quote">{%- if section.settings.karine_quote != blank -%}{{ section.settings.karine_quote }}{%- else -%}Je selectionne chaque pierre avec soin. Origine controlee, qualite verifiee avec rigueur, avant d'arriver dans nos ateliers.{%- endif -%}</p>
                <p class="milaura-gallery-story__signature">Karine</p>
                <p class="milaura-gallery-story__author">Fondatrice Mil'Aura</p>
              </div>
            </div>
          {%- endif -%}
        </div>
      </div>

      <!--
        ============================================
        VIDEO BUBBLE (floating, between header & actions on desktop)
        ============================================
      -->
      {%- if section.settings.show_video_slide and section.settings.video_url != blank -%}
        <div class="milaura-video-bubble-wrapper">
          <div class="milaura-video-bubble" data-video-url="{{ section.settings.video_url }}">
            {%- if section.settings.video_poster != blank -%}
              <div class="milaura-video-bubble__poster">
                {{ section.settings.video_poster | image_url: width: 400 | image_tag: loading: 'lazy', class: 'milaura-video-bubble__poster-img' }}
                <button class="milaura-video-bubble__play" aria-label="Lire la video">
                  <svg width="36" height="36" viewBox="0 0 36 36" fill="none">
                    <circle cx="18" cy="18" r="18" fill="rgba(0,0,0,0.4)"/>
                    <path d="M14 11L26 18L14 25V11Z" fill="white"/>
                  </svg>
                </button>
              </div>
            {%- else -%}
              <div class="milaura-video-bubble__poster milaura-video-bubble__poster--empty">
                <svg width="36" height="36" viewBox="0 0 36 36" fill="none">
                  <circle cx="18" cy="18" r="18" fill="rgba(192,160,98,0.15)"/>
                  <path d="M14 11L26 18L14 25V11Z" fill="var(--milaura-gold, #C0A062)"/>
                </svg>
                <span class="milaura-video-bubble__label">Video</span>
              </div>
            {%- endif -%}
          </div>
        </div>
      {%- endif -%}

      <!--
        ============================================
        RIGHT COL WRAPPER (HEADER + ACTIONS)
        Sur desktop : assigne a grid-area: rightcol, flex column.
        Evite le trou vertical entre header et actions du au row-spanning de la galerie.
        Refonte 2026-05-28 evening.
        ============================================
      -->
      <div class="milaura-hero-rightcol">
        <!--
          ============================================
          GROUPE 1: HEADER (titre + prix + badge promo)
          ============================================
        -->
        <div class="milaura-hero-header-group">
          {%- if section.settings.show_vendor -%}
            <div class="product__vendor caption-with-letter-spacing">{{ product.vendor }}</div>
          {%- endif -%}

          <h1 class="milaura-product__title">{{ product.title | escape }}</h1>

          <div class="no-js-hidden" id="price-{{ section.id }}" role="status">
            {%- render 'price',
              product: product,
              use_variant: true,
              show_badges: true,
              price_class: 'milaura-product__price'
            -%}
            {%- if product.compare_at_price > product.price -%}
              {%- assign discount = product.compare_at_price | minus: product.price | times: 100 | divided_by: product.compare_at_price -%}
              <span class="milaura-promo-badge">-{{ discount }}%</span>
            {%- endif -%}
          </div>
        </div>

        <!--
          ============================================
          GROUPE 3: ACTIONS (bundle + scratch + CTA)
          ============================================
        -->
        <div class="milaura-hero-actions-group">
        <!-- Note: Variant Picker was here, moved to gallery above -->

        <!-- Volume Offer Block -->
        {%- for block in section.blocks -%}
          {%- if block.type == 'volume_offer' -%}
            {% if block.settings.title != blank %}
              <h3 class="volume-section-title">{{ block.settings.title }}</h3>
            {% endif %}
            <div
              class="milaura-volume-grid"
              role="radiogroup"
              aria-label="Choisir une offre volume"
              {{ block.shopify_attributes }}
            >
              <!-- Option 1: Standard -->
              <div
                class="volume-card"
                role="radio"
                aria-checked="false"
                tabindex="0"
                onclick="selectVolume(1, this)"
                onkeydown="if(event.key==='Enter'||event.key===' '){event.preventDefault();selectVolume(1, this);}"
              >
                {% if block.settings.opt1_badge != blank %}
                  <span class="volume-card-badge">{{ block.settings.opt1_badge }}</span>
                {% endif %}
                <div class="volume-left">
                  <div class="volume-text">
                    <h5>{{ block.settings.opt1_label | default: '1×' }}</h5>
                    <p>{{ block.settings.opt1_sub | default: 'Standard' }}</p>
                  </div>
                </div>
                <div class="volume-price">{{ product.price | money }}</div>
              </div>

              <!-- Option 2: Populaire (sélectionné par défaut) -->
              <div
                class="volume-card is-selected"
                role="radio"
                aria-checked="true"
                tabindex="0"
                onclick="selectVolume(2, this)"
                onkeydown="if(event.key==='Enter'||event.key===' '){event.preventDefault();selectVolume(2, this);}"
              >
                {% if block.settings.opt2_badge != blank %}
                  <span class="volume-card-badge">{{ block.settings.opt2_badge }}</span>
                {% endif %}
                <div class="volume-left">
                  <div class="volume-text">
                    <h5>{{ block.settings.opt2_label | default: '2×' }}</h5>
                    <p>{{ block.settings.opt2_sub | default: '-10%' }}</p>
                  </div>
                </div>
                <div class="volume-price">
                  {%- assign price2 = product.price | times: 2 | times: 0.9 -%}
                  {{ price2 | money }}
                </div>
              </div>

              <!-- Option 3: Meilleure offre -->
              <div
                class="volume-card"
                role="radio"
                aria-checked="false"
                tabindex="0"
                onclick="selectVolume(3, this)"
                onkeydown="if(event.key==='Enter'||event.key===' '){event.preventDefault();selectVolume(3, this);}"
              >
                {% if block.settings.opt3_badge != blank %}
                  <span class="volume-card-badge">{{ block.settings.opt3_badge }}</span>
                {% endif %}
                <div class="volume-left">
                  <div class="volume-text">
                    <h5>{{ block.settings.opt3_label | default: '3×' }}</h5>
                    <p>{{ block.settings.opt3_sub | default: '-20%' }}</p>
                  </div>
                </div>
                <div class="volume-price">
                  {%- assign price3 = product.price | times: 3 | times: 0.8 -%}
                  {{ price3 | money }}
                </div>
              </div>
            </div>

            <script>
              function selectVolume(qty, card) {
                // 1. Visual + ARIA Update
                document.querySelectorAll('.volume-card').forEach((c) => {
                  c.classList.remove('is-selected');
                  c.setAttribute('aria-checked', 'false');
                });
                card.classList.add('is-selected');
                card.setAttribute('aria-checked', 'true');

                // 2. Update Hidden Quantity Input
                const qtyInput = document.getElementById('Quantity-{{ section.id }}');
                if (qtyInput) {
                  qtyInput.value = qty;
                  // Trigger change event if needed by other scripts
                  qtyInput.dispatchEvent(new Event('change', { bubbles: true }));
                }
              }
            </script>
          {%- endif -%}
        {%- endfor -%}

        {%- comment -%} Buy-row (qty picker + product-form ATC) supprime. Le CTA bundle-aware (sous le bundle, dans la col droite) gere l'ajout au panier via /cart/add.js. Trust badges + payment icons deplaces vers section milaura-product-trust-block. {%- endcomment -%}

        {%- comment -%} Description courte deplacee dans GROUPE 2 (col gauche, sous la galerie) - refonte 2026-05-28 {%- endcomment -%}

        {%- comment -%} Bundle selector deplace ici depuis GROUPE 4. Le scratch + CTA inline tier-aware suivent. {%- endcomment -%}
        {%- if section.settings.show_bundle -%}
          <div class="milaura-bundle-selector" id="milaura-bundle-selector-{{ section.id }}">
            <div class="milaura-bundle-header">
              {%- assign bundle_title_resolved = section.settings.bundle_title -%}
              {%- if bundle_title_resolved == blank or bundle_title_resolved == 'Composez votre coffret' -%}
                {%- assign bundle_title_resolved = 'Choisissez la quantite' -%}
              {%- endif -%}
              <h3 class="milaura-bundle-title">{{ bundle_title_resolved }}</h3>
              <p class="milaura-bundle-subtitle">{{ section.settings.bundle_subtitle | default: 'Plus vous commandez, plus vous deverrouillez de cadeaux' }}</p>
            </div>
            {%- comment -%} Prix tiers calcules dynamiquement depuis product.price + remises configurables (refonte 2026-05-28). {%- endcomment -%}
            {%- assign tier2_discount = section.settings.tier2_discount_pct | default: 10 -%}
            {%- assign tier3_discount = section.settings.tier3_discount_pct | default: 20 -%}
            {%- assign base_price = product.price -%}
            {%- assign base_compare = product.compare_at_price | default: product.price -%}

            {%- assign tier1_dyn_price = base_price -%}
            {%- assign tier1_dyn_compare = base_compare -%}

            {%- assign tier2_total = base_price | times: 2 -%}
            {%- assign tier2_keep_pct = 100 | minus: tier2_discount -%}
            {%- assign tier2_dyn_price = tier2_total | times: tier2_keep_pct | divided_by: 100 -%}
            {%- assign tier2_dyn_compare = base_compare | times: 2 -%}

            {%- assign tier3_total = base_price | times: 3 -%}
            {%- assign tier3_keep_pct = 100 | minus: tier3_discount -%}
            {%- assign tier3_dyn_price = tier3_total | times: tier3_keep_pct | divided_by: 100 -%}
            {%- assign tier3_dyn_compare = base_compare | times: 3 -%}

            <div class="milaura-bundle-tiers">
              {%- for i in (1..3) -%}
                {%- assign label_key = 'tier' | append: i | append: '_label' -%}
                {%- assign sub_key = 'tier' | append: i | append: '_sub' -%}
                {%- assign icon_key = 'tier' | append: i | append: '_icon' -%}
                {%- assign badge_key = 'tier' | append: i | append: '_badge' -%}
                {%- assign cards_key = 'tier' | append: i | append: '_cards_unlocked' -%}
                {%- assign tier_label = section.settings[label_key] -%}
                {%- assign tier_sub = section.settings[sub_key] -%}
                {%- assign tier_icon = section.settings[icon_key] -%}
                {%- assign tier_badge = section.settings[badge_key] -%}
                {%- assign tier_cards = section.settings[cards_key] -%}

                {%- if i == 1 -%}
                  {%- assign tier_price_cents = tier1_dyn_price -%}
                  {%- assign tier_compare_cents = tier1_dyn_compare -%}
                {%- elsif i == 2 -%}
                  {%- assign tier_price_cents = tier2_dyn_price -%}
                  {%- assign tier_compare_cents = tier2_dyn_compare -%}
                {%- else -%}
                  {%- assign tier_price_cents = tier3_dyn_price -%}
                  {%- assign tier_compare_cents = tier3_dyn_compare -%}
                {%- endif -%}

                {%- assign show_compare = false -%}
                {%- if tier_compare_cents > tier_price_cents -%}
                  {%- assign show_compare = true -%}
                {%- endif -%}

                <div class="milaura-bundle-tier" data-tier-index="{{ forloop.index0 }}" data-tier-pieces="{{ i }}" data-tier-price-cents="{{ tier_price_cents }}" data-cards-unlocked="{{ tier_cards | default: 0 }}" role="button" tabindex="0">
                  {%- if tier_badge != blank -%}
                    <span class="milaura-bundle-badge">{{ tier_badge }}</span>
                  {%- endif -%}
                  <div class="milaura-bundle-tier-left">
                    <div class="milaura-bundle-tier-icon">{{ tier_icon }}</div>
                    <div class="milaura-bundle-tier-text">
                      <div class="milaura-bundle-tier-label">{{ tier_label }}</div>
                      <div class="milaura-bundle-tier-sub">{{ tier_sub }}</div>
                    </div>
                  </div>
                  <div class="milaura-bundle-tier-price">
                    <div class="milaura-bundle-tier-current">{{ tier_price_cents | money }}</div>
                    {%- if show_compare -%}
                      <div class="milaura-bundle-tier-compare">{{ tier_compare_cents | money }}</div>
                    {%- endif -%}
                  </div>
                </div>
              {%- endfor -%}
            </div>
          </div>

          {%- comment -%} Scratch cards integrees dans la col droite, entre bundle et CTA (refonte 2026-05-28). {%- endcomment -%}
          {%- if section.settings.show_scratch -%}
            {%- assign gift_count_inline = 0 -%}
            {%- for block in section.blocks -%}
              {%- if block.type == 'gift' -%}
                {%- assign gift_count_inline = gift_count_inline | plus: 1 -%}
              {%- endif -%}
            {%- endfor -%}

            <div class="milaura-scratch-divider" aria-hidden="true">
              <span class="milaura-scratch-divider-text">{{ section.settings.scratch_title | default: 'Cadeaux a gratter' }}</span>
            </div>

            <div class="milaura-hero-scratch" id="milaura-hero-scratch-{{ section.id }}">
              <div class="milaura-scratch-header">
                <h3 class="milaura-scratch-title">Vos cadeaux</h3>
                <span class="milaura-scratch-counter" id="milaura-scratch-counter-{{ section.id }}">0/{{ gift_count_inline }} REVELES</span>
              </div>

              <div class="milaura-scratch-cards" id="milaura-scratch-cards-{{ section.id }}">
                {%- assign gift_idx = 0 -%}
                {%- for block in section.blocks -%}
                  {%- if block.type == 'gift' -%}
                    <div
                      class="milaura-scratch-card"
                      data-gift-index="{{ gift_idx }}"
                      data-gift-name="{{ block.settings.name }}"
                      data-gift-value="{{ block.settings.value }}"
                      data-gift-icon="{{ block.settings.icon }}"
                      data-gift-variant-id="{{ block.settings.variant_id }}"
                      data-gift-discount-code="{{ block.settings.discount_code }}"
                      {{ block.shopify_attributes }}
                    >
                      <div class="milaura-scratch-card-content">
                        <div class="milaura-scratch-card-icon">{{ block.settings.icon }}</div>
                        <div class="milaura-scratch-card-name">{{ block.settings.name }}</div>
                        <div class="milaura-scratch-card-value">{{ block.settings.value }}</div>
                      </div>
                    </div>
                    {%- assign gift_idx = gift_idx | plus: 1 -%}
                  {%- endif -%}
                {%- endfor -%}
              </div>

              <div class="milaura-scratch-pill" id="milaura-scratch-pill-{{ section.id }}">
                <span class="milaura-scratch-pill-inner" id="milaura-scratch-pill-text-{{ section.id }}"></span>
              </div>
            </div>
          {%- endif -%}

          <button
            type="button"
            class="milaura-hero-cta-bundle"
            id="milaura-hero-cta-bundle-{{ section.id }}"
            data-variant-id="{{ product.selected_or_first_available_variant.id }}"
            aria-label="Ajouter au panier">
            <span class="milaura-cta-icon" aria-hidden="true">
              <svg viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg">
                <path d="M6 7V6a6 6 0 0 1 12 0v1"/>
                <path d="M4 7h16l-1.5 12.5a2 2 0 0 1-2 1.75H7.5a2 2 0 0 1-2-1.75L4 7z"/>
              </svg>
            </span>
            <span class="milaura-cta-label">Ajouter au panier</span>
            <span class="milaura-cta-price" id="milaura-hero-cta-price-{{ section.id }}">{{ tier2_dyn_price | money }}</span>
          </button>
        {%- endif -%}

        {%- comment -%} ==========================================
          INFO BLOCK (apres CTA) : description + badges metafield + social proof
          Refonte 2026-05-28 : ces 3 elements descendent sous le CTA
          ========================================== {%- endcomment -%}
        <div class="milaura-info-block">
          {%- if section.settings.show_description -%}
            <div class="product__description milaura-info-description rte quick-add-hidden">
              {{ product.description | strip_html | truncatewords: 30 }}
              <a href="#ProductTabs" class="read-more-link" id="readMoreLink-{{ section.id }}">Lire la suite →</a>
            </div>
            <script>
              (function () {
                var link = document.getElementById('readMoreLink-{{ section.id }}');
                if (!link) return;
                link.addEventListener('click', function (e) {
                  e.preventDefault();
                  var target = document.getElementById('ProductTabs');
                  if (target) {
                    var headerHeight = parseInt(getComputedStyle(document.documentElement).getPropertyValue('--header-height')) || 80;
                    var targetPosition = target.getBoundingClientRect().top + window.pageYOffset - headerHeight - 20;
                    window.scrollTo({ top: targetPosition, behavior: 'smooth' });
                  }
                });
              })();
            </script>
          {%- endif -%}

          {%- comment -%} Badges metafield deplaces au-dessus de la galerie (entre bulle bleue et photo) - refonte 2026-05-28 {%- endcomment -%}

          {%- comment -%} Bulle social proof deplacee au-dessus de la galerie (refonte 2026-05-28) {%- endcomment -%}
        </div>
      </div>
        <!-- Fin GROUPE 3: Actions -->
      </div>
      <!-- Fin RIGHT COL wrapper -->

      <!-- GROUPE 4: SCRATCH-TO-REVEAL (full width, premium) -->
      {%- if section.settings.show_scratch -%}
        {%- assign gift_count = 0 -%}
        {%- for block in section.blocks -%}
          {%- if block.type == 'gift' -%}
            {%- assign gift_count = gift_count | plus: 1 -%}
          {%- endif -%}
        {%- endfor -%}

        {%- comment -%} Le HTML scratch et le bundle sont desormais dans GROUPE 3 (col droite, ordre : bundle -> scratch -> CTA). Ce wrapper conserve uniquement le script JS qui les pilote. {%- endcomment -%}

        <script>
        (function() {
          'use strict';

          var sid = '{{ section.id }}';
          var container = document.getElementById('milaura-hero-scratch-' + sid);
          if (!container) return;

          /* ===== CONSTANTS ===== */
          var GOLD_1 = '#E6C88B';
          var GOLD_2 = '#C0A062';
          var REVEAL_THRESHOLD = 0.55;
          var SCRATCH_RADIUS = 22;
          var CONFETTI_COLORS = ['#C0A062', '#E6C88B', '#8F723A', '#D4839E', '#6BA3C7'];
          var CONFETTI_COUNT = 18;
          var STORAGE_KEY = 'milaura-scratch-v3-' + sid;

          /* ===== STATE ===== */
          var revealedGifts = new Set();
          var gifts = [];

          /* ===== PARSE DOM ===== */
          var cardEls = container.querySelectorAll('.milaura-scratch-card');
          var counterEl = document.getElementById('milaura-scratch-counter-' + sid);
          var pillEl = document.getElementById('milaura-scratch-pill-' + sid);
          var pillTextEl = document.getElementById('milaura-scratch-pill-text-' + sid);

          cardEls.forEach(function(el) {
            gifts.push({
              el: el,
              index: parseInt(el.dataset.giftIndex, 10),
              name: el.dataset.giftName,
              value: el.dataset.giftValue,
              icon: el.dataset.giftIcon,
              canvasReady: false
            });
          });

          /* ===== SESSION STORAGE ===== */
          function loadState() {
            try {
              var raw = sessionStorage.getItem(STORAGE_KEY);
              if (raw) {
                var arr = JSON.parse(raw);
                var filtered = arr.filter(function(i) { return i >= 0 && i < gifts.length; });
                return new Set(filtered);
              }
            } catch (e) { /* ignore */ }
            return new Set();
          }

          function saveState() {
            try {
              sessionStorage.setItem(STORAGE_KEY, JSON.stringify(Array.from(revealedGifts)));
            } catch (e) { /* ignore */ }
          }

          revealedGifts = loadState();

          /* ===== BUNDLE TIER SELECTOR ===== */
          var DEFAULT_TIER_INDEX = 1; /* 2 Unites par defaut */
          var bundleEl = document.getElementById('milaura-bundle-selector-' + sid);
          var tierEls = bundleEl ? bundleEl.querySelectorAll('.milaura-bundle-tier') : [];
          var selectedTierIndex = DEFAULT_TIER_INDEX;

          function currentUnlockedCount() {
            if (!tierEls || tierEls.length === 0) return gifts.length;
            var tier = tierEls[selectedTierIndex];
            if (!tier) return 0;
            var raw = parseInt(tier.getAttribute('data-cards-unlocked'), 10);
            if (isNaN(raw)) return 0;
            return raw;
          }

          function updateLockedCards() {
            var unlocked = currentUnlockedCount();
            var stateChanged = false;
            gifts.forEach(function(gift, i) {
              var card = gift.el;
              if (i < unlocked) {
                /* Carte deverrouillee par le tier courant */
                if (card.classList.contains('is-locked')) {
                  card.classList.remove('is-locked');
                }
                /* Si carte deja revelee precedemment, conserver l'etat reveal */
                if (revealedGifts.has(i)) {
                  if (!card.classList.contains('is-revealed')) {
                    card.classList.add('is-revealed');
                  }
                  return;
                }
                /* Sinon, initialiser le canvas si necessaire */
                if (!gift.canvasReady && !card.querySelector('canvas')) {
                  initCanvas(card, gift);
                }
              } else {
                /* Carte au-dela du tier courant : RESET complet (verrouillee + non revelee) */
                if (revealedGifts.has(i)) {
                  revealedGifts.delete(i);
                  stateChanged = true;
                }
                card.classList.add('is-locked');
                card.classList.remove('is-revealed');
                var existingCanvas = card.querySelector('canvas');
                if (existingCanvas) existingCanvas.remove();
                gift.canvasReady = false;
              }
            });
            if (stateChanged) saveState();
            updateCounter();
            /* Hide / re-show the reveal pill in coherence with the new state */
            syncPillToState();
          }

          function syncPillToState() {
            if (!pillEl || !pillTextEl) return;
            if (revealedGifts.size === 0) {
              pillEl.classList.remove('is-visible');
              pillTextEl.textContent = '';
              return;
            }
            /* Liste de tous les cadeaux reveles et encore debloques par le tier courant */
            var unlocked = currentUnlockedCount();
            var validGifts = [];
            gifts.forEach(function(g, i) {
              if (i < unlocked && revealedGifts.has(i)) {
                validGifts.push(g.name);
              }
            });
            if (validGifts.length === 0) {
              pillEl.classList.remove('is-visible');
              pillTextEl.textContent = '';
              return;
            }
            var label;
            if (validGifts.length === 1) {
              label = '+ ' + validGifts[0] + ' offert avec votre commande';
            } else {
              /* Listing inline des N cadeaux : "+ Pochon velours + Code -10% + Bracelet Hematite 4mm offerts" */
              label = validGifts.map(function(n) { return '+ ' + n; }).join('   ') + ' offerts avec votre commande';
            }
            pillTextEl.textContent = label;
            pillEl.classList.add('is-visible');
          }

          function bindTierSelector() {
            if (!tierEls || tierEls.length === 0) return;
            tierEls.forEach(function(tier, i) {
              tier.addEventListener('click', function() {
                selectTier(i);
              });
              tier.addEventListener('keydown', function(e) {
                if (e.key === 'Enter' || e.key === ' ') {
                  e.preventDefault();
                  selectTier(i);
                }
              });
            });
            /* Selection par defaut */
            selectTier(DEFAULT_TIER_INDEX);
          }

          function selectTier(i) {
            if (i < 0 || i >= tierEls.length) return;
            tierEls.forEach(function(t) { t.classList.remove('is-selected'); });
            tierEls[i].classList.add('is-selected');
            selectedTierIndex = i;
            updateLockedCards();
            updateCtaButton();
          }

          /* ===== CTA BUNDLE-AWARE ===== */
          var ctaButton = document.getElementById('milaura-hero-cta-bundle-' + sid);
          var ctaPriceEl = document.getElementById('milaura-hero-cta-price-' + sid);
          var ctaVariantId = ctaButton ? parseInt(ctaButton.getAttribute('data-variant-id'), 10) : null;

          function updateCtaButton() {
            if (!ctaPriceEl || !tierEls || tierEls.length === 0) return;
            var tier = tierEls[selectedTierIndex];
            if (!tier) return;
            var priceEl = tier.querySelector('.milaura-bundle-tier-current');
            if (priceEl && priceEl.textContent) {
              ctaPriceEl.textContent = priceEl.textContent.trim();
            }
          }

          function getTierPieces(index) {
            if (!tierEls || !tierEls[index]) return 1;
            var pieces = parseInt(tierEls[index].getAttribute('data-tier-pieces'), 10);
            if (!isNaN(pieces) && pieces > 0) return pieces;
            var labelEl = tierEls[index].querySelector('.milaura-bundle-tier-label');
            if (!labelEl) return 1;
            var match = labelEl.textContent.match(/(\d+)/);
            return match ? parseInt(match[1], 10) : 1;
          }

          function bundleAddToCart() {
            if (!ctaVariantId || !ctaButton) return;
            var qty = getTierPieces(selectedTierIndex);
            var tierLabelEl = tierEls[selectedTierIndex].querySelector('.milaura-bundle-tier-label');
            var tierLabel = tierLabelEl ? tierLabelEl.textContent.trim() : '';
            var giftNames = [];
            var giftVariantItems = [];
            var discountCode = '';
            revealedGifts.forEach(function(idx) {
              var giftCard = container.querySelector('.milaura-scratch-card[data-gift-index="' + idx + '"]');
              if (giftCard) {
                var name = giftCard.getAttribute('data-gift-name');
                if (name) giftNames.push(name);
                var variantId = parseInt(giftCard.getAttribute('data-gift-variant-id'), 10);
                if (!isNaN(variantId) && variantId > 0) {
                  giftVariantItems.push({
                    id: variantId,
                    quantity: 1,
                    properties: {
                      '_gift': 'true',
                      'Cadeau Mil’Aura': name || 'Cadeau revele'
                    }
                  });
                }
                var code = giftCard.getAttribute('data-gift-discount-code');
                if (code && !discountCode) discountCode = code.trim();
              }
            });

            ctaButton.disabled = true;
            var labelEl = ctaButton.querySelector('.milaura-cta-label');
            var originalLabel = labelEl ? labelEl.textContent : 'Ajouter au panier';
            if (labelEl) labelEl.textContent = 'Ajout en cours...';

            var items = [{
              id: ctaVariantId,
              quantity: qty,
              properties: {
                'Formule': tierLabel,
                'Cadeaux': giftNames.length > 0 ? giftNames.join(', ') : 'Aucun'
              }
            }];
            /* Ajout des variants gratuits (free gifts) si configures cote section.blocks.gift.variant_id */
            for (var g = 0; g < giftVariantItems.length; g++) {
              items.push(giftVariantItems[g]);
            }

            fetch('/cart/add.js', {
              method: 'POST',
              headers: { 'Content-Type': 'application/json' },
              body: JSON.stringify({ items: items })
            })
            .then(function(r) {
              if (!r.ok) throw new Error('cart_error');
              /* Si un code promo est associe a une carte revelee, on passe par /discount/CODE qui applique + redirige. */
              if (discountCode) {
                window.location.href = '/discount/' + encodeURIComponent(discountCode) + '?redirect=/cart';
              } else {
                window.location.href = '/cart';
              }
            })
            .catch(function() {
              ctaButton.disabled = false;
              if (labelEl) labelEl.textContent = originalLabel;
            });
          }

          if (ctaButton) {
            ctaButton.addEventListener('click', bundleAddToCart);
          }

          /* ===== INIT CARDS ===== */
          function initAllCards() {
            var hasTiers = tierEls && tierEls.length > 0;
            var unlocked = hasTiers ? (parseInt(tierEls[DEFAULT_TIER_INDEX].getAttribute('data-cards-unlocked'), 10) || 0) : gifts.length;
            gifts.forEach(function(gift, i) {
              var card = gift.el;
              populateContent(card, gift);

              if (revealedGifts.has(gift.index)) {
                card.classList.add('is-revealed');
                return;
              }
              /* Si tiers actifs et carte au-dela de l'unlock, verrouiller */
              if (hasTiers && i >= unlocked) {
                card.classList.add('is-locked');
                return;
              }
              if (!gift.canvasReady) {
                initCanvas(card, gift);
              }
            });
            updateCounter();

            /* Restore last pill if any gift was revealed */
            if (revealedGifts.size > 0) {
              var lastIdx = Math.max.apply(null, Array.from(revealedGifts));
              var lastGift = gifts[lastIdx];
              if (lastGift) showPill(lastGift);
            }

            /* Brancher le selecteur de bundle apres l'init initial */
            bindTierSelector();
          }

          function populateContent(card, gift) {
            var content = card.querySelector('.milaura-scratch-card-content');
            content.querySelector('.milaura-scratch-card-icon').textContent = gift.icon;
            content.querySelector('.milaura-scratch-card-name').textContent = gift.name;
            var valueEl = content.querySelector('.milaura-scratch-card-value');
            if (valueEl) valueEl.textContent = gift.value;
          }

          /* ===== CANVAS SCRATCH ENGINE ===== */
          function initCanvas(card, gift) {
            var existing = card.querySelector('canvas');
            if (existing) existing.remove();

            var canvas = document.createElement('canvas');
            var w = card.offsetWidth || 130;
            var h = card.offsetHeight || 150;
            canvas.width = w;
            canvas.height = h;
            canvas.style.width = w + 'px';
            canvas.style.height = h + 'px';
            card.appendChild(canvas);

            var ctx = canvas.getContext('2d');

            /* Gold gradient fill */
            var gradient = ctx.createLinearGradient(0, 0, w, h);
            gradient.addColorStop(0, GOLD_1);
            gradient.addColorStop(1, GOLD_2);
            ctx.fillStyle = gradient;
            ctx.fillRect(0, 0, w, h);

            /* Draw "?" hint */
            ctx.fillStyle = 'rgba(255, 255, 255, 0.35)';
            ctx.font = 'bold 2rem sans-serif';
            ctx.textAlign = 'center';
            ctx.textBaseline = 'middle';
            ctx.fillText('?', w / 2, h / 2);

            gift.canvasReady = true;

            /* Scratch interaction state */
            var isScratching = false;
            var checkPending = false;

            function getPos(e) {
              var rect = canvas.getBoundingClientRect();
              var cx, cy;
              if (e.touches && e.touches.length > 0) {
                cx = e.touches[0].clientX;
                cy = e.touches[0].clientY;
              } else {
                cx = e.clientX;
                cy = e.clientY;
              }
              return {
                x: (cx - rect.left) * (canvas.width / rect.width),
                y: (cy - rect.top) * (canvas.height / rect.height)
              };
            }

            function doScratch(pos) {
              ctx.globalCompositeOperation = 'destination-out';
              ctx.beginPath();
              ctx.arc(pos.x, pos.y, SCRATCH_RADIUS, 0, Math.PI * 2);
              ctx.fill();
              ctx.globalCompositeOperation = 'source-over';

              if (!checkPending) {
                checkPending = true;
                requestAnimationFrame(function() {
                  checkPending = false;
                  checkReveal(card, gift, canvas, ctx);
                });
              }
            }

            function onStart(e) {
              if (card.classList.contains('is-revealed')) return;
              isScratching = true;
              doScratch(getPos(e));
            }

            function onMove(e) {
              if (!isScratching || card.classList.contains('is-revealed')) return;
              e.preventDefault();
              doScratch(getPos(e));
            }

            function onEnd() {
              isScratching = false;
            }

            /* Touch */
            canvas.addEventListener('touchstart', onStart, { passive: true });
            canvas.addEventListener('touchmove', onMove, { passive: false });
            canvas.addEventListener('touchend', onEnd, { passive: true });
            canvas.addEventListener('touchcancel', onEnd, { passive: true });

            /* Mouse */
            canvas.addEventListener('mousedown', onStart);
            canvas.addEventListener('mousemove', onMove);
            canvas.addEventListener('mouseup', onEnd);
            canvas.addEventListener('mouseleave', onEnd);
          }

          /* ===== REVEAL CHECK ===== */
          function checkReveal(card, gift, canvas, ctx) {
            if (revealedGifts.has(gift.index)) return;

            var w = canvas.width;
            var h = canvas.height;
            var imageData;
            try {
              imageData = ctx.getImageData(0, 0, w, h);
            } catch (e) { return; }

            var pixels = imageData.data;
            var total = w * h;
            var transparent = 0;

            /* Sample every 4th pixel for performance */
            for (var i = 3; i < pixels.length; i += 16) {
              if (pixels[i] < 10) transparent++;
            }
            transparent *= 4;

            if (transparent / total >= REVEAL_THRESHOLD) {
              revealCard(card, gift);
            }
          }

          /* ===== REVEAL CARD ===== */
          function revealCard(card, gift) {
            if (revealedGifts.has(gift.index)) return;

            revealedGifts.add(gift.index);
            saveState();

            /* Remove canvas */
            var canvas = card.querySelector('canvas');
            if (canvas) canvas.remove();
            gift.canvasReady = false;

            /* Reveal with bounce */
            card.classList.add('is-revealed', 'is-bouncing');
            card.addEventListener('animationend', function handler() {
              card.classList.remove('is-bouncing');
              card.removeEventListener('animationend', handler);
            });

            spawnConfetti(card);
            updateCounter();
            /* Affiche la liste cumulee de tous les cadeaux reveles + anime */
            syncPillToState();
            if (pillEl) {
              pillEl.classList.remove('is-visible');
              void pillEl.offsetWidth;
              pillEl.classList.add('is-visible');
            }
          }

          /* ===== CONFETTI ===== */
          function spawnConfetti(card) {
            var rect = card.getBoundingClientRect();
            var parentRect = container.getBoundingClientRect();

            for (var i = 0; i < CONFETTI_COUNT; i++) {
              var particle = document.createElement('div');
              particle.className = 'milaura-scratch-confetti';
              particle.style.backgroundColor = CONFETTI_COLORS[Math.floor(Math.random() * CONFETTI_COLORS.length)];
              particle.style.left = (rect.left - parentRect.left + Math.random() * rect.width) + 'px';
              particle.style.top = (rect.top - parentRect.top + Math.random() * 20 - 10) + 'px';
              particle.style.animationDuration = (0.8 + Math.random() * 0.6) + 's';
              particle.style.animationDelay = (Math.random() * 0.25) + 's';
              container.appendChild(particle);

              (function(p) {
                p.addEventListener('animationend', function() {
                  if (p.parentNode) p.parentNode.removeChild(p);
                });
                setTimeout(function() {
                  if (p.parentNode) p.parentNode.removeChild(p);
                }, 2500);
              })(particle);
            }
          }

          /* ===== COUNTER ===== */
          function updateCounter() {
            var total = gifts.length;
            var revealed = revealedGifts.size;
            if (counterEl) {
              counterEl.textContent = revealed + '/' + total + ' REVELES';
            }
          }

          /* ===== PILL ===== */
          function showPill(gift) {
            if (!pillEl || !pillTextEl) return;
            pillTextEl.textContent = '+ ' + gift.name + ' offert avec votre commande';
            pillEl.classList.remove('is-visible');
            /* Force reflow for re-animation */
            void pillEl.offsetWidth;
            pillEl.classList.add('is-visible');
          }

          /* ===== INIT ===== */
          initAllCards();
        })();
        </script>
      {%- endif -%}

    </div>
    <!-- Fin milaura-hero-wrapper -->

