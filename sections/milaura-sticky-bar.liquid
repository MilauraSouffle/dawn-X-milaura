{% comment %}
  MILAURA STICKY BAR
  Barre d'ajout au panier flottante.
  S'affiche uniquement quand le bouton principal n'est plus visible (scroll vers le bas).
  Version reward meter : progression cartes panier + CTA conserve.
{% endcomment %}

{%- if section.settings.enable_sticky_bar -%}
  {%- liquid
    assign reward_threshold_1_cents = section.settings.reward_threshold_1 | default: 20 | times: 100
    assign reward_threshold_2_cents = section.settings.reward_threshold_2 | default: 50 | times: 100
    assign reward_threshold_3_cents = section.settings.reward_threshold_3 | default: 80 | times: 100
    assign product_price_cents = product.selected_or_first_available_variant.price
    assign sticky_reward_logo = settings.favicon
    if sticky_reward_logo == blank
      assign sticky_reward_logo = settings.logo
    endif
  -%}
  <style>
    #shopify-section-{{ section.id }} {
      --sticky-bg: {{ section.settings.bg_color }};
      --sticky-text: {{ section.settings.text_color }};
      --sticky-gold: var(--milaura-gold, #C0A062);
      --sticky-ink: #1a1a2e;
      --sticky-cream: #fffaf0;
      z-index: 999;
      position: relative;
    }

    .milaura-sticky-bar {
      position: fixed;
      bottom: 0;
      left: 0;
      width: 100%;
      min-height: 104px;
      padding: 14px 28px;
      background:
        linear-gradient(180deg, rgba(255, 255, 255, 0.94), rgba(255, 250, 240, 0.98)),
        var(--sticky-bg);
      box-shadow:
        0 -18px 42px rgba(26, 26, 46, 0.12),
        inset 0 1px 0 rgba(255, 255, 255, 0.86);
      z-index: 9999;
      display: grid;
      grid-template-columns: minmax(210px, 360px) minmax(320px, 1fr) auto;
      align-items: center;
      gap: 20px;
      
      transform: translateY(101%);
      transition: transform 0.4s cubic-bezier(0.165, 0.84, 0.44, 1);
      border-top: 1px solid rgba(192, 160, 98, 0.26);
      backdrop-filter: blur(18px);
    }

    .milaura-sticky-bar.is-visible {
      transform: translateY(0);
    }

    .sticky-product-info {
      display: flex;
      align-items: center;
      gap: 14px;
      min-width: 0;
    }

    .sticky-product-media {
      width: 56px;
      height: 56px;
      border-radius: 12px;
      overflow: hidden;
      flex: 0 0 56px;
      background: rgba(192, 160, 98, 0.08);
      border: 1px solid rgba(192, 160, 98, 0.18);
      box-shadow: 0 5px 16px rgba(0, 0, 0, 0.08);
    }

    .sticky-product-media img {
      width: 100%;
      height: 100%;
      display: block;
      object-fit: cover;
    }

    .sticky-product-copy {
      display: flex;
      flex-direction: column;
      justify-content: center;
      min-width: 0;
    }

    .sticky-title {
      font-family: var(--milaura-font-heading, serif);
      font-size: {{ section.settings.title_size }}px;
      font-weight: 600;
      color: var(--sticky-text);
      margin: 0;
      line-height: 1.2;
      overflow: hidden;
      text-overflow: ellipsis;
      white-space: nowrap;
    }

    .sticky-price {
      font-size: {{ section.settings.price_size }}px;
      color: {{ section.settings.price_color }};
      font-weight: 700;
    }

    .sticky-reward {
      display: grid;
      gap: 9px;
      min-width: 0;
      padding: 12px 14px;
      border: 1px solid rgba(192, 160, 98, 0.22);
      border-radius: 18px;
      background:
        radial-gradient(circle at 8% 18%, rgba(230, 200, 139, 0.28), transparent 28%),
        linear-gradient(135deg, rgba(255, 255, 255, 0.86), rgba(253, 251, 247, 0.78));
    }

    .sticky-reward__top {
      display: flex;
      align-items: center;
      justify-content: space-between;
      gap: 14px;
      min-width: 0;
    }

    .sticky-reward__label {
      margin: 0;
      color: var(--sticky-ink);
      font-family: var(--milaura-font-heading, 'Playfair Display'), serif;
      font-size: 1.02rem;
      font-weight: 700;
      line-height: 1.1;
    }

    .sticky-reward__hint {
      margin: 0;
      color: var(--milaura-gold-dark, #8F723A);
      font-size: 0.78rem;
      font-weight: 900;
      line-height: 1.2;
      text-align: right;
      white-space: nowrap;
    }

    .sticky-reward__rail {
      position: relative;
      height: 11px;
      border-radius: 999px;
      background: rgba(26, 26, 46, 0.08);
      box-shadow: inset 0 1px 2px rgba(26, 26, 46, 0.08);
    }

    .sticky-reward__fill {
      position: absolute;
      inset: 0 auto 0 0;
      width: 0%;
      border-radius: inherit;
      background:
        linear-gradient(90deg, #D8B568 0%, #F5D994 54%, #B78A35 100%);
      box-shadow: 0 0 18px rgba(192, 160, 98, 0.36);
      transition: width 420ms cubic-bezier(0.22, 1, 0.36, 1);
    }

    .sticky-reward__mark {
      position: absolute;
      top: 50%;
      width: 28px;
      height: 28px;
      display: inline-flex;
      align-items: center;
      justify-content: center;
      border-radius: 50%;
      border: 1px solid rgba(192, 160, 98, 0.36);
      background: #fff;
      color: rgba(26, 26, 46, 0.46);
      font-size: 0.66rem;
      font-weight: 900;
      transform: translate(-50%, -50%);
      transition: background 220ms ease, color 220ms ease, transform 220ms ease, box-shadow 220ms ease;
      z-index: 2;
    }

    .sticky-reward__mark--one { left: 25%; }
    .sticky-reward__mark--two { left: 62.5%; }
    .sticky-reward__mark--three { left: 100%; }

    .sticky-reward__mark.is-unlocked {
      background:
        radial-gradient(circle at 35% 24%, rgba(255, 255, 255, 0.88), transparent 32%),
        linear-gradient(135deg, #FFF4CF, #D8B568 58%, #A67828);
      color: var(--sticky-ink);
      border-color: rgba(143, 114, 58, 0.48);
      box-shadow: 0 8px 20px rgba(192, 160, 98, 0.28);
      transform: translate(-50%, -50%) scale(1.04);
    }

    .sticky-reward__logo {
      width: 17px;
      height: 17px;
      display: block;
      object-fit: contain;
    }

    .sticky-reward__fallback-mark {
      font-family: var(--milaura-font-heading, 'Playfair Display'), serif;
      font-size: 0.7rem;
      font-weight: 900;
      line-height: 1;
    }

    .sticky-reward__steps {
      display: grid;
      grid-template-columns: repeat(3, 1fr);
      gap: 8px;
      color: rgba(26, 26, 46, 0.58);
      font-size: 0.68rem;
      font-weight: 800;
      line-height: 1;
      text-align: center;
    }

    .sticky-btn-wrapper {
      display: flex;
      align-items: center;
      justify-content: flex-end;
    }

    .sticky-btn.milaura-btn-gold {
      display: inline-flex;
      align-items: center;
      justify-content: center;
      border: none;
      width: auto;
      min-width: 168px;
      min-height: 48px;
      padding: 13px 28px;
      font-size: 13px;
      letter-spacing: 0.5px;
      line-height: 1;
      white-space: nowrap;
      align-self: center;
    }

    .sticky-btn-label-mobile {
      display: none;
    }

    .sticky-btn-qty {
      display: none;
      align-items: center;
      justify-content: center;
      min-width: 28px;
      min-height: 24px;
      margin-left: 10px;
      padding: 4px 8px;
      border-radius: 999px;
      background: rgba(26, 26, 46, 0.14);
      color: #1a1a2e;
      font-family: 'Lato', sans-serif;
      font-size: 12px;
      font-weight: 900;
      line-height: 1;
      letter-spacing: 0;
    }

    .sticky-btn-qty.is-visible {
      display: inline-flex;
    }

    /* --- MOBILE RESPONSIVE --- */
    @media screen and (max-width: 768px) {
      .milaura-sticky-bar {
        min-height: 118px;
        padding: 9px 10px 10px;
        gap: 9px 10px;
        grid-template-columns: minmax(0, 1fr) auto;
        grid-template-areas:
          "reward reward"
          "product button";
        bottom: 65px; /* Au-dessus du dock mobile */
      }

      .sticky-reward {
        grid-area: reward;
        gap: 7px;
        padding: 9px 10px;
        border-radius: 15px;
      }

      .sticky-product-info {
        grid-area: product;
        align-items: center;
        gap: 9px;
        min-width: 0;
      }

      .sticky-product-media {
        width: 42px;
        height: 42px;
        flex-basis: 42px;
        border-radius: 9px;
      }

      .sticky-title {
        display: block;
        font-size: 12px;
        max-width: 38vw;
        line-height: 1.18;
      }
      
      .sticky-price {
        font-size: 14px;
        line-height: 1.2;
      }

      .sticky-reward__top {
        gap: 8px;
      }

      .sticky-reward__label {
        font-size: 0.92rem;
      }

      .sticky-reward__hint {
        font-size: 0.68rem;
        max-width: 46vw;
        white-space: normal;
      }

      .sticky-reward__rail {
        height: 9px;
      }

      .sticky-reward__mark {
        width: 24px;
        height: 24px;
        font-size: 0.58rem;
      }

      .sticky-reward__steps {
        font-size: 0.6rem;
      }

      .sticky-btn.milaura-btn-gold {
        min-width: 92px;
        min-height: 40px;
        padding: 10px 13px;
        font-size: 12px;
        line-height: 1;
      }
      
      .sticky-btn-wrapper {
        grid-area: button;
        display: flex;
      }
      
      .sticky-btn {
        width: auto;
      }

      .sticky-btn-label-desktop {
        display: none;
      }

      .sticky-btn-label-mobile {
        display: inline;
      }

      .sticky-btn-qty {
        min-width: 24px;
        min-height: 22px;
        margin-left: 7px;
        padding: 3px 7px;
        font-size: 11px;
      }
    }
  </style>

  <div
    id="MilauraStickyBarSection"
    class="milaura-sticky-bar"
    data-product-price-cents="{{ product_price_cents }}"
    data-reward-threshold-1="{{ reward_threshold_1_cents }}"
    data-reward-threshold-2="{{ reward_threshold_2_cents }}"
    data-reward-threshold-3="{{ reward_threshold_3_cents }}"
  >
    
    <!-- Info Gauche -->
    <div class="sticky-product-info">
      {%- assign sticky_image = product.featured_image -%}
      {%- if sticky_image == blank and product.featured_media.preview_image != blank -%}
        {%- assign sticky_image = product.featured_media.preview_image -%}
      {%- endif -%}
      {%- if sticky_image != blank -%}
        <div class="sticky-product-media">
          {{
            sticky_image
            | image_url: width: 120
            | image_tag:
              loading: 'lazy',
              widths: '80, 120',
              sizes: '48px',
              alt: product.title
          }}
        </div>
      {%- endif -%}
      <div class="sticky-product-copy">
        <h4 class="sticky-title">{{ product.title | truncate: 42 }}</h4>
        <div id="StickyBarPrice" class="sticky-price">
          {{ product.selected_or_first_available_variant.price | money }}
        </div>
      </div>
    </div>

    <div class="sticky-reward" aria-live="polite">
      <div class="sticky-reward__top">
        <p class="sticky-reward__label" id="StickyRewardLabel">Votre carte MilAura vous attend</p>
        <p class="sticky-reward__hint" id="StickyRewardHint">À gratter dans le panier</p>
      </div>
      <div class="sticky-reward__rail" role="progressbar" aria-valuemin="0" aria-valuemax="100" aria-valuenow="0">
        <span class="sticky-reward__fill" id="StickyRewardFill"></span>
        <span class="sticky-reward__mark sticky-reward__mark--one" data-sticky-reward-mark="1" aria-hidden="true">
          {%- if sticky_reward_logo != blank -%}
            {{ sticky_reward_logo | image_url: width: 48 | image_tag: class: 'sticky-reward__logo', loading: 'lazy', widths: '32, 48', sizes: '18px', alt: '' }}
          {%- else -%}
            <span class="sticky-reward__fallback-mark">M</span>
          {%- endif -%}
        </span>
        <span class="sticky-reward__mark sticky-reward__mark--two" data-sticky-reward-mark="2" aria-hidden="true">
          {%- if sticky_reward_logo != blank -%}
            {{ sticky_reward_logo | image_url: width: 48 | image_tag: class: 'sticky-reward__logo', loading: 'lazy', widths: '32, 48', sizes: '18px', alt: '' }}
          {%- else -%}
            <span class="sticky-reward__fallback-mark">M</span>
          {%- endif -%}
        </span>
        <span class="sticky-reward__mark sticky-reward__mark--three" data-sticky-reward-mark="3" aria-hidden="true">
          {%- if sticky_reward_logo != blank -%}
            {{ sticky_reward_logo | image_url: width: 48 | image_tag: class: 'sticky-reward__logo', loading: 'lazy', widths: '32, 48', sizes: '18px', alt: '' }}
          {%- else -%}
            <span class="sticky-reward__fallback-mark">M</span>
          {%- endif -%}
        </span>
      </div>
      <div class="sticky-reward__steps" aria-hidden="true">
        <span>20 €</span>
        <span>50 €</span>
        <span>80 €</span>
      </div>
    </div>

    <!-- Bouton Droite -->
    <div class="sticky-btn-wrapper">
      <button class="sticky-btn milaura-btn-gold" id="TriggerMainAtc">
        <span class="sticky-btn-label-desktop">{{ section.settings.button_text }}</span>
        <span class="sticky-btn-label-mobile">Ajouter</span>
        <span class="sticky-btn-qty" id="StickyBarQtyBadge" aria-live="polite"></span>
      </button>
    </div>

  </div>

  <script>
    document.addEventListener('DOMContentLoaded', function() {
      const stickyBar = document.getElementById('MilauraStickyBarSection');
      const triggerBtn = document.getElementById('TriggerMainAtc');
      const qtyBadge = document.getElementById('StickyBarQtyBadge');
      const rewardLabel = document.getElementById('StickyRewardLabel');
      const rewardHint = document.getElementById('StickyRewardHint');
      const rewardFill = document.getElementById('StickyRewardFill');
      const rewardRail = stickyBar ? stickyBar.querySelector('.sticky-reward__rail') : null;
      const rewardMarks = stickyBar ? Array.from(stickyBar.querySelectorAll('[data-sticky-reward-mark]')) : [];
      const rewardThresholds = stickyBar ? [
        parseInt(stickyBar.dataset.rewardThreshold1, 10) || 2000,
        parseInt(stickyBar.dataset.rewardThreshold2, 10) || 5000,
        parseInt(stickyBar.dataset.rewardThreshold3, 10) || 8000
      ] : [2000, 5000, 8000];
      const productPriceCents = stickyBar ? (parseInt(stickyBar.dataset.productPriceCents, 10) || 0) : 0;
      let currentQuantity = 1;
      let paidCartSubtotalCents = 0;

      // Sélecteurs pour trouver le bouton principal dans la page
      // Ordre du plus specifique au plus generique. Le CTA bundle (hero refonte 2026-05-28)
      // doit etre prioritaire car c'est celui qui pilote l'ajout au panier + free gifts.
      const mainButtonSelectors = [
        '.milaura-hero-cta-bundle',
        '.milaura-add-btn',
        'button[name="add"]',
        '.product-form__submit',
        '[data-add-to-cart]'
      ];

      let mainButton = null;
      for (const sel of mainButtonSelectors) {
        const found = document.querySelector(sel);
        if (found && found.offsetParent !== null) {
          mainButton = found;
          break;
        }
      }

      // Bubble elements (for desktop repositioning when sticky is visible)
      const bubbleTrigger = document.querySelector('.milaura-bubble-trigger');
      const bubbleLabel = document.querySelector('.milaura-bubble-label');

      // Trouver le footer pour masquer la sticky bar quand on y arrive
      const footer = document.querySelector('footer') || document.querySelector('.footer') || document.querySelector('#shopify-section-footer');
      const stickyBarHeight = stickyBar ? stickyBar.offsetHeight : 80;
      const stickyAlwaysMobile = window.matchMedia ? window.matchMedia('(max-width: 768px)') : null;

      // 1. Logique d'affichage (Scroll)
      if (stickyBar && mainButton) {
        const handleScroll = () => {
          const rect = mainButton.getBoundingClientRect();
          const footerRect = footer ? footer.getBoundingClientRect() : null;
          const shouldShowAlways = stickyAlwaysMobile && stickyAlwaysMobile.matches;

          // Vérifier si le footer est visible (entre dans le viewport)
          const footerVisible = footerRect && footerRect.top < window.innerHeight;

          // Le bouton est-il passé au-dessus de l'écran ? (top < 0)
          // On ajoute une marge de sécurité (ex: -50px) pour être sûr qu'il est bien sorti
          if ((shouldShowAlways || rect.top < -50) && !footerVisible) {
            stickyBar.classList.add('is-visible');
          } else {
            stickyBar.classList.remove('is-visible');
          }

          // Push floating bubble above sticky bar on ALL viewports (desktop + mobile)
          if (bubbleTrigger) {
            const isUp = stickyBar.classList.contains('is-visible');
            if (isUp) {
              const stickyRect = stickyBar.getBoundingClientRect();
              const stickyBottomOffset = window.innerHeight - stickyRect.top;
              const gap = 16;
              bubbleTrigger.style.bottom = (stickyBottomOffset + gap) + 'px';
              if (bubbleLabel) bubbleLabel.style.bottom = (stickyBottomOffset + gap + 8) + 'px';
            } else {
              // Reset to CSS defaults (24px desktop, 85px mobile above dock)
              bubbleTrigger.style.bottom = '';
              if (bubbleLabel) bubbleLabel.style.bottom = '';
            }
          }
        };

        window.addEventListener('scroll', handleScroll, { passive: true });
        if (stickyAlwaysMobile && typeof stickyAlwaysMobile.addEventListener === 'function') {
          stickyAlwaysMobile.addEventListener('change', handleScroll);
        } else if (stickyAlwaysMobile && typeof stickyAlwaysMobile.addListener === 'function') {
          stickyAlwaysMobile.addListener(handleScroll);
        }
        // Check initial
        handleScroll();
      } else {
        // Fallback si pas de bouton trouvé (ex: page bizarre), on affiche après un certain scroll
        window.addEventListener('scroll', () => {
          const footerRect = footer ? footer.getBoundingClientRect() : null;
          const footerVisible = footerRect && footerRect.top < window.innerHeight;

          if (window.scrollY > 800 && !footerVisible) stickyBar.classList.add('is-visible');
          else stickyBar.classList.remove('is-visible');
        }, { passive: true });
      }

      // 2. Logique de clic
      function setTriggerLabels(text) {
        if (!triggerBtn) return;
        const desktopLabel = triggerBtn.querySelector('.sticky-btn-label-desktop');
        const mobileLabel = triggerBtn.querySelector('.sticky-btn-label-mobile');
        if (desktopLabel) desktopLabel.textContent = text;
        if (mobileLabel) mobileLabel.textContent = text;
      }

      if (triggerBtn && mainButton) {
        const desktopLabel = triggerBtn.querySelector('.sticky-btn-label-desktop');
        const mobileLabel = triggerBtn.querySelector('.sticky-btn-label-mobile');
        const originalDesktopText = desktopLabel ? desktopLabel.textContent : triggerBtn.textContent;
        const originalMobileText = mobileLabel ? mobileLabel.textContent : originalDesktopText;
        triggerBtn.addEventListener('click', (e) => {
          e.preventDefault();
          mainButton.click();
          // Petit feedback visuel
          setTriggerLabels('Ajout...');
          setTimeout(() => {
            if (desktopLabel) desktopLabel.textContent = originalDesktopText;
            if (mobileLabel) mobileLabel.textContent = originalMobileText;
          }, 1000);
        });
      }

      function updateQtyBadge(quantity) {
        if (!qtyBadge) return;
        const nextQuantity = Number.parseInt(quantity, 10);
        if (Number.isFinite(nextQuantity) && nextQuantity > 1) {
          qtyBadge.textContent = 'x' + nextQuantity;
          qtyBadge.classList.add('is-visible');
          qtyBadge.removeAttribute('hidden');
        } else {
          qtyBadge.textContent = '';
          qtyBadge.classList.remove('is-visible');
          qtyBadge.setAttribute('hidden', '');
        }
      }

      document.addEventListener('milaura:product-quantity-change', (event) => {
        currentQuantity = Number.parseInt(event.detail && event.detail.quantity, 10) || 1;
        updateQtyBadge(currentQuantity);
        updateRewardMeter();
      });
      updateQtyBadge(1);

      function formatMoney(cents) {
        try {
          return new Intl.NumberFormat('fr-FR', {
            style: 'currency',
            currency: '{{ cart.currency.iso_code | default: shop.currency }}',
            maximumFractionDigits: 2
          }).format(cents / 100);
        } catch (e) {
          return (cents / 100).toFixed(2).replace('.', ',') + ' €';
        }
      }

      function isMilAuraGiftItem(item) {
        if (!item) return false;
        const props = item.properties || {};
        return props._milaura_gift === 'true' ||
          (item.handle && item.handle.indexOf('cadeau-') === 0) ||
          (item.product_title && item.product_title.indexOf('Cadeau -') === 0);
      }

      function paidSubtotalCents(cart) {
        if (!cart || !cart.items) return 0;
        return cart.items.reduce(function(total, item) {
          if (isMilAuraGiftItem(item)) return total;
          return total + (Number(item.original_line_price || item.final_line_price || item.line_price || 0) || 0);
        }, 0);
      }

      function unlockedCardsForAmount(cents) {
        if (cents >= rewardThresholds[2]) return 3;
        if (cents >= rewardThresholds[1]) return 2;
        if (cents >= rewardThresholds[0]) return 1;
        return 0;
      }

      function progressPercent(cents) {
        const max = rewardThresholds[2] || 8000;
        return Math.max(0, Math.min(100, Math.round((cents / max) * 100)));
      }

      function nextThreshold(cents) {
        for (let i = 0; i < rewardThresholds.length; i += 1) {
          if (cents < rewardThresholds[i]) {
            return {
              index: i + 1,
              amount: rewardThresholds[i],
              remaining: rewardThresholds[i] - cents
            };
          }
        }
        return null;
      }

      function updateRewardMeter() {
        if (!stickyBar || !rewardLabel || !rewardHint || !rewardFill) return;
        const actualSubtotal = Math.max(0, paidCartSubtotalCents);
        const projectedSubtotal = paidCartSubtotalCents + (productPriceCents * Math.max(1, currentQuantity));
        const unlocked = unlockedCardsForAmount(actualSubtotal);
        const projectedUnlocked = unlockedCardsForAmount(projectedSubtotal);
        const projectedGain = Math.max(0, projectedUnlocked - unlocked);
        const actualNext = nextThreshold(actualSubtotal);
        const projectedNext = nextThreshold(projectedSubtotal);
        const percent = progressPercent(actualSubtotal);

        rewardFill.style.width = percent + '%';
        if (rewardRail) rewardRail.setAttribute('aria-valuenow', String(percent));
        rewardMarks.forEach(function(mark) {
          const index = parseInt(mark.getAttribute('data-sticky-reward-mark'), 10);
          mark.classList.toggle('is-unlocked', index <= unlocked);
        });

        if (unlocked >= 3) {
          rewardLabel.textContent = '3 cartes MilAura dans votre panier';
          rewardHint.textContent = 'À gratter dans le panier';
        } else if (unlocked === 2) {
          rewardLabel.textContent = '2 cartes MilAura dans votre panier';
          rewardHint.textContent = projectedGain > 0
            ? 'Ce produit débloque la Surprise été'
            : (actualNext ? 'Encore ' + formatMoney(actualNext.remaining) + ' pour la Surprise été' : 'À gratter dans le panier');
        } else if (unlocked === 1) {
          rewardLabel.textContent = '1 carte MilAura dans votre panier';
          rewardHint.textContent = projectedGain > 0
            ? 'Ce produit débloque la carte suivante'
            : (actualNext ? 'Encore ' + formatMoney(actualNext.remaining) + ' pour la suivante' : 'À gratter dans le panier');
        } else {
          if (projectedUnlocked >= 2) {
            rewardLabel.textContent = 'Ce produit débloque ' + projectedUnlocked + ' cartes MilAura';
            rewardHint.textContent = 'Ajoutez-le au panier, elles vous y attendront';
          } else if (projectedUnlocked === 1) {
            rewardLabel.textContent = 'Ce produit débloque votre 1re carte MilAura';
            rewardHint.textContent = 'Ajoutez-le au panier, elle vous y attendra';
          } else {
            rewardLabel.textContent = 'Votre première carte MilAura se prépare';
            rewardHint.textContent = projectedNext
              ? 'Encore ' + formatMoney(projectedNext.remaining) + ' après ajout de ce produit'
              : (actualNext ? 'Encore ' + formatMoney(actualNext.remaining) + ' pour la première carte' : 'À gratter dans le panier');
          }
        }
      }

      function refreshRewardCartState(cart) {
        if (cart) {
          paidCartSubtotalCents = paidSubtotalCents(cart);
          updateRewardMeter();
          return;
        }
        fetch('/cart.js')
          .then(function(response) { return response.ok ? response.json() : null; })
          .then(function(nextCart) {
            paidCartSubtotalCents = paidSubtotalCents(nextCart);
            updateRewardMeter();
          })
          .catch(updateRewardMeter);
      }

      document.addEventListener('cart:updated', function(event) {
        refreshRewardCartState(event.detail);
      });
      window.addEventListener('cart:updated', function(event) {
        refreshRewardCartState(event.detail);
      });
      refreshRewardCartState();

      // 3. Mise à jour du prix (si variant change)
      const stickyPrice = document.getElementById('StickyBarPrice');
      const mainPrice = document.querySelector('.price-item--regular') || document.querySelector('.milaura-product__price');
      
      if (stickyPrice && mainPrice) {
        const observer = new MutationObserver(() => {
           // On nettoie un peu le HTML pour éviter les duplications
           stickyPrice.innerHTML = mainPrice.innerText; 
        });
        observer.observe(mainPrice, { childList: true, subtree: true, characterData: true });
      }
    });
  </script>
{%- endif -%}

