{% comment %}
  MILAURA HERO HOMEPAGE
  Mobile-first product hero for the featured weekly stone.
  Product, copy, benefits and trust badges stay editable.
  A small scroll hook hides the gift bubble while the hero is in view.
{% endcomment %}

{%- assign product = section.settings.product -%}
{%- assign hero_image = section.settings.image -%}
{%- if hero_image == blank and product != blank and product.featured_image -%}
  {%- assign hero_image = product.featured_image -%}
{%- endif -%}
{%- assign cta_url = section.settings.cta_url | default: product.url | default: '/collections/bijoux-pierres-naturelles' -%}
{%- assign hero_label = section.settings.pretitle | default: section.settings.headline | strip_html | escape -%}
{%- assign headline_line_1 = "Mil'Aura !" -%}
{%- assign headline_line_2 = 'Qui sera la plus belle' -%}
{%- assign headline_line_3 = 'sur la plage cet &eacute;t&eacute; ?' -%}
{%- assign top_hook_kicker = 'S&eacute;lection estivale 2026' -%}
{%- assign top_hook_text = 'Le bijou de' -%}
{%- assign top_hook_highlight = "l'&eacute;t&eacute;" -%}

{% style %}
  #MilauraHeroHome-{{ section.id }} {
    --hero-ink: #10232c;
    --hero-muted: #315461;
    --hero-aqua: #9de7ee;
    --hero-aqua-strong: #49afc6;
    --hero-aqua-deep: #1e718c;
    --hero-pearl: #fbfff9;
    --hero-cream: #fff4df;
    --hero-gold: #c0a062;
    --hero-gold-soft: #f1d59a;
    --hero-line: rgba(255, 255, 255, 0.55);
    --hero-shadow: 0 28px 70px rgba(16, 35, 44, 0.24);
    position: relative;
    overflow: hidden;
    color: var(--hero-ink);
    background:
      linear-gradient(180deg, rgba(137, 226, 235, 0.98) 0%, rgba(89, 199, 217, 0.96) 38%, rgba(203, 232, 221, 0.94) 62%, rgba(246, 221, 171, 0.94) 84%, var(--milaura-surface-warm, #fff7e8) 100%);
    letter-spacing: 0;
    isolation: isolate;
  }

  #MilauraHeroHome-{{ section.id }}::before,
  #MilauraHeroHome-{{ section.id }}::after {
    content: "";
    position: absolute;
    inset: 0;
    pointer-events: none;
    z-index: -1;
  }

  #MilauraHeroHome-{{ section.id }}::before {
    background:
      linear-gradient(116deg, rgba(255, 255, 255, 0.82) 0 13%, transparent 13% 100%),
      linear-gradient(151deg, transparent 0 48%, rgba(255, 255, 255, 0.28) 48% 52%, transparent 52% 100%),
      repeating-linear-gradient(168deg, rgba(255, 255, 255, 0.16) 0 1px, transparent 1px 28px);
    opacity: 0.72;
  }

  #MilauraHeroHome-{{ section.id }}::after {
    background:
      linear-gradient(180deg, transparent 0 50%, rgba(255, 247, 228, 0.38) 72%, var(--milaura-surface-warm, #fff7e8) 100%),
      linear-gradient(92deg, transparent 0 62%, rgba(16, 35, 44, 0.18) 62% 100%);
  }

  #MilauraHeroHome-{{ section.id }} .hero-home-shell {
    min-height: calc(100svh - var(--header-height-mobile, 80px) - 170px);
    padding: 16px 18px 28px;
    display: grid;
    align-items: stretch;
  }

  #MilauraHeroHome-{{ section.id }} .hero-home-inner {
    width: min(100%, 1340px);
    margin: 0 auto;
    display: grid;
    grid-template-rows: minmax(194px, auto) auto;
    align-content: start;
    gap: 8px;
  }

  #MilauraHeroHome-{{ section.id }} .hero-home-visual-col {
    position: relative;
    order: 1;
    min-height: 194px;
    display: grid;
    place-items: center;
  }

  #MilauraHeroHome-{{ section.id }} .hero-home-visual {
    position: relative;
    width: min(100%, 304px);
    aspect-ratio: 1 / 0.92;
    display: grid;
    place-items: center;
  }

  #MilauraHeroHome-{{ section.id }} .hero-home-visual::before {
    content: "";
    position: absolute;
    width: 86%;
    height: 58%;
    left: 7%;
    bottom: 2%;
    background:
      linear-gradient(180deg, rgba(255, 248, 229, 0.94), rgba(211, 177, 111, 0.45)),
      repeating-linear-gradient(90deg, rgba(16, 35, 44, 0.08) 0 1px, transparent 1px 13px);
    border: 1px solid rgba(255, 255, 255, 0.58);
    border-radius: 8px;
    transform: perspective(540px) rotateX(58deg) rotateZ(-7deg);
    box-shadow: 0 24px 48px rgba(16, 35, 44, 0.20);
  }

  #MilauraHeroHome-{{ section.id }} .hero-home-visual::after {
    content: "";
    position: absolute;
    width: 64%;
    height: 1px;
    right: 1%;
    top: 17%;
    background: linear-gradient(90deg, transparent, rgba(255, 255, 255, 0.86), transparent);
    transform: rotate(-10deg);
  }

  #MilauraHeroHome-{{ section.id }} .hero-home-img {
    position: relative;
    z-index: 2;
    width: min(86%, 252px);
    height: auto;
    aspect-ratio: 1 / 1;
    object-fit: cover;
    border-radius: 10px;
    box-shadow: var(--hero-shadow);
    transform: rotate(-5deg);
  }

  #MilauraHeroHome-{{ section.id }} .hero-home-stone-tag {
    position: absolute;
    z-index: 3;
    right: 0;
    bottom: 10px;
    display: inline-flex;
    align-items: center;
    gap: 7px;
    min-height: 36px;
    padding: 8px 12px;
    border-radius: 999px;
    background: rgba(255, 255, 255, 0.84);
    color: var(--hero-ink);
    font: 700 0.72rem/1 var(--milaura-font-body);
    box-shadow: 0 12px 28px rgba(16, 35, 44, 0.16);
    backdrop-filter: blur(14px);
  }

  #MilauraHeroHome-{{ section.id }} .hero-home-stone-dot {
    width: 12px;
    height: 12px;
    border-radius: 50%;
    background: linear-gradient(135deg, var(--hero-aqua), #ffffff 48%, var(--hero-gold-soft));
    border: 1px solid rgba(16, 35, 44, 0.12);
    flex: 0 0 auto;
  }

  #MilauraHeroHome-{{ section.id }} .hero-home-content {
    position: relative;
    z-index: 2;
    order: 2;
    align-self: end;
    padding: 0 0 2px;
  }

  #MilauraHeroHome-{{ section.id }} .hero-home-badge-row {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: 8px;
    margin-bottom: 10px;
  }

  #MilauraHeroHome-{{ section.id }} .hero-home-badge,
  #MilauraHeroHome-{{ section.id }} .hero-home-stock {
    display: inline-flex;
    align-items: center;
    min-height: 28px;
    padding: 7px 11px;
    border-radius: 999px;
    border: 1px solid rgba(16, 35, 44, 0.13);
    background: rgba(255, 255, 255, 0.58);
    color: var(--hero-ink);
    font: 800 0.68rem/1 var(--milaura-font-body);
    backdrop-filter: blur(14px);
  }

  #MilauraHeroHome-{{ section.id }} .hero-home-pretitle {
    margin: 0 0 4px;
    max-width: 18rem;
    color: var(--hero-ink);
    font: 700 0.92rem/1.22 var(--milaura-font-body);
  }

  #MilauraHeroHome-{{ section.id }} .hero-home-headline {
    margin: 0;
    color: var(--hero-ink);
    font-family: var(--milaura-font-heading);
    font-size: 2.62rem;
    font-weight: 600;
    line-height: 0.94;
    text-wrap: balance;
  }

  #MilauraHeroHome-{{ section.id }} .hero-home-headline span {
    color: var(--hero-aqua-deep);
  }

  #MilauraHeroHome-{{ section.id }} .hero-home-subtitle {
    max-width: 34rem;
    margin: 9px 0 0;
    color: var(--hero-muted);
    font: 500 0.8rem/1.36 var(--milaura-font-body);
  }

  #MilauraHeroHome-{{ section.id }} .hero-home-benefits {
    list-style: none;
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: 6px;
    margin: 11px 0 0;
    padding: 0;
  }

  #MilauraHeroHome-{{ section.id }} .hero-home-benefits li {
    display: grid;
    grid-template-columns: 1fr;
    align-items: center;
    justify-items: center;
    gap: 5px;
    min-height: 54px;
    padding: 7px 5px;
    border: 1px solid rgba(255, 255, 255, 0.48);
    border-radius: 8px;
    background: rgba(255, 255, 255, 0.24);
    color: var(--hero-ink);
    font: 800 0.62rem/1.14 var(--milaura-font-body);
    text-align: center;
  }

  #MilauraHeroHome-{{ section.id }} .hero-home-benefit-icon {
    display: grid;
    place-items: center;
    width: 28px;
    height: 28px;
    border-radius: 50%;
    border: 1px solid rgba(255, 255, 255, 0.72);
    background: rgba(255, 255, 255, 0.42);
    box-shadow: 0 8px 18px rgba(16, 35, 44, 0.10);
    font-size: 0.9rem;
  }

  #MilauraHeroHome-{{ section.id }} .hero-home-action-row {
    display: grid;
    grid-template-columns: 1fr;
    gap: 9px;
    margin-top: 11px;
  }

  #MilauraHeroHome-{{ section.id }} .hero-home-price {
    display: flex;
    align-items: baseline;
    gap: 8px;
    color: var(--hero-ink);
    font-family: var(--milaura-font-body);
  }

  #MilauraHeroHome-{{ section.id }} .hero-home-price-now {
    font-size: 1.12rem;
    font-weight: 900;
  }

  #MilauraHeroHome-{{ section.id }} .hero-home-price-label {
    color: var(--hero-muted);
    font-size: 0.78rem;
    font-weight: 700;
  }

  #MilauraHeroHome-{{ section.id }} .hero-home-price-was {
    color: rgba(16, 35, 44, 0.48);
    font-size: 0.86rem;
    font-weight: 700;
    text-decoration: line-through;
  }

  #MilauraHeroHome-{{ section.id }} .hero-home-cta {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    gap: 10px;
    justify-self: start;
    min-height: 48px;
    width: min(100%, 252px);
    padding: 14px 18px;
    border: 1px solid rgba(255, 255, 255, 0.62);
    border-radius: 999px;
    background: linear-gradient(180deg, var(--milaura-cta-gold-top, #fff7e5), var(--milaura-cta-gold-bottom, #f0c777));
    color: var(--milaura-cta-ink, #2c210f);
    font: 900 0.96rem/1 var(--milaura-font-body);
    text-decoration: none;
    box-shadow:
      inset 0 1px 0 rgba(255, 255, 255, 0.9),
      0 16px 34px rgba(50, 80, 90, 0.22);
    transition: transform 0.2s ease, box-shadow 0.2s ease;
  }

  #MilauraHeroHome-{{ section.id }} .hero-home-cta:hover {
    transform: translateY(-2px);
    box-shadow:
      inset 0 1px 0 rgba(255, 255, 255, 0.9),
      0 20px 42px rgba(50, 80, 90, 0.28);
  }

  #MilauraHeroHome-{{ section.id }} .hero-home-cta:focus-visible {
      outline: 3px solid rgba(16, 35, 44, 0.62);
    outline-offset: 4px;
  }

  #MilauraHeroHome-{{ section.id }} .hero-home-cta svg {
    width: 17px;
    height: 17px;
    flex: 0 0 auto;
  }

  #MilauraHeroHome-{{ section.id }} .hero-home-trust {
    display: none;
    flex-wrap: wrap;
    gap: 8px 12px;
    margin-top: 9px;
    color: rgba(16, 35, 44, 0.82);
    font: 800 0.72rem/1.2 var(--milaura-font-body);
  }

  #MilauraHeroHome-{{ section.id }} .hero-home-trust span {
    display: inline-flex;
    align-items: center;
    gap: 5px;
  }

  @media (max-width: 379px) {
    #MilauraHeroHome-{{ section.id }} .hero-home-shell {
      min-height: calc(100svh - var(--header-height-mobile, 80px) - 150px);
      padding-left: 13px;
      padding-right: 13px;
    }

    #MilauraHeroHome-{{ section.id }} .hero-home-inner {
      grid-template-rows: minmax(184px, auto) auto;
      gap: 7px;
    }

    #MilauraHeroHome-{{ section.id }} .hero-home-headline {
      font-size: 2.28rem;
    }

    #MilauraHeroHome-{{ section.id }} .hero-home-subtitle {
      font-size: 0.8rem;
    }

    #MilauraHeroHome-{{ section.id }} .hero-home-benefits li {
      min-height: 52px;
      font-size: 0.58rem;
    }
  }

  @media (max-height: 740px) and (max-width: 767px) {
    #MilauraHeroHome-{{ section.id }} .hero-home-shell {
      min-height: auto;
    }

    #MilauraHeroHome-{{ section.id }} .hero-home-inner {
      grid-template-rows: minmax(188px, auto) auto;
    }

    #MilauraHeroHome-{{ section.id }} .hero-home-benefits {
      gap: 4px;
      margin-top: 10px;
    }
  }

  @media (min-width: 768px) {
    #MilauraHeroHome-{{ section.id }} .hero-home-shell {
      min-height: calc(100svh - var(--header-height-tablet, 88px) - 64px);
      padding: 34px 32px 40px;
    }

    #MilauraHeroHome-{{ section.id }} .hero-home-inner {
      grid-template-columns: minmax(0, 0.86fr) minmax(390px, 1.14fr);
      grid-template-rows: 1fr;
      align-content: center;
      align-items: center;
      gap: 32px;
    }

    #MilauraHeroHome-{{ section.id }} .hero-home-content {
      order: 1;
      align-self: center;
    }

    #MilauraHeroHome-{{ section.id }} .hero-home-visual-col {
      order: 2;
      min-height: 470px;
    }

    #MilauraHeroHome-{{ section.id }} .hero-home-visual {
      width: min(100%, 610px);
    }

    #MilauraHeroHome-{{ section.id }} .hero-home-img {
      width: min(86%, 510px);
    }

    #MilauraHeroHome-{{ section.id }} .hero-home-stone-tag {
      right: 4%;
      bottom: 30px;
    }

    #MilauraHeroHome-{{ section.id }} .hero-home-pretitle {
      max-width: 28rem;
      font-size: 1.22rem;
    }

    #MilauraHeroHome-{{ section.id }} .hero-home-headline {
      font-size: 4.85rem;
    }

    #MilauraHeroHome-{{ section.id }} .hero-home-subtitle {
      font-size: 1.02rem;
    }

    #MilauraHeroHome-{{ section.id }} .hero-home-benefits {
      grid-template-columns: repeat(3, minmax(0, 1fr));
      gap: 10px;
      max-width: 610px;
    }

    #MilauraHeroHome-{{ section.id }} .hero-home-benefits li {
      grid-template-columns: 36px 1fr;
      gap: 9px;
      justify-items: start;
      min-height: 54px;
      padding-right: 8px;
      padding-top: 0;
      padding-bottom: 0;
      padding-left: 0;
      border: 0;
      background: transparent;
      text-align: left;
    }

    #MilauraHeroHome-{{ section.id }} .hero-home-benefit-icon {
      width: 36px;
      height: 36px;
    }

    #MilauraHeroHome-{{ section.id }} .hero-home-action-row {
      grid-template-columns: auto 1fr;
      align-items: center;
      gap: 18px;
      margin-top: 22px;
    }

    #MilauraHeroHome-{{ section.id }} .hero-home-cta {
      width: auto;
      min-width: 236px;
    }

    #MilauraHeroHome-{{ section.id }} .hero-home-trust {
      display: flex;
    }
  }

  @media (min-width: 1100px) {
    #MilauraHeroHome-{{ section.id }} .hero-home-shell {
      min-height: calc(100svh - var(--header-height-desktop, 110px) - 72px);
      padding: 42px 56px 54px;
    }

    #MilauraHeroHome-{{ section.id }} .hero-home-inner {
      grid-template-columns: minmax(410px, 0.82fr) minmax(560px, 1.18fr);
      gap: 54px;
    }

    #MilauraHeroHome-{{ section.id }} .hero-home-visual-col {
      min-height: 630px;
    }

    #MilauraHeroHome-{{ section.id }} .hero-home-visual {
      width: min(100%, 760px);
    }

    #MilauraHeroHome-{{ section.id }} .hero-home-img {
      width: min(86%, 635px);
    }

    #MilauraHeroHome-{{ section.id }} .hero-home-stone-tag {
      right: 7%;
      bottom: 42px;
      min-height: 42px;
      padding: 9px 15px;
      font-size: 0.78rem;
    }

    #MilauraHeroHome-{{ section.id }} .hero-home-headline {
      font-size: 5.95rem;
    }

    #MilauraHeroHome-{{ section.id }} .hero-home-subtitle {
      max-width: 31rem;
    }
  }

  @media (min-width: 1400px) {
    #MilauraHeroHome-{{ section.id }} .hero-home-shell {
      padding-left: 70px;
      padding-right: 70px;
    }

    #MilauraHeroHome-{{ section.id }} .hero-home-headline {
      font-size: 6.35rem;
    }
  }

  @media (prefers-reduced-motion: reduce) {
    #MilauraHeroHome-{{ section.id }} .hero-home-cta {
      transition: none;
    }

    #MilauraHeroHome-{{ section.id }} .hero-home-top-phrase,
    #MilauraHeroHome-{{ section.id }} .hero-home-top-highlight::after {
      animation: none;
    }

    #MilauraHeroHome-{{ section.id }} .hero-home-top-phrase {
      opacity: 1;
    }
  }

  #shopify-section-{{ section.id }}.milaura-hero-homepage {
    margin-top: calc(-1 * var(--milaura-hero-overlap-mobile, 306px)) !important;
    overflow: hidden;
  }

  body:has(#MilauraHeroHome-{{ section.id }}) main#MainContent {
    padding-top: 0 !important;
  }

  #MilauraHeroHome-{{ section.id }} {
    min-height: 100svh;
    background: #bceff1;
  }

  #MilauraHeroHome-{{ section.id }}::before {
    z-index: 1;
    background:
      linear-gradient(180deg, rgba(189, 241, 244, 0.08) 0%, rgba(189, 241, 244, 0.08) 34%, rgba(199, 240, 237, 0.84) 62%, rgba(255, 244, 218, 0.98) 100%),
      radial-gradient(ellipse at 22% 66%, rgba(255, 249, 230, 0.68) 0 18%, transparent 46%),
      linear-gradient(90deg, rgba(8, 35, 43, 0.34) 0%, rgba(8, 35, 43, 0.06) 44%, rgba(255, 248, 230, 0.84) 100%);
    opacity: 1;
  }

  #MilauraHeroHome-{{ section.id }}::after {
    z-index: 1;
    background:
      radial-gradient(circle at 78% 22%, rgba(255, 255, 255, 0.76) 0 12%, transparent 32%),
      linear-gradient(112deg, transparent 0 52%, rgba(255, 248, 226, 0.70) 52% 100%);
  }

  #MilauraHeroHome-{{ section.id }} .hero-home-shell {
    position: relative;
    z-index: 2;
    min-height: 100svh;
    padding: calc(var(--header-height-mobile, 118px) + 22px) 18px calc(104px + env(safe-area-inset-bottom));
    display: grid;
    align-items: end;
  }

  #MilauraHeroHome-{{ section.id }} .hero-home-inner {
    display: block;
    width: min(100%, 1380px);
  }

  #MilauraHeroHome-{{ section.id }} .hero-home-visual-col {
    position: absolute;
    inset: 0;
    z-index: 0;
    min-height: 0;
    display: block;
  }

  #MilauraHeroHome-{{ section.id }} .hero-home-visual {
    width: 100%;
    height: 100%;
    aspect-ratio: auto;
    display: block;
  }

  #MilauraHeroHome-{{ section.id }} .hero-home-top-hook {
    position: absolute;
    z-index: 5;
    top: 0;
    left: 50%;
    right: auto;
    display: grid;
    grid-template-columns: minmax(0, 1fr);
    align-content: start;
    align-items: start;
    justify-content: center;
    justify-items: center;
    gap: 0;
    width: 100vw;
    min-height: calc(var(--header-height-mobile, 80px) + clamp(76px, 10svh, 92px));
    padding: calc(var(--header-height-mobile, 80px) + 6px) 96px 10px 24px;
    border-top: 0;
    border-right: 0;
    border-bottom: 1px solid rgba(255, 255, 255, 0.66);
    border-left: 0;
    border-radius: 0;
    background:
      linear-gradient(105deg, rgba(255, 249, 230, 0.97), rgba(240, 207, 146, 0.92) 42%, rgba(239, 215, 236, 0.88) 100%),
      linear-gradient(90deg, rgba(255, 255, 255, 0.42), transparent);
    color: rgba(7, 29, 37, 0.88);
    box-shadow:
      inset 0 1px 0 rgba(255, 255, 255, 0.82),
      0 14px 30px rgba(93, 64, 26, 0.13);
    backdrop-filter: blur(18px);
    overflow: visible;
    transform: translateX(-50%);
  }

  #MilauraHeroHome-{{ section.id }} .hero-home-top-hook::before {
    content: "";
    position: absolute;
    inset: calc(var(--header-height-mobile, 80px) + 7px) 18px 7px;
    z-index: 0;
    border-top: 0;
    border-right: 0;
    border-bottom: 1px solid rgba(255, 255, 255, 0.46);
    border-left: 0;
    border-radius: 0;
    pointer-events: none;
  }

  #MilauraHeroHome-{{ section.id }} .hero-home-top-hook::after {
    display: none;
  }

  #MilauraHeroHome-{{ section.id }} .hero-home-top-logo {
    display: block;
    position: absolute;
    z-index: 4;
    right: clamp(12px, 4vw, 24px);
    bottom: calc(-1 * clamp(50px, 11.6vw, 68px));
    width: clamp(78px, 22vw, 104px);
    height: auto;
    filter: drop-shadow(0 14px 18px rgba(93, 64, 26, 0.24));
  }

  #MilauraHeroHome-{{ section.id }} .hero-home-top-wordmark {
    position: absolute;
    z-index: 4;
    right: 22px;
    bottom: -18px;
    color: #b28a38;
    font: 500 1.5rem/1 var(--milaura-font-script);
    letter-spacing: 0;
  }

  #MilauraHeroHome-{{ section.id }} .hero-home-top-copy {
    position: relative;
    z-index: 2;
    display: grid;
    justify-items: center;
    gap: 3px;
    width: min(100%, 320px);
    min-width: 0;
    text-align: center;
  }

  #MilauraHeroHome-{{ section.id }} .hero-home-top-kicker {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    gap: 7px;
    color: #071d25;
    font: 500 28px/0.9 var(--milaura-font-script);
    letter-spacing: 0;
    text-transform: none;
    text-shadow: 0 1px 0 rgba(255, 255, 255, 0.68);
    transform: translate(22px, -34px);
  }

  #MilauraHeroHome-{{ section.id }} .hero-home-top-kicker::before {
    content: "";
    display: inline-block;
    width: 20px;
    height: 20px;
    flex: 0 0 auto;
