{% comment %}
  MILAURA HERO HOMEPAGE
  Mobile-first product hero for the featured weekly stone.
  Product, copy, benefits and trust badges stay editable.
  A small scroll hook hides the gift bubble while the hero is in view.
{% endcomment %}

{%- assign product = section.settings.product -%}
{%- assign hero_image = section.settings.image -%}
{%- if hero_image == blank and product != blank and product.featured_image -%}
  {%- assign hero_image = product.featured_image -%}
{%- endif -%}
{%- assign cta_url = section.settings.cta_url | default: product.url | default: '/collections/bijoux-pierres-naturelles' -%}
{%- assign cta_text = section.settings.cta_text | default: 'Découvrir cette création' -%}
{%- assign hero_label = section.settings.pretitle | default: section.settings.headline | strip_html | escape -%}
{%- assign headline_line_1 = section.settings.headline_line_1 | default: 'MilAura' -%}
{%- assign headline_line_2 = section.settings.headline_line_2 | default: 'Qui sera la plus belle' -%}
{%- assign headline_line_3 = section.settings.headline_line_3 | default: 'sur la plage cet été ?' -%}
{%- assign top_hook_kicker = section.settings.top_hook_kicker | default: 'Sélection estivale 2026' -%}
{%- assign top_hook_text = section.settings.top_hook_text | default: 'Le bijou de' -%}
{%- assign top_hook_highlight = section.settings.top_hook_highlight | default: "l'été" -%}
{%- assign top_hook_brand_prefix = section.settings.top_hook_brand_prefix | default: 'par' -%}
{%- assign product_note = section.settings.product_note | default: 'Aigue Marine Grade AA' -%}
{%- assign product_material_note = section.settings.product_material_note | default: 'Argent rhodié 925' -%}

