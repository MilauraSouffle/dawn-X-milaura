  #MilauraHeroHome-{{ section.id }}::before,
  #MilauraHeroHome-{{ section.id }}::after {
    content: "";
    position: absolute;
    inset: 0;
    pointer-events: none;
    z-index: 0;
  }

  #MilauraHeroHome-{{ section.id }}::before {
    background:
      linear-gradient(116deg, rgba(255, 255, 255, 0.82) 0 13%, transparent 13% 100%),
      linear-gradient(151deg, transparent 0 48%, rgba(255, 255, 255, 0.28) 48% 52%, transparent 52% 100%),
      repeating-linear-gradient(168deg, rgba(255, 255, 255, 0.16) 0 1px, transparent 1px 28px);
    opacity: 0.72;
  }

  #MilauraHeroHome-{{ section.id }}::after {
    background:
      linear-gradient(180deg, transparent 0 50%, rgba(255, 247, 228, 0.38) 72%, var(--milaura-surface-warm, #fff7e8) 100%),
      linear-gradient(92deg, transparent 0 62%, rgba(16, 35, 44, 0.18) 62% 100%);
  }

  #MilauraHeroHome-{{ section.id }} .hero-home-shell {
    min-height: calc(100svh - var(--header-height-mobile, 80px) - 170px);
    padding: 16px 18px 28px;
    display: grid;
    align-items: stretch;
  }

  #MilauraHeroHome-{{ section.id }} .hero-home-inner {
    width: min(100%, 1340px);
    margin: 0 auto;
    display: grid;
    grid-template-rows: minmax(194px, auto) auto;
    align-content: start;
    gap: 8px;
  }

  #MilauraHeroHome-{{ section.id }} .hero-home-visual-col {
    position: relative;
    order: 1;
    min-height: 194px;
    display: grid;
    place-items: center;
  }

  #MilauraHeroHome-{{ section.id }} .hero-home-visual {
    position: relative;
    width: min(100%, 304px);
    aspect-ratio: 1 / 0.92;
    display: grid;
    place-items: center;
  }

  #MilauraHeroHome-{{ section.id }} .hero-home-visual::before {
    content: "";
    position: absolute;
    width: 86%;
    height: 58%;
    left: 7%;
    bottom: 2%;
    background:
      linear-gradient(180deg, rgba(255, 248, 229, 0.94), rgba(211, 177, 111, 0.45)),
