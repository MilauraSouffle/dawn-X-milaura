      bottom: var(--hero-cta-desktop-bottom);
      left: 50%;
      right: auto;
      transform: translateX(-50%);
    }

    #MilauraHeroHome-{{ section.id }} .hero-home-cta {
      min-width: var(--hero-cta-desktop-min-width);
      min-height: var(--hero-cta-desktop-min-height);
      padding: var(--hero-cta-desktop-padding);
      font: 700 var(--hero-cta-desktop-font-size)/0.9 var(--milaura-font-script) !important;
    }

    #MilauraHeroHome-{{ section.id }} .hero-home-cta span {
      font: inherit !important;
    }
  }
{% endstyle %}

{% render 'milaura-hero-slide',
  section: section,
  product: product,
  hero_image: hero_image,
  cta_url: cta_url,
  cta_text: cta_text,
  hero_label: hero_label,
  headline_line_1: headline_line_1,
  headline_line_2: headline_line_2,
  headline_line_3: headline_line_3,
  top_hook_kicker: top_hook_kicker,
  top_hook_text: top_hook_text,
  top_hook_highlight: top_hook_highlight,
  top_hook_brand_prefix: top_hook_brand_prefix,
  product_note: product_note,
  product_material_note: product_material_note
%}

<script>
  (() => {
    const hero = document.getElementById('MilauraHeroHome-{{ section.id }}');
    if (!hero) return;

    let ticking = false;
    const updateGiftBubble = () => {
      const rect = hero.getBoundingClientRect();
      const hideBubble = rect.top < window.innerHeight && rect.bottom > window.innerHeight * 0.18;
      document.body.classList.toggle('milaura-hero-home-visible', hideBubble);
      ticking = false;
    };

    const requestUpdate = () => {
      if (ticking) return;
      ticking = true;
      window.requestAnimationFrame(updateGiftBubble);
    };

    updateGiftBubble();
    window.addEventListener('scroll', requestUpdate, { passive: true });
    window.addEventListener('resize', requestUpdate);
    document.addEventListener('shopify:section:unload', () => {
      document.body.classList.remove('milaura-hero-home-visible');
    }, { once: true });
  })();
</script>

