{%- comment -%}
  Cross-links collections — Affiche les principales collections sur chaque page collection.
  Booste le maillage interne SEO + navigation entre univers.
{%- endcomment -%}

{%- assign menu = linklists[section.settings.menu] -%}
{%- if menu.links.size > 0 -%}
  <div class="milaura-crosslinks" id="MilauraCrosslinks-{{ section.id }}">
    <div class="milaura-crosslinks-inner page-width">
      <h3 class="milaura-cl-title">{{ section.settings.title | default: 'Explorez nos univers' }}</h3>
      <div class="milaura-cl-grid">
        {%- for link in menu.links -%}
          {%- assign is_current = false -%}
          {%- if link.url == collection.url -%}
            {%- assign is_current = true -%}
          {%- endif -%}
          <a href="{{ link.url }}" class="milaura-cl-card{% if is_current %} milaura-cl-card--active{% endif %}" {% if is_current %}aria-current="page"{% endif %}>
            <span class="milaura-cl-card-title">{{ link.title }}</span>
            {%- if link.links.size > 0 -%}
              <span class="milaura-cl-card-sub">
                {%- for child in link.links limit: 3 -%}
                  {{ child.title }}{%- unless forloop.last %}, {% endunless -%}
                {%- endfor -%}
                {%- if link.links.size > 3 -%}…{%- endif -%}
              </span>
            {%- endif -%}
          </a>
        {%- endfor -%}
      </div>

      {%- comment -%} Collections par intention — toujours visibles pour le SEO {%- endcomment -%}
      {%- if section.settings.show_intentions -%}
        <div class="milaura-cl-intentions">
          <span class="milaura-cl-intentions-label">Par intention de bien-etre</span>
          <div class="milaura-cl-intentions-pills">
            {%- assign intentions = 'serenite-sommeil,protection-energie,amour-relations' | split: ',' -%}
            {%- assign intention_labels = 'Serenite & Sommeil,Protection & Energie,Amour & Relations' | split: ',' -%}
            {%- for handle in intentions -%}
              {%- assign col = collections[handle] -%}
              {%- if col != blank and col.products_count > 0 -%}
                <a href="{{ col.url }}" class="milaura-il-pill{% if collection.handle == handle %} milaura-cl-pill--active{% endif %}">
                  {{ intention_labels[forloop.index0] }}
                </a>
              {%- endif -%}
            {%- endfor -%}
          </div>
        </div>
      {%- endif -%}
    </div>
  </div>

  <style>
    .milaura-crosslinks {
      padding: 24px 0 12px;
    }

    .milaura-crosslinks-inner {
      display: flex;
      flex-direction: column;
      gap: 16px;
    }

    .milaura-cl-title {
      font-family: var(--milaura-font-heading, 'Playfair Display', serif);
      font-size: 1.2rem;
      font-weight: 600;
      color: var(--milaura-text, #000);
      margin: 0;
    }

    .milaura-cl-grid {
      display: flex;
      flex-wrap: wrap;
      gap: 10px;
    }

    .milaura-cl-card {
      display: flex;
      flex-direction: column;
      gap: 2px;
      padding: 12px 20px;
      background: rgba(192, 160, 98, 0.06);
      border: 1px solid rgba(192, 160, 98, 0.18);
      border-radius: 14px;
      text-decoration: none;
      transition: all 0.25s ease;
      min-width: 140px;
    }

    .milaura-cl-card:hover {
      background: rgba(192, 160, 98, 0.14);
      border-color: rgba(192, 160, 98, 0.35);
      transform: translateY(-2px);
      box-shadow: 0 4px 16px rgba(192, 160, 98, 0.15);
    }

    .milaura-cl-card--active {
      background: rgba(192, 160, 98, 0.15);
      border-color: var(--milaura-gold, #C0A062);
    }

    .milaura-cl-card-title {
      font-family: var(--milaura-font-body, 'Lato', sans-serif);
      font-size: 0.85rem;
      font-weight: 700;
      color: var(--milaura-text, #000);
      text-transform: uppercase;
      letter-spacing: 0.5px;
    }

    .milaura-cl-card-sub {
      font-family: var(--milaura-font-body, 'Lato', sans-serif);
      font-size: 0.72rem;
      color: var(--milaura-text-light, #666);
      font-weight: 400;
    }

    .milaura-cl-intentions {
      display: flex;
      flex-wrap: wrap;
      align-items: center;
      gap: 10px;
      padding-top: 8px;
      border-top: 1px solid rgba(192, 160, 98, 0.12);
    }

    .milaura-cl-intentions-label {
      font-family: var(--milaura-font-body, 'Lato', sans-serif);
      font-size: 0.75rem;
      font-weight: 600;
      color: var(--milaura-text-light, #333);
      text-transform: uppercase;
      letter-spacing: 0.8px;
    }

    .milaura-cl-intentions-pills {
      display: flex;
      flex-wrap: wrap;
      gap: 8px;
    }

    /* Reutilise les styles de milaura-internal-links */
    .milaura-cl-intentions-pills .milaura-il-pill {
      display: inline-flex;
      align-items: center;
      padding: 6px 14px;
      font-family: var(--milaura-font-body, 'Lato', sans-serif);
      font-size: 0.78rem;
      font-weight: 500;
      color: var(--milaura-gold-dark, #8F723A);
      text-decoration: none;
      background: rgba(192, 160, 98, 0.08);
      border: 1px solid rgba(192, 160, 98, 0.2);
      border-radius: 50px;
      transition: all 0.25s ease;
    }

    .milaura-cl-intentions-pills .milaura-il-pill:hover {
      background: rgba(192, 160, 98, 0.18);
      border-color: rgba(192, 160, 98, 0.4);
    }

    .milaura-cl-pill--active {
      background: rgba(192, 160, 98, 0.18) !important;
      border-color: var(--milaura-gold, #C0A062) !important;
    }

    @media screen and (max-width: 767px) {
      .milaura-cl-grid {
        gap: 8px;
      }

      .milaura-cl-card {
        padding: 10px 16px;
        min-width: 120px;
      }

      .milaura-cl-card-title {
        font-size: 0.78rem;
      }

      .milaura-cl-intentions {
        flex-direction: column;
        align-items: flex-start;
      }
    }

    @media (prefers-reduced-motion: reduce) {
      .milaura-cl-card,
      .milaura-cl-intentions-pills .milaura-il-pill {
        transition: none;
      }
    }
  </style>
{%- endif -%}

{% schema %}
{
  "name": "Cross-links collections",
  "settings": [
    {
      "type": "text",
      "id": "title",
      "label": "Titre",
      "default": "Explorez nos univers"
    },
    {
      "type": "link_list",
      "id": "menu",
      "label": "Menu source",
      "default": "main-menu"
    },
    {
      "type": "checkbox",
      "id": "show_intentions",
      "label": "Afficher les collections par intention",
      "default": true
    }
  ],
  "presets": [
    {
      "name": "Cross-links collections"
    }
  ]
}
{% endschema %}
