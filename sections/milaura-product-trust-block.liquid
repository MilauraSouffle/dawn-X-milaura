{%- comment -%}
  MILAURA PRODUCT TRUST BLOCK
  Bloc reassurance full-width extrait du hero produit.
  Affiche : image equipe + certificat LFG + 4 lignes de garantie,
  trust badges (livraison, garantie, 3x) et payment icons Shopify.
  Insere entre milaura-product-hero et milaura-product-tabs.
{%- endcomment -%}

{%- style -%}
  #MilauraTrustBlock-{{ section.id }} {
    padding: var(--milaura-spacing-lg) var(--milaura-spacing-md);
    background: var(--milaura-beige, #FDFBF7);
  }

  #MilauraTrustBlock-{{ section.id }} .milaura-trust-inner {
    max-width: 1200px;
    margin: 0 auto;
    display: flex;
    flex-direction: column;
    gap: var(--milaura-spacing-md);
  }

  #MilauraTrustBlock-{{ section.id }} .milaura-trust-block {
    background: linear-gradient(135deg, #FFFCF7, #FAF4E8);
    border: 1px solid rgba(192, 160, 98, 0.18);
    border-radius: 16px;
    padding: var(--milaura-spacing-md);
  }

  #MilauraTrustBlock-{{ section.id }} .milaura-trust-layout {
    display: flex;
    align-items: center;
    gap: var(--milaura-spacing-md);
  }

  #MilauraTrustBlock-{{ section.id }} .milaura-trust-cert-wrap {
    position: relative;
    flex-shrink: 0;
  }

  #MilauraTrustBlock-{{ section.id }} .milaura-trust-main-img {
    width: 120px;
    height: 120px;
    border-radius: 50%;
    object-fit: cover;
    border: 3px solid var(--milaura-gold);
  }

  #MilauraTrustBlock-{{ section.id }} .milaura-trust-cert-img {
    position: absolute;
    bottom: -4px;
    right: -8px;
    width: 56px;
    height: auto;
  }

  #MilauraTrustBlock-{{ section.id }} .milaura-trust-points {
    display: flex;
    flex-direction: column;
    gap: 8px;
    flex: 1;
  }

  #MilauraTrustBlock-{{ section.id }} .milaura-trust-point {
    display: flex;
    align-items: center;
    gap: 10px;
    font-size: 0.9rem;
    line-height: 1.4;
    color: var(--milaura-text);
  }

  #MilauraTrustBlock-{{ section.id }} .milaura-trust-point .milaura-trust-icon {
    color: var(--milaura-gold);
    font-size: 1rem;
    flex-shrink: 0;
  }

  #MilauraTrustBlock-{{ section.id }} .milaura-trust-badges {
    display: flex;
    justify-content: center;
    gap: var(--milaura-spacing-md);
    flex-wrap: wrap;
  }

  #MilauraTrustBlock-{{ section.id }} .milaura-trust-item {
    display: flex;
    align-items: center;
    gap: 8px;
    padding: 10px 16px;
    background: white;
    border: 1px solid rgba(192, 160, 98, 0.2);
    border-radius: 12px;
    font-size: 0.85rem;
    color: var(--milaura-text);
  }

  #MilauraTrustBlock-{{ section.id }} .milaura-trust-item .milaura-trust-icon {
    font-size: 1.1rem;
  }

  #MilauraTrustBlock-{{ section.id }} .milaura-payment-icons {
    display: flex;
    justify-content: center;
    gap: 8px;
    flex-wrap: wrap;
    list-style: none;
    padding: 0;
    margin: 0;
  }

  #MilauraTrustBlock-{{ section.id }} .milaura-payment-icon {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    height: 24px;
  }

  #MilauraTrustBlock-{{ section.id }} .milaura-payment-icon svg {
    height: 24px;
    width: auto;
  }

  @media (max-width: 768px) {
    #MilauraTrustBlock-{{ section.id }} .milaura-trust-layout {
      flex-direction: column;
      text-align: center;
    }

    #MilauraTrustBlock-{{ section.id }} .milaura-trust-main-img {
      width: 96px;
      height: 96px;
    }

    #MilauraTrustBlock-{{ section.id }} .milaura-trust-cert-img {
      width: 44px;
    }

    #MilauraTrustBlock-{{ section.id }} .milaura-trust-badges {
      flex-direction: column;
      align-items: stretch;
    }

    #MilauraTrustBlock-{{ section.id }} .milaura-trust-item {
      justify-content: center;
    }
  }
{%- endstyle -%}

<div id="MilauraTrustBlock-{{ section.id }}">
  <div class="milaura-trust-inner">
    {%- if section.settings.show_trust_block -%}
      <div class="milaura-trust-block">
        <div class="milaura-trust-layout">
          {%- if section.settings.trust_image != blank or section.settings.trust_cert_image != blank -%}
            <div class="milaura-trust-cert-wrap">
              {%- if section.settings.trust_image != blank -%}
                <img
                  class="milaura-trust-main-img"
                  src="{{ section.settings.trust_image | image_url: width: 300 }}"
                  alt="Mil'Aura, nos client(e)s"
                  width="120"
                  height="120"
                  loading="lazy"
                >
              {%- endif -%}
              {%- if section.settings.trust_cert_image != blank -%}
                <img
                  class="milaura-trust-cert-img"
                  src="{{ section.settings.trust_cert_image | image_url: width: 200 }}"
                  alt="Certificat LFG Paris"
                  width="80"
                  height="auto"
                  loading="lazy"
                >
              {%- endif -%}
            </div>
          {%- endif -%}
          <div class="milaura-trust-points">
            {%- if section.settings.line_social != blank -%}
              <div class="milaura-trust-point">
                <span class="milaura-trust-icon">&#10003;</span>
                <span>{{ section.settings.line_social }}</span>
              </div>
            {%- endif -%}
            {%- if section.settings.line_karine != blank -%}
              <div class="milaura-trust-point">
                <span class="milaura-trust-icon">&#9733;</span>
                <span>{{ section.settings.line_karine }}</span>
              </div>
            {%- endif -%}
            {%- if section.settings.line_lfg != blank -%}
              <div class="milaura-trust-point">
                <span class="milaura-trust-icon">&#128142;</span>
                <span>{{ section.settings.line_lfg }}</span>
              </div>
            {%- endif -%}
            {%- if section.settings.line_guarantee != blank -%}
              <div class="milaura-trust-point">
                <span class="milaura-trust-icon">&#9989;</span>
                <span>{{ section.settings.line_guarantee }}</span>
              </div>
            {%- endif -%}
          </div>
        </div>
      </div>
    {%- endif -%}

    {%- if section.blocks.size > 0 -%}
      <div class="milaura-trust-badges">
        {%- for block in section.blocks -%}
          {%- if block.type == 'trust_badge' -%}
            <div class="milaura-trust-item" {{ block.shopify_attributes }}>
              <span class="milaura-trust-icon">{{ block.settings.icon }}</span>
              <span>{{ block.settings.text }}</span>
            </div>
          {%- endif -%}
        {%- endfor -%}
      </div>
    {%- endif -%}

    {%- if section.settings.show_payment_icons -%}
      <ul class="milaura-payment-icons">
        {%- for type in shop.enabled_payment_types -%}
          <li class="milaura-payment-icon">{{ type | payment_type_svg_tag }}</li>
        {%- endfor -%}
      </ul>
    {%- endif -%}
  </div>
</div>

{% schema %}
{
  "name": "Milaura Trust Block",
  "tag": "section",
  "class": "milaura-product-trust-block",
  "settings": [
    {
      "type": "header",
      "content": "Bloc reassurance unifie"
    },
    {
      "type": "checkbox",
      "id": "show_trust_block",
      "label": "Afficher le bloc image + 4 lignes",
      "default": true
    },
    {
      "type": "image_picker",
      "id": "trust_image",
      "label": "Photo equipe / client(e)s"
    },
    {
      "type": "image_picker",
      "id": "trust_cert_image",
      "label": "Certificat LFG Paris"
    },
    {
      "type": "text",
      "id": "line_social",
      "label": "Ligne 1 - Social proof",
      "default": "+ de 500 client(e)s (boutique, salons, en ligne)"
    },
    {
      "type": "text",
      "id": "line_karine",
      "label": "Ligne 2 - Karine",
      "default": "Selection personnelle de Karine, fondatrice"
    },
    {
      "type": "text",
      "id": "line_lfg",
      "label": "Ligne 3 - LFG",
      "default": "Pierres certifiees LFG Paris"
    },
    {
      "type": "text",
      "id": "line_guarantee",
      "label": "Ligne 4 - Garantie",
      "default": "Garantie satisfait ou rembourse 30 jours"
    },
    {
      "type": "header",
      "content": "Icones de paiement"
    },
    {
      "type": "checkbox",
      "id": "show_payment_icons",
      "label": "Afficher les icones de paiement Shopify",
      "default": true
    }
  ],
  "blocks": [
    {
      "type": "trust_badge",
      "name": "Badge reassurance",
      "settings": [
        {
          "type": "text",
          "id": "icon",
          "label": "Icone (emoji)",
          "default": "🚚"
        },
        {
          "type": "text",
          "id": "text",
          "label": "Texte",
          "default": "Livraison offerte des 39 euros"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Milaura Trust Block",
      "blocks": [
        { "type": "trust_badge", "settings": { "icon": "🚚", "text": "Livraison offerte des 39€" } },
        { "type": "trust_badge", "settings": { "icon": "🛡️", "text": "Garantie 30 jours" } },
        { "type": "trust_badge", "settings": { "icon": "🏦", "text": "Paiement 3x sans frais" } }
      ]
    }
  ]
}
{% endschema %}
