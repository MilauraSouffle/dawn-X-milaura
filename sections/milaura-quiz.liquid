              { label: {{ block.settings.answer_4_label | json }}, profile: {{ block.settings.answer_4_profile | json }} },
            {% endif %}
            {% if block.settings.answer_5_label != blank %}
              { label: {{ block.settings.answer_5_label | json }}, profile: {{ block.settings.answer_5_profile | json }} }
            {% endif %}
          ]
        });
      {% endif %}
    {% endfor %}

    // ============================================
    // FONCTIONS DE NAVIGATION
    // ============================================
    let hasUserInteracted = false; // Flag pour éviter le scroll au chargement initial
    let stateTransitionTimeout = null; // Track pending state transitions

    function syncResultOverlays(state) {
      var hideFloatingGift = state === QuizState.RESULT && window.matchMedia('(max-width: 989px)').matches;
      ['milaura-bubble-trigger', 'milaura-bubble-label'].forEach(function(id) {
        var el = document.getElementById(id);
        if (!el) return;
        if (hideFloatingGift) {
          el.dataset.quizResultHidden = 'true';
          el.style.display = 'none';
        } else if (el.dataset.quizResultHidden === 'true') {
          el.style.display = '';
          delete el.dataset.quizResultHidden;
        }
      });
    }

    function goToState(state, shouldScroll = true) {
      // Cancel any pending transition to prevent race conditions
      if (stateTransitionTimeout) {
        clearTimeout(stateTransitionTimeout);
        stateTransitionTimeout = null;
      }

      const states = container.querySelectorAll('.quiz-state');
      const currentActiveState = container.querySelector('.quiz-state.is-active');

      // Exit animation for current state
      if (currentActiveState) {
        currentActiveState.classList.add('is-exiting');
        currentActiveState.classList.remove('is-active');
      }

      // Wait for exit animation, then switch states
      stateTransitionTimeout = setTimeout(() => {
        states.forEach(s => {
          s.classList.remove('is-active', 'is-exiting');
          s.style.display = 'none';
        });

        const targetState = container.querySelector(`.quiz-state-${state}`);
        if (targetState) {
          targetState.style.display = 'block';
          // Force reflow for animation
          targetState.offsetHeight;
          setTimeout(() => {
            targetState.classList.add('is-active');
          }, 10);
        }

        currentState = state;
        syncResultOverlays(state);

        const lastResultLinkEl = container.querySelector('#quiz-last-result-link-' + sectionId);
        if (lastResultLinkEl) {
          var hasStoredResult = false;
          try {
            hasStoredResult = !!localStorage.getItem('milauraLastResult');
          } catch (e) {}
          lastResultLinkEl.style.display = state === QuizState.INTRO && hasStoredResult ? 'block' : 'none';
        }

        // Scroll vers le haut de la section quiz SEULEMENT après interaction utilisateur
        // et pas pour l'état initial (intro)
        if (shouldScroll && hasUserInteracted && state !== QuizState.INTRO) {
          setTimeout(() => {
            var headerOffset = 130; // Generous offset for fixed header + announcement
            var elementTop = container.getBoundingClientRect().top + window.pageYOffset;
            window.scrollTo({ top: elementTop - headerOffset, behavior: 'smooth' });
          }, 50);
        }

        stateTransitionTimeout = null; // Clear reference after completion
      }, currentActiveState ? 650 : 0); // Wait for exit animation (650ms) or instant if no current state
    }

    function goToIntro() {
      goToState(QuizState.INTRO);
    }

    function goToQuestions() {
      preloadStoneImages();
      currentQuestionIndex = 0;
      scores = {
        apaisement: 0,
        protection: 0,
        serenite: 0,
        amour: 0,
        chance: 0
      };
      question7Answer = null; // Reset tiebreaker
      goToState(QuizState.QUESTIONS);
      displayQuestion(0);
    }

    function goToTransition() {
      preloadStoneImages();
      goToState(QuizState.TRANSITION);
      const duration = {{ section.settings.transition_duration_ms | default: 3000 }};
      setTimeout(() => {
        goToResult();
      }, duration);
    }

    function goToResult() {
      calculateResults();
      displayResults();
      goToState(QuizState.RESULT);
    }

    // ============================================
    // LOGIQUE DES QUESTIONS
    // ============================================
    function displayQuestion(index) {
      if (index >= questionsData.length) {
        goToTransition();
        return;
      }

      const question = questionsData[index];
      const questionTitleEl = container.querySelector('#quiz-question-title-' + sectionId);
      const answersEl = container.querySelector('#quiz-answers-' + sectionId);
      const progressTextEl = container.querySelector('#quiz-progress-text-' + sectionId);
      const progressFillEl = container.querySelector('#quiz-progress-fill-' + sectionId);

      if (questionTitleEl) {
        questionTitleEl.textContent = question.label;
      }

      if (progressTextEl) {
        progressTextEl.textContent = `Question ${index + 1} sur ${questionsData.length}`;
      }

      if (progressFillEl) {
        const progress = ((index + 1) / questionsData.length) * 100;
        progressFillEl.style.width = progress + '%';
      }

      if (answersEl) {
        answersEl.innerHTML = '';
        question.answers.forEach((answer, i) => {
          const btn = document.createElement('button');
          btn.type = 'button';
          btn.className = 'quiz-answer-btn';
          btn.textContent = answer.label;
          // Apply stagger delay for entrance animation
          btn.style.transitionDelay = `${i * 80}ms`;
          btn.addEventListener('click', (e) => {
            handleAnswerClick(btn, answer.profile);
          });
          answersEl.appendChild(btn);
        });

        // Trigger staggered entrance animation
        setTimeout(() => {
          const btns = answersEl.querySelectorAll('.quiz-answer-btn');
          btns.forEach(btn => btn.classList.add('is-visible'));
        }, 50);
      }
    }

    // Handle answer click with pulse animation
    function handleAnswerClick(buttonEl, profile) {
      // Disable all buttons during animation
      const allBtns = container.querySelectorAll('.quiz-answer-btn');
      allBtns.forEach(b => b.style.pointerEvents = 'none');

      // Apply pulse animation
      buttonEl.classList.add('is-selected');

      // Capture question 7 answer BEFORE incrementing (for tiebreaker rule)
      if (currentQuestionIndex === 6) { // Question 7 (0-indexed)
        question7Answer = profile;
      }

      // Wait for pulse animation (600ms), then advance
      setTimeout(() => {
        if (profiles.includes(profile)) {
          scores[profile] = (scores[profile] || 0) + 1;
        }
        currentQuestionIndex++;
        displayQuestion(currentQuestionIndex);
      }, 600);
    }

    // Legacy function for compatibility
    function handleAnswer(profile) {
      if (profiles.includes(profile)) {
        scores[profile] = (scores[profile] || 0) + 1;
      }

      currentQuestionIndex++;
      displayQuestion(currentQuestionIndex);
    }

    // ============================================
    // CALCUL DES RÉSULTATS
    // ============================================
    function calculateResults() {
      const totalScore = Object.values(scores).reduce((sum, val) => sum + val, 0);
      const percentages = {};
      let maxScore = -1;
      let tiedProfiles = [];

      // First pass: find max score and collect tied profiles
      profiles.forEach(profile => {
        const score = scores[profile] || 0;
        percentages[profile] = totalScore > 0 ? Math.round((score / totalScore) * 100) : 0;
        if (score > maxScore) {
          maxScore = score;
          tiedProfiles = [profile];
        } else if (score === maxScore) {
          tiedProfiles.push(profile);
        }
      });

      // Apply tiebreaker rule: if there's a tie, use question 7 answer
      let winnerProfile = tiedProfiles[0];
      if (tiedProfiles.length > 1 && question7Answer && tiedProfiles.includes(question7Answer)) {
        winnerProfile = question7Answer;
      }

      return {
        winnerProfile: winnerProfile,
        scores: scores,
        percentages: percentages,
        totalScore: totalScore
      };
    }

    // ============================================
    // AFFICHAGE DES RÉSULTATS - HERO HORIZONTAL
    // Affichage direct, pas de phases
    // ============================================

    // Stone handle mapping for cross-sell sections
    const stoneHandleMap = {
      apaisement: 'calcedoine-bleue',
      protection: 'obsidienne-noire',
      serenite: 'amethyste',
      amour: 'quartz-rose',
      chance: 'aventurine-verte'
    };

    let stoneImagesPreloaded = false;

    function preloadStoneImages() {
      if (stoneImagesPreloaded) return;
      stoneImagesPreloaded = true;

      profiles.forEach(profileId => {
        const profile = profileData[profileId];
        if (!profile || !profile.stoneImage) return;

        const img = new Image();
        img.decoding = 'async';
        img.src = profile.stoneImage;
        if (img.decode) img.decode().catch(function() {});
      });
    }

    function displayResults() {
      const results = calculateResults();
      const winnerProfile = results.winnerProfile;

      const profile = profileData[winnerProfile];
      if (!profile) return;

      // Set profile accent CSS custom properties on the container
      const revealContainer = container.querySelector('.quiz-reveal-container');
      if (revealContainer) {
        revealContainer.style.setProperty('--profile-accent', profile.colorAccent || '#C0A062');
        revealContainer.style.setProperty('--profile-accent-rgb', profile.colorAccentRgb || '192, 160, 98');
      }

      // === PROFIL ET PIERRE ===
      const profileTitleEl = container.querySelector('#quiz-reveal-profile-title-' + sectionId);
      if (profileTitleEl) profileTitleEl.textContent = profile.displayName || profile.label || '';

      const stoneTitleEl = container.querySelector('#quiz-reveal-stone-title-' + sectionId);
      if (stoneTitleEl) stoneTitleEl.textContent = profile.stone || '';

      // === LECTURE ===
      const readingEl = container.querySelector('#quiz-reveal-reading-' + sectionId);
      if (readingEl && profile.description) readingEl.textContent = profile.description;

      // === HOOK RESULTAT ===
      const hookEl = container.querySelector('#quiz-reveal-hook-' + sectionId);
      if (hookEl) hookEl.textContent = profile.dashboardTitle || profile.hookTitle || profile.stone || '';

      const stoneImageEl = container.querySelector('#quiz-reveal-stone-image-' + sectionId);
      if (stoneImageEl && profile.stoneImage) {
        stoneImageEl.loading = 'eager';
        stoneImageEl.decoding = 'async';
        if ('fetchPriority' in stoneImageEl) stoneImageEl.fetchPriority = 'high';
        stoneImageEl.src = profile.stoneImage;
        stoneImageEl.alt = profile.stoneImageAlt || profile.stone || '';
      }

      // === SYSTEME D'ONGLETS PRODUIT (Bracelet/Bougie/Collier) ===
      const productTypes = {
        bracelet: { data: profile.braceletProduct, label: 'Bracelet', ctaLabel: 'Découvrir mon bracelet' },
        bougie: { data: profile.bougieProduct, label: 'Bougie', ctaLabel: 'Découvrir ma bougie' },
        collier: { data: profile.collierProduct, label: 'Collier', ctaLabel: 'Découvrir mon collier' }
      };

      // Masquer les onglets sans produit assigne
      const tabsContainer = container.querySelector('#quiz-reveal-product-tabs-' + sectionId);
      var availableTabs = [];
      if (tabsContainer) {
        var tabBtns = tabsContainer.querySelectorAll('.quiz-rpt-tab');
        tabBtns.forEach(function(btn) {
          var tabKey = btn.getAttribute('data-tab');
          if (productTypes[tabKey] && productTypes[tabKey].data) {
            btn.style.display = '';
            var tabProduct = productTypes[tabKey].data;
            var tabThumb = btn.querySelector('[data-tab-thumb="' + tabKey + '"]');
            if (tabThumb && tabProduct.featured_image) {
              tabThumb.style.backgroundImage = 'url("' + String(tabProduct.featured_image).replace(/"/g, '%22') + '")';
              tabThumb.classList.add('has-image');
            } else if (tabThumb) {
              tabThumb.style.backgroundImage = '';
              tabThumb.classList.remove('has-image');
            }
            availableTabs.push(tabKey);
          } else {
            btn.style.display = 'none';
          }
        });
        // Si un seul onglet, masquer les onglets entierement
        if (availableTabs.length <= 1) {
          tabsContainer.style.display = 'none';
        } else {
          tabsContainer.style.display = '';
        }
      }

      // Fonction pour afficher un produit dans la zone galerie
      function showProductTab(tabKey) {
        var pt = productTypes[tabKey];
        if (!pt || !pt.data) return;
        var prod = pt.data;

        // Image
        var imgEl = container.querySelector('#quiz-reveal-product-image-' + sectionId);
        var wrapEl = container.querySelector('#quiz-reveal-img-wrap-' + sectionId);
        var placeholderEl = container.querySelector('#quiz-reveal-product-placeholder-' + sectionId);
        if (imgEl) {
          if (prod.featured_image) {
            imgEl.src = prod.featured_image;
            imgEl.alt = prod.title || pt.label;
            imgEl.style.display = '';
            if (wrapEl) wrapEl.style.background = '';
            if (placeholderEl) placeholderEl.style.display = 'none';
          } else {
            imgEl.style.display = 'none';
            if (placeholderEl) {
              placeholderEl.textContent = pt.label;
              placeholderEl.style.display = 'flex';
            }
          }
        }

        // Titre + Prix
        var titleEl = container.querySelector('#quiz-reveal-product-title-' + sectionId);
        var priceEl = container.querySelector('#quiz-reveal-product-price-' + sectionId);
        if (titleEl) titleEl.textContent = prod.title || '';
        if (priceEl) priceEl.textContent = prod.price || '';

        // CTAs
        var ctaEl = container.querySelector('#quiz-reveal-cta-' + sectionId);
        if (ctaEl) {
          // Note: all values here come from Shopify Liquid settings (trusted server-side data),
          // not from user input, so innerHTML is safe in this context.
          var html = '';
          var productUrl = prod.url || (prod.handle ? '/products/' + prod.handle : '');
          if (productUrl) {
            html += '<a href="' + productUrl + '" class="quiz-reveal-cta-primary">' + (pt.ctaLabel || 'Découvrir cette création') + '</a>';
          }
          // Lien secondaire vers la collection filtree par pierre
          var stoneHandle = stoneHandleMap[results.winnerProfile] || '';
          var stoneName = profile.stone || '';
          if (stoneHandle) {
            html += '<a href="/collections/all?filter.v.m.milaura.stone_handle=' + stoneHandle + '" class="quiz-reveal-cta-secondary"><span>Voir toutes les créations en ' + stoneName + '</span></a>';
          }
          ctaEl.innerHTML = html;
        }

        // Update active tab
        if (tabsContainer) {
          tabsContainer.querySelectorAll('.quiz-rpt-tab').forEach(function(btn) {
            btn.classList.toggle('active', btn.getAttribute('data-tab') === tabKey);
          });
        }
      }

      // Afficher le premier onglet disponible
      var firstTab = availableTabs.length > 0 ? availableTabs[0] : 'bracelet';
      showProductTab(firstTab);

      // Event listeners sur les onglets
      if (tabsContainer) {
        tabsContainer.querySelectorAll('.quiz-rpt-tab').forEach(function(btn) {
          btn.onclick = function() {
            showProductTab(btn.getAttribute('data-tab'));
          };
        });
      }

      // === INVITATION COMPTE ===
      const accountInviteEl = container.querySelector('#quiz-reveal-account-invite-' + sectionId);
      if (accountInviteEl) {
        accountInviteEl.style.display = isCustomerLoggedIn ? 'none' : '';
      }

      // === STOCKAGE LOCAL (enrichi pour sections downstream) ===
      const storageData = {
        profileId: winnerProfile,
        profileName: profile.displayName || profile.label,
        stone: profile.stone,
        stoneHandle: stoneHandleMap[winnerProfile] || null,
        mantra: profile.mantra || null,
        ritual: profile.ritual || null,
        profileAccent: profile.colorAccent || '#C0A062',
        profileAccentRgb: profile.colorAccentRgb || '192, 160, 98',
        scores: results.scores,
        percentages: results.percentages,
        braceletHandle: profile.braceletProduct ? profile.braceletProduct.handle : null,
        braceletTitle: profile.braceletProduct ? profile.braceletProduct.title : null,
        timestamp: Date.now()
      };
      localStorage.setItem('milauraLastResult', JSON.stringify(storageData));

      // Aussi sauvegarder en cookie (30 jours) pour persistance cross-session
      try {
        var cookieData = encodeURIComponent(JSON.stringify(storageData));
        var expires = new Date(Date.now() + 30 * 24 * 60 * 60 * 1000).toUTCString();
        document.cookie = 'milauraLastResult=' + cookieData + '; expires=' + expires + '; path=/; SameSite=Lax';
      } catch(e) {}

      // Dispatch event so downstream sections can react
      window.dispatchEvent(new CustomEvent('milaura:quiz-result', { detail: storageData }));

      // === SAUVEGARDE METAFIELD CLIENT (si connecte) ===
      // Ecrit le profil dans milaura.last_profile_handle pour la personnalisation newsletter
      if (isCustomerLoggedIn) {
        try {
          var profileHandle = winnerProfile; // ex: "serenite", "protection", "amour", "apaisement", "chance"
          // Ajouter le tag profil au client via l'API cart (seule API accessible cote storefront)
          // Le metafield sera ecrit via Shopify Flow (trigger: tag ajoute)
          fetch('/cart/update.js', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({
              attributes: {
                'quiz_profile': profileHandle,
                'quiz_stone': stoneHandleMap[profileHandle] || '',
                'quiz_date': new Date().toISOString().split('T')[0]
              }
            })
          }).catch(function() {});
        } catch(e) {}
      }

      // Toujours stocker dans un attribut cart (meme si non connecte)
      // Sera recupere lors du checkout et lie au client
      try {
        fetch('/cart/update.js', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({
            attributes: {
              'quiz_profile': winnerProfile,
              'quiz_stone': stoneHandleMap[winnerProfile] || '',
              'quiz_date': new Date().toISOString().split('T')[0]
            }
          })
        }).catch(function() {});
      } catch(e) {}
    }

    // ============================================
    // GESTION DU LOCALSTORAGE
    // ============================================
    function checkLastResult() {
      const lastResult = localStorage.getItem('milauraLastResult');
      if (lastResult) {
        try {
          const data = JSON.parse(lastResult);
          const linkEl = container.querySelector('#quiz-last-result-link-' + sectionId);
          const showLinkEl = container.querySelector('#quiz-show-last-' + sectionId);
          
          if (linkEl) linkEl.style.display = 'block';
          if (showLinkEl) {
            showLinkEl.addEventListener('click', (e) => {
              e.preventDefault();
              hasUserInteracted = true; // Activer le scroll
              // Recharger les résultats depuis localStorage
              const storedData = JSON.parse(localStorage.getItem('milauraLastResult'));
              scores = storedData.scores;
              displayResults();
              goToState(QuizState.RESULT);
            });
          }
        } catch (e) {
          console.error('Error parsing last result:', e);
        }
      }
    }

    // ============================================
    // INITIALISATION
    // ============================================
    function init() {
      // Bouton start
      const startBtn = container.querySelector('#quiz-start-btn-' + sectionId);
      if (startBtn) {
        startBtn.addEventListener('click', () => {
          hasUserInteracted = true; // Activer le scroll après la première interaction
          goToQuestions();
        });
      }

      // Bouton restart
      const restartBtn = container.querySelector('#quiz-restart-btn-' + sectionId);
      if (restartBtn) {
        restartBtn.addEventListener('click', () => {
          scores = {
            apaisement: 0,
            protection: 0,
            serenite: 0,
            amour: 0,
            chance: 0
          };
          currentQuestionIndex = 0;
          question7Answer = null;
          goToQuestions();
        });
      }

      // Vérifier dernière révélation
      checkLastResult();

      // Si ?show=result dans l'URL → afficher direct le dernier résultat
      if (new URLSearchParams(window.location.search).get('show') === 'result') {
        const stored = localStorage.getItem('milauraLastResult');
        if (stored) {
          try {
            const storedData = JSON.parse(stored);
            scores = storedData.scores;
            hasUserInteracted = true;
            displayResults();
            goToState(QuizState.RESULT);
            return; // ne pas afficher l'intro
          } catch (e) {}
        }
      }

      // Afficher l'état initial
      goToState(QuizState.INTRO);
    }

    // Démarrer quand le DOM est prêt
    if (document.readyState === 'loading') {
      document.addEventListener('DOMContentLoaded', init);
    } else {
      init();
    }
  })();
</script>

