        bullets: "<ul><li>Apaisement immédiat du système nerveux</li><li>Douceur émotionnelle et lâcher-prise</li><li>Sensation de cocon réparateur</li></ul>",
        ritual: "1. " + {{ section.settings.profile_apaisement_ritual_1 | default: "Allumez votre bougie. Inspirez 3 fois." | json }} + "\n2. " + {{ section.settings.profile_apaisement_ritual_2 | default: "Autorisez-vous à être vulnérable, juste 10 minutes." | json }} + "\n3. " + {{ section.settings.profile_apaisement_ritual_3 | default: "Dites-vous : « Je peux déposer les armes. »" | json }},
        mantra: {{ section.settings.profile_apaisement_mantra | default: "Je peux déposer les armes" | json }},
        stone: "Calcédoine bleue",
        scent: "Néroli",
        icon: "💙",
        colorAccent: "#6BA3C7",
        colorAccentRgb: "107, 163, 199",
        product: {% if section.settings.profile_apaisement_product %}{
          title: {{ section.settings.profile_apaisement_product.title | json }},
          url: {{ section.settings.profile_apaisement_product.url | json }},
          price: {{ section.settings.profile_apaisement_product.price | money | json }},
          featured_image: {% if section.settings.profile_apaisement_product.featured_image %}{{ section.settings.profile_apaisement_product.featured_image | image_url: width: 600 | json }}{% else %}null{% endif %},
          handle: {{ section.settings.profile_apaisement_product.handle | json }},
          variant_id: {% if section.settings.profile_apaisement_product.selected_or_first_available_variant %}{{ section.settings.profile_apaisement_product.selected_or_first_available_variant.id | json }}{% else %}null{% endif %}
        }{% else %}null{% endif %}
      },
      protection: {
        label: "Protection",
        displayName: "Protection",
        moodLabel: "Énergie envahie",
        dashboardTitle: "Votre énergie est précieuse, arrêtez de la distribuer.",
        description: "Vous avez une hypersensibilité que vous essayez de cacher. Vous ressentez les ambiances et les intentions des gens avant même qu'ils ne parlent. C'est un don, mais en ce moment, c'est une malédiction : vous vous laissez envahir. Vous finissez vos journées vidé(e) non pas par votre travail, mais par les autres. Vous avez besoin de reconstruire vos frontières.",
        bullets: "<ul><li>Bouclier énergétique</li><li>Frontières claires et nettes</li><li>Sanctuaire personnel</li></ul>",
