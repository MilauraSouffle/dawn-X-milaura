<div id="MilauraQuiz-{{ section.id }}">
  <div class="quiz-container milaura-section-card">
    <!-- Lien dernière révélation (si existe) -->
    <div class="quiz-last-result-link" id="quiz-last-result-link-{{ section.id }}" style="display: none;">
      <a href="#" id="quiz-show-last-{{ section.id }}">Revoir ma dernière révélation ✨</a>
    </div>

    <!-- ÉTAT 1 : INTRO -->
    <div class="quiz-state quiz-state-intro" data-state="intro">
      <div class="quiz-intro-card">
        {% if section.settings.intro_title != blank %}
          <h1 class="quiz-intro-title milaura-heading">{{ section.settings.intro_title }}</h1>
        {% endif %}

        {% if section.settings.intro_subtitle != blank %}
          <div class="quiz-intro-subtitle milaura-text">{{ section.settings.intro_subtitle }}</div>
        {% endif %}

        {% if section.settings.show_expert and section.settings.expert_image != blank %}
          <div class="quiz-expert-block">
            <img
              src="{{ section.settings.expert_image | image_url: width: 200 }}"
              alt="{{ section.settings.expert_name }}"
              class="quiz-expert-image"
              width="200"
              height="200"
            >
            <div class="quiz-expert-info">
              {% if section.settings.expert_name != blank %}
                <div class="quiz-expert-name">{{ section.settings.expert_name }}</div>
              {% endif %}
              {% if section.settings.expert_title != blank %}
                <div class="quiz-expert-title">{{ section.settings.expert_title }}</div>
              {% endif %}
              {% if section.settings.expert_text != blank %}
                <div class="quiz-expert-text milaura-text">{{ section.settings.expert_text }}</div>
              {% endif %}
            </div>
          </div>
        {% endif %}

        {% if section.settings.intro_button_label != blank %}
          <button
            type="button"
            class="milaura-cta"
            id="quiz-start-btn-{{ section.id }}"
          >
            {{ section.settings.intro_button_label }}
          </button>
        {% endif %}
      </div>
    </div>

    <!-- ÉTAT 2 : QUESTIONS -->
    <div class="quiz-state quiz-state-questions" data-state="questions" style="display: none;">
      <div class="quiz-questions-header">
        <div class="quiz-progress-text" id="quiz-progress-text-{{ section.id }}">Question 1 sur 7</div>
        <div class="quiz-progress-bar">
          <div class="quiz-progress-fill" id="quiz-progress-fill-{{ section.id }}" style="width: 14.28%;"></div>
        </div>
      </div>

      <div class="quiz-question-card">
        <h3 class="quiz-question-title" id="quiz-question-title-{{ section.id }}"></h3>
        <div class="quiz-answers" id="quiz-answers-{{ section.id }}"></div>
      </div>
    </div>

    <!-- ÉTAT 3 : TRANSITION -->
    <div class="quiz-state quiz-state-transition" data-state="transition" style="display: none;">
      <div class="quiz-transition-card">
        {% if section.settings.transition_title != blank %}
          <h2 class="quiz-transition-title milaura-heading">{{ section.settings.transition_title }}</h2>
        {% endif %}

        {% if section.settings.transition_subtitle != blank %}
          <div class="quiz-transition-subtitle milaura-heading-script">{{ section.settings.transition_subtitle }}</div>
        {% endif %}

        {% if section.settings.transition_body != blank %}
          <div class="quiz-transition-body milaura-text">{{ section.settings.transition_body }}</div>
        {% endif %}

        <div class="quiz-loader">
          <div class="quiz-loader-dot"></div>
          <div class="quiz-loader-dot"></div>
          <div class="quiz-loader-dot"></div>
        </div>
      </div>
    </div>

    <!-- ÉTAT 4 : RESULT - REVELATION CONVERSION -->
    <div class="quiz-state quiz-state-result" data-state="result" style="display: none;">
      <div class="quiz-reveal-container">
        <div class="quiz-reveal-shell">
          <div class="quiz-reveal-main">
            <section class="quiz-reveal-card" aria-labelledby="quiz-reveal-profile-title-{{ section.id }}">
              <div class="quiz-reveal-mark" aria-hidden="true">
                <span></span>
                <span></span>
                <span></span>
              </div>

              <p class="quiz-reveal-result-label">Votre résultat</p>
              <p class="quiz-reveal-profile-kicker">Profil</p>
              <h2 class="quiz-reveal-profile-name" id="quiz-reveal-profile-title-{{ section.id }}">-</h2>

              <div class="quiz-reveal-divider" aria-hidden="true">
                <span></span>
                <i></i>
                <span></span>
              </div>

              <p class="quiz-reveal-question">Et si votre pierre était</p>
              <h3 class="quiz-reveal-stone-title" id="quiz-reveal-stone-title-{{ section.id }}">-</h3>

              <div class="quiz-reveal-stone-media">
                <img
                  id="quiz-reveal-stone-image-{{ section.id }}"
                  class="quiz-reveal-stone-image"
                  src="{{ 'milaura-quiz-stone-amour-quartz-rose.webp' | asset_url }}"
                  alt=""
                  width="900"
                  height="900"
                  loading="eager"
                  fetchpriority="high"
                  decoding="async"
                >
              </div>

              <p class="quiz-reveal-stone-note" id="quiz-reveal-hook-{{ section.id }}">-</p>
            </section>

            <section class="quiz-reveal-selection" aria-labelledby="quiz-reveal-selection-title-{{ section.id }}">
              <p class="quiz-reveal-selection-kicker">Votre sélection</p>
              <h2 class="quiz-reveal-selection-title" id="quiz-reveal-selection-title-{{ section.id }}">
                Choisissez la création qui vous correspond le mieux
              </h2>

              <div class="quiz-reveal-product-tabs" id="quiz-reveal-product-tabs-{{ section.id }}">
                <button type="button" class="quiz-rpt-tab active" data-tab="bracelet">
                  <span class="quiz-rpt-tab-media" data-tab-thumb="bracelet" aria-hidden="true"></span>
                  <span class="quiz-rpt-tab-label">Bracelet</span>
                </button>
                <button type="button" class="quiz-rpt-tab" data-tab="bougie">
                  <span class="quiz-rpt-tab-media" data-tab-thumb="bougie" aria-hidden="true"></span>
                  <span class="quiz-rpt-tab-label">Bougie</span>
                </button>
                <button type="button" class="quiz-rpt-tab" data-tab="collier">
                  <span class="quiz-rpt-tab-media" data-tab-thumb="collier" aria-hidden="true"></span>
                  <span class="quiz-rpt-tab-label">Collier</span>
                </button>
              </div>

              <div class="quiz-reveal-product-card">
                <div class="quiz-reveal-product-img-wrap" id="quiz-reveal-img-wrap-{{ section.id }}">
                  <img
                    id="quiz-reveal-product-image-{{ section.id }}"
                    class="quiz-reveal-product-image"
                    src="{{ 'loading-spinner.svg' | asset_url }}"
                    alt=""
                    width="400"
                    height="400"
                  >
                  <span
                    id="quiz-reveal-product-placeholder-{{ section.id }}"
                    class="quiz-reveal-product-placeholder"
                    aria-hidden="true"
                  ></span>
                </div>

                <div class="quiz-reveal-product-content">
                  <div class="quiz-reveal-product-info" id="quiz-reveal-product-info-{{ section.id }}">
                    <p class="quiz-reveal-product-kicker">Création recommandée</p>
                    <h3 class="quiz-reveal-product-title" id="quiz-reveal-product-title-{{ section.id }}"></h3>
                    <div class="quiz-reveal-product-price" id="quiz-reveal-product-price-{{ section.id }}"></div>
                  </div>
                  <div class="quiz-reveal-cta-stack" id="quiz-reveal-cta-{{ section.id }}">
                    <!-- Injecte par JS : boutons CTA -->
                  </div>
                </div>
              </div>

              <div class="quiz-reveal-trust">
                <span class="quiz-reveal-trust-item">Livraison offerte</span>
                <span class="quiz-reveal-trust-item">Artisanat français</span>
                <span class="quiz-reveal-trust-item">100% naturel</span>
              </div>
            </section>
          </div>

          <section class="quiz-reveal-reading-block">
            <h3 class="quiz-reveal-reading-title">Ce que révèle votre diagnostic</h3>
            <p class="quiz-reveal-reading-text" id="quiz-reveal-reading-{{ section.id }}"></p>
          </section>

          <div class="quiz-reveal-footer">
            <button type="button" class="quiz-reveal-restart" id="quiz-restart-btn-{{ section.id }}">
              Trouver ma pierre
            </button>
            <div class="quiz-reveal-account-invite" id="quiz-reveal-account-invite-{{ section.id }}">
              <p class="quiz-reveal-account-text">Sauvegardez votre profil émotionnel</p>
              <a href="{{ routes.account_register_url }}" class="quiz-reveal-account-link">Créer mon compte</a>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>
</div>

<script>
  (function() {
    const sectionId = '{{ section.id }}';
    const container = document.querySelector('#MilauraQuiz-' + sectionId);
    if (!container) return;

    // ============================================
    // STATE MACHINE
    // ============================================
    const QuizState = {
      INTRO: 'intro',
      QUESTIONS: 'questions',
      TRANSITION: 'transition',
      RESULT: 'result'
    };

    let currentState = QuizState.INTRO;
    let currentQuestionIndex = 0;
    let scores = {
      apaisement: 0,
      protection: 0,
      serenite: 0,
      amour: 0,
      chance: 0
    };

    // Profils disponibles (5 profils finaux)
    const profiles = ['apaisement', 'protection', 'serenite', 'amour', 'chance'];

    // Stockage de la réponse à la question 7 pour règle anti-égalité
    let question7Answer = null;

    // Données des profils avec textes "lecture à froid"
    const profileData = {
      apaisement: {
        label: "Apaisement",
        displayName: "Apaisement",
        moodLabel: "Système nerveux en surchauffe",
        dashboardTitle: "Votre système nerveux a besoin de douceur.",
        hookTitle: "Laisser la pression redescendre",
        description: "Vous êtes la personne qui tient, qui gère, qui avance. De l’extérieur, tout semble encore en place. Mais à l’intérieur, la tension s’accumule. Le corps se crispe, le souffle se raccourcit, le repos ne suffit plus vraiment. Votre besoin du moment n’est pas d’en faire plus, mais de relâcher ce que vous portez depuis trop longtemps.",
        solution: "<strong>La Calcédoine bleue</strong> devient votre rappel physique de ralentir, de respirer et de revenir à vous avant la surcharge.",
        bullets: "<ul><li>Apaisement immédiat du système nerveux</li><li>Douceur émotionnelle et lâcher-prise</li><li>Sensation de cocon réparateur</li></ul>",
        ritual: "1. " + {{ section.settings.profile_apaisement_ritual_1 | default: "Portez votre pierre. Fermez les yeux, inspirez 3 fois." | json }} + "\n2. " + {{ section.settings.profile_apaisement_ritual_2 | default: "Autorisez-vous à être vulnérable, juste 10 minutes." | json }} + "\n3. " + {{ section.settings.profile_apaisement_ritual_3 | default: "Dites-vous : « Je peux déposer les armes. »" | json }},
        mantra: {{ section.settings.profile_apaisement_mantra | default: "Je peux relâcher la pression." | json }},
        stone: "Calcédoine bleue",
        stoneImage: {% if section.settings.profile_apaisement_stone_image %}{{ section.settings.profile_apaisement_stone_image | image_url: width: 1000 | json }}{% else %}{{ 'milaura-quiz-stone-apaisement-calcedoine.webp' | asset_url | json }}{% endif %},
        stoneImageAlt: "Calcédoine bleue, pierre révélée par le diagnostic émotionnel Milaura",
        icon: "💙",
        colorAccent: "#6BA3C7",
        colorAccentRgb: "107, 163, 199",
        braceletProduct: {% if section.settings.profile_apaisement_bracelet_product %}{
          title: {{ section.settings.profile_apaisement_bracelet_product.title | json }},
          url: {{ section.settings.profile_apaisement_bracelet_product.url | json }},
          price: {{ section.settings.profile_apaisement_bracelet_product.price | money | json }},
          featured_image: {% if section.settings.profile_apaisement_bracelet_product.featured_image %}{{ section.settings.profile_apaisement_bracelet_product.featured_image | image_url: width: 600 | json }}{% else %}null{% endif %},
          handle: {{ section.settings.profile_apaisement_bracelet_product.handle | json }},
          variant_id: {% if section.settings.profile_apaisement_bracelet_product.selected_or_first_available_variant %}{{ section.settings.profile_apaisement_bracelet_product.selected_or_first_available_variant.id | json }}{% else %}null{% endif %}
        }{% else %}null{% endif %},
        bougieProduct: {% if section.settings.profile_apaisement_bougie_product %}{
          title: {{ section.settings.profile_apaisement_bougie_product.title | json }},
          url: {{ section.settings.profile_apaisement_bougie_product.url | json }},
          price: {{ section.settings.profile_apaisement_bougie_product.price | money | json }},
          featured_image: {% if section.settings.profile_apaisement_bougie_product.featured_image %}{{ section.settings.profile_apaisement_bougie_product.featured_image | image_url: width: 600 | json }}{% else %}null{% endif %},
          handle: {{ section.settings.profile_apaisement_bougie_product.handle | json }},
          variant_id: {% if section.settings.profile_apaisement_bougie_product.selected_or_first_available_variant %}{{ section.settings.profile_apaisement_bougie_product.selected_or_first_available_variant.id | json }}{% else %}null{% endif %}
        }{% else %}null{% endif %},
        collierProduct: {% if section.settings.profile_apaisement_collier_product %}{
          title: {{ section.settings.profile_apaisement_collier_product.title | json }},
