{% style %}
  /* ============================================
     MILAURA QUIZ - DIAGNOSTIC ÉMOTIONNEL
     ============================================ */

  main#MainContent > #shopify-section-{{ section.id }} {
    padding-top: 0 !important;
    padding-bottom: 0 !important;
  }

     #MilauraQuiz-{{ section.id }} {
    width: 100%;
    padding: 0 var(--milaura-spacing-sm) 0;
    background: transparent;
    min-height: 400px;
    margin-top: 0 !important;
    margin-bottom: 0 !important;
  }

  /* --- CONTENEUR PRINCIPAL --- */
  #MilauraQuiz-{{ section.id }} .quiz-container {
    /* Utilise la classe générique .milaura-section-card */
    /* max-width, width, margin gérés par .milaura-section-card */
    position: relative;
    /* Réduire le padding-top de la carte dorée pour coller au header */
    padding-top: var(--milaura-spacing-xs);
  }

  /* --- ÉTAT : INTRO --- */
  #MilauraQuiz-{{ section.id }} .quiz-state {
    display: none;
    opacity: 0;
    transform: translateX(40px);
    transition:
      opacity 520ms cubic-bezier(0.22, 1, 0.36, 1),
      transform 650ms cubic-bezier(0.22, 1, 0.36, 1);
  }

  /* Exit animation (slide left) */
  #MilauraQuiz-{{ section.id }} .quiz-state.is-exiting {
    transform: translateX(-40px);
    opacity: 0;
  }

  #MilauraQuiz-{{ section.id }} .quiz-state.is-active {
    display: block;
    opacity: 1;
    transform: translateX(0);
  }

  #MilauraQuiz-{{ section.id }} .quiz-intro-card {
    /* Le halo est géré par le conteneur parent .milaura-section-card */
    background: transparent;
    border: none;
    border-radius: 0;
    padding: 0;
    box-shadow: none;
    text-align: center;
  }

  #MilauraQuiz-{{ section.id }} .quiz-intro-title {
    font-family: var(--milaura-font-heading);
    color: var(--milaura-gold);
    font-size: 2.5rem;
    font-weight: 700;
    margin-bottom: var(--milaura-spacing-md);
    line-height: 1.2;
  }

  #MilauraQuiz-{{ section.id }} .quiz-intro-subtitle {
    font-family: var(--milaura-font-body);
    color: var(--milaura-text);
    font-size: 1.1rem;
    line-height: 1.6;
    margin-bottom: var(--milaura-spacing-lg);
  }

  #MilauraQuiz-{{ section.id }} .quiz-expert-block {
    background: rgba(255, 255, 255, 0.7);
    backdrop-filter: blur(25px) saturate(180%);
    -webkit-backdrop-filter: blur(25px) saturate(180%);
    border: 1px solid rgba(192, 160, 98, 0.35);
    box-shadow: 0 10px 30px rgba(192, 160, 98, 0.15);
    border-radius: var(--milaura-border-radius-sm);
    padding: var(--milaura-spacing-md);
    margin: var(--milaura-spacing-lg) 0;
    display: flex;
    align-items: center;
    gap: var(--milaura-spacing-md);
    text-align: left;
    transition: all 0.3s ease;
  }

  #MilauraQuiz-{{ section.id }} .quiz-expert-block:hover {
    background: rgba(255, 255, 255, 0.8);
    box-shadow: 0 12px 35px rgba(192, 160, 98, 0.2);
  }

  #MilauraQuiz-{{ section.id }} .quiz-expert-image {
    width: 100px;
    height: 100px;
    border-radius: 50%;
    object-fit: cover;
    border: 2px solid var(--milaura-gold);
    flex-shrink: 0;
  }

  #MilauraQuiz-{{ section.id }} .quiz-expert-info {
    flex: 1;
  }

  #MilauraQuiz-{{ section.id }} .quiz-expert-name {
    font-family: var(--milaura-font-heading);
    color: var(--milaura-text);
    font-size: 1.3rem;
    font-weight: 700;
    margin-bottom: 5px;
  }

  #MilauraQuiz-{{ section.id }} .quiz-expert-title {
    font-family: var(--milaura-font-body);
    color: var(--milaura-gold);
    font-size: 1rem;
    text-transform: uppercase;
    letter-spacing: 1px;
    margin-bottom: 8px;
  }

  #MilauraQuiz-{{ section.id }} .quiz-expert-text {
    font-family: var(--milaura-font-body);
    color: var(--milaura-text-light);
    font-size: 1.05rem;
    line-height: 1.5;
  }

  /* --- ÉTAT : QUESTIONS --- */
  #MilauraQuiz-{{ section.id }} .quiz-questions-header {
    background: rgba(255, 255, 255, 0.7);
    backdrop-filter: blur(20px);
    border-radius: var(--milaura-border-radius);
    padding: var(--milaura-spacing-md);
    margin-bottom: var(--milaura-spacing-lg);
    text-align: center;
    border: 1px solid rgba(192, 160, 98, 0.3);
  }

  #MilauraQuiz-{{ section.id }} .quiz-progress-text {
    font-family: var(--milaura-font-body);
    color: var(--milaura-text);
    font-size: 1rem;
    margin-bottom: 10px;
    text-transform: uppercase;
    letter-spacing: 1px;
  }

  #MilauraQuiz-{{ section.id }} .quiz-progress-bar {
    width: 100%;
    height: 8px;
    background: rgba(192, 160, 98, 0.2);
    border-radius: 10px;
    overflow: hidden;
    position: relative;
  }

  #MilauraQuiz-{{ section.id }} .quiz-progress-fill {
    height: 100%;
    background: linear-gradient(90deg, var(--milaura-gold) 0%, var(--milaura-gold-light) 100%);
    border-radius: 10px;
    transition: width 0.4s ease;
    box-shadow: 0 2px 10px rgba(192, 160, 98, 0.4);
    position: relative;
    overflow: hidden;
  }

  /* Shimmer effect on progress bar */
  #MilauraQuiz-{{ section.id }} .quiz-progress-fill::after {
    content: '';
    position: absolute;
    top: 0;
    left: 0;
    width: 200%;
    height: 100%;
    background: linear-gradient(
      120deg,
      transparent 0%,
      rgba(255, 255, 255, 0.6) 50%,
      transparent 100%
    );
    transform: translateX(-100%);
    animation: quiz-shimmer 2.5s ease-in-out infinite;
  }

  @keyframes quiz-shimmer {
    0% { transform: translateX(-100%); }
    100% { transform: translateX(100%); }
  }

  #MilauraQuiz-{{ section.id }} .quiz-question-card {
    /* Le halo est géré par le conteneur parent .milaura-section-card */
    background: transparent;
    border: none;
    border-radius: 0;
    padding: 0;
    box-shadow: none;
  }

  #MilauraQuiz-{{ section.id }} .quiz-question-title {
    font-family: var(--milaura-font-heading);
    color: var(--milaura-text);
    font-size: 2rem;
    font-weight: 700;
    margin-bottom: var(--milaura-spacing-md);
    text-align: center;
    line-height: 1.3;
  }

  #MilauraQuiz-{{ section.id }} .quiz-answers {
    display: grid;
    grid-template-columns: repeat(6, 1fr);
    gap: var(--milaura-spacing-md);
    margin-top: var(--milaura-spacing-lg);
  }

  #MilauraQuiz-{{ section.id }} .quiz-answer-btn {
    grid-column: span 2;
  }

  /* 3+2 centered layout: bottom row cards centered */
  #MilauraQuiz-{{ section.id }} .quiz-answer-btn:nth-child(4) {
    grid-column: 2 / span 2;
  }

  #MilauraQuiz-{{ section.id }} .quiz-answer-btn:nth-child(5) {
    grid-column: 4 / span 2;
  }

  #MilauraQuiz-{{ section.id }} .quiz-answer-btn {
    background: rgba(255, 255, 255, 0.85);
    backdrop-filter: blur(15px) saturate(160%);
    -webkit-backdrop-filter: blur(15px) saturate(160%);
    border: 2px solid rgba(192, 160, 98, 0.4);
    border-radius: var(--milaura-border-radius-sm);
    padding: var(--milaura-spacing-md);
    font-family: var(--milaura-font-body);
    color: var(--milaura-text);
    font-size: 1.15rem;
    font-weight: 600;
    cursor: pointer;
    text-align: center;
    min-height: 95px;
    display: flex;
    align-items: center;
    justify-content: center;
    box-shadow: 0 8px 24px rgba(192, 160, 98, 0.1);
    /* Staggered entrance animation */
    opacity: 0;
    transform: translateY(20px);
    transition:
      opacity 380ms cubic-bezier(0.22, 1, 0.36, 1),
      transform 520ms cubic-bezier(0.22, 1, 0.36, 1),
      border-color 260ms ease,
      box-shadow 260ms ease,
      background 260ms ease;
  }

  #MilauraQuiz-{{ section.id }} .quiz-answer-btn.is-visible {
    opacity: 1;
    transform: translateY(0);
  }

  #MilauraQuiz-{{ section.id }} .quiz-answer-btn:hover {
    background: rgba(255, 255, 255, 0.95);
    border-color: rgba(192, 160, 98, 0.6);
    transform: translateY(-2px);
    box-shadow: 0 12px 32px rgba(192, 160, 98, 0.2);
  }

  #MilauraQuiz-{{ section.id }} .quiz-answer-btn:active {
    transform: translateY(0);
  }

  /* Pulse + gold border on click */
  #MilauraQuiz-{{ section.id }} .quiz-answer-btn.is-selected {
    animation: quiz-answer-pulse 600ms cubic-bezier(0.34, 1.56, 0.64, 1);
    border-color: var(--milaura-gold);
    background: rgba(255, 248, 225, 0.9);
    box-shadow:
      0 0 0 4px rgba(192, 160, 98, 0.3),
      var(--milaura-shadow-md);
  }

  @keyframes quiz-answer-pulse {
    0% {
      transform: scale(1);
      box-shadow: 0 0 0 0 rgba(192, 160, 98, 0);
    }
    40% {
      transform: scale(1.05);
      box-shadow: 0 0 0 8px rgba(192, 160, 98, 0.4);
    }
    100% {
      transform: scale(1);
      box-shadow: 0 0 0 4px rgba(192, 160, 98, 0.3);
    }
  }

  /* --- ÉTAT : TRANSITION --- */
  #MilauraQuiz-{{ section.id }} .quiz-transition-card {
    /* Le halo est géré par le conteneur parent .milaura-section-card */
    background: transparent;
    border: none;
    border-radius: 0;
    padding: 0;
    box-shadow: none;
    text-align: center;
    min-height: 300px;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
  }

  #MilauraQuiz-{{ section.id }} .quiz-transition-title {
    font-family: var(--milaura-font-heading);
    color: var(--milaura-gold);
    font-size: 2.2rem;
    font-weight: 700;
    margin-bottom: var(--milaura-spacing-md);
    line-height: 1.3;
  }

  #MilauraQuiz-{{ section.id }} .quiz-transition-subtitle {
    font-family: var(--milaura-font-script);
    color: var(--milaura-text);
    font-size: 1.5rem;
    margin-bottom: var(--milaura-spacing-lg);
  }

  #MilauraQuiz-{{ section.id }} .quiz-transition-body {
    font-family: var(--milaura-font-body);
    color: var(--milaura-text);
    font-size: 1.1rem;
    line-height: 1.7;
    max-width: 600px;
    margin: 0 auto;
  }

  #MilauraQuiz-{{ section.id }} .quiz-loader {
    display: flex;
    gap: 10px;
    margin-top: var(--milaura-spacing-lg);
    justify-content: center;
  }

  #MilauraQuiz-{{ section.id }} .quiz-loader-dot {
    width: 12px;
    height: 12px;
    background: var(--milaura-gold);
    border-radius: 50%;
    animation: quiz-loader-float 1.6s ease-in-out infinite;
  }

  #MilauraQuiz-{{ section.id }} .quiz-loader-dot:nth-child(2) {
    animation-delay: 0.3s;
  }

  #MilauraQuiz-{{ section.id }} .quiz-loader-dot:nth-child(3) {
    animation-delay: 0.6s;
  }

  @keyframes quiz-loader-float {
    0%, 100% {
      opacity: 0.4;
      transform: translateY(0) scale(1);
    }
    50% {
      opacity: 1;
      transform: translateY(-12px) scale(1.3);
    }
  }

  /* Fade text during loading */
  #MilauraQuiz-{{ section.id }} .quiz-transition-body,
  #MilauraQuiz-{{ section.id }} .quiz-transition-subtitle {
    animation: quiz-text-pulse 2.4s ease-in-out infinite;
  }

  @keyframes quiz-text-pulse {
    0%, 100% { opacity: 0.7; }
    50% { opacity: 1; }
  }

  /* ============================================
     ÉTAT : RESULT - HERO HORIZONTAL LAYOUT
     Calqué sur product-hero : image gauche, infos droite
     ============================================ */

  /* Container principal */
  #MilauraQuiz-{{ section.id }} .quiz-reveal-container {
    --profile-accent: var(--milaura-gold);
    --profile-accent-rgb: 192, 160, 98;
    max-width: 1200px;
    margin: 0 auto;
    width: 100%;
  }

  /* Hero grid : 2 colonnes sur desktop */
  #MilauraQuiz-{{ section.id }} .quiz-reveal-hero {
    display: flex;
    flex-direction: column;
    gap: 20px;
  }

  /* === COLONNE GAUCHE : Galerie produit === */
  #MilauraQuiz-{{ section.id }} .quiz-reveal-gallery {
    display: flex;
    flex-direction: column;
    gap: var(--milaura-spacing-md);
  }

  #MilauraQuiz-{{ section.id }} .quiz-reveal-selection-intro {
    text-align: center;
    padding: 0 4px;
  }

  #MilauraQuiz-{{ section.id }} .quiz-reveal-selection-title {
    font-family: var(--milaura-font-heading);
    color: var(--milaura-text);
    font-size: clamp(1.35rem, 2.4vw, 1.9rem);
    font-weight: 700;
    line-height: 1.15;
    margin: 0 0 6px;
  }

  #MilauraQuiz-{{ section.id }} .quiz-reveal-selection-text {
    max-width: 520px;
    margin: 0 auto;
    font-family: var(--milaura-font-body);
    color: var(--milaura-text-light, #666);
    font-size: 0.95rem;
    line-height: 1.45;
  }

  /* --- ONGLETS PRODUIT (Bracelet/Bougie/Collier) --- */
  #MilauraQuiz-{{ section.id }} .quiz-reveal-product-tabs {
    display: flex;
    gap: 8px;
    margin-bottom: 4px;
    padding: 0 4px;
  }

  #MilauraQuiz-{{ section.id }} .quiz-rpt-tab {
    flex: 1;
    min-height: 44px;
    padding: 10px 12px;
    font-family: 'Lato', sans-serif;
    font-size: 0.92rem;
    font-weight: 800;
    text-transform: none;
    letter-spacing: 0;
    border: 1px solid rgba(192, 160, 98, 0.24);
    border-radius: 50px;
    background: rgba(255, 255, 255, 0.82);
    color: var(--milaura-text, #000);
    cursor: pointer;
    transition: all 0.25s ease;
    white-space: nowrap;
  }

  #MilauraQuiz-{{ section.id }} .quiz-rpt-tab:hover {
    border-color: rgba(192, 160, 98, 0.4);
    color: var(--milaura-gold-dark, #8F723A);
  }

  #MilauraQuiz-{{ section.id }} .quiz-rpt-tab.active {
    background: linear-gradient(
      180deg,
      var(--milaura-cta-gold-top, #FFF7E5) 0%,
      var(--milaura-cta-gold-mid, #F7DCA5) 56%,
      var(--milaura-cta-gold-bottom, #F0C777) 100%
    );
    color: var(--milaura-cta-ink, #2C210F);
    border-color: var(--milaura-cta-border, rgba(255, 255, 255, 0.72));
    box-shadow: inset 0 1px 0 rgba(255, 255, 255, 0.86), 0 10px 22px rgba(50, 80, 90, 0.14);
  }

  #MilauraQuiz-{{ section.id }} .quiz-reveal-product-img-wrap {
    aspect-ratio: 1;
    border-radius: 16px;
    overflow: hidden;
    position: relative;
    box-shadow: 0 10px 40px rgba(var(--profile-accent-rgb), 0.2);
  }

  #MilauraQuiz-{{ section.id }} .quiz-reveal-product-placeholder {
    position: absolute;
    inset: 0;
    display: none;
    align-items: center;
    justify-content: center;
    background: linear-gradient(135deg, var(--milaura-beige), #f5f0e8);
    color: var(--profile-accent);
    font-size: 3rem;
  }

  #MilauraQuiz-{{ section.id }} .quiz-reveal-product-image {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
    transition: transform 0.3s ease;
  }

  #MilauraQuiz-{{ section.id }} .quiz-reveal-product-image:hover {
    transform: scale(1.02);
  }

  /* Product title + price */
  #MilauraQuiz-{{ section.id }} .quiz-reveal-product-info {
    text-align: center;
    padding: 0 4px;
  }
  #MilauraQuiz-{{ section.id }} .quiz-reveal-product-title {
    font-family: var(--milaura-font-heading);
    font-size: 1.3rem;
    font-weight: 600;
    color: var(--milaura-text);
    margin: 0;
    line-height: 1.3;
  }
  #MilauraQuiz-{{ section.id }} .quiz-reveal-product-price {
    font-family: var(--milaura-font-body);
    font-size: 1.1rem;
    color: var(--milaura-gold);
    font-weight: 600;
    margin-top: 4px;
  }

  /* CTA stack sous image */
  #MilauraQuiz-{{ section.id }} .quiz-reveal-cta-stack {
    display: flex;
    flex-direction: column;
    gap: 8px;
  }

  #MilauraQuiz-{{ section.id }} .quiz-reveal-cta-primary {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 100%;
    min-height: 52px;
    background:
      linear-gradient(
        180deg,
        var(--milaura-cta-gold-top, #FFF7E5) 0%,
        var(--milaura-cta-gold-mid, #F7DCA5) 56%,
        var(--milaura-cta-gold-bottom, #F0C777) 100%
      );
    color: var(--milaura-cta-ink, #2C210F) !important;
    font-family: var(--milaura-font-body);
    font-size: 0.98rem;
    font-weight: 900;
    line-height: 1.08;
    text-align: center;
    text-decoration: none !important;
    padding: 15px 24px;
    border-radius: 999px;
    border: 1px solid var(--milaura-cta-border, rgba(255, 255, 255, 0.72));
    cursor: pointer;
    transition: transform 180ms ease, box-shadow 220ms ease, filter 220ms ease;
    box-shadow: inset 0 1px 0 rgba(255, 255, 255, 0.92), 0 16px 34px rgba(50, 80, 90, 0.22);
  }

  #MilauraQuiz-{{ section.id }} .quiz-reveal-cta-primary:hover {
    color: var(--milaura-cta-ink, #2C210F) !important;
    transform: translateY(-2px);
    filter: saturate(1.02) brightness(1.01);
    box-shadow: inset 0 1px 0 rgba(255, 255, 255, 0.96), 0 20px 42px rgba(50, 80, 90, 0.28);
  }

  #MilauraQuiz-{{ section.id }} .quiz-reveal-cta-primary:active {
    transform: translateY(-1px);
  }

  #MilauraQuiz-{{ section.id }} .quiz-reveal-cta-secondary {
    display: block;
    width: 100%;
    background: transparent;
    color: var(--milaura-gold) !important;
    font-family: var(--milaura-font-body);
    font-size: 0.95rem;
    font-weight: 600;
    text-align: center;
    text-decoration: none !important;
    padding: 12px;
    border: none;
    cursor: pointer;
    transition: color 0.3s ease;
  }

  #MilauraQuiz-{{ section.id }} .quiz-reveal-cta-secondary:hover {
    color: var(--milaura-gold-dark) !important;
  }

  #MilauraQuiz-{{ section.id }} .quiz-reveal-cta-secondary span {
    text-decoration: underline;
  }

  /* Micro-trust badges */
  #MilauraQuiz-{{ section.id }} .quiz-reveal-trust {
    display: flex;
    justify-content: center;
    gap: var(--milaura-spacing-md);
    padding-top: var(--milaura-spacing-sm);
    border-top: 1px solid rgba(192, 160, 98, 0.1);
  }

  #MilauraQuiz-{{ section.id }} .quiz-reveal-trust-item {
    display: flex;
    align-items: center;
    gap: 6px;
    font-family: var(--milaura-font-body);
    color: var(--milaura-text-light, #666);
    font-size: 0.75rem;
  }

  #MilauraQuiz-{{ section.id }} .quiz-reveal-trust-icon {
    font-size: 0.9rem;
  }

  /* === COLONNE DROITE : Infos profil === */
  #MilauraQuiz-{{ section.id }} .quiz-reveal-info {
    display: flex;
    flex-direction: column;
    gap: var(--milaura-spacing-md);
  }

  /* Bloc 2 : Lecture */
  #MilauraQuiz-{{ section.id }} .quiz-reveal-reading-block {
    border-left: 4px solid var(--profile-accent);
    padding-left: var(--milaura-spacing-md);
  }

  #MilauraQuiz-{{ section.id }} .quiz-reveal-reading-title {
    font-family: var(--milaura-font-heading);
    color: var(--milaura-text);
    font-size: clamp(1.25rem, 2.1vw, 1.7rem);
    font-weight: 700;
    line-height: 1.18;
    margin: 0 0 10px;
  }

  #MilauraQuiz-{{ section.id }} .quiz-reveal-reading-text {
    font-family: var(--milaura-font-body);
    color: var(--milaura-text);
    font-size: 1rem;
    font-style: normal;
    line-height: 1.7;
    margin: 0;
  }

  /* Bloc prioritaire : pierre revelee */
  #MilauraQuiz-{{ section.id }} .quiz-reveal-stone-block {
    background: rgba(255, 255, 255, 0.78);
    backdrop-filter: blur(20px);
    -webkit-backdrop-filter: blur(20px);
    border: 1px solid rgba(192, 160, 98, 0.22);
    border-radius: var(--milaura-border-radius);
    padding: var(--milaura-spacing-md);
    box-shadow: 0 14px 40px rgba(var(--profile-accent-rgb), 0.12);
  }

  #MilauraQuiz-{{ section.id }} .quiz-reveal-stone-kicker {
    font-family: var(--milaura-font-heading);
    color: var(--milaura-gold);
    font-size: 0.8rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 2px;
    margin: 0 0 4px;
  }

  #MilauraQuiz-{{ section.id }} .quiz-reveal-stone-name {
    font-family: var(--milaura-font-heading);
    color: var(--milaura-text);
    font-size: clamp(1.7rem, 3vw, 2.5rem);
    font-weight: 700;
    line-height: 1.12;
    margin: 0 0 var(--milaura-spacing-sm);
  }

  #MilauraQuiz-{{ section.id }} .quiz-reveal-stone-media {
    position: relative;
    width: 100%;
    max-width: 100%;
    aspect-ratio: 1 / 1;
    min-height: clamp(360px, 38vw, 560px);
    overflow: hidden;
    border-radius: var(--milaura-border-radius-sm);
    background: linear-gradient(135deg, rgba(var(--profile-accent-rgb), 0.08), rgba(255, 255, 255, 0.9));
    box-shadow: 0 12px 32px rgba(var(--profile-accent-rgb), 0.18);
  }

  #MilauraQuiz-{{ section.id }} .quiz-reveal-stone-image {
    width: 100%;
    height: 100%;
    display: block;
    object-fit: contain;
    transform: none;
  }

  #MilauraQuiz-{{ section.id }} .quiz-reveal-stone-caption {
    display: none;
  }

  /* Footer */
