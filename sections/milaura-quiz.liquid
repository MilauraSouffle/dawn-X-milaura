        mantra: {{ section.settings.profile_protection_mantra | default: "Je protège mon énergie" | json }},
        stone: "Obsidienne noire",
        scent: "Bois d'oud",
        icon: "🖤",
        colorAccent: "#4A4A4A",
        colorAccentRgb: "74, 74, 74",
        product: {% if section.settings.profile_protection_product %}{
          title: {{ section.settings.profile_protection_product.title | json }},
          url: {{ section.settings.profile_protection_product.url | json }},
          price: {{ section.settings.profile_protection_product.price | money | json }},
          featured_image: {% if section.settings.profile_protection_product.featured_image %}{{ section.settings.profile_protection_product.featured_image | image_url: width: 600 | json }}{% else %}null{% endif %},
          handle: {{ section.settings.profile_protection_product.handle | json }},
          variant_id: {% if section.settings.profile_protection_product.selected_or_first_available_variant %}{{ section.settings.profile_protection_product.selected_or_first_available_variant.id | json }}{% else %}null{% endif %}
        }{% else %}null{% endif %}
      },
      serenite: {
        label: "Sérénité",
        displayName: "Sérénité",
        moodLabel: "Mental en sur-contrôle",
        dashboardTitle: "Votre mental est saturé, vous devez couper le flux.",
        description: "Vous n'êtes pas fatigué(e) de la vie, vous êtes fatigué(e) de la gérer. Votre problème n'est pas le chaos, c'est le sur-contrôle. Vous analysez, vous planifiez, vous anticipez les problèmes qui n'existent pas encore. Votre cerveau est comme un navigateur avec 50 onglets ouverts qui ne répond plus. Vous avez perdu la clarté parce que vous avez peur que si vous arrêtez d'y penser, tout s'écroule. Spoiler : le monde continuera de tourner si vous débranchez 10 minutes.",
