{%- comment -%}
  MILAURA CART SUMMARY
  Recapitulatif avec code promo et checkout
  Badges confiance + icones paiement + sticky checkout bar
  @version 2.0.0 - 2026-02-09
{%- endcomment -%}

{%- liquid
  assign free_shipping_threshold = section.settings.free_shipping_threshold | times: 100
  assign free_shipping_enabled = true
  if section.settings.free_shipping_threshold <= 0
    assign free_shipping_enabled = false
  endif
  assign is_free_shipping = false
  if free_shipping_enabled and cart.total_price >= free_shipping_threshold
    assign is_free_shipping = true
  endif
  assign shipping_reward_active = false
  for attribute in cart.attributes
    if attribute.first == 'Carte MilAura 1' and attribute.last != blank
      assign shipping_reward_active = true
    endif
  endfor
  assign shipping_display_free = false
  if free_shipping_enabled and is_free_shipping
    assign shipping_display_free = true
  elsif shipping_reward_active
    assign shipping_display_free = true
  endif
-%}

{%- style -%}
  #MilauraCartSummary-{{ section.id }} {
    padding: var(--milaura-spacing-lg) 0 var(--milaura-spacing-xl) 0;
  }

  #MilauraCartSummary-{{ section.id }} .milaura-summary__card {
    /* No max-width — full width */
  }

  /* Desktop 2-column layout */
  @media screen and (min-width: 769px) {
    #MilauraCartSummary-{{ section.id }} .milaura-summary__grid {
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: var(--milaura-spacing-lg);
      align-items: start;
    }
  }

  /* Summary lines */
  #MilauraCartSummary-{{ section.id }} .milaura-summary__lines {
    display: flex;
    flex-direction: column;
    gap: var(--milaura-spacing-sm);
    padding-bottom: var(--milaura-spacing-md);
    border-bottom: 1px solid rgba(192, 160, 98, 0.2);
    margin-bottom: var(--milaura-spacing-md);
  }

  #MilauraCartSummary-{{ section.id }} .milaura-summary__line {
    display: flex;
    justify-content: space-between;
    align-items: center;
    font-size: 15px;
    color: var(--milaura-text, #000000);
  }

  #MilauraCartSummary-{{ section.id }} .milaura-summary__line--shipping {
    color: var(--milaura-text-light, #666666);
  }

  #MilauraCartSummary-{{ section.id }} .milaura-summary__line--shipping.is-free {
    color: #4CAF50;
  }

  #MilauraCartSummary-{{ section.id }} .milaura-summary__shipping-note {
    margin-top: -4px;
    font-size: 12px;
    line-height: 1.35;
    color: var(--milaura-text-light, #666666);
  }

  #MilauraCartSummary-{{ section.id }} .milaura-summary__line--total {
    font-size: 18px;
    font-weight: 700;
    padding-top: var(--milaura-spacing-sm);
  }

  #MilauraCartSummary-{{ section.id }} .milaura-summary__line--total .milaura-summary__value {
    font-size: 22px;
    color: var(--milaura-gold, #C0A062);
  }

  /* Discount code */
  #MilauraCartSummary-{{ section.id }} .milaura-summary__discount {
    margin-bottom: var(--milaura-spacing-md);
  }

  #MilauraCartSummary-{{ section.id }} .milaura-summary__discount-label {
    font-size: 14px;
    font-weight: 600;
    color: var(--milaura-text, #000000);
    margin-bottom: 8px;
    display: block;
  }

  #MilauraCartSummary-{{ section.id }} .milaura-summary__discount-form {
    display: flex;
    gap: 8px;
  }

  #MilauraCartSummary-{{ section.id }} .milaura-summary__discount-input {
    flex: 1;
    padding: 12px 16px;
    border: 1px solid rgba(192, 160, 98, 0.3);
    border-radius: 10px;
    font-size: 14px;
    background: #ffffff;
    transition: border-color 0.3s ease;
  }

  #MilauraCartSummary-{{ section.id }} .milaura-summary__discount-input:focus {
    outline: none;
    border-color: var(--milaura-gold, #C0A062);
  }

  #MilauraCartSummary-{{ section.id }} .milaura-summary__discount-input::placeholder {
    color: var(--milaura-text-light, #666666);
  }

  #MilauraCartSummary-{{ section.id }} .milaura-summary__discount-btn {
    padding: 12px 20px;
    background: transparent;
    border: 1px solid rgba(192, 160, 98, 0.3);
    border-radius: 10px;
    font-size: 14px;
    font-weight: 600;
    color: var(--milaura-text, #000000);
    cursor: pointer;
    transition: all 0.3s ease;
    white-space: nowrap;
  }

  #MilauraCartSummary-{{ section.id }} .milaura-summary__discount-btn:hover {
    border-color: var(--milaura-gold, #C0A062);
    color: var(--milaura-gold, #C0A062);
  }

  /* Right column */
  #MilauraCartSummary-{{ section.id }} .milaura-summary__right {
    display: flex;
    flex-direction: column;
    gap: var(--milaura-spacing-md);
  }

  /* Checkout button */
  #MilauraCartSummary-{{ section.id }} .milaura-summary__checkout {
    width: 100%;
    padding: 16px;
    font-size: 16px;
  }

  #MilauraCartSummary-{{ section.id }} .milaura-summary__trust {
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: 12px;
  }

  #MilauraCartSummary-{{ section.id }} .milaura-summary__trust-item {
    display: grid;
    grid-template-columns: 30px minmax(0, 1fr);
    gap: 9px;
    align-items: start;
    min-width: 0;
  }

  #MilauraCartSummary-{{ section.id }} .milaura-summary__trust-icon {
    width: 30px;
    height: 30px;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    border-radius: 50%;
    border: 1px solid rgba(192, 160, 98, 0.24);
    color: var(--milaura-gold-dark, #8F723A);
    background: rgba(192, 160, 98, 0.08);
  }

  #MilauraCartSummary-{{ section.id }} .milaura-summary__trust-icon svg {
    width: 16px;
    height: 16px;
    fill: none;
    stroke: currentColor;
    stroke-width: 2;
    stroke-linecap: round;
    stroke-linejoin: round;
  }

  #MilauraCartSummary-{{ section.id }} .milaura-summary__trust-title {
    display: block;
    font-size: 13px;
    line-height: 1.25;
    font-weight: 800;
    color: var(--milaura-text, #000000);
  }

  #MilauraCartSummary-{{ section.id }} .milaura-summary__trust-text {
    display: block;
    margin-top: 2px;
    font-size: 12px;
    line-height: 1.3;
    color: var(--milaura-text-light, #666666);
  }

  #MilauraCartSummary-{{ section.id }} .milaura-summary__payments {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    justify-content: center;
    gap: 8px 10px;
    padding-top: 4px;
  }

  #MilauraCartSummary-{{ section.id }} .milaura-summary__payment-label {
    width: 100%;
    text-align: center;
    font-size: 11px;
    line-height: 1.2;
    text-transform: uppercase;
    letter-spacing: 0;
    color: var(--milaura-text-light, #666666);
  }

  #MilauraCartSummary-{{ section.id }} .milaura-summary__payment-icons {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    justify-content: center;
    gap: 6px;
    margin: 0;
    padding: 0;
    list-style: none;
  }

  #MilauraCartSummary-{{ section.id }} .milaura-summary__payment-icon {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    height: 24px;
  }

  #MilauraCartSummary-{{ section.id }} .milaura-summary__payment-icon svg {
    display: block;
    width: 38px;
    height: 24px;
  }

  /* Cart discounts display */
  #MilauraCartSummary-{{ section.id }} .milaura-summary__discounts {
    margin-bottom: var(--milaura-spacing-sm);
  }

  #MilauraCartSummary-{{ section.id }} .milaura-summary__discount-item {
    display: flex;
    align-items: center;
    gap: 6px;
    font-size: 14px;
    color: #4CAF50;
    margin-bottom: 4px;
  }

  #MilauraCartSummary-{{ section.id }} .milaura-summary__discount-item svg {
    width: 16px;
    height: 16px;
  }

  /* ── Sticky checkout bar ── */
  #MilauraStickyCheckout-{{ section.id }} {
    position: fixed;
    bottom: 0;
    left: 0;
    right: 0;
    z-index: 90;
    background: rgba(253, 251, 247, 0.85);
    backdrop-filter: blur(20px);
    -webkit-backdrop-filter: blur(20px);
    border-top: 1px solid rgba(192, 160, 98, 0.25);
    padding: 12px 0;
    transform: translateY(100%);
    transition: transform 0.35s cubic-bezier(0.25, 0.8, 0.25, 1);
    pointer-events: none;
  }

  #MilauraStickyCheckout-{{ section.id }}.is-visible {
    transform: translateY(0);
    pointer-events: auto;
  }

  #MilauraStickyCheckout-{{ section.id }} .milaura-sticky__inner {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: var(--milaura-spacing-md);
    max-width: 1200px;
    margin: 0 auto;
    padding: 0 var(--milaura-spacing-md);
  }

  #MilauraStickyCheckout-{{ section.id }} .milaura-sticky__total {
    font-size: 16px;
    font-weight: 700;
    color: var(--milaura-text, #000000);
  }

  #MilauraStickyCheckout-{{ section.id }} .milaura-sticky__total-amount {
    color: var(--milaura-gold, #C0A062);
    font-size: 18px;
    margin-left: 6px;
  }

  #MilauraStickyCheckout-{{ section.id }} .milaura-sticky__cta {
    padding: 12px 32px;
    font-size: 15px;
    white-space: nowrap;
    flex-shrink: 0;
  }

  /* Mobile sticky */
  @media screen and (max-width: 768px) {
    #MilauraStickyCheckout-{{ section.id }} .milaura-sticky__inner {
      padding: 0 16px;
    }

    #MilauraStickyCheckout-{{ section.id }} .milaura-sticky__total {
      font-size: 14px;
    }

    #MilauraStickyCheckout-{{ section.id }} .milaura-sticky__total-amount {
      font-size: 16px;
    }

    #MilauraStickyCheckout-{{ section.id }} .milaura-sticky__cta {
      padding: 12px 24px;
      font-size: 14px;
    }
  }

  /* Mobile summary */
  @media screen and (max-width: 768px) {
    #MilauraCartSummary-{{ section.id }} .milaura-summary__discount-form {
      flex-direction: column;
    }

    #MilauraCartSummary-{{ section.id }} .milaura-summary__trust {
      grid-template-columns: 1fr;
      gap: 10px;
    }
  }

  /* Reduced motion */
  @media (prefers-reduced-motion: reduce) {
    #MilauraCartSummary-{{ section.id }} .milaura-summary__discount-input,
    #MilauraCartSummary-{{ section.id }} .milaura-summary__discount-btn {
      transition: none;
    }

    #MilauraStickyCheckout-{{ section.id }} {
      transition: none;
    }
  }
{%- endstyle -%}

{%- if cart.item_count > 0 -%}
  <section
    id="MilauraCartSummary-{{ section.id }}"
    class="milaura-cart-summary"
    data-section-id="{{ section.id }}"
  >
    <div class="page-width">
      <div class="milaura-summary__card milaura-section-card">
        <div class="milaura-summary__grid">

          {%- comment -%} Left column: recap {%- endcomment -%}
          <div class="milaura-summary__left">

            {%- comment -%} Cart level discounts {%- endcomment -%}
            {%- if cart.cart_level_discount_applications.size > 0 -%}
              <div class="milaura-summary__discounts">
                {%- for discount in cart.cart_level_discount_applications -%}
                  <div class="milaura-summary__discount-item">
                    <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                      <polyline points="20 6 9 17 4 12"></polyline>
                    </svg>
                    {{ discount.title | escape }} (-{{ discount.total_allocated_amount | money }})
                  </div>
                {%- endfor -%}
              </div>
            {%- endif -%}

            {%- comment -%} Summary lines {%- endcomment -%}
            <div class="milaura-summary__lines">
              <div class="milaura-summary__line">
                <span class="milaura-summary__label">Sous-total</span>
                <span class="milaura-summary__value">{{ cart.original_total_price | money }}</span>
              </div>

              {%- if cart.total_discount > 0 -%}
                <div class="milaura-summary__line" style="color: #4CAF50;">
                  <span class="milaura-summary__label">Remise</span>
                  <span class="milaura-summary__value">-{{ cart.total_discount | money }}</span>
                </div>
              {%- endif -%}

              <div class="milaura-summary__line milaura-summary__line--shipping {% if shipping_display_free %}is-free{% endif %}">
                <span class="milaura-summary__label">Livraison</span>
                <span class="milaura-summary__value">
                  {%- if shipping_display_free -%}
                    Offert
                  {%- else -%}
                    Selon adresse
                  {%- endif -%}
                </span>
              </div>
              <div class="milaura-summary__shipping-note">
                {%- if shipping_display_free -%}
                  Carte livraison activée.
                {%- else -%}
                  Transporteur choisi après saisie de l'adresse.
                {%- endif -%}
              </div>

              <div class="milaura-summary__line milaura-summary__line--total">
                <span class="milaura-summary__label">Total estimé</span>
                <span class="milaura-summary__value">{{ cart.total_price | money_with_currency }}</span>
              </div>
            </div>

            {%- comment -%} Discount code input {%- endcomment -%}
            <div class="milaura-summary__discount">
              <label class="milaura-summary__discount-label" for="discount-code-{{ section.id }}">
                Code promo ou carte MilAura
              </label>
              <div class="milaura-summary__discount-form">
                <input
                  type="text"
                  id="discount-code-{{ section.id }}"
                  class="milaura-summary__discount-input"
                  placeholder="Votre code"
                  data-discount-input
                >
                <button
                  type="button"
                  class="milaura-summary__discount-btn"
                  data-discount-apply
                >
                  Appliquer
                </button>
              </div>
            </div>
          </div>

          {%- comment -%} Right column: checkout + reassurance {%- endcomment -%}
          <div class="milaura-summary__right">

            {%- comment -%} Checkout button {%- endcomment -%}
            <button
              type="submit"
              name="checkout"
              class="milaura-summary__checkout milaura-btn-gold"
              form="milaura-cart-form"
              data-main-checkout
            >
              {{ section.settings.checkout_text | default: 'Passer commande' }}
            </button>

            <div class="milaura-summary__trust" aria-label="Réassurance MilAura">
              <div class="milaura-summary__trust-item">
                <span class="milaura-summary__trust-icon" aria-hidden="true">
                  <svg viewBox="0 0 24 24"><path d="M14 18V6H3v12h11Z"></path><path d="M14 9h4l3 4v5h-7V9Z"></path><circle cx="7" cy="18" r="2"></circle><circle cx="18" cy="18" r="2"></circle></svg>
                </span>
                <span>
                  <span class="milaura-summary__trust-title">Expédiée aujourd'hui</span>
                  <span class="milaura-summary__trust-text">Commande validée avant 14h</span>
                </span>
              </div>

              <div class="milaura-summary__trust-item">
                <span class="milaura-summary__trust-icon" aria-hidden="true">
                  <svg viewBox="0 0 24 24"><rect x="4" y="10" width="16" height="10" rx="2"></rect><path d="M8 10V7a4 4 0 0 1 8 0v3"></path></svg>
                </span>
                <span>
                  <span class="milaura-summary__trust-title">Paiement sécurisé</span>
                  <span class="milaura-summary__trust-text">CB, PayPal, Apple Pay, Shop Pay</span>
                </span>
              </div>

              <div class="milaura-summary__trust-item">
                <span class="milaura-summary__trust-icon" aria-hidden="true">
                  <svg viewBox="0 0 24 24"><path d="M12 21s7-4.4 7-11V5l-7-3-7 3v5c0 6.6 7 11 7 11Z"></path><path d="m9 12 2 2 4-5"></path></svg>
                </span>
                <span>
                  <span class="milaura-summary__trust-title">Préparée à Metz</span>
                  <span class="milaura-summary__trust-text">Par Karine</span>
                </span>
              </div>
            </div>

            {%- unless shop.enabled_payment_types == empty -%}
              <div class="milaura-summary__payments" aria-label="Moyens de paiement acceptés">
                <span class="milaura-summary__payment-label">Moyens de paiement acceptés</span>
                <ul class="milaura-summary__payment-icons" role="list">
                  {%- for type in shop.enabled_payment_types -%}
                    <li class="milaura-summary__payment-icon">{{ type | payment_type_svg_tag }}</li>
                  {%- endfor -%}
                </ul>
              </div>
            {%- endunless -%}

          </div>
        </div>
      </div>
    </div>
  </section>

  {%- comment -%} Sticky checkout bar {%- endcomment -%}
  <div id="MilauraStickyCheckout-{{ section.id }}" class="milaura-sticky-checkout" aria-hidden="true">
    <div class="milaura-sticky__inner">
      <span class="milaura-sticky__total">
        Total estimé<span class="milaura-sticky__total-amount">{{ cart.total_price | money_with_currency }}</span>
      </span>
      <button
        type="submit"
        name="checkout"
        class="milaura-sticky__cta milaura-btn-gold"
        form="milaura-cart-form"
      >
        {{ section.settings.checkout_text | default: 'Passer commande' }}
      </button>
    </div>
  </div>
{%- endif -%}

<script>
(function() {
  var sectionId = '{{ section.id }}';
  var section = document.getElementById('MilauraCartSummary-' + sectionId);
  if (!section) return;

  /* --- Discount code --- */
  var discountInput = section.querySelector('[data-discount-input]');
  var discountBtn = section.querySelector('[data-discount-apply]');

  if (discountInput && discountBtn) {
    discountBtn.addEventListener('click', function() {
      var code = discountInput.value.trim();
      if (code) {
        window.location.href = '/checkout?discount=' + encodeURIComponent(code);
      }
    });

    discountInput.addEventListener('keypress', function(e) {
      if (e.key === 'Enter') {
        e.preventDefault();
        discountBtn.click();
      }
    });
  }

  /* --- Sticky checkout bar (IntersectionObserver) --- */
  var mainCheckout = section.querySelector('[data-main-checkout]');
  var stickyBar = document.getElementById('MilauraStickyCheckout-' + sectionId);

  if (mainCheckout && stickyBar && 'IntersectionObserver' in window) {
    var observer = new IntersectionObserver(function(entries) {
      entries.forEach(function(entry) {
        if (entry.isIntersecting) {
          stickyBar.classList.remove('is-visible');
          stickyBar.setAttribute('aria-hidden', 'true');
        } else {
          stickyBar.classList.add('is-visible');
          stickyBar.setAttribute('aria-hidden', 'false');
        }
      });
    }, {
      threshold: 0,
      rootMargin: '0px'
    });

    observer.observe(mainCheckout);
  }
})();
</script>

{% schema %}
{
  "name": "Milaura Cart Summary",
  "tag": "section",
  "class": "milaura-section",
  "settings": [
    {
      "type": "header",
      "content": "Contenu"
    },
    {
      "type": "text",
      "id": "checkout_text",
      "label": "Texte bouton checkout",
      "default": "Passer commande"
    },
    {
      "type": "header",
      "content": "Configuration"
    },
    {
      "type": "range",
      "id": "free_shipping_threshold",
      "label": "Seuil avantage livraison",
      "min": 0,
      "max": 100,
      "step": 1,
      "unit": "€",
      "default": 0,
      "info": "Mettre 0 pour ne pas annoncer d'avantage livraison dans le panier."
    }
  ],
  "presets": [
    {
      "name": "Milaura Cart Summary"
    }
  ]
}
{% endschema %}
